], "misc": ["Genre: 歴史\nName (kana): スケドノ\nProduct: 鎌倉の王様"]}, {"names": ["紅丸組", "西川かおり"], "misc": ["Genre: 歴史\nName (kana): クレマルグミ\nProduct: 木曽義仲の基礎知識\n木曽義仲軍勢の研究と漫画"]}, {"names": ["雅〈MIYABI〉亭", "蓮華院胡蝶"], "misc": ["Genre: 歴史\nName (kana): ミヤビテイ\nProduct: 亢竜有悔"]}, {"names": ["きよもりよりもよき", "まみころ"], "misc": ["Genre: 歴史\nName (kana): キヨモリヨリモヨキ\nProduct: 渡る世間は平家ばかり\nemail: mamikoron@fxm.highway.ne.jp\n『平家物語』ギャグ漫画中心です。本の中で出番が多いのは、清盛・宗盛・知盛・重衡・維盛と、義経。シリアス漫画も少々あり。", "http://www.geocities.jp/mmkoron/"]}, {"names": ["城南武者絵巻所", "外海凵舟"], "misc": ["Genre: 歴史\nName (kana): ジョウナンムシャエマキド\nProduct: 四コマ平家物語\nemail: chihayabito@mail.goo.ne.jp\n平家物語を漫画にしてます。", "http://chihayabito.com/"]}, {"names": ["橘史館", "羽野真鳥"], "misc": ["Genre: 歴史\nName (kana): タチバナシカン\nProduct: 草紙・平家物語"]}, {"names": ["きまぐれ工房", "瀬尾とも子"], "misc": ["Genre: 歴史\nName (kana): キマグレコウボウ\nProduct: てっぺんの海"]}, {"names": ["松川口留番所", "松川湖通里"], "misc": ["Genre: 歴史\nName (kana): マツガワクチトメバンショ\nProduct: 羽州乱声譜"]}, {"names": ["鬼ヶ茶屋", "稲氷"], "misc": ["Genre: 歴史\nName (kana): オニガチャヤ\nProduct: 月牙泉 壱～髭 月の名前\nemail: onigachaya@yahoo.co.jp\n平安時代、大江山酒呑童子伝説をモチーフにした、歴史創作です。源頼光、安倍晴明、など。", "http://www.geocities.jp/onigachaya/"]}, {"names": ["王都復興計画", "柊野真紀"], "misc": ["Genre: 歴史\nName (kana): オウトフッコウケイカク\nProduct: 王城散華"]}, {"names": ["烏羽珠", "やませ"], "misc": ["Genre: 歴史\nName (kana): ウバタマ\nProduct: 鎮宅霊符神信仰の研究"]}, {"names": ["闇のかぎしっぽ屋", "新地昭彦"], "misc": ["Genre: 歴史\nName (kana): ヤミノカギシッポヤ\nProduct: 御神忌壱千年\nemail: sinti@yaskawa.co.jp\n平安妖かし系歴史サークル、闇のかぎしっぽ屋では、主に安倍晴明、陰陽道に関する史跡のレポート本を発行しております。また、修験／密教／陰陽道／民間信仰を取り上げた京都妖処案内本なども。平成十八丙戌年夏の新刊は安倍晴明史跡レポート『玄冥』です。皆様のご来店、心よりお待ち申し上げております。問合せはseoritu@infoseek.jpまでお願いします。 店主敬白"]}, {"names": ["丸ゆべし愛好会", "竹河せりか"], "misc": ["Genre: 歴史\nName (kana): マルユベシアイコウカイ\nProduct: いつかは君を\n平安中期中心"]}, {"names": ["ものしのみ", "大山猫"], "misc": ["Genre: 歴史\nName (kana): モノシノミ\nProduct: うらまくら"]}, {"names": ["クレリックΩ", "三季貴夜"], "misc": ["Genre: 歴史\nName (kana): クレリックオメガ\nProduct: 源氏物語99の謎\nemail: takaya59@aol.com\n源氏物語の意訳小説と解説書。紫式部日記の漫画版。着物と着付のハウツウ本。", "http://plaza.rakuten.co.jp/takaya59"]}, {"names": ["花群星", "紅迷"], "misc": ["Genre: 歴史\nName (kana): ハナムリブシ\nProduct: 夜半の月影\nemail: hongmi@msh.biglobe.ne.jp\n源氏物語女君マンガ", "http://www5f.biglobe.ne.jp/~kt1512/hongmi/"]}, {"names": ["MIDI KIDS", "まつしま たかふみ"], "misc": ["Genre: 歴史\nName (kana): ミディキッズ\nProduct: 古代幻想シリーズ"]}, {"names": ["松羽目堂", "日暮みちる"], "misc": ["Genre: 歴史\nName (kana): マツバメドウ\nProduct: 樂バカ日誌"]}, {"names": ["全宇宙仏像連合", "十一面"], "misc": ["Genre: 歴史\nName (kana): ゼンウチュウブツゾウレ\nProduct: 天才仏本"]}, {"names": ["EXCUSE", "滝上わらび"], "misc": ["Genre: 歴史\nName (kana): エクスキューズ\nProduct: 散文古事記"]}, {"names": ["月読", "市経麻代"], "misc": ["Genre: 歴史\nName (kana): ツクヨミ\nProduct: 朝月夜"]}, {"names": ["ウィストリア", "柴天羽"], "misc": ["Genre: 歴史\nName (kana): ウィストリア\nProduct: 天地の祭典"]}, {"names": ["幽翠街道", "石川"], "misc": ["Genre: 歴史\nName (kana): ユウスイカイドウ\nProduct: 太古の記憶を訪ねて"]}, {"names": ["春巻マニア", "風宮さくら"], "misc": ["Genre: 歴史\nName (kana): ハルマキマニア\nProduct: てくてく古代めぐり10"]}, {"names": ["CAKES ＆ ALE", "ナビ"], "misc": ["Genre: 歴史\nName (kana): ケイクスアンドエール\nProduct: ナビちゃんの古墳散歩"]}, {"names": ["たいこや", "辰口昇"], "misc": ["Genre: 歴史\nName (kana): タイコヤ\nProduct: 出土品マスコット\nemail: fxndxn@ki.rim.or.jp\n国内外の出土品を元にデザインした、手造りのマスコットを販売する。マスコットの素材は土（素焼き）中心。販売時は、本物の出土品に関する学術情報を記載したカードを無料で配布する。", "http://taikoya.info"]}, {"names": ["アトリエかとり", "香 桃花"], "misc": ["Genre: 歴史\nName (kana): アトリエカトリ\nProduct: 私説三國志\nemail: atelier@katori.ne.jp\n歴史・三国志。江森備著「天の華・地の風」パロ。周瑜×孔明、魏延×孔明。長編小説「私説三國志」「続天の華・地の風」を発行中。三国志ネタギャグ漫画やオリジナルの三国志グッズなどもあります。", "http://www.katori.ne.jp/atelier/"]}, {"names": ["UHA－UHA", "白竜"], "misc": ["Genre: 歴史\nName (kana): ウハウハ\nProduct: 冥～くらやみ～上"]}, {"names": ["桜皇貴族", "凰霞"], "misc": ["Genre: 歴史\nName (kana): オウコウキゾク\nProduct: 記憶の華\n三國志 蜀中心趙雲×劉備小説サークル"]}, {"names": ["做夢", "KARI春四音"], "misc": ["Genre: 歴史\nName (kana): ツオムン\nProduct: 做夢1"]}, {"names": ["風姫", "龍也ネコ"], "misc": ["Genre: 歴史\nName (kana): カゼヒメ\nProduct: 朝顔"]}, {"names": ["エコchop", "小栗 まぐろ"], "misc": ["Genre: 歴史\nName (kana): エコチョップ\nProduct: 馬鹿でもいい\nemail: ogurippa@hotmail.com\n三国志の劉備玄徳至上主義です。簡雍と張飛が殿と仲良しです。", "http://ogurippa.e-city.tv"]}, {"names": ["嗚呼・悪徳奉行", "杜硴■"], "misc": ["Genre: 歴史\nName (kana): アアアクトクブギョウ\nProduct: ミニマムだって良いじゃない"]}, {"names": ["銀嚢酒家", "伊曉亮"], "misc": ["Genre: 歴史\nName (kana): ギンノウシュカ\nProduct: ギエンの仮面"]}, {"names": ["ひろしま穴うめ本舗", "伏本オリ"], "misc": ["Genre: 歴史\nName (kana): ヒロシマアナウメホンポ\nProduct: かきくけ孔明くん25"]}, {"names": ["フーツラ", "切人"], "misc": ["Genre: 歴史\nName (kana): フーツラ\nProduct: 錯綜\nemail: futura@i.707.to\n創作三国志で孔明と徐庶と司馬懿と張飛の話を取り扱ってます。"]}, {"names": ["熊猫金魚", "朝倉紹"], "misc": ["Genre: 歴史\nName (kana): パンダキンギョ\nProduct: 緑一色"]}, {"names": ["Laissez Faire", "矢宮夏月"], "misc": ["Genre: 歴史\nName (kana): レイセズフェア\nemail: canaan@md.neweb.ne.jp\n三国志・蜀・女性向、馬岱×馬超シリアスメインで活動中。最新の活動情報はサイトにてご確認いただけます。", "http://taoyuan.moo.jp/index.htm"]}, {"names": ["杜康企画", "杜康潤"], "misc": ["Genre: 歴史\nName (kana): トコウキカク\nProduct: 中国は深い穴だらけ"]}, {"names": ["捜神", "野水杳"], "misc": ["Genre: 歴史\nName (kana): ソウジン\nProduct: 天の涯にて（上）"]}, {"names": ["釜中の豆", "釜中の豆"], "misc": ["Genre: 歴史\nName (kana): カマナカノマメ\nProduct: 釜中の豆の本12\n三国志オールキャラギャグです。健全です。"]}, {"names": ["風彩美"], "misc": ["Genre: 歴史\nName (kana): フウサイビ"]}, {"names": ["万燈会", "ひめまる"], "misc": ["Genre: 歴史\nName (kana): マントウエ\nProduct: 壮年よ大志を抱け\n横光三国志"]}, {"names": ["三色団子", "水高マユミ"], "misc": ["Genre: 歴史\nName (kana): サンショクダンゴ\nProduct: 三色無双3"]}, {"names": ["アムリタ・ドロップ", "ロスロリアン東風"], "misc": ["Genre: 歴史\nName (kana): アムリタドロップ\nProduct: 玄徳と蜀の地図\nemail: gen-toku@pf6.so-net.ne.jp\n三国志、玄徳中心"]}, {"names": ["コドモノカンヅメ", "applum"], "misc": ["Genre: 歴史\nName (kana): コドモノカンヅメ\nProduct: 苹果三国志\nemail: applum@nifty.com\n創作三国志で、通常は呉中心ギャグで活動しています。新刊は軍師中心の蜀本の予定。", "http://www.applum.net/"]}, {"names": ["歴史屋河内遠州", "王維"], "misc": ["Genre: 歴史\nName (kana): レキシヤカワチエンシュウ\nProduct: 天下大亂"]}, {"names": ["記跡", "膳隆沙羅"], "misc": ["Genre: 歴史\nName (kana): キセキ\nProduct: 沈まぬ太陽"]}, {"names": ["GET HAPPY", "里宮ぼたん"], "misc": ["Genre: 歴史\nName (kana): ゲットハッピー\nProduct: 曹HあT風\nemail: ktmt@s7.dion.ne.jp\n三国志（オールラウンド）"]}, {"names": ["MWG", "マジデン"], "misc": ["Genre: 歴史\nName (kana): エムダブルジー\nProduct: 妄想三国志事典"]}, {"names": ["東西南北人", "碧海"], "misc": ["Genre: 歴史\nName (kana): トウザイナンボクノヒト\nProduct: Brotherhood\nemail: aomi-n@ad.wakwak.com\n三国志 三国オールラウンドで活動中"]}, {"names": ["さと^2みっちー", "有相良"], "misc": ["Genre: 歴史\nName (kana): サトサトミッチー\nProduct: 大将浪漫\nemail: liang_2@h2.dion.ne.jp\n上総亮と有相良による三国志中心よろず2人サークル。主にオールキャラギャグのバラエティ、たまに小説込みのシリアスやほのぼので活動してます。HP情報をチェックしてみてください。＞HPメニュー内「うらみち」にて。他の活動ジャンルは漢楚（前漢演義）、封神演義、踊る大捜査線など。個別に上総亮はワンピース、有相良はウンナン、現在進行形で大河「組！」でも活動。続編「！！」本出る予定！ HPに独立別館がありますので、ご興味のある方はそちらをチェックしてください。", "http://www.h2.dion.ne.jp/~liang_2"]}, {"names": ["東大三国志研究会", "門十活"], "misc": ["Genre: 歴史\nName (kana): トウダイサンゴクシケンキ\nProduct: 雑覇"]}, {"names": ["GIGA", "きのしげと"], "misc": ["Genre: 歴史\nName (kana): ギガ\nProduct: 傾国異聞\nemail: ki-no@ymail.plala.or.jp\n三国志演義をベースにした創作漫画（健全）。オールキャラでギャグ、シリアスなど何でもありです。", "http://www6.plala.or.jp/giga/"]}, {"names": ["漢帝国＆FAR AND WILD", "李英拯"], "misc": ["Genre: 歴史\nName (kana): カンテイコクアンドファーア\nProduct: 中国建築を見に行こう2\n中国、日本建築のイラストと歴史。三国志、水滸伝の時代の中国を舞台にしたマンガとフリートーク。"]}, {"names": ["木鶏庵工房"], "misc": ["Genre: 歴史\nName (kana): モクケイアンコウボウ\nProduct: 見参！さむらい展"]}, {"names": ["Hi－DARLING", "中河内あすけ"], "misc": ["Genre: 歴史\nName (kana): ハイダーリン\nProduct: FATALIST(17)\n三国志・呉・周瑜受け", "http://hi-darling.net"]}, {"names": ["Otter", "紗鳳ひな"], "misc": ["Genre: 歴史\nName (kana): オッター\nProduct: Reconfirmation\nemail: satorihina@shrw.net\n三國志、呉中心で周瑜メインです。微妙に女性向…です…", "http://or.shrw.net/"]}, {"names": ["民草厨房", "福浦風子"], "misc": ["Genre: 歴史\nName (kana): タミグサチュウボウ"]}, {"names": ["Yellow Peach", "瀬在丸いてや"], "misc": ["Genre: 歴史\nName (kana): イエローピーチ\nProduct: 紅蘭\n三国志。甘寧×陸遜。孫権本。呉中心。"]}, {"names": ["豆腐三昧", "KITTY－KIRIN"], "misc": ["Genre: 歴史\nName (kana): トウフザンマイ\nProduct: 哀愁でいと\n三国志 甘凌"]}, {"names": ["痛快", "ダダ"], "misc": ["Genre: 歴史\nName (kana): ツウカイ\nProduct: 大江剣戟伝"]}, {"names": ["少年よ野望をいだけ", "松島灯"], "misc": ["Genre: 歴史\nName (kana): ショウネンヨタイシヲイダケ\nProduct: きみにめぐりあえた\nemail: nwqwj688@yahoo.co.jp\n三国志・正史ベース創作／呉・魏／孫策＆周瑜、呂蒙×孫貞姫とその周辺（A.D.208あたり）／徐庶＆程イク、徐晃＆張コウほか／／ファンタジー／児童文学／ゲド戦記（ゲド×テナー）／ナルニア／ハリポタ／指輪", "http://www.tulip.sannet.ne.jp/queen/"]}, {"names": ["ひねもす中国", "なしごれん野中"], "misc": ["Genre: 歴史\nName (kana): ヒネモスチュウゴク\nProduct: 諸葛瑾の本\nemail: info@nasigoren.com\n三国志（正史中心）の小説中心、女性向けです。呉の諸葛瑾が中心で、蒋欽×諸葛瑾などのマイナーカップリングが多めです。", "http://www.nasigoren.com/"]}, {"names": ["SECTION24", "かわにししょ"], "misc": ["Genre: 歴史\nName (kana): セクションニジュウヨン\nProduct: なんちゃって呂蒙陸遜伝\nemail: sec24@nifty.com\n三国志・呉中心・オールキャラ・ギャグ系", "http://homepage2.nifty.com/sec24/"]}, {"names": ["OHJU＆Selfish", "桜樹"], "misc": ["Genre: 歴史\nName (kana): オウジュセルフィッシュ\nProduct: 三国一の男前10"]}, {"names": ["桂花苑", "秋山律子"], "misc": ["Genre: 歴史\nName (kana): ケイカエン\nProduct: 沈まない月～東呉之異伝～\n三国志。東呉中心（正史ベース）孫策の活躍していた時代を中心にした捏造小説。"]}, {"names": ["曙紅楼"], "misc": ["Genre: 歴史\nName (kana): シューホンロウ\n正史三国志 呉中心"]}, {"names": ["遊蝶花", "桐生かづさ"], "misc": ["Genre: 歴史\nName (kana): ユウチョウカ\nProduct: hotch potch\n三国志"]}, {"names": ["WSP広報課", "桐元悠子"], "misc": ["Genre: 歴史\nName (kana): ダヴリューエスピーコウ\nProduct: 後漢日記"]}, {"names": ["BAR長江", "姜ママ"], "misc": ["Genre: 歴史\nName (kana): バーチョウコウ\nProduct: 此処より永遠に\nemail: caza@mb.infoweb.ne.jp\n三国志夏侯惇×曹操姜維ギャグ", "http://homepage2.nifty.com/caza/mama/"]}, {"names": ["大河の渡し", "山口陸海歌"], "misc": ["Genre: 歴史\nName (kana): タイガノワタシ\nProduct: 祭六章"]}, {"names": ["天使の正体", "森悠位"], "misc": ["Genre: 歴史\nName (kana): テンシノショウタイ\nProduct: 臨川慕思\n曹丕＆曹植"]}, {"names": ["シャーロック", "小暮公子"], "misc": ["Genre: 歴史\nName (kana): シャーロック\nProduct: 流連のまどろみ"]}, {"names": ["懐中君主", "鷹野加奈"], "misc": ["Genre: 歴史\nName (kana): カイチュウクンシュ\nProduct: 日常至上主義\n三国志魏国ほのぼの中心曹操×荀イク など"]}, {"names": ["春花", "榎柴 潮"], "misc": ["Genre: 歴史\nName (kana): ハルハナ\nProduct: 春英詩抄\nemail: usio@zi.chu.jp\n真枝みなみ＆榎柴潮によるヲトメ向け魏国中心三国志新米サークル。小説＆漫画、曹操×荀イク／司馬懿×曹丕でまったりと。今回参加は懿丕づくしです（多分）", "http://usio.chu.jp/ura/entrance.html"]}, {"names": ["ドルフィンズパフェー", "マーガレット更子"], "misc": ["Genre: 歴史\nName (kana): ドルフィンズパフェー\nProduct: ビリビリ三国志"]}, {"names": ["翠馨", "陽成院等"], "