ames": ["Label・I.O.S."], "misc": ["Block: CD試聴コーナー参加サークル一, ラ area", "http://labelios.fc2web.com/"]}, {"names": ["REKION"], "misc": ["Block: CD試聴コーナー参加サークル一, ラ area", "http://www.eonet.ne.jp/~yama-b/"]}, {"names": ["REd Hot HouSe"], "misc": ["Block: CD試聴コーナー参加サークル一, ラ area", "http://sound.jp/redhothouse"]}, {"names": ["LOiDΠ corporation,"], "misc": ["Block: CD試聴コーナー参加サークル一, ラ area", "http://loid.syncl.jp/"]}, {"names": ["我侭☆王子"], "misc": ["Block: CD試聴コーナー参加サークル一, ラ area", "http://www.geocities.co.jp/AnimeComic-Ink/2214/"]}], "M3-23": [{"names": ["WAVE"], "misc": ["Block: [ A ] (音楽：オリジナル)\nオリジナル、アレンジを問わず幅広い音楽作品を制作", "http://www.circle-wave.net/"]}, {"names": ["りさのうたうたうたいまぁす"], "misc": ["Block: [ A ] (音楽：オリジナル)\nオリジナルガールズユニット「りさうた☆ALLSTARS」によるサークルです☆", "http://www.risauta.com/"]}, {"names": ["nana sea"], "misc": ["Block: [ A ] (音楽：オリジナル)\nオリジナルボーカルアルバムを制作中です。"]}, {"names": ["RUN GIRLS RUN"], "misc": ["Block: [ A ] (音楽：オリジナル)\nオリジナルボーカルアルバムを制作中です。", "http://rgr.raindrop.jp/"]}, {"names": ["ALLEGORY WORKS"], "misc": ["Block: [ A ] (音楽：オリジナル)\nオリジナルのボーカルアルバムを制作する・コツキミヤのサークルです。", "http://kotukimiya.com/"]}, {"names": ["Primary"], "misc": ["Block: [ A ] (音楽：オリジナル)\nPrimary・yuikoのオリジナルボーカルＣＤを制作しています。", "http://primary-yuiko.com/"]}, {"names": ["ピクセルビー"], "misc": ["Block: [ A ] (音楽：オリジナル)\n久々の参加です！ monet復活、新譜が出ます！", "http://www.pixelbee.jp/"]}, {"names": ["メリディアンローグ（Meridian Rogue）"], "misc": ["Block: [ A ] (音楽：オリジナル)\n男性ボーカルPOPSバンドです。お陰様でついにメジャーデビューしました！約２年半振りのＭ３です。よろしくお願い致します！", "http://meridianrogue.com/"]}, {"names": ["SYNC.ART'S"], "misc": ["Block: [ A ] (音楽：オリジナル)\nいろいろなジャンルの女性ボーカル曲をオリジナルやら東方アレンジやら…", "http://syncarts.jp/"]}, {"names": ["rythmique"], "misc": ["Block: [ A ] (音楽：オリジナル)\n東方projectの曲を、SmoothJazzアレンジします。", "http://rythmique.mu-sic.jp/"]}, {"names": ["紳士ジャンキー"], "misc": ["Block: [ A ] (音楽：オリジナル)\nインダストリアル・テクノポップグループ「紳士ジャンキー」のCDとか出したりしてます。", "http://shinshijunkie.com/"]}, {"names": ["リサレコ"], "misc": ["Block: [ A ] (音楽：オリジナル)\nDS-10をつかった、カワイイ系ピコピコ音楽", "http://lisa-rec.net/"]}, {"names": ["Soranetarium"], "misc": ["Block: [ A ] (音楽：オリジナル)\n癒し系・民族系のオリジナル楽曲メインの結月そら個人サークルです。", "http://soranetarium.com"]}, {"names": ["solfa"], "misc": ["Block: [ A ] (音楽：オリジナル)\nmarble sky recordsがsolfaへ名称変更しました！iyuna/my sound life/iyunalineの作品を発表中です。", "http://www.solfa.asia/"]}, {"names": ["MintJam"], "misc": ["Block: [ A ] (音楽：オリジナル)\n商業、同人をまたにかけ活動しているサウンドクリエイターズ。", "http://www.mintjam.net/"]}, {"names": ["Maple Leaf"], "misc": ["Block: [ A ] (音楽：オリジナル)\n霜月はるか主宰サークル。オリジナルファンタジーボーカルCDをメインに制作しています。コラボサークルtieLeafの作品も有り。", "http://shimotsukin.com/"]}, {"names": ["不気味社"], "misc": ["Block: [ B ] (音楽：オリジナル)\n漫画家・有馬啓太郎委嘱作品＠不気味社が「切なく」歌うとこうなる！", "http://www.bukimi.com/maal/"]}, {"names": ["Heal Abenue"], "misc": ["Block: [ B ] (音楽：オリジナル)\n最近活動が止まってますが、そろそろ始動したいです。", "http://healabenue.jp/"]}, {"names": ["東京工科大学サウンドジェネシス"], "misc": ["Block: [ B ] (音楽：オリジナル)\n東京工科大学からきましたサウンドジェネシスです（・∀・）オリジナルCD配布します。", "http://soundgenesis.net/"]}, {"names": ["オト　ノ　カケラ"], "misc": ["Block: [ B ] (音楽：オリジナル)\nピアノをベースにしたオリジナル曲を作っています。初音ミクものもあり。", "http://pieceofsound.ddo.jp/"]}, {"names": ["HARDCORE TANO*C"], "misc": ["Block: [ B ] (音楽：オリジナル)\nREDALiCE初のオリジナルソロアルバム！", "http://tano-c.net/"]}, {"names": ["ウチナキレコード"], "misc": ["Block: [ B ] (音楽：オリジナル)\n民族風の少し泥臭く懐かしい唄を創っています。", "http://uchinaki.com"]}, {"names": ["バター工房"], "misc": ["Block: [ B ] (音楽：オリジナル)\n■オーケストラ・ピアノ中心のオリジナル曲を作ってます■最近プログレッシブな曲が書きたいです", "http://www.batakobo.com/"]}, {"names": ["月読レコード"], "misc": ["Block: [ B ] (音楽：オリジナル)\n雅楽、プログレ、オーケストラ、女性ヴォーカルにカウンターテナーなどなど。幻想的で独創的な音楽を創作しています。", "http://www.tsukuyomi-rec.net/"]}, {"names": ["WIND VOICE"], "misc": ["Block: [ B ] (音楽：オリジナル)\nピアノと弦・管楽器による独特なの世界観構築。ヒーリング・民族音楽がメイン。ボーカルCDも手がける。", "http://www.mikami.sakura.ne.jp/"]}, {"names": ["Seele"], "misc": ["Block: [ B ] (音楽：オリジナル)\nゲーム音楽を中心にオーケストラやロック等、多ジャンル収録のアレンジやイメージアルバムを制作しています。", "http://www.seele.halfmoon.jp"]}, {"names": ["Sing, R. Sing!"], "misc": ["Block: [ B ] (音楽：オリジナル)\n鍵盤ハーモニカをフィーチャーした新作、VOCALOID旧作を頒布", "http://www.singrsing.com/"]}, {"names": ["Casket"], "misc": ["Block: [ B ] (音楽：オリジナル)\nマウスでアイリッシュトラッドミクスチュア楽曲を制作しています。", "http://www.yukinohana.net/~casket/"]}, {"names": ["CN2&TEAR*"], "misc": ["Block: [ B ] (音楽：オリジナル)\n少女色音楽と称して女性Voで「少女」をモチーフにした作品や「色」をテーマに連作CDを出しています。", "http://mure.sakura.ne.jp/"]}, {"names": ["RomariaCrusade"], "misc": ["Block: [ B ] (音楽：オリジナル)\n男女ツインボーカル。新作は再録曲+新曲を含む闇鍋アルバムを予定しています", "http://romariacrusade.web.fc2.com/"]}, {"names": ["流浪の民"], "misc": ["Block: [ B ] (音楽：オリジナル)\n幻想民族音楽と呼ばれながら、ゲーム音楽をやりつつ、たまにギャグに走る、そんな流浪の民です。新譜は何かストーリーミニアルバムを出せれば良いなと思っていますが、ギリギリにならないと何がでるか解らない、そんな流浪の民です。", "http://www3.to/dareka"]}, {"names": ["Tako工房"], "misc": ["Block: [ B ] (音楽：オリジナル)\nMIDI環境でMIDI環境らしいクラシック音楽を目指して活動中。オリジナル中心で、主に交響曲。", "http://www5d.biglobe.ne.jp/~tako2/"]}, {"names": ["しろかがみ"], "misc": ["Block: [ B ] (音楽：オリジナル)\n「民族楽器＋女性ボーカル＋電子音＝しろかがみ」です，優しい透き通った音色を作っています．", "http://shirokagami.tabigeinin.com/"]}, {"names": ["Black Onyx"], "misc": ["Block: [ B ] (音楽：オリジナル)\nロックだったりオリエンタルだったりするオリジナルインストCD出します。", "http://www.ne.jp/asahi/rgf/ace/black-onyx/"]}, {"names": ["織姫オペラシアター"], "misc": ["Block: [ B ] (音楽：オリジナル)\n同人オリジナルオーケストラ（生演奏）や演劇団のCD・DVD等を頒布します。交響楽団新作アリ！", "http://www.orihime-opera.org"]}, {"names": ["office ACER"], "misc": ["Block: [ B ] (音楽：オリジナル)\nオリジナルのクラシック曲を制作、一部楽曲については楽譜も頒布します。", "http://office-acer.net/"]}, {"names": ["クムクム"], "misc": ["Block: [ B ] (音楽：オリジナル)\n今回は主にプログレ・サイケ系のオリジナルを作る予定です。", "http://sound.jp/kumukumu/index.html"]}, {"names": ["Enfance fini"], "misc": ["Block: [ B ] (音楽：オリジナル)\n少年少女の頃、空想に描いていたファンタジーの世界達を音楽につづることを目標として結成された同人音楽サークルです。曲調は民族音楽を初め、幻想的な雰囲気の曲が中心です。もう大人となってしまった自分達と、過ぎ去りし少年少女時代との出会いが生み出す、どこか懐かしく、そしてはかないメロディーを是非お楽しみください。", "http://enfini.yu-nagi.com/"]}, {"names": ["もえ＠みくる"], "misc": ["Block: [ B ] (音楽：オリジナル)\n東方アレンジとオリジナル楽曲をボーカル録音＋初音ミクで作っています。", "http://moemikuru.web.fc2.com/"]}, {"names": ["LOTS."], "misc": ["Block: [ B ] (音楽：オリジナル)\nPOWER DoLLS1 サウンドトラックとなにかが出る予定です。", "http://www.lilt.net/"]}, {"names": ["Big South Valley Music"], "misc": ["Block: [ B ] (音楽：オリジナル)\nソロ・ギター、ソロ・ピアノ、プラネタリウム番組のサウンドトラックなど", "http://www.bsvmusic.com/"]}, {"names": ["弥生兎"], "misc": ["Block: [ B ] (音楽：オリジナル)\nはじめまして。よろしくおねがいします", "http://yayoiusagi.com/"]}, {"names": ["ロータスルートオーケストラ"], "misc": ["Block: [ B ] (音楽：オリジナル)\n新作は、５曲前後のボーカル+２０曲前後インストのアルバムです。制作協力したオリジナルＡＤＶゲームの頒布もあります。", "http://yk.cage.to/"]}, {"names": ["O+N Factory"], "misc": ["Block: [ B ] (音楽：オリジナル)\nうたえない女子2人組の作詞作曲ユニット。ゲストボーカルさんいつもありがと。", "http://www.eightmelodies.net/"]}, {"names": ["ぷらいむまりぃ"], "misc": ["Block: [ B ] (音楽：オリジナル)\n愛原圭織×真野綾によるツインヴォーカルユニット。電波からポップス、ロック、バラードなど、幅広く挑戦しております。オリジナルＣＤ頒布中！", "http://aya.2-d.jp/pra/"]}, {"names": ["THE ROOM OF SHOW IKEDA"], "misc": ["Block: [ B ] (音楽：オリジナル)\n女性ボーカル、池田奨のオリジナル楽曲を扱うサークル。新作アルバム頒布予定。", "http://showikeda.eek.jp/"]}, {"names": ["Gungnir Over Rev"], "misc": ["Block: [ B ] (音楽：オリジナル)\nみんなで突き進む！愉快なクルーが集う、アットホームな海賊船。そして、”歌・詞・音楽”を”歌い・紡ぎ・奏で”形にするサークル。webラジオも配信中！", "http://www.gungni.com/"]}, {"names": ["ガラムまさら"], "misc": ["Block: [ B ] (音楽：オリジナル)\n当サークルは同人と呼べるものは幅広く、全てのことにチャレンジしていく藤沢大典の個人サークルです。今回は初出展作品として、トークスラングCDの頒布を予定しております。", "http://garam-masala.sakura.ne.jp"]}, {"names": ["MiddleIsland"], "misc": ["Block: [ B ] (音楽：オリジナル)\nピアノを中心とした様々なジャンルを哀愁的に表現したサウンドを制作しています。", "http://www.middleisland.net/"]}, {"names": ["TGZ SOUNDs"], "misc": ["Block: [ B ] (音楽：オリジナル)\nM3初参加です。SHIM・館内によるオリジナルインスト集の新作を予定しています。", "http://tgzsounds.com/"]}, {"names": ["k-waves LAB"], "misc": ["Block: [ B ] (音楽：オリジナル)\nアイリッシュ系の楽器演奏と打ち込みを合わせた音楽を作ってます。", "http://kou-ogata.net"]}, {"names": ["Ricefield Village Labo"], "misc": ["Block: [ B ] (音楽：オリジナル)\nRicefield Village Music Laboに所属する人達のサークル。プロとして活躍している人からプロを目指し活動してる人、趣味で音楽活動をしてる人が所属。ジャンルや形態は様々～バンド・インスト・生演奏・オーケストラ etc・・・　個性豊かな様々なサウンドをお届けします！", "http://www.ricefield-village.com/"]}, {"names": ["SunnyVale"], "misc": ["Block: [ B ] (音楽：オリジナル)\nダンス、シンセポップ系中心の女性ボーカルユニット。オリジナルの他にアニソンやFFなどゲーム音楽のアレンジも制作しています。", "http://www.sunnyvale-online.com/"]}, {"names": ["LINKAGE"], "misc": ["Block: [ B ] (音楽：オリジナル)\n高音ボーカルが売り(?)の、引き篭もり系打ち込み宅録ユニット。普段はネット上のみの活動でＭ3参加は4度目。 新譜リリース予定です。", "http://link-age.net/"]}, {"names": ["ももじゃむ"], "misc": ["Block: [ B ] (音楽：オリジナル)\n木ノ下ゆりのＣＤあります♪", "http://yuririn.net"]}, {"names": ["すずまり族"], "misc": ["Block: [ B ] (音楽：オリジナル)\nアイドルポップスにこだわって曲を作っています。ぜひ見に来てくださいね。", "http://mariex.hp.infoseek.co.jp/"]}, {"names": ["twinkle*twinkle"], "misc": ["Block: [ B ] (音楽：オリジナル)\n坂上なちの個人サークルです", "http://breathe.halfmoon.jp/twinkle/"]}, {"names": ["Dropの小屋。"], "misc": ["Block: [ B ] (音楽：オリジナル)\nオリジナル楽曲を制作しています。ゴシック×テクノというコンセプトを基調としたスタイルで活動しています。", "http://sound.jp/dropsound/"]}, {"names": ["doubleeleven"], "misc": ["Block: [ B ] (音楽：オリジナル)\n山下航生の個人サークル。声優のakariとdoubleeleven undercurrentの新作発表予定ありです！", "http://www.doubleeleven.net"]}, {"names": ["Materialize"], "misc": ["Block: [ B ] (音楽：オリジナル)\nオリジナルのテクノポップユニット。新作アルバム発売予定！", "http://www.materialize.jp"]}, {"names": ["ないしょの音楽館"], "misc": ["Block: [ B ] (音楽：オリジナル)\nお耳と心に何かが響きますように。", "http://naki.michikusa.jp/"]}, {"names": ["one.operation"], "misc": ["Block: [ B ] (音楽：オリジナル)\nＭ３初参加です。あんまり重くなく、手軽に聴ける楽曲作りを目指してます。一応、いい意味で安っぽい感じが出るように頑張ってます。今回はインストのアルバムを用意する予定です。"]}, {"names": ["ホームラウンド"], "misc": ["Block: [ B ] (音楽：オリジナル)\n「ファンタジーと日常を同レベルで描く」をテーマに活動している歌モノギターポップユニットです。新作シングルを配布予定です。", "http://16.xmbs.jp/homeround/"]}, {"names": ["SK-LAND"], "misc": ["Block: [ B ] (音楽：オリジナル)\n「Inspire Enjoyment」をキーワードに活動しているサークルです！映像・音楽・画像・写真・ゲームなどのコンテンツをホームページで好評配信中です。今回も、男性／女性ボーカルのＣＤを複数発売します！", "http://skland.dip.jp/skland/"]}, {"names": ["2-dimension"], "misc": ["Block: [ B ] (音楽：オリジナル)\n2-dimensionがM3初参加ですよー！続きはWebで。", "http://2-dimension.net/"]}, {"names": ["Margall"], "misc": ["Block: [ B ] (音楽：オリジナル)\n「甘美な夜には…」・・・4thアルバム「Mellow Night 」に続く最新5thアルバム発表！！普通のようで独自の道を突き進む集団Margall・・・どこまでまがれるのか？ぜひアナタの耳で確かめてください！", "http://margall.s228.xrea.com/index.html"]}, {"names": ["彩音 ～xi-on～"], "misc": ["Block: [ B ] (音楽：オリジナル)\nVocaloidを使用したオリジナル曲や東方アレンジを中心に活動中。", "http://xion.art-studio.cc/"]}, {"names": ["yusuke.cc"], "misc": ["Block: [ B ] (音楽：オリジナル)\nVOCALOIDオリジナルＣＤとアコースティックギター中心のインストゥルメンタルアルバムをリリース予定。", "http://yusuke.cc"]}, {"names": ["空色絵本"], "misc": ["Block: [ C ] (音楽：オリジナル)\nオリジナル曲でボーカルとギターと電子音を組み合わせた曲調です。", "http://www.sorairoehon.net/"]}, {"names": ["クランベリースタジオ"], "misc": ["Block: [ C ] (音楽：オリジナル)\n藤みさき＋などオリジナルのPOPSを中心に活動しています。", "http://cranberry-studio.com"]}, {"names": ["Hearts Sound"], "misc": ["Block: [ C ] (音楽：オリジナル)\nPCゲーム等に提供した楽曲のみで構成されたボーカルアルバム「Ｈ」、提供していない楽曲で構成されたオリジナルボーカルアルバム「Distance」を出展します。", "http://sound.jp/hearts_sound/"]}, {"names": ["NanosizeMir"], "misc": ["Block: [ C ] (音楽：オリジナル)\nトラッド系音楽ユニットの私たち、M3初参加となります。スペースではさいしょのアルバム『小さなせかい』を頒布。遊びにいらしてくださいね～！", "http://nanosizemir.com/"]}, {"names": ["れいんふぉれすと"], "misc": ["Block: [ C ] (音楽：オリジナル)\n女性ボーカリスト暮月夕可をフィーチャーしたセカンドマキシＣＤリリース", "http://rainforest.harmony.fm/"]}, {"names": ["ACSa-Direct"], "misc": ["Block: [ C ] (音楽：オリジナル)\nライトノベルやマンガのオリジナルイメージソングを中心に色々やってます", "http://www.sol.dti.ne.jp/~sept/jinn_say.html"]}, {"names": ["M●THERsDAY"], "misc": ["Block: [ C ] (音楽：オリジナル)\n「M●THERsDAY」は、ピアノと女性ヴォーカルを中心とした打ち込みPOPユニットです。オリジナルをメインにカバー曲等、様々なジャンルに挑戦しています。", "http://sound.jp/mothers"]}, {"names": ["Phonoscape Factory"], "misc": ["Block: [ C ] (音楽：オリジナル)\nオリジナルイメージソングStrings of Heartをはじめ、既存作を頒布。新作も？", "http://homepage1.nifty.com/Exass/Phonoscape/"]}, {"names": ["はるのひ"], "misc": ["Block: [ C ] (音楽：オリジナル)\nオリジナルボーカルアルバムあります♪", "http://www.eonet.ne.jp/~harunohi/"]}, {"names": ["麹町音源"], "misc": ["Block: [ C ] (音楽：オリジナル)\nparaokaソロとか麹町養蚕館とか", "http://homepage1.nifty.com/paraoka/"]}, {"names": ["Corky Voce"], "misc": ["Block: [ C ] (音楽：オリジナル)\nCorky Voce 1st Mini Album頒布予定です。", "http://www.corkyvoce.com/"]}, {"names": ["PrincessAlice"], "misc": ["Block: [ C ] (音楽：オリジナル)\nロリータ系音楽ユニット、PrincessAliceです！", "http://ameblo.jp/princessalicemusic/"]}, {"names": ["かるしゅーみゅ"], "misc": ["Block: [ C ] (音楽：オリジナル)\nコンピューターアート研究会のDTM班として活動しています。", "http://www.ca-s.org/"]}, {"names": ["Armonia"], "misc": ["Block: [ C ] (音楽：オリジナル)\nArmonia 3rdアルバムをM3春に向けて制作中。kikuyo(Vocal/作詞)、かなづき(作編曲)が中心に、ゆったり、まったり、コミカルなポップスを作っています。旧作「LIFE」「LINKAGE」も持っていく予定です。", "http://armonia.seesaa.net/"]}, {"names": ["ペンギンレコード"], "misc": ["Block: [ C ] (音楽：オリジナル)\n両声類な声優やましたとものオリジナル中心。最近はボーカロイドカバーなどもやっております。ドラマＣＤやライブＤＶＤも置いてます。", "http://pg-r.hp.infoseek.co.jp/"]}, {"names": ["ほりっくさーびす"], "misc": ["Block: [ C ] (音楽：オリジナル)\nオリジナル電波ソング作ってます！有名な作曲家Pとのコラボで新譜出します！", "http://holicservice.com/"]}, {"names": ["卯油屋（旧 女夭女夭）"], "misc": ["Block: [ C ] (音楽：オリジナル)\n妖怪・伝承を題材にした音楽です。しかも無料配布。毎回音楽スタイル変わるので、ジャンルわかんないです。。", "http://sound.jp/youkaiflat/"]}, {"names": ["Merrydoll"], "misc": ["Block: [ C ] (音楽：オリジナル)\n哲学できる、独創的でロマンティックな音楽を目指しています。", "http://sonud.jp/merrydoll"]}, {"names": ["桜ノ咲音響産業"], "misc": ["Block: [ C ] (音楽：オリジナル)\nポップ系オリジナルボーカルを幅広くやっています。", "http://sakion.net/"]}, {"names": ["鈴葉屋"], "misc": ["Block: [ C ] (音楽：オリジナル)\n一瞬に輝く強い想いや、儚い感情を失わないように楽曲に閉じ込めています。多重コーラスをメインに置いた幻想的な旋律をお楽しみ下さい。", "http://www.geocities.jp/ym_noir/"]}, {"names": ["東京農工大学 作曲・DTMサークル"], "misc": ["Block: [ C ] (音楽：オリジナル)\n2008年に創設された新しいサークルです。音楽ジャンルにこだわらず、各部員が自由に楽曲を制作しています。", "http://cctat.net/"]}, {"names": ["The Spring Beach Works."], "misc": ["Block: [ C ] (音楽：オリジナル)\nこんにちは、The Spring Beach Works.です。Nina Branchとはりいによるユニットです。女声ボーカル曲をメインに、やりたいものはなんでもありのノンジャンルで活動してます。", "http://www.haruhama.com/"]}, {"names": ["IndigoFlower"], "misc": ["Block: [ C ] (音楽：オリジナル)\nポップ～ロックを中心にオリジナルをやってます", "http://angelica.s229.xrea.com/"]}, {"names": ["mimei"], "misc": ["Block: [ C ] (音楽：オリジナル)\nレトロで幻想的な和洋折衷女性ボーカル曲のＣＤを主に発行しています。", "http://totsu-kuni.net/"]}, {"names": ["Fine Feeling"], "misc": ["Block: [ C ] (音楽：オリジナル)\n主にポップス、BGM系をメインに作曲活動をしております。初音ミクを使用した楽曲等も作っており、ややアニソン方向です。", "http://sound-wave.symphonic-net.com/"]}, {"names": ["とかげのてりやき"], "misc": ["Block: [ C ] (音楽：オリジナル)\nサイエンスをテーマにした擬人化ポップソング", "http://tokateri.com/"]}, {"names": ["PrimeLine"], "misc": ["Block: [ C ] (音楽：オリジナル)\nボーカル神尾みず、楽曲GOHによる音楽ユニット。オリジナルでポップス中心に活動中。", "http://y-infi.com/primeline/"]}, {"names": ["吉田音楽製作所"], "misc": ["Block: [