names": ["碧空プラネタリウム"], "misc": ["Block: [ D ]\n少年少女を中心とした朗読・音響劇を制作しています。透明感ある物語を目指しています。", "http://hekiku.net/", "https://twitter.com/hekiku_planet"]}, {"names": ["Spiral Spirit"], "misc": ["Block: [ D ]\n「少年」と「SF（少し不思議）」をテーマにボイスドラマと歌を創っています。東京２３区擬人化ボイスドラマやBLもあります。", "http://magumi.xyz/isyo/", "https://soundcloud.com/takentra/m3-2015comitia112", "https://soundcloud.com/spiral-spirit", "http://spiralspirit.net/", "https://twitter.com/spiral_spirit"]}, {"names": ["celestaria*"], "misc": ["Block: [ D ]\n自作の音楽を使ったボイスドラマをメインに少々音楽作品(素材CD含む)で活動しております。新作未定です。", "http://celestaria.fem.jp/", "https://twitter.com/kanade_cele"]}, {"names": ["遊玄堂"], "misc": ["Block: [ D ]\n聴いていてふと泣いたり笑ったり…そんなドラマを創っています。", "http://s.ameblo.jp/yuugendou/", "http://twitter.com/yuugendo"]}, {"names": ["翠櫻院"], "misc": ["Block: [ D ]\nゴシックファンタジー、探偵もの、ダークヒーローもの等、フリージャンルで思うがままに活動しています。", "http://suiohin.jimdo.com/?logout=1", "https://twitter.com/suiohin"]}, {"names": ["劇団　金のねじ"], "misc": ["Block: [ D ]\n時計を動かすねじのように、誰かの心を動かすきっかけになりたい。今後は舞台等にも手を伸ばしていこうと画策中です。どうぞ、金のねじをよろしくお願いします。", "http://www.nicovideo.jp/watch/sm25833986", "https://twitter.com/kitawo", "http://kinnonezi.blog.jp/"]}, {"names": ["表現集団クリエイト"], "misc": ["Block: [ D ]\n表現に魅せられ葛藤する役者と制作者。そんな彼らの表現から生み出される幾千の世界。それを、そして自分たちをクリエイトしていくのが表現集団クリエイトです。", "http://create-eg.com/", "https://twitter.com/create_eg", "http://www.nicovideo.jp/user/7358835"]}, {"names": ["ぽすといっと"], "misc": ["Block: [ D ]\n都内で活動していますオーディオボイスドラマサークルぽすといっと。主にドラマCDやWEBでのラジオ配信、ショートボイスドラマなど様々な媒体を介して作品公開中。あなたの心に特別な付箋を・・。", "http://circlepostit.web.fc2.com/index.html", "https://twitter.com/postit0512", "http://www.nicovideo.jp/user/18887361(9)"]}, {"names": ["GN放送局"], "misc": ["Block: [ D ]\nGN放送局の所属MC・製作staffが製作した音声作品。是非お聞きください♪", "http://gnwbc.net/gnbc/"]}, {"names": ["新選組異聞"], "misc": ["Block: [ D ]\n新選組のボイスドラマを製作しております。夏には舞台公演もしちゃいます！チケットも同時発売です！", "http://hizikata3okita.web.fc2.com/index.html"]}, {"names": ["E*Project"], "misc": ["Block: [ D ]\n汐瀬悠里が個人で制作しているボイスドラマサークルです。ほのぼの・シリアス等何でも有り。雑食です。", "http://epro.ehoh.net/", "http://twitter.com/shioseyuuri", "http://epro.ehoh.net/ending/", "http://epro.ehoh.net/M3/M3.html"]}, {"names": ["AKITOLET"], "misc": ["Block: [ D ]\nサウンドオペラ制作ユニットです。ダークファンタジー・ＳＦものを多く取り扱っております。力強いヴォーカルとサウンドストーリーのユニゾン、是非ご拝聴頂ければ幸いです！", "http://akitolet.com/", "https://twitter.com/kyrieakito"]}, {"names": ["おぼろまどか"], "misc": ["Block: [ D ]\nボイスドラマ創作ユニット「おぼろまどか」です。新作は「シキサイ文庫」です。", "http://2style.in/oboromadoka/", "https://twitter.com/oboromadoka"]}, {"names": ["空想科学研究所"], "misc": ["Block: [ D ]\n空想科学研究所（SFL）です。今回はサスペンスボイスドラマとiDearoom様との合同作品を頒布致します。", "http://sflabo.com/", "https://twitter.com/sf_labo000"]}, {"names": ["S-Scape"], "misc": ["Block: [ D ]\n「何気ない日常に愛をこめて」をテーマにボイスドラマ作ってます。色々あるので遊びに来てください。", "http://blank.sakura.ne.jp/", "https://twitter.com/s_scape/", "http://blank.sakura.ne.jp/blacksheep/", "http://blank.sakura.ne.jp/magmell/"]}, {"names": ["USA WORKS"], "misc": ["Block: [ D ]\nソフトM向けのめちゃシコエロボイスあります！", "http://usaworks.x.fc2.com/", "https://twitter.com/usa_works"]}, {"names": ["ARCFOX"], "misc": ["Block: [ D ]\n横浜生まれの東京育ち、創設18年目のオリジナル作品中心のアフレコサークルです。多ジャンルの作品色々あります！", "http://woodruff.press.ne.jp/arcfox/index.html", "https://twitter.com/ARCFOX_1997"]}, {"names": ["DelusionAristocart"], "misc": ["Block: [ D ]\nオリジナルのドラマCDを制作しているサークルです", "http://http://daristocart.com/"]}, {"names": ["elpis"], "misc": ["Block: [ D ]\nM3サークル初参加です。　切ないオリジナルボイスドラマを細々と制作しています。", "http://lafine.hiho.jp/", "https://twitter.com/nao8_plan"]}, {"names": ["とみみあん"], "misc": ["Block: [ D ]\nとみみ庵です！休日がテーマの耳かき音声等の入った音声作品を予定しています！", "http://blog.livedoor.jp/tomimi_nico/", "https://twitter.com/tomimi_nico", "http://www.nicovideo.jp/user/40141408"]}, {"names": ["YUME☆VOICE"], "misc": ["Block: [ D ]\nボイスドラマサークルYUME☆VOICEです！最新作は初の歴史作品！《デフォルメ三国志 蜀》初めての方も分かりやすくコメディタッチで描いてますので、是非聴いてみて下さい！", "http://nekomimiyumevoice.web.fc2.com", "https://twitter.com/yumevoice", "http://www.nicovideo.jp/user/13647177"]}, {"names": ["蟻部。"], "misc": ["Block: [ D ]\nゆるゆるボイスドラマ制作サークルです。ダークからコメディまで好き放題制作中です！", "http://aribu-goto.com/", "https://twitter.com/aribu_info"]}, {"names": ["なゆハム堂"], "misc": ["Block: [ D ]\n演劇ユニットなゆたハムニダが10周年になりました。初のオリジナルボイスドラマを展開します。高田那由太書き下ろしの作品をどうぞよろしく！", "http://ameblo.jp/nayu-hamu/", "https://twitter.com/NayutaHamunida7"]}, {"names": ["Colorful Pallet"], "misc": ["Block: [ D ]\n初参加！坂咲麗奈＆小沢雪霧の合同サークルです。共同制作の作品や、個人作品も頒布予定。", "http://colorfulpallet.hanabie.com/", "https://twitter.com/colorful_pallet"]}, {"names": ["声音魂帝国"], "misc": ["Block: [ D ]\n俳優・声優達が集い”ゼロ”から作り上げる、声・音の物語", "http://kotodama.miraiserver.com/"]}, {"names": ["創作団体『こぼれ桜』"], "misc": ["Block: [ D ]\n紙芝居アニメ、音楽とボイスドラマを出してます！すべてオリジナル作品です", "http://story.koborezakura.net/", "https://twitter.com/koborezakura3"]}, {"names": ["ディーブルスト"], "misc": ["Block: [ D ]\n耳かき、添い寝、マッサージ、耳舐めなど音フェチ要素を含めた癒し系ボイスドラマをメインに制作しています。お姉さんなど年上キャラが多め。", "http://b.dlsite.net/RG04303/", "http://twitter.com/uninimu", "http://www.nicovideo.jp/user/40390840"]}, {"names": ["FLYHIGHS"], "misc": ["Block: [ D ]\nプロの声優が送るオリジナルドラマCDをお送り致します。", "http://flyhighs.web.fc2.com/top.html", "https://twitter.com/flyhighs0808", "http://www.nicovideo.jp/user/37264356"]}, {"names": ["クレッシェンド"], "misc": ["Block: [ D ]\n主にボイスドラマ、ボイスblogでの活動を行っています。様々なジャンルのボイスドラマを用意しており、演劇を学んだメンバーで制作していますので是非一度聴いてみてください！", "http://crescendo-voiceactors.com/", "https://twitter.com/voice_crescendo?s=09", "http://crescendo-voiceblog.seesaa.net/s/"]}, {"names": ["GENERAL DOG"], "misc": ["Block: [ D ]\nハードファンタジー中心のオリジナルボイスドラマサークルです。関西圏を中心に活動しています！　オリジナル漫画のボイスドラマ化等のコラボ有り。「聴きやすさ」に拘ってます！", "http://generaldog.net/", "https://twitter.com/generaldog_"]}, {"names": ["匠＆音メイド"], "misc": ["Block: [ E ]\n声優によるオリジナルドラマCDを制作展開しているサークルです。", "http://www.otomeid.com/", "https://twitter.com/otomeid", "http://www.nicovideo.jp/user/23295961"]}, {"names": ["桜坂学園☆プロジェクト"], "misc": ["Block: [ E ]\n坂学園☆プロジェクトです。4コマ漫画やボイスドラマを中心に配信しております。", "http://www.sakutyuu.com/", "https://twitter.com/sakura_gakuen"]}, {"names": ["melimelo"], "misc": ["Block: [ E ]\n童話・メルヘン・ファンタジー・・おとぎの世界をあなたへ。えのもとみか、３１０５、謝花ゆうき、鳥都さま汰の4人グループ。2014年「おとぎの国の青い鳥」公演に始まり、枠に捕らわれない表現活動を行っています。", "http://melimelo.ame-zaiku.com/", "https://twitter.com/melimelo_quatre", "http://com.nicovideo.jp/community/co2322779"]}, {"names": ["劇団Galassia"], "misc": ["Block: [ E ]\n牧野秀紀主催の劇団です。朗読劇中心で活動しています。", "http://www.nubiest.sakura.ne.jp/", "https://twitter.com/Galassia2014"]}, {"names": ["a 7days L.A.B"], "misc": ["Block: [ E ]\n初参加になります。今回は主に現在販売中のドラマCD、それから新作のCDを販売致します。何卒宜しくお願い致します＾＾", "http://a7dayslab.wix.com/main", "https://twitter.com/a7daysLAB"]}, {"names": ["Arcadia"], "misc": ["Block: [ E ]\n聴き応えのあるシナリオ、臨場感のある編集に力を入れています。", "http://arcadiashow.info/", "https://twitter.com/Arcadia_show"]}, {"names": ["アテ逃げ本舗"], "misc": ["Block: [ E ]\nオリジナル等ボイスドラマを制作してます。", "http://blog.livedoor.jp/atenige_honpo/"]}, {"names": ["RBプロジェクト"], "misc": ["Block: [ E ]\n脚本、音響、声優、全てプロが行っています。クオリティには自信がありますので、是非一度スペースまで足をお運び下さい。", "http://rb0831.com/", "@RBproject_0831"]}, {"names": ["ばっどえんど"], "misc": ["Block: [ E ]\nオリジナルのボイスドラマで活動しています。最新作は主題歌にデジモンの宮崎歩さん、挿入歌に大島はるなさん、EMYUさんを起用、音楽・演技ともにクオリティ重視で気合入れて制作しています。", "http://badend.jp", "https://twitter.com/badend_official", "http://www.nicovideo.jp/user/2687014"]}, {"names": ["iDearoom"], "misc": ["Block: [ E ]\nオリジナルボイスドラマ、及び物語音楽CDの頒布を行っています。少しでも心に残る物語をお届けできれば幸いです。", "http://idearoom.xxxxxxxx.jp/", "https://twitter.com/iDearoom_"]}, {"names": ["secret sugar"], "misc": ["Block: [ E ]\nオリジナルボイスドラマCDを頒布予定です。メルヘンなお話を作っています。", "http://secret8sugar.himegimi.jp/sugarcandy/", "https://twitter.com/secret8sugar"]}, {"names": ["GarnetGarden"], "misc": ["Block: [ E ]\n日下稔の新作「ミラージュ」（オーディオドラマ）を無料配布！　シリアスやダークな物語が好きな方はぜひどうぞ！", "http://cats.yukimizake.net/mirage_ura/index.html", "https://twitter.com/garnetgarden_gg"]}, {"names": ["いろはカルタ"], "misc": ["Block: [ E ]\nオリジナルボイスドラマ制作サークル・いろはカルタです。今回、サークル初出展です♪　新作（現代ラブコメ）持っていきます！", "http://irohacarta.velvet.jp/index.html", "https://twitter.com/iroha_carta"]}, {"names": ["机上の遊戯"], "misc": ["Block: [ E ]\nボイスドラマ制作を中心とした一次創作サークルです。M3での作品頒布を一つの目標とし、よりよい作品をより楽しんで作ることを目指しています。", "http://kijounoyugi2014.web.fc2.com", "https://twitter.com/KiJoNoYuGi"]}, {"names": ["壊転ラヂオ"], "misc": ["Block: [ E ]\nオリジナルボイスドラマ制作中。日常の隣に居そうな非日常を目指して。", "http://soul-ful.sakura.ne.jp/", "https://twitter.com/soundof"]}, {"names": ["Confetti arc"], "misc": ["Block: [ E ]\nオリジナルボイスドラマ・女性向け恋愛ゲームを中心に制作しております。今回は新作を含め、ミステリーからファンタジー、恋愛ものなど、様々なジャンルの作品を頒布致します。", "http://confettiarc.wix.com/confetti-arc", "https://twitter.com/Confetti_arc"]}, {"names": ["MOJA"], "misc": ["Block: [ E ]\n子供向け作品をつくりつつ、個人個人で好き勝手に作っている雑貨屋サークルです。バッドエンドコンピなど多数新作予定！", "http://moja.o3asterisk.com/"]}, {"names": ["【 劇団ねこ入玉手箱 】"], "misc": ["Block: [ E ]\nオリジナルオーディオドラマの制作配信など。", "http://neko5.sub.jp/", "gekineko5"]}, {"names": ["颱風壱家"], "misc": ["Block: [ E ]\n颱風壱家はおかわり自由", "http://www.typhoonikka.com", "https://twitter.com/mamecop"]}, {"names": ["destiny"], "misc": ["Block: [ E ]\n崖っぷち二人組の桜井みおと木下結璃による創作サークル≪destiny≫です。オリジナルソングとボイスドラマのコラボレーションをお届け！", "http://stargazer.flop.jp/pl/destiny/", "https://twitter.com/destiny30y__"]}, {"names": ["キッカケ"], "misc": ["Block: [ E ]\n声優志望者応援サークルの「キッカケ」です。声優クラスタの代表が、声優を目指す皆さんを応援したく、皆でドラマCD作っちゃいました。できたてサークルですが、声優業界を盛り上げようとこれからも仕掛けます！", "http://key-cake.com/", "https://twitter.com/50Seisaku"]}, {"names": ["Doodle Factory"], "misc": ["Block: [ E ]\n貴方の知らない神様達のお話。実は、どいつもこいつもクセモノです☆", "http://doodlefactory.web.fc2.com/", "https://twitter.com/doodle_factory", "http://www.nicovideo.jp/user/41966844"]}, {"names": ["@THE dawn"], "misc": ["Block: [ E ]\n男性声優5人によるボイスアクターユニット、様々なジャンルのボイス系CDを製作しています☆", "http://at-the-dawn.sakura.ne.jp/", "https://twitter.com/at_THE_dawn"]}, {"names": ["SoundCloudすぴりたす☆Mix"], "misc": ["Block: [ E ]\n初参加のコツコツまったりと活動している音響ドラマを制作するサークルです。ちょっぴり仄暗い物語をお届けします。本当にありがとうございます！", "http://spirytus.client.jp/", "https://twitter.com/happyhappy_time"]}, {"names": ["総合創作サークルAXeSS"], "misc": ["Block: [ E ]\n自主創作ネットラジオ「木曜じゃダメかな」の収録音源のCDと、癒し系旅番組「BonVoyage35」のDVDの頒布を行います。", "http://axess.tabigeinin.com/", "https://twitter.com/axess_nagatani", "http://www.nicovideo.jp/user/5827160"]}, {"names": ["RIDE-OUT"], "misc": ["Block: [ E ]\nエンターテイメント関連の制作を行っているサークルです。今回の新作が、最後のドラマCDとなる予定です…！ 是非ともお越し下さいませ…！(*‘ω‘ *)", "http://rideout3s.blog134.fc2.com/", "https://twitter.com/rideout_off"]}, {"names": ["CM Laboratory"], "misc": ["Block: [ E ]\nモンスター！怪獣！妖怪！な魑魅魍魎をテーマにしたボイドラ・楽曲・イラスト等ざっくばらんなオムニバス作品を頒布します。こんなサークル名ですがCMはありません。", "http://clabo.xxxxxxxx.jp/", "https://twitter.com/CMLaboratory"]}, {"names": ["人間カプリチオ"], "misc": ["Block: [ E ]\n「人間らしさ」をテーマにゆるりと創作活動をしております。", "http://ti-ti-oo.net/", "https://twitter.com/humancapriccio"]}, {"names": ["オトノネ。プロジェクト"], "misc": ["Block: [ E ]\n物語のような音楽と、音楽のような物語。火照ちげ完全オリジナル新作。", "http://otonone.jp/", "https://twitter.com/otonone_jp"]}, {"names": ["Greedian"], "misc": ["Block: [ E ]\n「身近に潜む狂気」をテーマにオリジナルボイスドラマを制作。過去作品に加え、新作SFドラマを頒布予定。", "http://www3.to/greedian", "greedian_p"]}, {"names": ["ぴろしきーず"], "misc": ["Block: [ E ]\nぴろしきーずは３年目！M-3ももう４回目！バリバリ新作作ります！今回は一人制作、一人芝居！一人の限界を刮目せよッ！", "http://pirosikis.web.fc2.com/", "https://twitter.com/piroshikis"]}, {"names": ["うさぎパンチ！"], "misc": ["Block: [ E ]\nオリジナルボイスドラマを販売中！某有名漫画家さんとのコラボ企画あり。"]}, {"names": ["Play＆Play"], "misc": ["Block: [ E ]\nこっそり初参加。ボイスドラマ関係（レビュー・その他）のコピー本を無料頒布予定。", "http://circle.playvd.net/"]}, {"names": ["piponder worcket"], "misc": ["Block: [ E ]\n★ピポワールドとワンダーポケットの合同サークル★ 新作ボイスドラマ「こもれびの森の仲間たち」と「パンツをはいた猫」頒布致します！どちらも動物モノです！", "http://pipo.ma-jide.com/", "https://twitter.com/pipo_wo"]}, {"names": ["企画ユニットあいてむぼっくす"], "misc": ["Block: [ E ]\n当団体は神社・和物系音声ドラマを制作しています！今回は新作で恋愛ストーリータイトルを用意致しました！ぜひ遊びにいらして下さい！", "http://itembox1101.wix.com/itemhp", "@itembox1101/企画ユニットあいてむぼっくす"]}, {"names": ["LittleTrip #tone"], "misc": ["Block: [ E ]\n耳で聴くアニメーション！音楽家×役者コラボのボイスドラマです。", "http://boe5.net", "https://twitter.com/boe5net", "http://www.nicovideo.jp/user/40066536"]}, {"names": ["モモサキはここにいます。"], "misc": ["Block: [ E ]\nコメディなどを中心に、ちょっと頭がおかしい感じのボイスドラマを作っていけたらと思います。", "http://cult.jp/momosaki_moya/kikaku.html", "https://twitter.com/momomoya_saki"]}, {"names": ["サチアレ"], "misc": ["Block: [ E ]\nほんの少しの非現実が混ざった話が主です。", "http://cano-rain.com/sachiare/", "https://twitter.com/sachiare_info"]}, {"names": ["ふしぎの国ねこ横町さん番地"], "misc": ["Block: [ E ]\nアイドルマスター、ガールフレンド（仮）等で活躍中の声優陣による男性向けシチュエーションCD新登場！", "http://fushiginoneko.yokochou.com/", "https://twitter.com/fushigino_neko3", "http://www.nicovideo.jp/mylist/45115806", "http://fushiginoneko3.blog.fc2.com/"]}, {"names": ["アストロモノグラフィ"], "misc": ["Block: [ E ]\nボイスドラマ企画者3人が集まり、好き勝手ボイスドラマを制作するサークルです。サークル第一作目のドラマCDを頒布予定。", "http://asmono.eek.jp/", "https://twitter.com/asmono03"]}, {"names": ["Project YUNA"], "misc": ["Block: [ E ]\nProject YUNAはオリジナルアイドル達のボイスドラマ、イラスト、ミュージックなど多岐にわたって活動をしていく同人サークルです", "http://projectyuna.wix.com/aidoru", "https://twitter.com/idolalpha_six", "http://www.nicovideo.jp/user/45232788"]}, {"names": ["WAVES Production"], "misc": ["Block: [ E ]\n全編アニメーション化を目指して、クロスメディアSF作品『PROGRAMMED』制作中。", "http://programmed42.com", "https://twitter.com/programmed42"]}, {"names": ["ＲＭＲ"], "misc": ["Block: [ F ]\n新作あり！98年創設のオリジナルロボットものオンリーサークル。SFアクション音声劇と主題歌集を頒布します！", "http://www1.ttcn.ne.jp/~rmr/", "https://twitter.com/rmr_info", "http://www.nicovideo.jp/user/995420/video"]}, {"names": ["TEPS"], "misc": ["Block: [ F ]\nオリジナルのボイスドラマCD、稀にアニソンカバーCDを作っています。", "http://tepsnet.com/", "https://twitter.com/tepsnet", "http://www.nicovideo.jp/user/19537421"]}, {"names": ["RBC"], "misc": ["Block: [ F ]\n相も変わらず一般受けしないオリジナルドラマCDと効果音集を持参します。", "http://http://www.rbcnet.jp/", "rbcnet_jp"]}, {"names": ["ムラサキノオト"], "misc": ["Block: [ F ]\nオーディオドラマ制作サークル", "http://ameblo.jp/purplesounds/", "https://twitter.com/gankuma_"]}, {"names": ["egg factory"], "misc": ["Block: [ F ]\nドラマCD（コメディー・ＢＬ百合など）を頒布予定です。", "http://eggfactory.hiyoko.biz/"]}, {"names": ["劇団NAFF"], "misc": ["Block: [ F ]\n魔法学園に通うアデルの成長物語。無料配布もありますよ。", "http://naffriend.blog.fc2.com/"]}, {"names": ["LMProject"], "misc": ["Block: [ F ]\n音・物語・声・イラスト・言葉…様々な要素から織り成す音楽作品やドラマCDを制作しています。", "http://lm-project.com/", "https://twitter.com/lm_ksrg", "http://www.nicovideo.jp/user/35174477"]}, {"names": ["めみゅっと　オーディオドラマ制作サークル"], "misc": ["Block: [ F ]\nオーディオドラマ制作＆無料配布と声優さんの募集・みんなで遊ぼう！練習会のメンバーも募集してます", "http://www.memut.net", "https://twitter.com/PinKooDELTA"]}, {"names": ["SVAS"], "misc": ["Block: [ F ]\n声の仕事に関わる全てのことをやりたいと集まった声優グループかつサークルです。現在は音響作品制作・ラジオ配信・e-Sports実況を中心に活動しています。", "http://stylishvoiceactorspe.wix.com/svas", "https://twitter.com/SVASinfo", "http://www.nicovideo.jp/user/3045760"]}, {"names": ["鶏子だよぉ！"], "misc": ["Block: [ F ]\n鶏子が鶏子で鶏子な鶏子ワールド全開作品いっぱいなサークル・・・鶏子だよぉ！", "http://tori29.nomaki.jp/", "https://twitter.com/tori2929", "http://com.nicovideo.jp/community/co1409013"]}, {"names": ["Wherever"], "misc": ["Block: [ F ]\n御心に何か一つでも残せるような曲を目指して、幻想・民族系を中心に日々精進しております！", "http://hopesky.riric.jp/kaitou/index.html", "http://hopesky.riric.jp/wherever/index.html", "https://twitter.com/hisame1231"]}, {"names": ["Sator"], "misc": ["Block: [ F ]\nストーリーと音楽で1つの作品を作るサークル。2015年秋M3完成予定のオリジナルファンタジーCDより先行収録版を頒布予定。", "http://tanebito.web.fc2.com/", "https://twitter.com/aokaze_souka"]}, {"names": ["Happy Forest"], "misc": ["Block: [ F ]\n2015年、Happy Forestは生まれ変わります。", "http://www.naccle.net/", "https://twitter.com/naccle"]}, {"names": ["KANKITSU RECORDS"], "misc": ["Block: [ F ]\nnaccleとくふの作曲ユニット「なくふる」の2ndアルバムを出します。ジャズ風×民族風×テックダンスとかそんな感じの予定です（予定は未定）", "http://kankitsu.net/", "kuhudon"]}, {"names": ["team fiore"], "misc": ["Block: [ F ]\n『fiore＝イタリア語で“花”』から由来する“心の中に花を”をモットーに、『メロディ重視』のオリジナル曲をメインに作成。今回は、仮想ゲームＢＧＭをイメージしたオリジナルインストアルバムを頒布予定。", "http://m-pe.tv/u/?ilfioraio", "https://twitter.com/verticaldriveXX"]}, {"names": ["あまつぶ＆erum."], "misc": ["Block: [ F ]\nあまつぶ＆erum.の合同スペースです。民族調、アンビエント、ボカロインスト（架空言語）、任天堂アレンジもあります！", "http://music.geocities.jp/erum_corico/2014_amarum.htm", "corico0729", "13965478"]}, {"names": ["すかいあ"], "misc": ["Block: [ F ]\n「森」をテーマにした、ファンタジーで民族調のアルバムを頒布します。", "http://skyer.han-be.com/", "https://twitter.com/skyer07"]}, {"names": ["Sancarea Record"], "misc": ["Block: [ F ]\n格言その一、ぼっちも集まればコンピになる。", "https://twitter.com/domsouki"]}, {"names": ["minimum design"], "misc": ["Block: [ F ]\n天戸屋成といいます。今まで歌った曲のベスト盤と、旧譜コープスパーティーアレンジCD持って行きます。LOVEマシーンの東方アレンジCDも委託で持って行きます。よろしくお願いします。", "http://amat.sakura.ne.jp/", "https://twitter.com/ama_toyao", "http://amat.sakura.ne.jp/mnmm-0004_cd.html", "https://soundcloud.com/ama_toyao/sets/nari-amatoya-s-song"]}, {"names": ["PercivalClyde"], "misc": ["Block: [ F ]\nオリジナル音楽サークル。仮想サウンドトラック的なアルバムを制作しています。", "http://titany.sakura.ne.jp/", "https://twitter.com/tinyroamer"]}, {"names": ["NO TITLE"], "misc": ["Block: [ F ]\nラヴクラフト原神話モチーフのオリジナル曲を頒布予定です。固定値は裏切らない！　ねこかわいい。", "http://www.enola.jp/", "https://twitter.com/solferino", "http://www.enola.jp/134340/index.html", "http://www.enola.jp/gretel/index.html", "https://soundcloud.com/solferino"]}, {"names": ["梶迫小道具店"], "misc": ["Block: [ F ]\nトライバルハウス中心の希少ジャンルサークルです。", "http://cajiva.net/", "https://twitter.com/cajiva"]}, {"names": ["LILT RECORDS"], "misc": ["Block: [ F ]\n齋藤博人(と仲間たちがいたりいなかったり)が送るオリジナル音楽サークルです。", "http://www.lilt.net/", "https://twitter.com/nimaco"]}, {"names": ["ARKHEMINA RECORDS"], "misc": ["Block: [ F ]\n関美奈子がかかわるプロジェクト ARKHEMINA （アルケミナ）。1st Album 「ARKHEMINA」、オリジナル予定です。（Artifact Recordsから名前を変更しました）", "http://bit.ly/1FoHcw3"]}, {"names": ["Episodes ＆ Melody/ポケットサウンド"], "misc": ["Block: [ F ]\n「音楽で旅する宇宙旅行」をテーマにショートストーリー付きのアルバムを頒布予定。シナリオに超水道の蜂八憲氏をお招きしています。", "http://www.ep-melody.com/", "https://twitter.com/Azell365", "http://www.nicovideo.jp/user/292035", "http://www.ep-melody.com/circle/robotica/"]}, {"names": ["君の音。×くらやみ横丁"], "misc": ["Block: [ F ]\n真島こころによる、物語風新作ＣＤ「フエラムネの向こう側」を頒布予定です。今回はくらやみ横丁の、漫画家・宵町めめ先生をイラストにお招きします。ピアノ曲や、豪華ゲストを招いたボーカル曲・朗読曲を収録します", "http://flower-prayer.com/", "https://twitter.com/masima_pianote", "http://flower-prayer.com/cd/fue/", "http://flower-prayer.com/cd/yuki/", "http://flower-prayer.com/cd/look/", "http://www.ep-melody.com/circle/santa/", "https://www.youtube.com/channel/UC2Gy79MDbvkD1BdlnrE6ghw", "https://soundcloud.com/cocoromashima"]}, {"names": ["AL Fantasia"], "misc": ["Block: [ F ]\n新譜製作予定です。他にチェンバロコンピ企画など。中世ファンタジー系、古楽器、バロック、クラシック系が好きな個人サークルです。作品は主に劇伴系インスト、アンサンブルなど。", "http://www.mrorigin.com/", "https://twitter.com/Ak_mzkw", "http://mrorigin.wix.com/alfweb"]}, {"names": ["望月幻奏楽団"], "misc": ["Block: [ F ]\n電子オルガンやら打ち込みやらの1人楽団。ファンタジー風なインスト曲を。", "http://carillon-bemore.tumblr.com/", "https://soundcloud.com/kanon_mikozuki/m3carillon-bemore-f-14b", "http://lunareverie.iza-yoi.net/"]}, {"names": ["バター工房"], "misc": ["Block: [ F ]\n■ニコニコ動画でピアノ奏者として活動するVUTTERのオリジナル楽曲プロジェクト", "http://www.batakobo.com/", "http://www.batakobo.com/btkb0010.html", "https://twitter.com/VUTTER", "http://www.nicovideo.jp/mylist/11670571"]}, {"names": ["son　voyage"], "misc": ["Block: [ F ]\n幻想物語音楽サークルです。", "http://sonvoyage.net/", "https://twitter.com/son_voyage"]}, {"names": ["CHRONOS RECORD"], "misc": ["Block: [ F ]\n民族音楽をモチーフにしたインスト中心の楽曲を作曲しています。", "http://http://chronosrecord.daa.jp/", "https://twitter.com/chronosrecord"]}, {"names": ["旅音"], "misc": ["Block: [ F ]\n旅音 (たびおん)とはその土地土地で録音した自然・文化・人自分の足音などを使って作った旅の音楽です。フィールドレコーディングと編集、それらのリミックス。録音は４７都道府県を終え海外でも続行中。", "http://tabionm3.tumblr.com/", "https://twitter.com/tabion", "http://www.tabion.net/"]}, {"names": ["Cincleaf"], "misc": ["Block: [ F ]\nCincleafです。アコーディオン・ピアノ・クラシックギターをメインとしたBGMを制作しています。ジプシー・ジャズ、ミュゼットなどなど。過去に制作した曲の一部はHPもしくはSoundcloudにて視聴できます。", "http://cincleaf.com", "https://twitter.com/yokushida"]}, {"names": ["Unknown - Dimension"], "misc": ["Block: [ F ]\nゲームＢＧＭやTV番組のＢＧＭなどで活動中。ヒーリングを主に、オーケストラ・民族音楽・ゲームアレンジなど取扱いジャンルは多いです。", "http://unknown-dimension.com/", "https://twitter.com/Rei_Shimizu", "http://www.nicovideo.jp/user/12525361/"]}, {"names": ["Niusounds"], "misc": ["Block: [ F ]\nintercityさんとのコラボでCD作ります！シンフォニックメタル的なのもある…かも…？", "http://www.niusounds.com", "https://twitter.com/niusounds", "http://www.nicovideo.jp/user/722342"]}, {"names": ["storia musica"], "misc": ["Block: [ F ]\nインスト曲をメインに活動していくサークルです。幻想的な世界に引き込まれるような音楽をお届けします。", "http://storiamusica.web.fc2.com/index.html", "https://twitter.com/storia_musica"]}, {"names": ["幻想音劇団"], "misc": ["Block: [ F ]\nついに完成！2ndフルコンセプトアルバム『Snow Queen』（２枚組）をリリースします。とてもシネマトリアルな作品です。今回も変わった仕掛けを用意しています。音楽と生きよう！", "http://profile.ameba.jp/gensouongekidan/", "https://twitter.com/gensouongekidan"]}, {"names": ["Beagle Kick"], "misc": ["Block: [ F ]\nハイレゾ音楽制作サークルです。初のフルアルバム（先行CD版）を頒布予定です！新曲も収録。生演奏特盛り！", "http://dimension-cruise.jp/beaglekick/", "http://beaglekick.blog.fc2.com/"]}, {"names": ["SiE Records"], "misc": ["Block: [ F ]\n東京電機大学のDTM部レーベル「SiE Records」です！！！！様々なジャンルを取り揃えております！！！！！！！！！！！！！！！", "http://tdudtm.web.fc2.com/", "https://twitter.com/TDU_DTM"]}, {"names": ["airy bird"], "misc": ["Block: [ F ]\nairy birdのmiaです。ファンタジー、メルヘンの作風が強いです。新譜持っていきます！", "http://airybird.moo.jp/", "https://twitter.com/mia_airybird"]}, {"names": ["Music Pandora"], "misc": ["Block: [ F ]\n作曲家光田晋哉が好きな音楽を好きな仲間たちと好きな様にやっているサークルです。今回の新譜は一昨年に開催した個展のライブCD/DVDと、音楽仲間と作るコンセプトコンピCD「ぜんぶ共作」の2作品を予定しています。", "http://music-pandora.com/", "https://twitter.com/musicpandora", "http://music-pandora.com/mpaf002/", "http://music-pandora.com/1st_concert/cd.html"]}, {"names": ["ANIMATONE"], "misc": ["Block: [ F ]\nインディーズの音楽制作ユニットです。ビデオゲームやアニメーションのBGMを手がけています。", "http://animatone.jp", "https://twitter.com/animatone"]}, {"names": ["へっぷらけっこ！"], "misc": ["Block: [ F ]\nオリジナルのインスト音楽を制作しています。「カフェBGM」と「ロールプレイングゲームBGM」のCDを頒布します。", "http://heppura.noppikinaranu.com/"]}, {"names": ["愛のうた"], "misc": ["Block: [ F ]\nピアノメインのノスタルジックなサントラ系音楽作ってます。あとねこ", "http://yurikaji.jimdo.com/", "https://twitter.com/kajiyuri"]}, {"names": ["Endless tapes"], "misc": ["Block: [ F ]\nカセットテープ配布します", "https://twitter.com/keninngton", "https://twitter.com/INDOPE_MSS", "https://twitter.com/kinkyuyuruport", "https://twitter.com/meguru303"]}, {"names": ["示方堂"], "misc": ["Block: [ F ]\n打込み系変拍子コンピレーションをお届けいたします", "https://twitter.com/ZyuuziA8"]}, {"names": ["Hawk Circle"], "misc": ["Block: [ F ]\nさわゆき個人サークル。環境音楽やポップスや民族調に影響を受けたオリジナルのインスト曲を作ってます。心に届く感動できる曲を作りたいとチャレンジしてます。気軽にお立ち寄りください！", "http://hawkcircle.blog.fc2.com/", "https://twitter.com/dip_in_dip_in"]}, {"names": ["Flowlight Music"], "misc": ["Block: [ F ]\nFlowlight作編曲のオーケストラ、民族音楽曲を中心に、ボカロ曲、エレクトロっとさまざまなアレンジの楽曲を収録予定！詳しくは「Flowlight」で検索！", "http://flowlight-music.com/", "https://soundcloud.com/flowlight-music/m3-2015s", "https://twitter.com/Flowlight_music", "http://www.nicovideo.jp/user/15754499", "https://www.youtube.com/channel/UCnq0lkQ2ZoQI-IplktonkjA"]}, {"names": ["UtAGe"], "misc": ["Block: [ G ]\n主に生楽器を使用した楽曲の制作。弦楽器･ピアノなど。", "http://utagemusic.net", "Sebastian_UtAGe"]}, {"names": ["AKATSUKI"], "misc": ["Block: [ G ]\n某妹アニメの作曲メンバーで構成された活かしたサークルです！！", "http://aktk.info/index.html", "@shivainu0812"]}, {"names": ["不気味社"], "misc": ["Block: [ G ]\n男声合唱によるあらゆる楽曲（特撮曲・アニソン・歌謡曲含）のカバー。全てを男の口から出た音のみで表現。", "http://www.bukimi.com/maal/", "https://twitter.com/BUKIMISYA_MAAL"]}, {"names": ["Heal Abenue"], "misc": ["Block: [ G ]\nここだけの癒しの音楽を皆様へ。", "http://healabenue.jp/weblog/"]}, {"names": ["- Sohmatoa -"], "misc": ["Block: [ G ]\n民族調な楽曲や造語によるボーカル曲などを作っているサークルです。", "http://www.sohmatoa.com/", "http://twitter.com/wata_t/"]}, {"names": ["ななたね"], "misc": ["Block: [ G ]\nオリジナル民族系音楽を製作しております。ファンタジー馨る旋律とどこかの世界のコトバを織りあげた【ななたね】風味の音楽をお届けします◎", "http://ttca-ono-efp.kilo.jp/", "https://twitter.com/ttca_nanatane"]}, {"names": ["Canopus Sounds"], "misc": ["Block: [ G ]\nオーケストラ風のファンタジーなオリジナルサウンドトラックを制作しています。ゲーム音楽、映画音楽等が好きな方は是非お越し下さい。", "http://avior.jp", "http://avior.jp/m3_doujin.html", "http://avior.jp/soundtrack/2014/", "https://twitter.com/CanopusSounds"]}, {"names": ["WiH Records."], "misc": ["Block: [ G ]\n風景をテーマとした生音系楽器＋電子音なelectoronicaをつくっています", "http://glustar.sub.jp", "https://twitter.com/WiH_Records"]}, {"names": ["PBOXX"], "misc": ["Block: [ G ]\n文化庁メディア芸術祭アート部門や文化庁芸術祭レコード部門などで話題の、作曲家安野太郎による自動演奏ロボット音楽、「ゾンビ音楽」のCDをリリースしているサークルです。", "http://zombie.poino.net", "https://twitter.com/zombie_musica"]}, {"names": ["EBI Zanmai"], "misc": ["Block: [ G ]\n主に民族風・ヒーリング系のインスト曲をつくっています。EZの曲たちと共に空想の世界へ旅立ちませんか？", "http://sound.jp/ebi_zanmai/", "https://twitter.com/EBI_at_EZ", "https://soundcloud.com/ebi_at_ez"]}, {"names": ["So√a."], "misc": ["Block: [ G ]\nオリジナルのエレクトロニカ、アンビエント、エクスペリメンタルなどを主に扱ってます。ダークで距離感のある作風が持ち味です。", "http://viciarecords.web.fc2.com/", "https://twitter.com/milra_spin"]}, {"names": ["2.8mile"], "misc": ["Block: [ G ]\n新譜は、海外アーチストも参加した『ケルト・アイリッシュ』をコンピレーションで配布します。また、リラクゼーション効果抜群の「わだつみ」、ボーカロイドが紡ぐ小話音楽「大げさな秘密」もあります。", "http://2ten8mile.web.fc2.com/index.html", "https://twitter.com/2_8mile", "http://www.nicovideo.jp/user/5581674"]}, {"names": ["Casket"], "misc": ["Block: [ G ]\nアイルランド中心･諸ケルト音楽とミクスチュアによる楽曲制作サークルです。", "http://www.yukinohana.net/~casket", "https://twitter.com/Escarmew"]}, {"names": ["ヴェクセルドミナンテ"], "misc": ["Block: [ G ]\n音の響きを重視して楽曲を作っています。新譜はピアノインストのオリジナルの予定。ハイレゾ(PCM88.2kHz/DSD256)データの配布もします。", "http://wechdomi.org/"]}, {"names": ["ReMode"], "misc": ["Block: [ G ]\n作曲ユニットReModeです。よろしくお願いします。", "http://re-mo-de.net/", "https://twitter.com/remode_comp"]}, {"names": ["EarthSoundscape"], "misc": ["Block: [ G ]\nクラシック・アンビエント・エレクトロニカ・ダブステップ等、ジャンルに縛られない活動をしています。オリジナル曲制作以外にも、BGM制作や音効もしています。", "http://earthsoundscape.tumblr.com/", "https://twitter.com/EarthSoundscape", "https://soundcloud.com/earthsoundscape"]}, {"names": ["月読レコード"], "misc": ["Block: [ G ]\nプログレ、雅楽、民俗音楽など様々な要素を取り入れたオリジナル作品を制作しています。", "http://www.tsukuyomi-rec.net/", "https://twitter.com/hisui_tky"]}, {"names": ["tester studio"], "misc": ["Block: [ G ]\n映画音楽系、劇伴音楽を実験的に製作しています。今回はシネマテックコンピレーションＣＤをリリースします！", "http://conarrcmpkyo.wix.com/cinematic-compi", "https://soundcloud.com/takehiro_hentaisound"]}, {"names": ["eiyeeend/sachimaru"], "misc": ["Block: [ G ]\neiyeeend/sachimaru合同サークルです。初めての出展です。ノイズとスカムやってす", "https://soundcloud.com/eiyeeend/eiyeeend-milelejoeexcerpts-20150426m3g10a-eiyeeendsachimaru", "https://soundcloud.com/eiyeeend/st-expects"]}, {"names": ["ABSORB COLOR"], "misc": ["Block: [ G ]\nスパニッシュ寄りのアコギ＋民族音楽のオリジナルアルバム出す予定です!", "http://absorbcolor.web.fc2.com/", "https://twitter.com/aja_kids"]}, {"names": ["Gothic Marionette"], "misc": ["Block: [ G ]\nお話と曲による創作歌物語を作ってます。民族調からゴシックっぽいもの合唱アレンジまでゆるゆると。", "http://gothic-marionette.net", "https://twitter.com/marionette_yuki"]}, {"names": ["渦巻野郎"], "misc": ["Block: [ G ]\nオリジナルのオーケストラBGMを頒布予定です。", "http://soundcloud.com/uzumaki_yarou/sets/vol-1"]}, {"names": ["Corolaska"], "misc": ["Block: [ G ]\n幻想的でどこか儚いケルティックな曲調と、透明感のある造語ヴォーカルが特徴のサークルです。新譜頒布を予定しています。", "http://corolaska.web.fc2.com/", "https://twitter.com/corolaska"]}, {"names": ["鶏肉製造所"], "misc": ["Block: [ G ]\n当サークルの直売所では、ブラジル産鶏肉を100g98円で販売しません！民族調オリジナル楽曲をつくってます。", "http://toriniku.ie-t.net/", "http://twitter.com/chic_king", "http://www.nicovideo.jp/user/958681", "https://soundcloud.com/chic_king"]}, {"names": ["ロータスルートオーケストラ"], "misc": ["Block: [ G ]\n今回よりInitiumRecordsとしての新作スケッチ作品シングルシリーズを新たに始めます。前回ツキナミのコトより少し設定年齢層上のファンタジー作品になる予定です。", "http://lro-info.jimdo.com", "https://twitter.com/yuka_lro", "https://soundcloud.com/initiumrecords/lala01"]}, {"names": ["おとのはこにわ"], "misc": ["Block: [ G ]\n代表「そよもぎ」の個人サークルです。打ち込み中心で色々なジャンルを作っています。", "http://oto-hako.net/", "https://twitter.com/soyomogi", "https://soundcloud.com/soyomogi/tokyo-inema-paradiso-demo-2015m3-1st-album", "http://gakuonoise.tumblr.com/"]}, {"names": ["Enharmonic"], "misc": ["Block: [ G ]\n個人サークル「Enharmonic」主宰の「Ayur」が制作する、民族音楽・クラシック・声楽・多重コーラスの要素を織り交ぜた幻想的なオリジナル曲を頒布予定。", "http://enharmonic.info/"]}, {"names": ["ふじくら！"], "misc": ["Block: [ G ]\n旧譜あります。パンツコンピなど", "http://uwanosora.org/archives/3624", "https://twitter.com/nujisato", "http://mofday.info/"]}, {"names": ["しがべや"], "misc": ["Block: [ G ]\nジャズ風味なあれやそれや", "http://musicnakajima.web.fc2.com/", "https://twitter.com/naquaji", "https://soundcloud.com/naquaji/c86jzz-street", "https://soundcloud.com/naquaji/6011bqmosgws"]}, {"names": ["さんしち亭"], "misc": ["Block: [ G ]\nオリジナルインストアルバムを取り扱っています。", "http://thanshichi.saisokukan.net/", "https://twitter.com/thanshichiT37"]}, {"names": ["Corvo Grano"], "misc": ["Block: [ G ]\n民族、オルゴールなどのゆっくりまったり系オリジナルインストサークルです。", "http://crovograno.web.fc2.com/", "https://twitter.com/corvo_grano", "http://www.nicovideo.jp/user/3899680"]}, {"names": ["Harmonie Chromatique"], "misc": ["Block: [ G ]\n架空の宗教典礼儀式音楽 ”Magna Solemnitas” をリリース予定。巨大オーケストラと大合唱の荘厳な響きをお届けします。", "http://h-chromatique.info/", "https://twitter.com/har_chromatique", "http://www.nicovideo.jp/user/268450"]}, {"names": ["なないろらむね＋"], "misc": ["Block: [ G ]\n民族調・幻想的な楽曲を制作しています。新譜「黒猫ピケと金平糖の夜」（新シリーズ）と旧譜の頒布をします！", "http://rainbowramune.site44.com/07.html", "https://twitter.com/yuikirishima", "http://www.nicovideo.jp/my/mylist/#/41905672", "https://soundcloud.com/yuikirishima/sets/zkv1miqban5b"]}, {"names": ["RUBIS."], "misc": ["Block: [ G ]\nオリジナルの女性ヴォーカル曲やインストを制作しています。物語調のCDを頒布予定。", "http://rubis.yaekumo.com/", "https://twitter.com/rubbit_stone", "http://rubis.yaekumo.com/memoir/index.html", "https://www.youtube.com/watch?v=CG3HNEQGASs", "https://www.youtube.com/channel/UC7qogXmUCX7y6kGrx5bexiA/videos"]}, {"names": ["イノセント・ローグ"], "misc": ["Block: [ G ]\n幻想的なボーカル曲をメインに。新譜ございます♪", "http://mist.in/innocentrogue/index.html"]}, {"names": ["el ma Riu"], "misc": ["Block: [ G ]\nel ma Riu（えるまりう）のファンタジー音楽サークルです。民族・幻想・ゲーム系音楽を作っています♪創作童話等、『物語のある音楽』を大切にしています！", "http://el-ma-riu.com/", "https://twitter.com/el_ma_riu", "http://el-ma-riu.com/siren", "http://el-ma-riu.com/tortine", "http://www.nicovideo.jp/user/39595650", "http://www.muzie.ne.jp/artist/r044192/"]}, {"names": ["Jazzy Navel"], "misc": ["Block: [ G ]\nジャズ・サウンドを中心としたCDを頒布予定。　昨年秋より活動再開、WebサイトのBGM制作を手がけるなど活動の幅を広げている。", "http://jazzy-navel.com/", "https://twitter.com/glassthemoon"]}, {"names": ["ArcadiaHearts"], "misc": ["Block: [ G ]\nArcadiaHeartsではStoryVocalCDと銘打ったオリジナルの物語楽曲を主に制作中。「聴く物語」に近いクラシック主体のファンタジー、ゴシック、民族系サウンドをお届けします。", "http://arcadiahearts.com/", "https://twitter.com/ArcadiaHearts", "https://www.youtube.com/user/ArcadiaHearts"]}, {"names": ["OOPARTS＆PROJECT C"], "misc": ["Block: [ G ]\n新しい仮想RPGコンピアルバムを持って行きます。", "http://yn7623.wix.com/projectc", "https://twitter.com/yebisuebi", "http://www.nicovideo.jp/user/6237816"]}, {"names": ["鬼方謌"], "misc": ["Block: [ G ]\n何かだします", "http://kihouka.blog.shinobi.jp/"]}, {"names": ["Symphonic City"], "misc": ["Block: [ G ]\n壮大で幻想的、また迫力満点のオーケストラサウンドトラックをご堪能頂けます。", "http://conarrcmpkyo.wix.com/symphonic-city", "https://twitter.com/Kyocmp1", "http://www.nicovideo.jp/user/44860167"]}, {"names": ["OriverMusic"], "misc": ["Block: [ G ]\nアイリッシュフルート、ホイッスルを吹いて、曲を作っています。民族系インスト、オーケストラなど。東方アレンジも。", "http://orivermusic.blog.fc2.com/", "https://twitter.com/Oriver2112", "http://www.nicovideo.jp/user/619354"]}, {"names": ["Prhyzmica"], "misc": ["Block: [ G ]\nジャンルをまたいでいろんな曲を作っています。今回こそInner self 2を出したい", "http://prhyzmica.com", "kuguma"]}, {"names": ["ROUGH TIME"], "misc": ["Block: [ G ]\nJazz、Bluesなど割と渋い系のギターを弾いてるサークルです。", "http://roughtime.web.fc2.com/", "https://twitter.com/roughtime", "http://www.nicovideo.jp/user/327087"]}, {"names": ["ENSO５６"], "misc": ["Block: [ G ]\nユーロラックを使ったローファイドローンかシューゲイザーのようなもの", "https://soundcloud.com/enso56", "https://twitter.com/enso"]}, {"names": ["C-hicken工房"], "misc": ["Block: [ G ]\n今回はオリジナルアコースティックギターインストアルバムを予定、もしかしたらもう１枚おまけで出るかも", "http://c-hicken.com/", "https://twitter.com/c_hicken", "http://www.nicovideo.jp/user/513020"]}, {"names": ["恵方巻きコルネ"], "misc": ["Block: [ H ]\n「鬼の娘と和風音楽」､日本鬼子（ひのもとおにこ）をテーマにしたコンピレーションアルバムを制作しています。第５作めを頒布予定！", "http://www.onibake.tumblr.com", "https://twitter.com/Saki_Ohenri"]}, {"names": ["Musica Energetica"], "misc": ["Block: [ H ]\nBGM的なインスト曲をまったり作っています。", "http://musicaen.exblog.jp/"]}, {"names": ["NR-Taka"], "misc": ["Block: [ H ]\nオリジナルＢＧＭ作品集メイン。ミックスを手がけたオーガスト系アレンジ作品も持参します", "http://ameblo.jp/takachi-music/", "https://twitter.com/takachi_music"]}, {"names": ["augs"], "misc": ["Block: [ H ]\nオリジナルギタードローン曲の頒布、そういった用途向けのガジェット楽器を展示します", "http://augs9.tumblr.com", "https://twitter.com/q_u_e"]}, {"names": ["G-flatRecords"], "misc": ["Block: [ H ]\nフルート、オーボエのインスト曲、女性ボーカルの物語音楽を中心に、ロック、ポップス、劇伴風など様々な楽曲制作を行っています。", "http://g-flat.com/", "https://twitter.com/G_flat_Records"]}, {"names": ["ペンギン娯楽企画"], "misc": ["Block: [ H ]\n主に生楽器を使用したオリジナルの歌物や音楽劇。最近はダム巡りにはまってるので、ダムソングも作ってる。クラシックよりだが電気的なポップの曲調も好き。モットーはCtoD クラシカルからデスメタルまで。", "http://penep.org/", "https://twitter.com/penep_", "https://soundcloud.com/penep/qw9bwaetolgy"]}, {"names": ["スヤスヤレコード"], "misc": ["Block: [ H ]\nスヤスヤできる音楽をつくります", "http://suyarec.tumblr.com", "https://twitter.com/muhn"]}, {"names": ["13endcard"], "misc": ["Block: [ H ]\n前作「SUGAR＆SALT〜福音の組曲〜Sound of Sugar Edition」の続編にあたる民族系ボーカルアルバムの新譜を頒布予定！", "http://13endcard.com", "https://twitter.com/13endcard", "http://www.nicovideo.jp/user/39268169", "https://soundcloud.com/13endcard/salteditionxfadedemo", "https://www.youtube.com/watch?v=gJEXzGBMi98", "http://www.nicovideo.jp/watch/sm25984006?via=thumb_watch"]}, {"names": ["監督の小部屋"], "misc": ["Block: [ H ]\n「監督の小部屋」は今年もギターインスト系Fusionです。", "http://ameblo.jp/kantokunokobeya/", "https://twitter.com/chanyamakantoku", "http://www.nicovideo.jp/user/1156140"]}, {"names": ["2200K"], "misc": ["Block: [ H ]\nアンビエント中心のインスト仕立て。ニューエイジやエレクトロニカ成分も含まれることがあります。", "http://autoscopic-hallucination.tumblr.com", "http://am-tor.tumblr.com", "https://twitter.com/ambientortoise"]}, {"names": ["Voca brasileira"], "misc": ["Block: [ H ]\nブラジル音楽/ラテン音楽テイストのオリジナル曲をボカロ等の歌声合成歌唱で制作。ボッサ,サンバ,サルサは勿論ジャズ、フュージョンをベースにしたトラックは玄人から歌えるポップス好きの方まで幅広く楽しめます！", "http://smb2.net/vocabra/", "https://twitter.com/voca_bra"]}, {"names": ["とうふとめんつゆ"], "misc": ["Block: [ H ]\n作曲者めんつゆによる個人サークル。民族系の新譜持って行きます。", "http://mentuyu-straight.blog.so-net.ne.jp/", "mentsuyu_0"]}, {"names": ["Canaria Rhythm"], "misc": ["Block: [ H ]\n小鳥遊まこ（うたのは）と鳥島（フィンチ）の合同マルチメディアサークルです。ダークでファンタジーで物語な作品をCDや漫画で描きます", "http://canariz.sakura.ne.jp/"]}, {"names": ["錆浅葱"], "misc": ["Block: [ H ]\nキラキラしたアンビエントをお届けします", "http://sabiasagi.tumblr.com/", "https://twitter.com/_tsukki_"]}, {"names": ["B.rose＆crown"], "misc": ["Block: [ H ]\nアイリッシュ、ケルトを取り入れた民族調オリジナル曲を製作しているサークルです", "http://ameblo.jp/rujou/", "https://soundcloud.com/#mai-mori", "http://www.muzie.ne.jp/artist/r054691/"]}, {"names": ["mojo_nobuhiko"], "misc": ["Block: [ H ]\nピアノとエレクトロニカです。", "https://twitter.com/mojo_nobu", "http://www.nicovideo.jp/mylist/34947541", "https://www.youtube.com/channel/UCgygBaLOCv0ZZKGrW6mGP4w"]}, {"names": ["sound pulse"], "misc": ["Block: [ H ]\nCyberpunk！", "https://twitter.com/kesaaaaaaaaaan"]}, {"names": ["或型可２"], "misc": ["Block: [ H ]\nふわっとした印象の曲を作ってます", "http://neilguse.blog.fc2.com/", "https://twitter.com/neilguse", "http://www.nicovideo.jp/user/216827"]}, {"names": ["MUSIRISCA"], "misc": ["Block: [ H ]\n造語・女性多重コーラスで織りなす、Yuria Miyazonoのリリカルなミュージックコレクション。", "http://musirisca.p1.bindsite.jp", "https://twitter.com/YuriaMiyazono"]}, {"names": ["ウチナキレコード"], "misc": ["Block: [ H ]\n「少し泥臭く、懐かしい唄を。」がコンセプトの創作民族音楽です。多重コーラスや笛やアコなど。", "http://uchinaki.com", "https://twitter.com/uchinaki"]}, {"names": ["Studio Lepus"], "misc": ["Block: [ H ]\n物語は再び森の深くへ。ケルトの風が綴る、幻想なる音世界の物語。", "http://studio-lepus.com/", "mitakichi"]}, {"names": ["comme l’azur"], "misc": ["Block: [ H ]\n主にインスト、たまにボカロなどのCDを制作しています。空をテーマにしたインストアルバムGathering Skyの続編を頒布します。", "http://commelazur.net", "commelazur"]}, {"names": ["The Spring Beach Works."], "misc": ["Block: [ H ]\nNina Branchとはりいによるユニット、The Spring Beach Works.です。女性ボーカルのオリジナル曲をメインにジャンルなんでもありで活動してます。", "http://www.haruhama.com/", "https://twitter.com/_haruhama/"]}, {"names": ["ITC STUDIO"], "misc": ["Block: [ H ]\n遠くカンボジアのカフェで実際にBGMとして使用されたインストのコンピアルバムなどなど。", "http://itcstudio.jimdo.com/", "https://twitter.com/Itcha", "http://www.nicovideo.jp/user/7017558"]}, {"names": ["キラリ音楽工房"], "misc": ["Block: [ H ]\nゲームでの使用を想定したオーケストラ風のBGMを作っています！　購入後はフリー素材としてご利用可能です！　ご希望の方には楽譜もお付け致します！", "http://kiralynet.web.fc2.com/", "https://twitter.com/Kiraly_neko"]}, {"names": ["white snow"], "misc": ["Block: [ H ]\n環境音楽、その他BGM系音楽を発表予定です。"]}, {"names": ["ふえ吹き野うさぎ"], "misc": ["Block: [ H ]\n自分が大好きなFluteをずっと続けたいという思いから、コンサートや作曲活動を行ったり、音楽仲間の方と演奏したりして活動しています。主にFluteを使った楽曲を制作中です♪", "http://haseflotist.moonlit.to/", "https://twitter.com/hareflutist"]}, {"names": ["organic records"], "misc": ["Block: [ H ]\n色、自然現象、ゲーム音楽風など、様々なテーマのもと、オリジナルのインストコンピレーションアルバムを制作しています。ヒーリング、エレクトロニカ系メイン。", "http://organicrecords.jp/", "http://www.nicovideo.jp/user/18917276/"]}, {"names": ["帝国音楽堂"], "misc": ["Block: [ H ]\n作家・編集者のバーバラ・アスカの音楽サークルです。軍歌、レトロ歌謡中心です。", "https://twitter.com/barbara_asuka"]}, {"names": ["YETI Music by yanma"], "misc": ["Block: [ H ]\nPodcast制作屋からBGM楽曲集を提供します！", "http://yanma.jp/yetimusic/", "yanma111"]}, {"names": ["Sono de pasio"], "misc": ["Block: [ H ]\nヴァイオリン弾き閔賢基と仲間達の音源を用意。リベラシエロ他、オリジナルインスト曲を発表しています", "http://minkenki.com", "https://twitter.com/minkenki"]}, {"names": ["流浪の民"], "misc": ["Block: [ H ]\nファンタジー系の音楽を作りながら稀によく迷走中。こんどこそ人狼イメージアルバムをだすぞ！", "http://www5.ocn.ne.jp/~rulotami/", "https://twitter.com/rulotami"]}, {"names": ["シャルキィロマ"], "misc": ["Block: [ H ]\nダラブッカ、ウード、ブズーキ、バイオリンの生演奏によるオリジナル曲。アラブ・ジプシー・ロマ・アイリッシュスタイルを基調にした創作的民族音楽は山を海を、そして国境を越え、聴く者に新しい地平をもたらす。", "http://sharkiroma.com/", "https://twitter.com/SharkiRoma", "http://www.nicovideo.jp/user/18835423"]}, {"names": ["Euchaeta"], "misc": ["Block: [ H ]\n聴いたことのない世界へ、皆様をお連れします。プログレッシブロック/エレクトロニカ/ニューエイジ、そしてパレード。", "http://euchaeta.net/", "https://twitter.com/euchaeta", "https://soundcloud.com/euchaeta/album-unreal-cross-mix-demo"]}, {"names": ["windy・way"], "misc": ["Block: [ H ]\n民族っぽい音楽作ってます。今回は人が想いを馳せる場所について描きます。今回もお菓子あります♪wellcome!!", "http://windy-way.wix.com/niekuni", "http://twitter.com/wynwind"]}, {"names": ["Hagall"], "misc": ["Block: [ H ]\n民族音楽を取り入れた曲や、サウンドトラック風の曲を自由に制作しています。", "http://hagall.hacca.jp", "https://twitter.com/hagall_music"]}, {"names": ["まもも家"], "misc": ["Block: [ H ]\nピアノのなんかインストのやつとかちょっとボーカルのやつとかもあるやつです。", "http://www.s-mamomo.com/", "https://twitter.com/s_mamomo", "http://www.nicovideo.jp/user/766148"]}, {"names": ["armonia"], "misc": ["Block: [ H ]\nまっつんが、音楽でつながった仲間と一緒に、自由に作品を作り上げていく音楽集団。 音楽テーマ・作風はその都度変更していき、ジャンルに囚われない様々な音楽を作っていく。（←要は好き勝手したい）", "http://armomania.web.fc2.com/about.html", "https://twitter.com/mattundaira2525"]}, {"names": ["絃奏水琴樂章"], "misc": ["Block: [ H ]\n久しぶりにオーケストラな新作が出せそうです。", "http://melodic-harp.net/", "https://twitter.com/krsm"]}, {"names": ["宇宙フリーク"], "misc": ["Block: [ H ]\n打ち込みフレーズを生っぽくするためにリズムのずれを研究する変態。ファンクやジャズ、カリブ、ボサノヴァらしきものを作ります。"]}, {"names": ["signal+noise"], "misc": ["Block: [ H ]\nフュージョン、テクノ系のオリジナルインストを作ってます。", "http://signalnoise.jp/"]}, {"names": ["cache-cache"], "misc": ["Block: [ H ]\nサークル、cache-cache（かしゅかしゅ）です。  今回はファンタジーな世界のゲームの音楽を制作しました。  それぞれにシーン、テーマを持った楽曲を用意しました。", "http://cachecachemusic.com/", "https://twitter.com/cachecacheMusic"]}, {"names": ["The Photographers"], "misc": ["Block: [ H ]\nヒーリング:ピアノ/ブレイクビーツ:グルーヴ/文章 「音と文で、写真展やろうよ」 一つの世界に生きる、人々の瞬間。その情感を切り取り浮かぶ『風景』。それを捉える音と文の組合せで、色彩は鮮やかな変化を見せる。", "http://thephotographers.sakura.ne.jp/", "https://twitter.com/NasKage", "http://www.nicovideo.jp/user/41151813"]}, {"names": ["Minstrel Fantasy -吟遊詩人の幻想歌-"], "misc": ["Block: [ H ]\n音楽が誘うファンタジーの世界へ…。民族音楽風・ゲーム音楽等の幻想的な曲がお好きな方に。", "http://minstrelfantasy.web.fc2.com/", "https://twitter.com/mf_ruca"]}, {"names": ["MachiaWorks"], "misc": ["Block: [ I ]\n1つの物語をベースに作編曲し、民族楽器・シンセサイザー等を用いたアルバムを頒布予定です。", "http://machiaworx.net/", "http://twitter.com/MachiaWorx"]}, {"names": ["patriot"], "misc": ["Block: [ I ]\nオリジナルのアコギインストCDです。今回はソロギターがメイン。聴いてくれた方の癒しやプラスの力になれればと思います、よろしくお願いします", "http://patriot3104.org/", "https://twitter.com/samurai_brave"]}, {"names": ["ロドハウス"], "misc": ["Block: [ I ]\nピアノと電子音楽", "https://twitter.com/rodo1023", "https://soundcloud.com/rodo1023/cejffeszbttc"]}, {"names": ["GOLDFISH"], "misc": ["Block: [ I ]\n女性ボーカルのいわゆる歌謡ジャズです。弦、管すべて生音にこだわり、楽曲を制作しています。透き通る歌声と内面を描く詞が特徴です。", "https://youtu.be/HK28reO_CEk", "https://twitter.com/goldfish_web", "http://www.nicovideo.jp/user/4188317"]}, {"names": ["houyhnhnm."], "misc": ["Block: [ I ]\nファンタジー風オリジナルインストサークル。旅する音楽幻奏旅行記シリーズ展開中。今度は外伝……予定！", "http://houyhnhnm-aim.tumblr.com/", "https://twitter.com/aim_hynm"]}, {"names": ["Queen Bell"], "misc": ["Block: [ I ]\n和風な曲調を主体としたインストのオリジナル曲と、それらのオーケストラ・ピアノアレンジを制作しています", "http://www.queenbell.info/"]}, {"names": ["YubuneStudio"], "misc": ["Block: [ I ]\nピアノを主体としたオリジナルインスト曲を作っています！", "http://yubune.org", "https://twitter.com/alt_sakatsuki"]}, {"names": ["merciBOX"], "misc": ["Block: [ I ]\nred glasses主催merciBOX関連作品はこちらで！", "http://merci-box.net/", "https://twitter.com/red_glasses_", "http://www.nicovideo.jp/user/362817"]}, {"names": ["直カフェ"], "misc": ["Block: [ I ]\nアニソンからＪ−ＰＯＰ、演歌まで敷居を広げて楽曲を制作しています。全国流通で販売中のＣＤに加え、新作を携えて参加いたします！是非チェックお願いいたします！", "http://ongaku.fm/recommend/yuna/", "http://ameblo.jp/akikoshinagawa/"]}, {"names": ["Gigantic Tune"], "misc": ["Block: [ I ]\n初参加です！カッコ可愛いポップロックや、バラードなどの入ったボーカルCDです。他にもトランス、ドラムンから民族音楽までいろいろ。", "http://gigantic-tune.com", "https://twitter.com/gigantic_tune", "http://www.nicovideo.jp/user/25439504"]}, {"names": ["MellowMerrow"], "misc": ["Block: [ I ]\nうさおりーぬソロプロジェクト。アイリッシュ音楽を主軸にファンタジーでメルヘンな世界を描きます。", "http://www.mellow-merrow.com", "https://twitter.com/usaoline", "http://www.nicovideo.jp/user/385670"]}, {"names": ["吉田音楽製作所"], "misc": ["Block: [ I ]\n当サークル吉田音楽製作所（愛称：きっちょん）は音楽、特に作曲、およびオリジナル曲の演奏を中心としたライブ活動に興味を持つ人に、交流・作品発表の場を提供する京都大学公認の音楽サークルです。", "http://kitchonofficial.web.fc2.com/", "https://twitter.com/kitchon"]}, {"names": ["Laqshe"], "misc": ["Block: [ I ]\nKiyonoとShin Sheenaによるユニットです。少し切なめの女性ヴォーカルな歌ものです。アブストラクトなポップス。", "http://www.laqshe.net/", "https://twitter.com/shinsheena", "http://www.nicovideo.jp/user/1290025"]}, {"names": ["muon"], "misc": ["Block: [ I ]\nオリジナル音楽制作サークルです。", "http://neko.mokuren.ne.jp/yuzuki/"]}, {"names": ["Bellmonte"], "misc": ["Block: [ I ]\nさぁいこう・・・", "http://www.bellmonte.net/"]}, {"names": ["somnium"], "misc": ["Block: [ I ]\n新生音楽レーベル「somnium」1stコンピ出します。まずはHPをご覧ください！", "http://somnium-rec.com/", "https://twitter.com/Re_laznyan"]}, {"names": ["Prince of Wales"], "misc": ["Block: [ I ]\nわかる人にはわかる、某「ずっそばの人」こと、音遊人 -mu-jin-の個人サークルです。ジャンルに捉われず、ありのままに？思うがままに！