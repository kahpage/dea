oundcloud.com/yumeoibito111"]}, {"names": ["PsyGoRecords"], "misc": ["Block: [ R ]\nGothicをテーマとしたコンピレーションアルバムを頒布します。今回は主宰のソロアルバムも同時リリース！", "https://twitter.com/ty2su_", "http://www.nicovideo.jp/user/32338201"]}, {"names": ["Crescent Phantom"], "misc": ["Block: [ R ]\n永遠の三日月の夜空に、願いのかけらが舞い落ちるーーー感情を司る人形たちの舞台劇第二幕「カラクリトロイメライ」開幕予定", "https://karakuritraumerei.tumblr.com/", "https://twitter.com/crescentphantom"]}, {"names": ["Flowlight Music"], "misc": ["Block: [ R ]\nFlowlight作編曲のオーケストラ、民族音楽曲を中心に、さまざまなアレンジの楽曲を収録予定！詳しくは「Flowlight」で検索！", "http://flowlight-music.com/", "https://twitter.com/Flowlight_music", "http://www.nicovideo.jp/user/15754499"]}, {"names": ["望月幻奏楽団"], "misc": ["Block: [ R ]\nインストCDとテイルズとグラブルと。DX3rdのイメージCD作りたいなぁ。", "http://lunareverie.iza-yoi.net/", "https://twitter.com/Kanon_Mikozuki"]}, {"names": ["WIZARD ODYSSEY"], "misc": ["Block: [ R ]\n民族音楽が織りなす旅人の世界。哀愁の旋律が幻想的な物語を紡ぎだす・・・。", "http://yanotomo.wixsite.com/yanotomo", "https://twitter.com/Yano_Composer", "http://www.nicovideo.jp/user/79740799"]}, {"names": ["Dragon Spiral Music"], "misc": ["Block: [ R ]\nオリジナルインストのロック プログレ フュージョン系を頒布しています。サントラBGMのようなイメージで作った楽曲をバンド演奏、打ち込み様々な形態で収録。", "http://dragon-s.sub.jp/dragon/spiral.htm"]}, {"names": ["【m:cafe】-mikaRingの音楽小部屋-"], "misc": ["Block: [ R ]\nDTM女子＠仙台・mikaRingの音楽作品発表場です。オリジナルのサウンドトラック、歌モノ、ピコピコ３音アレンジなど、作詞作曲編曲をひとりで行います。", "https://mikaring0311.jimdo.com/", "https://twitter.com/mikaring0311", "http://com.nicovideo.jp/community/co1540005"]}, {"names": ["何度でも死ねる"], "misc": ["Block: [ R ]\nポガティブ系創作サークル「何度でも死ねる」です。打ち込みインスト曲メイン、女性ボーカルもほんの少しあります。明るくて暗いファンタジーをどうぞ、お気に召すまま！", "http://yourrain1617.blog.fc2.com/", "https://twitter.com/NANSHI_info"]}, {"names": ["Tonometer"], "misc": ["Block: [ R ]\nピアノ曲、歌ものを中心に制作しています。", "https://twitter.com/tonoasami"]}, {"names": ["erum."], "misc": ["Block: [ R ]\nオリジナルインスト(民族調、アコースティックなど)を中心に活動しているサークルです。ゲームアレンジ企画もあり。", "http://erum-c.com", "https://twitter.com/corico_erum", "http://www.nicovideo.jp/user/13965478"]}, {"names": ["あろきゃに♪"], "misc": ["Block: [ R ]\nエレキギターのせん太郎とピアノの月枷からなるユニット「あろきゃに♪」が綴る壮大なストーリー＼(^ω^)／＼(^曲^)／", "https://arrocany.com/", "https://twitter.com/@sen_arrocany", "http://www.nicovideo.jp/user/16758857"]}, {"names": ["studio-kurage"], "misc": ["Block: [ R ]\n変拍子多め、ジャズ、ロック、ポップスな歌ものを中心に取り扱っています", "http://studio-kurage.com/", "https://twitter.com/Studio_Kurage"]}, {"names": ["hi-sence"], "misc": ["Block: [ R ]\n「浮遊意識」という言葉をテーマにしたコンピレーションCDを頒布します。過去のユニークなコンピ作品もあります。", "http://hi-sence.net/", "https://twitter.com/twt_ryota"]}, {"names": ["fernweh"], "misc": ["Block: [ R ]\n”此処ではない何処か”への郷愁と音楽をテーマに、まだ見たことのないその音を一枚のアルバムにしました。ピアノとボーカルからなるイージーリスニングな景色。彼方（あなた）が求める場所はきっとこの中に。", "http://emma-fernweh.tumblr.com/", "https://twitter.com/emma_fernweh"]}, {"names": ["One Hundred Wishes"], "misc": ["Block: [ R ]\n【準新作】星に願った、彼女達のピアノボーカルアルバム「Second Wish～夜に煌めく碧玲の追憶～」好評につき再販！哀愁漂う楽曲や多重コーラス曲、スピード感溢れるポジティブソングまで収録した意欲作。", "http://100wishes.unison.jp/", "http://twitter.com/1Hundred_Wishes", "http://www.nicovideo.jp/user/63921962"]}, {"names": ["05"], "misc": ["Block: [ R ]\n店内BGM・イベントBGMなどの制作・プロモーション等をやっております。今回は、自由が丘のバー「Reborn」にて採用されたBGMのコンピレーションアルバムを頒布いたします。", "https://twitter.com/suguru_uraken"]}, {"names": ["必ず生きて、腸まで届く"], "misc": ["Block: [ R ]\nChicala Lpis(力ルピス)の個人サークルです。オーケストラや民族楽器を軸に、音ゲーに影響を受けたクラブテイストの音を僅かだけ盛り込んだファンタジー音楽を作ります。「悲劇」がテーマのアルバムを頒布予定です。", "http://c-lpis.net", "https://twitter.com/Chicala_Lpis"]}, {"names": ["ロドハウス"], "misc": ["Block: [ R ]\nオリジナルのゲーム音楽を製作しています。ぜひ来てね！", "https://twitter.com/rodo1023"]}, {"names": ["Symphonic City"], "misc": ["Block: [ R ]\n交響曲の街Symphonic Cityへようこそ！壮大で幻想的、また迫力満点のオーケストラ・サウンドトラック・映画音楽をお楽しみ頂けます。新譜で壮大な曲コンピレーションアルバム「ONNUEHO 6th Edition 」を頒布します。", "https://conarrcmpkyo.wixsite.com/symphonic-city", "https://twitter.com/@Kyocmp1", "http://www.nicovideo.jp/user/44860167"]}, {"names": ["Phonon forte"], "misc": ["Block: [ R ]\n平和な国に訪れる100年に一度の天災。生贄となる運命を変えるべく、第二王女と従者は動き出す。遺跡の中に存在するという、願いを叶える魔道書を求めて。――Fil Bleu", "http://phononforte.collon.net/", "https://twitter.com/ebiflyer", "http://www.nicovideo.jp/user/5013037"]}, {"names": ["飛練音響工業"], "misc": ["Block: [ R ]\n電車の走行音と爽やかなフュージョンで楽しむソージックシリーズ新作！！田園風景を駆け抜け、雄大な日本海をひた走る。あの特急をイメージした作品です！", "http://hiaudio.ame-zaiku.com/", "https://twitter.com/hiaudio"]}, {"names": ["B.rose&crown"], "misc": ["Block: [ R ]\n物語からイメージした幻想的な民族調楽曲を制作しております。多重コーラス多めです", "http://rujoutan.wixsite.com/the-artist-jp", "https://twitter.com/@maimaikatatumur", "https://soundcloud.com/mai-mori/2018-1a"]}, {"names": ["なないろらむね＋"], "misc": ["Block: [ R ]\n民族調・幻想的な楽曲を制作しています。謎解き少女シリーズ『黒髪少女と追想ディストピア』と旧譜の頒布をします！", "http://rainbowramune.site44.com/", "https://twitter.com/yuikirishima"]}, {"names": ["ウチナキレコード"], "misc": ["Block: [ R ]\n「少し泥臭く、懐かしい唄を。」をコンセプトにした創作民族系・多重・コーラス・民謡などを創作しています。", "http://uchinaki.com", "https://twitter.com/sakimafmi"]}, {"names": ["R-gear"], "misc": ["Block: [ R ]\nジャズ系インストアルバムとシリアス系インストアルバムを頒布。作業用BGMにどうぞ。", "http://regiapon1.wixsite.com/r-gear", "https://twitter.com/regia_tk101"]}, {"names": ["carimelo club"], "misc": ["Block: [ R ]\n古事記の世界をファンタジーRPGのようなオーケストラで再現します", "http://carimelo.com", "https://twitter.com/carimeloclub"]}, {"names": ["おやすみコンチェルト"], "misc": ["Block: [ R ]\n一人で黙々とファンタジックな音楽を作っている森の音楽家です◎", "http://harukineru.wixsite.com/harukineru", "https://twitter.com/haruki_neru"]}, {"names": ["箱の中のユーフォリア"], "misc": ["Block: [ R ]\n箱の中のユーフォリアの百守がさまざまなジャンルの楽曲を提供します。今回はダークファンタジーやクラシカルな新譜を予定しておりますよ。", "https://twitter.com/Mosu5mbx"]}, {"names": ["appolo monomania"], "misc": ["Block: [ R ]\nピアノとストリングスでファンタジー。ときどき歌。眠れない夜に聞いてほしい。", "http://yaplog.jp/a_m_0200/", "https://twitter.com/asg_am0200"]}, {"names": ["F-signal"], "misc": ["Block: [ R ]\n古き良きゲーム音楽を踏襲したインストサークル。新譜は連作コンピ、トリビュートコンピと音楽素材利用可能な個人アルバムを頒布予定。", "http://www.fsignal.miraiserver.net/", "https://twitter.com/rsy_fsignal"]}, {"names": ["MUSIRISCA"], "misc": ["Block: [ R ]\n英語詞・ソプラノ・幻想コーラスで紡ぐ、Yuria Miyazonoのメランコリックなミュージックコレクション。", "http://www.musirisca.com", "https://twitter.com/YuriaMiyazono"]}, {"names": ["DCRC music team"], "misc": ["Block: [ R ]\nこんにちは、DCRC music teamです。サークル会員が一生懸命制作したファンタジー系やアイマスアレンジ等のCDを出します。お気軽にいらしてください。"]}, {"names": ["音楽性の違いにより結成しました"], "misc": ["Block: [ R ]\n若鶏のグリル (新譜 CD と旧譜 DL カード頒布予定風)", "https://ongakusei.tumblr.com/", "https://twitter.com/ongakusei"]}, {"names": ["Amalgam"], "misc": ["Block: [ R ]\nジャズやロック、ローファイ等のインストゥルメントを配布予定です。", "http://amalgam10.blog.fc2.com/", "https://twitter.com/Amalgam_sound", "http://www.nicovideo.jp/user/82241419"]}, {"names": ["Corvo Grano"], "misc": ["Block: [ R ]\nゆっくりまったり系オリジナルインストを主に作ってます", "https://soundcloud.com/corvo_grano", "https://twitter.com/corvo_grano", "http://www.nicovideo.jp/user/3899680"]}, {"names": ["Acua Piece"], "misc": ["Block: [ R ]\n優しくてあたたかい雰囲気の音楽・BGMをメインに作っています。", "https://acua-piece.com", "https://twitter.com/acua_piece"]}, {"names": ["STUDIO AGASHA"], "misc": ["Block: [ R ]\n音楽素材、劇伴、BGM、声優ソング、舞台主題歌、エレクトロニカミュージックの作曲等をしています。", "http://studio-agasha.com", "https://twitter.com/studio_agasha"]}, {"names": ["広島作曲友の会"], "misc": ["Block: [ R ]\n広島作曲友の会は、広島の高校／大学同窓の音楽バ…もとい作曲家4人が立ち上げたサークルで、クラシック系の生演奏音楽を中心に、幅広く発表することを目指しています。", "http://aoba-physics.xsrv.jp/hirocon.html", "https://twitter.com/composehi", "http://www.nicovideo.jp/user/10550627"]}, {"names": ["Warp in the World"], "misc": ["Block: [ R ]\n宇宙を舞台としたオリジナル楽曲＆ボイスドラマ作品。計4時間を超える大ボリューム作品は全て一人で制作。声優演じる物語、迫力ある音響演出、そして場面を彩る様々な楽曲をお楽しみください。", "https://twitter.com/TomoSakura010"]}, {"names": ["AKATSUKI"], "misc": ["Block: [ R ]\n良質であることはもちろん、世に一石を投じることの出来る作品作りを心がけています。", "http://aktk.info/", "https://twitter.com/AKATSUKIkousiki"]}, {"names": ["Studio 輝音"], "misc": ["Block: [ R ]\n関西より初参加！Studio 輝音です！当日はオリジナルソングCDを頒布予定です！お気軽にお越し下さい♪", "http://kagune.com", "https://twitter.com/studio_kagune", "http://www.nicovideo.jp/user/82279917"]}, {"names": ["俺式ファンタジー"], "misc": ["Block: [ S ]\n自作曲・アレンジ曲による幻想物語音楽サイト。ファンタジックな世界観を基調に、民族音楽のエッセンスを活かしたインストや、エピックなオーケストラ曲を制作しています。", "https://www.oreshiki-fantasy.com/", "https://twitter.com/nabemon"]}, {"names": ["Recezza."], "misc": ["Block: [ S ]\n中国古来の楽器「二胡」が奏でる切ない旋律とジャズ、神秘的なシンセサウンドが融合したバンドRecezza.です。ぜひご試聴下さい！", "http://ongaku.fm/recommend/recezza/", "https://twitter.com/Recezza"]}, {"names": ["Rigel Theatre"], "misc": ["Block: [ S ]\nRigel Theatreは、欧州圏の民族音楽やハンス・ジマー系のサウンドトラックを取り入れたNeo Pagan Folk系オリジナル曲のアルバムを頒布しております。壮大で叙情的な作品が特徴です。", "http://www.rigeltheatre.com/index.html", "https://twitter.com/14_Rigel"]}, {"names": ["Drizzly light"], "misc": ["Block: [ S ]\nフュージョンからケルト調のハードコアまで色々。", "https://twitter.com/relite3526"]}, {"names": ["pura a puella"], "misc": ["Block: [ S ]\n2度目の参加となります、Puellaです。少女の指先は、光の物語を紡ぐ――", "http://p-puella.com", "https://twitter.com/si_puella", "http://www.nicovideo.jp/user/79501914"]}, {"names": ["ムシぴっぴのおうち"], "misc": ["Block: [ S ]\nムシぴ/ Solitary Orchestraのサークルです。オシャレかっこいい、ポストジャズとアルゼンチンタンゴの融合した新譜をリリースします！", "http://muship.wixsite.com/muship", "https://twitter.com/muship_64"]}, {"names": ["ITC STUDIO"], "misc": ["Block: [ S ]\n凝ったアルバム企画と、オリジナル曲集と、もしかしたらまたCDじゃない作品が出ます", "https://itcstudio.jimdo.com/", "https://twitter.com/Itcha"]}, {"names": ["おとのはこにわ"], "misc": ["Block: [ S ]\nそよもぎによる個人サークルです。なんか新しいCD出したい", "http://oto-hako.net", "https://twitter.com/soyomogi", "http://www.nicovideo.jp/user/1283916"]}, {"names": ["示方堂"], "misc": ["Block: [ S ]\nフュージョンとかプログレとかの影響を受けたゲーム音楽等", "https://soundcloud.com/zyuuziro", "https://twitter.com/ZyuuziA8"]}, {"names": ["菊田研究所"], "misc": ["Block: [ S ]\n菊田です。bpm120前後でサンプリング主体のインストを多く作ります。音同士を組み合わせたときに発生するいびつさを使って、寂しさとうつくしさを持つ音を出すことを目指しています。", "http://kikutalab.me/post/133728764201/about", "https://twitter.com/kikutalab"]}, {"names": ["ふえ吹き野うさぎ"], "misc": ["Block: [ S ]\n大好きなFluteをずっと続けたいという思いから、コンサートや作曲活動などで音楽を続けています。 最新作「Break moments」を含めたオリジナル曲集CDを販売いたします。", "http://haseflotist.moonlit.to", "https://twitter.com/hareflutist"]}, {"names": ["Musicae Fragmentum"], "misc": ["Block: [ S ]\n音楽を描く。物語を描く。絵本風のブックレットとともに音楽を。", "https://musicaefrugmentum.wordpress.com/", "https://twitter.com/MFragmentum"]}, {"names": ["COCOX"], "misc": ["Block: [ S ]\n山形県出身、ルンバ・フラメンカスタイルでスンガーソングライターをしているcocoxと申します。青い空と白い雲、くだらない事が大好き。あと、耳が遠いです。", "https://www.cocox.info", "https://twitter.com/cocox_sasayaki"]}, {"names": ["INUUNIQ"], "misc": ["Block: [ S ]\n\"生命\"という意味を持つ、変幻自在なプロジェクトユニット。音楽だけでなく、映像・音響・ダンサー・絵画など様々な分野のプロフェッショナル達と、前衛的でいてエンターテインメントな作品を創り上げている。", "http://inuuniq.com/", "https://twitter.com/INUUNIQmusic"]}, {"names": ["Sator"], "misc": ["Block: [ S ]\n絵と文字と音で1つの物語を作るサークル。1か月の記憶と、人に関するあらゆる記憶を忘れた青年が、現実と向き合う物語「IFの世界で生きる僕」頒布予定。（インスト＆女性ボーカルアルバム）", "http://tanebito.web.fc2.com/", "https://twitter.com/aokaze_souka"]}, {"names": ["Minstrel Fantasy -吟遊詩人の幻想歌-"], "misc": ["Block: [ S ]\n音楽が誘うファンタジーの世界へ…。民族音楽風・ゲーム音楽等の幻想的な曲がお好きな方に。", "http://minstrelfantasy.web.fc2.com/", "https://twitter.com/mf_ruca"]}, {"names": ["ぺんたす"], "misc": ["Block: [ S ]\nインダストリアルなアンビエントかもしれない", "https://circle-pentas.com/", "https://twitter.com/pentas91"]}, {"names": ["ねこわらし"], "misc": ["Block: [ S ]\nかききまなみとねこなごのサークルです。懐かしい気持ちになるエレポップなオリジナル曲をかわいらしい歌声で届けます。", "https://nekowarashi.jimdo.com", "https://twitter.com/neko_warashi"]}, {"names": ["Sailla col"], "misc": ["Block: [ S ]\nドラマー・ピアニストの二人組。透明感ある電子音とピアノによるインスト曲をメインに取り扱っています。", "https://saillacol.tumblr.com", "https://twitter.com/ak_kico"]}, {"names": ["stilka"], "misc": ["Block: [ S ]\nスティルカ【ｓｔｉｌｋａ】は、 女性ボーカルを中心に民族調やオーケストラ楽曲、 時にロックなども交えながら、 ふとした瞬間に聞き手の心と調和するような 幻想的な物語音楽を作っています。", "http://http://humbert.html.xdomain.jp/stilka.html", "https://twitter.com/stil_ka"]}, {"names": ["サイソウクウカン"], "misc": ["Block: [ S ]\n少女×音楽をテーマにファンタジーな世界観を創作するサークル。今回は従来シリーズではなくシンフォニックサウンドを軸に音楽中心のアルバムを制作予定", "https://saisokukan.net", "https://twitter.com/ao_saisokukan"]}, {"names": ["しっぽ置き場"], "misc": ["Block: [ S ]\nしっぽです！今回はファンタジー系個人アルバム２で参加予定です。", "http://sippo2117.wixsite.com/sippo", "https://twitter.com/sippomugi3"]}, {"names": ["木製みゅーと"], "misc": ["Block: [ S ]\n和風オリジナルインスト曲の制作を中心に活動しています", "http://sakamt.web.fc2.com/", "https://twitter.com/Ay_SAKA", "http://www.nicovideo.jp/user/15007062"]}, {"names": ["Sonatine à la Menuet"], "misc": ["Block: [ S ]\nピアノアレンジやピアノの自作曲をメインに出しております。", "https://twitter.com/mikomazic"]}, {"names": ["ABSORB COLOR"], "misc": ["Block: [ S ]\nアコギメインで頑張ってます!", "http://absorbcolor.jp/", "https://twitter.com/aja_kids"]}, {"names": ["armonia"], "misc": ["Block: [ S ]\nまっつんが、音楽でつながった仲間と一緒に、自由に作品を作り上げていく音楽集団。  音楽テーマ・作風はその都度変更していき、ジャンルに囚われない様々な音楽を作っていく。", "https://twitter.com/mattundaira2525"]}, {"names": ["Kasebrot"], "misc": ["Block: [ S ]\nケルト音楽、アイルランド音楽を取り入れたファンタジー世界観の打ち込み音楽CDを制作しています。", "http://sound-tribe.que.ne.jp/Kasebrot/", "https://mobile.twitter.com/yusukekogawa"]}, {"names": ["GOLDFISH"], "misc": ["Block: [ S ]\n女性ボーカル、ジャズ調のオリジナル曲です。弦、管すべて生音にこだわり、楽曲を制作しています。透き通る歌声と内面を描く詞が特徴です。", "https://goldfishes.wixsite.com/goldfish", "https://twitter.com/goldfish_web", "http://www.nicovideo.jp/user/4188317"]}, {"names": ["Abandoned Antique Moon Faktoria"], "misc": ["Block: [ S ]\n新譜やります！RPGのBGMっぽいCDやります！", "https://twitter.com/yagokoro_8556"]}, {"names": ["絃奏水琴樂章"], "misc": ["Block: [ S ]\n北欧の花の香里", "http://melodic-harp.net/", "https://twitter.com/krsm"]}, {"names": ["Spectra"], "misc": ["Block: [ S ]\nニコニコ動画を中心とした個人サークルSpectraです。今回は華麗で美しいボーカロイド初音ミクが帰らぬ想い人に捧げる一途な想いを歌った曲で、和風ダイナミックなオーケストラサウンドでお届けします。", "http://spectra.site", "https://twitter.com/spectracreativ2", "http://www.nicovideo.jp/user/49443903"]}, {"names": ["Unknown - Dimension"], "misc": ["Block: [ S ]\nピアノを主体としたヒーリングをメインに、民族音楽、オーケストラ、ジャズなど幅広く楽曲を制作しています。", "http://unknown-dimension.com/", "https://twitter.com/Rei_Shimizu", "http://www.nicovideo.jp/user/12525361"]}, {"names": ["EBI Zanmai"], "misc": ["Block: [ S ]\nあなたの身近に音楽を。主に民族・ヒーリング系インスト曲をアコースティックに乗せてお届けしております♪", "http://sound.jp/ebi_zanmai/", "https://twitter.com/EBI_at_EZ"]}, {"names": ["もぜ園"], "misc": ["Block: [ S ]\n主に民族系のオリジナルインスト曲を作っております。", "http://mozeen.com", "https://twitter.com/mozeen_mozell", "http://www.nicovideo.jp/user/2975648"]}, {"names": ["KLANG-GEAR"], "misc": ["Block: [ S ]\n20年以上のゲームファン&DTM歴。 古き良きゲーム音楽素材から、 本格的なリアルサウンドのＢＧＭ素材まで。 あなたの創作を熱く盛り上げたい。", "http://klang-gear.x0.com/", "https://twitter.com/matsumartin"]}, {"names": ["桜仔猫*"], "misc": ["Block: [ S ]\n『絵本のような物語』をテーマに、和風・西洋・民族などなど、ファンタジーな世界観をミュージカル調メインにさまざまなジャンルの楽曲で描いております。", "http://megmiu.ciao.jp/", "https://twitter.com/megmiu_aria"]}, {"names": ["お月さま交響曲"], "misc": ["Block: [ S ]\nツインボーカルや多重コーラス、台詞を交えた物語音楽やミュージカルを制作しているサークルです。", "http://moon-symphony.site/", "https://twitter.com/omiyaminase"]}, {"names": ["清田屋"], "misc": ["Block: [ S ]\nゼノブレイドの癒し系音楽などを担当しています作曲家清田愛未の清田屋です。コーラス盛りだくさんのファンタジー系作品を多く取り扱っています。KAGAYAスタジオの最新サントラあります！", "http://www.manamikiyota.com/", "https://twitter.com/manamikiyota"]}, {"names": ["なかやまらいでんのひみつ基地出張所"], "misc": ["Block: [ S ]\nゲーム音楽を作り続けて３０年手前！M3ではオリジナル作品（インスト、歌）を発表し続けております。ディープなテーマのアルバムを是非聴いてみてください！", "https://www.nakayamaraiden.com/", "https://twitter.com/nakayamaraiden", "http://www.nicovideo.jp/user/1038813"]}, {"names": ["流浪の民"], "misc": ["Block: [ S ]\n幻想民族音楽を作っております。稀によく迷走します。主にストーリーありきのファンタジーなボーカル楽曲を製作。誰かの耳と心に残る音楽を目指して。", "http://rulotami.web.fc2.com/", "https://twitter.com/rulotami", "http://www.nicovideo.jp/user/13618076"]}, {"names": ["ロータスルートオーケストラ"], "misc": ["Block: [ S ]\n広い意味でのファンタジー系中心に作ったり歌ったりしています。今回はるろーたす4とイニレコ関係の新作…予定です。", "https://lro-info.jimdo.com", "https://twitter.com/LotusYuka"]}, {"names": ["Duende Pianoforute"], "misc": ["Block: [ S ]\nジャズとクラシックの中間的なピアノ演奏メインのオリジナルインスト楽曲を好んで制作しています。家でのくつろぎ、移動時間のやすらぎ音楽をお届けします。", "https://duendepianoforte.popolony.com/", "https://duendepianoforte.popolony.com/discography/grooming/", "https://twitter.com/duende_pf"]}, {"names": ["Prictnium"], "misc": ["Block: [ S ]\nオリジナルジャズアルバムやカバー等を制作・頒布しています。", "http://prictnium.net", "https://twitter.com/Prictnium"]}, {"names": ["Metomate"], "misc": ["Block: [ S ]\nストリングス、ピアノを主体とした退廃的な世界観の女性Voロックを制作しています。過去曲をピアノアレンジした新譜を頒布予定です。ドラマティックや壮大なピアノ編成曲が好きな方は是非お立ち寄りください。", "http://metomate.com/", "https://pianocollection2.tumblr.com/", "https://twitter.com/tk_meto", "https://soundcloud.com/meto-6"]}, {"names": ["Lilfy"], "misc": ["Block: [ S ]\n女性ボーカル２人、イラストレーター１人で活動中。今回Lilfyは旧譜のみですが、上園個人の新譜があります。モチーフアクセも頒布予定。", "http://lilfy.com", "https://twitter.com/chisamaroon", "http://www.nicovideo.jp/user/3145610"]}, {"names": ["Mundi renovatio"], "misc": ["Block: [ S ]\n実の三姉妹による空想民族ポリフォニー", "http://mundirenovatio.com", "https://twitter.com/mundirenovatio"]}, {"names": ["シャルキィロマ"], "misc": ["Block: [ S ]\nアラブ・ロマ・アイリッシュなどを基調としたオリジナル音楽を各国の民族楽器を使って収録。ZABADAKの吉良知彦・Rita・藤野由佳・佐々木絵実らも参加した待望の3rdアルバムはエスニックプログレとも呼ばれる話題作。", "http://sharkiroma.com/", "https://twitter.com/sharkiroma", "http://www.nicovideo.jp/user/18835423", "https://www.youtube.com/watch?v=2HhHWKCo1W4", "https://www.youtube.com/channel/UCjFso3u0MyJBETU0bJf0Nyw"]}, {"names": ["KANKITSU RECORDS"], "misc": ["Block: [ T ]\n春M3で出せなかったnaccleとくふの作曲ユニット「なくふる」の3rdアルバム「シトラス・フォレスト３（仮）」をこんどこそこんどこそ出します。ジャズ風×民族風×テックダンスの予定です！今回は派手な感じにしたい！", "http://kankitsu.net", "https://twitter.com/kuhudon"]}, {"names": ["Happy Forest"], "misc": ["Block: [ T ]\nスマートフォン用音楽ゲーム「STELLIGHTS」収録の、\"星屑の手紙\" ロングバージョンを収録し、その他、本E.P.用描き下ろし楽曲を５曲収録。", "http://www.naccle.net/", "https://twitter.com/naccle"]}, {"names": ["houyhnhnm."], "misc": ["Block: [ T ]\nファンタジー風インスト中心サークル。旅する音楽・幻奏旅行記、シリーズ最終作を頒布します。", "http://hynm-wakabatei.strikingly.com/", "https://twitter.com/aim_hynm"]}, {"names": ["Euchaeta"], "misc": ["Block: [ T ]\nパレード = プログレッシブ・ロック / エレクトロニカ / その他さまざまな音楽の要素をたくさん", "http://euchaeta.net/", "https://twitter.com/euchaeta"]}, {"names": ["明治大学オーディオエンジニアリングクラブ"], "misc": ["Block: [ T ]\n今回もマルチジャンルでお届けします『こだいあ』はついに10作目になりました！感謝もこめつつ新たなメンバーと共に個性豊かなオリジナル曲をお届けします！！", "https://twitter.com/AUDIOTTER"]}, {"names": ["The Spring Beach Works."], "misc": ["Block: [ T ]\nNina Branchとはりいによるユニット、The Spring Beach Works.です。女性ボーカルのオリジナル曲をメインにジャンルなんでもありで活動してます。", "http://www.haruhama.com/", "https://twitter.com/_haruhama"]}, {"names": ["el ma Riu"], "misc": ["Block: [ T ]\nel ma Riu（えるまりう）の個人サークルです！オリジナルの民族調×幻想系×ファンタジー音楽や、架空言語多重コーラス作品を扱っております。+小説やイメージアクセサリーetc...", "http://el-ma-riu.com", "https://twitter.com/el_ma_riu", "http://www.nicovideo.jp/user/39595650"]}, {"names": ["Hagall"], "misc": ["Block: [ T ]\n民族音楽を取り入れた曲や、サウンドトラック風の曲を自由に制作しています。", "http://hagall.hacca.jp/", "https://twitter.com/hagall_music"]}, {"names": ["Imaginary Perception"], "misc": ["Block: [ T ]\nピアノ・インスト・プロジェクトです。 メロディと音色の美しさや、変拍子によるプログレッシヴな緊張感のあるリズムの楽曲がメインです。  透明感のある音が好きな方は是非聴いてみてください。", "https://yusuke-ip.tumblr.com/", "https://twitter.com/YusukeIP", "http://www.nicovideo.jp/user/18211822"]}, {"names": ["SoundstorM"], "misc": ["Block: [ T ]\n「重く、激しく、美しく」をコンセプトに歌モノ・インストを問わず楽曲制作しています。メタル、シンフォニック、ゴシック成分多め。クールに熱い曲をお届けします。", "https://soundcloud.com/kamui-4/the-fifth-blue-moon-xfade", "https://twitter.com/stormkamui", "http://ameblo.jp/stormkamui", "http://www.nicovideo.jp/user/1821678"]}, {"names": ["office ACER"], "misc": ["Block: [ T ]\nオリジナルのクラシック曲を制作しております。楽譜も頒布しております。", "http://office-acer.net", "https://twitter.com/office_acer", "http://www.nicovideo.jp/user/391552"]}, {"names": ["son voyage"], "misc": ["Block: [ T ]\n劇場型、宝塚風音楽を創作しているサークルです。歌唱パートと、芝居パートによる表現を目指しています。", "http://sonvoyage.net/", "https://twitter.com/son_voyage"]}, {"names": ["四つ角屋"], "misc": ["Block: [ T ]\nミクさんの口三味線(くちじゃみせん)による民謡カバーをやってます。名付けて「しゃみくせん」を出します。トンチチトンチチ、とミクさんの口三味線がかわいらしいと思います(*´ω｀*)", "http://yotsukado-ya.jimdo.com", "https://twitter.com/ki10roh", "http://www.nicovideo.jp/user/38322221"]}, {"names": ["Heal Abenue"], "misc": ["Block: [ T ]\nここだけの癒しの音楽を皆様へ", "http://healabenue.jp/weblog/"]}, {"names": ["骸骨音楽堂"], "misc": ["Block: [ T ]\n作曲家”Jaikki-Rocky”の即興ピアノ作品、クラシカルな音楽や、実験音楽などをお取り扱いしております。", "http://jaikki-rocky.com/", "https://twitter.com/SMF_jaikki/"]}, {"names": ["ペンギン娯楽企画"], "misc": ["Block: [ T ]\n生楽器を録ったり、オーケストラを打ちこんでみたりしています。オリジナルの歌物や音楽劇。最近はダム巡りにはまってるので、ダムソングも作ってる。", "http://penep.org/", "https://twitter.com/penep_"]}, {"names": ["OriverMusic"], "misc": ["Block: [ T ]\nケルトの笛(ティンホイッスルやアイリッシュフルートなど)をフーフー吹きつつ、オーケストラ、 民族、ピアノ、主にオリジナルのサウンドトラックをがしゃがしゃ作っています。ティンホイッスルの販売も始めました。", "https://www.orivermusic.com/", "