es": ["みけねこれこーど☆"], "misc": ["Block: [ I ]\nどう見てもょぅι゛ょな茶花ういさんと今回は可愛いくておしゃれなコラボアルバム作ります！", "https://mikerec.wixsite.com/mikerec", "https://twitter.com/mikenekostar"]}, {"names": ["水彩アトリエ"], "misc": ["Block: [ I ]\nRetropolitaliensの新譜が出ます", "https://ms-iro-atelier.com", "https://twitter.com/ms_clnlb"]}, {"names": ["rice_cracker."], "misc": ["Block: [ I ]\n多方向音楽制作サークル。", "https://twitter.com/rice_cracker_0", "https://twitter.com/rice_cracker_0"]}, {"names": ["Queen of Wand"], "misc": ["Block: [ I ]\nダークメルヘンでバロックでクラシカル、一方でダンサブルでポップでキャッチーな女性ボーカルユニット。一見ジャンルはカオスなのになぜか統一感が有る。嘆美と素朴の合わせ技、それがQueen of Wandです。", "http://q-o-w.jp", "https://twitter.com/QoW_kitsune"]}, {"names": ["Duke Takazawa Sound Lab"], "misc": ["Block: [ I ]\nポップなノリと、グルーヴ感あふれるサウンドを追求したハウスミュージック", "https://twitter.com/duketakazawa", "https://twitter.com/duketakazawa"]}, {"names": ["appolo monomania"], "misc": ["Block: [ I ]\nピアノとストリングスをメインに歌やインストゥルメンタル楽曲を。", "https://www.appolomonomania.com/", "https://twitter.com/asg_am0200"]}, {"names": ["ひろポンとその家族"], "misc": ["Block: [ I ]\n良きサウンドを！！をコンセプトにサウンドクリエーター「えびせん」こと鍵盤弾き「吉野 ひろき」が今ある力を最大限に駆使しエモく楽しい音楽を創るプロジェクト", "https://twitter.com/ebisen_p", "https://www.nicovideo.jp/my/mylist/#/63754100"]}, {"names": ["ロータスルートオーケストラ"], "misc": ["Block: [ I ]\n普段はファンタジー系楽曲が多めですが、今回はFenrir recordsさんとの今までのコラボ楽曲をまとめたベストアルバムを予定しています。昭和風多め！", "https://lro-info.jimdo.com/", "https://twitter.com/yuka_lro"]}, {"names": ["流浪の民"], "misc": ["Block: [ I ]\nファンタジー音楽作ってます。稀によく迷走します。ファンタジー畑のサークルですが、それがポップスを作ったらどうなるかにチャレンジしてみようかな。", "http://rulotami.web.fc2.com/", "https://twitter.com/rulotami"]}, {"names": ["At the Garret"], "misc": ["Block: [ I ]\nレトロ・アンティークな世界観で物語音楽を制作しています。", "http://atthegarret.web.fc2.com/", "https://twitter.com/at_garret"]}, {"names": ["Ideadoll"], "misc": ["Block: [ I ]\n初参加！ At the Garretのボーカル鹿伽あかりと桃羽ことによる新・ユニット『Ideadoll(イデアドール)』です。 雪に微睡む世界で出会う２人の少女の百合系物語音楽をお届けします。", "https://ideadoll.web.fc2.com/matsuyukisou/", "https://twitter.com/idea_doll"]}, {"names": ["kalligulauph -カリギュラフ-"], "misc": ["Block: [ I ]\nケロとほのづきによるレーベル。季節をテーマにしたボーカルアルバム第2弾『フユノイロ』を頒布予定。", "https://www.youtube.com/watch?v=VSuOAgI6RuA", "https://twitter.com/kero_BIRUGE", "https://www.nicovideo.jp/user/974756"]}, {"names": ["定時後ビールタイム"], "misc": ["Block: [ I ]\n会社の音楽好きな仲間が大集合！定時後に曲を作ってます。歌もの多ジャンルのコンピレーションアルバム、新譜出せるように頑張ります！", "https://teijigo-beer-ti.me/", "https://twitter.com/tbt_cf"]}, {"names": ["ヲレンヂシグナル"], "misc": ["Block: [ I ]\nボーカルmanamoとコンポーザーk@nyのユニットです。看板猫のねこおばけが目印です！(旧momo monaka)", "https://orange-signal.tumblr.com", "@orange_signal"]}, {"names": ["liqueurprime"], "misc": ["Block: [ I ]\n可愛いもキラキラも電波も切なさも、いーっぱい詰め込んだ、オリジナルボーカルCDを制作しています。新譜は可愛いをめいっぱい詰め込んだ久しぶりのシングルです。よろしくお願いいたします！", "https://liqueurprime.amebaownd.com", "https://twitter.com/liquoricedrop", "http://www.nicovideo.jp/user/66905233"]}, {"names": ["kujuプロレコーズ"], "misc": ["Block: [ I ]\n茨城県の名物プロデューサー「クジライヨシユキ」の作品群を主に販売してます。アイドルソングからEDM、歌謡曲からインスト物、バンドのプロデューサーまで幅広く作ってます！", "http://kujuproduction.com", "https://twitter.com/kujuproduction"]}, {"names": ["NEXUS BRAIN"], "misc": ["Block: [ I ]\nNEXUS BRAINは、男性ヴォーカリスト「MASAYA 」によるエレクトロ、ロック、メタル、シンフォニックでサイバーな音楽プロジェクトです。今回初参加になりますが、皆さんご贔屓に宜しくお願いします！", "http://nexusbraim58.wixsite.com/mysite", "https://twitter.com/brain_nexus"]}, {"names": ["屋根裏ひみつ結社"], "misc": ["Block: [ I ]\nエレクトロファンタジーを創作するプロダクション。屋根裏の歌劇座、路地裏みかん箱。、back alley orange box. など。", "https://mecanbaco.net/", "https://twitter.com/mecanbox"]}, {"names": ["クロノメルフェ"], "misc": ["Block: [ I ]\n童話を題材としたダークファンタジーを紡ぐ集団。ゴシックメタルからテクノ、多重コーラスの民族調音楽まで幅広いジャンルの楽曲と女性ボーカル二人のハーモニーであなたを、本当は怖い童話の世界へ。", "http://chronomerfe.chu.jp/", "https://twitter.com/chronomerfe"]}, {"names": ["Merveille"], "misc": ["Block: [ I ]\nSound Horizonメタルアレンジカヴァーバンド。メタルのみならず、様々なアレンジでSound Horizonの新しい魅力を引き出していきます。", "homepage2.nifty.com/veer/merveille/", "https://twitter.com/Team_Merveille"]}, {"names": ["ぽてとたわー"], "misc": ["Block: [ I ]\n女性ボーカルの爽やかポップス!", "https://potatotower.jp", "https://twitter.com/kana85hz2c"]}, {"names": ["chouchou fleur"], "misc": ["Block: [ I ]\n季節の花とともに贈る物語「Herbarium」の新譜が出ます。Magicalinyも一緒！", "http://glass-moon.com/ccfleur/", "https://twitter.com/ccfleur000", "http://glass-moon.com/ccfleur/", "https://www.youtube.com/watch?v=Hrbn0RRIG7Y"]}, {"names": ["CharmQuadru Records"], "misc": ["Block: [ I ]\n毎回異なるジャンルを作曲するメンバー達を募り、コンピアルバムを制作。 今回は、shout（心の叫び、秘めてること、言えないこと）をテーマにコンピアルバムを出します。 是非、お手に取って聴いてみてください。", "https://twitter.com/CharQua_Record", "https://twitter.com/CharQua_Record"]}, {"names": ["stellarium"], "misc": ["Block: [ I ]\nここは、星の記録庫。宇宙中の物語が集まる場所。今日も、新たな「お話」を用意してお待ちしています。", "https://twitter.com/toboshi_u", "https://www.nicovideo.jp/user/40818258"]}, {"names": ["神戸大学DTM作曲同好会音見鶏"], "misc": ["Block: [ I ]\n今年も神戸から新譜を引っ提げ登場します", "http://www.otomidori.at-ninja.jp/", "https://twitter.com/KobeDtm"]}, {"names": ["ideal Imitation"], "misc": ["Block: [ I ]\nAlternative Rock, Post Rockを軸に心象のスケッチを試みています。", "https://twitter.com/awlsfy", "https://twitter.com/awlsfy"]}, {"names": ["auspicious lethargy"], "misc": ["Block: [ I ]\nバンドサウンドを基調とした女性ボーカル曲を作っている大学生です。アニメソングやアイドルソングといったポップな曲調が好きです。", "https://mobile.twitter.com/SKGon_the_shore"]}, {"names": ["UEC DTM研究会"], "misc": ["Block: [ I ]\n電気通信大学非公認DTMサークル　UEC DTM研究会です！このサークルではテーマに沿ってサークルメンバーが作った様々なジャンルの曲をお楽しみいただけます。", "https://twitter.com/uec_dtm"]}, {"names": ["大阪大学音楽制作サークルラムレーズン"], "misc": ["Block: [ I ]\n音楽制作サークルラムレーズンです！大阪大学を中心に活動している、オリジナル楽曲をつくるサークルです！", "http://machikanecat.web.fc2.com", "https://twitter.com/tsukuritai2012"]}, {"names": ["AITC"], "misc": ["Block: [ I ]\n東京理科大情報技術クラブのOB達がCD作ります", "https://twitter.com/ZyuuziA8"]}, {"names": ["DJ東大生"], "misc": ["Block: [ I ]\n社交ダンス・インストポップス・アイドルポップス・EDM！社交ダンス用のリミックスアルバム、インストポップスも出してます。いつでも声かけてください！！", "なし", "https://twitter.com/dancewavestaff"]}, {"names": ["東京都市大学デジタルコンテンツ研究会"], "misc": ["Block: [ I ]\n東京都市大学・デジタルコンテンツ研究会のDTM部門の部員が作った楽曲アルバムを頒布します。", "https://tcu-dc.net/", "https://twitter.com/tcu_dc"]}, {"names": ["ZeroDivideRecords"], "misc": ["Block: [ I ]\nサークルメンバーによるコンピレーションアルバム、”ZDream Vol.7”を新作品として販売します。旧作品も数種販売します。", "http://zerodividerecords.wixsite.com/zerodividerecords", "https://twitter.com/ZER0_DR"]}, {"names": ["Anti-Aging Record"], "misc": ["Block: [ I ]\n名古屋大学作曲サークルAnti-Aging Recordです！今回はフリージャンルのvol.18とテーマCDの計2種を頒布する予定です！また、さまざまな旧譜も持っていく予定です。お楽しみに！", "http://aar.lolipop.jp", "https://twitter.com/antiagingrecord", "https://www.nicovideo.jp/user/33292044/video?sort=v"]}, {"names": ["FancyRecords"], "misc": ["Block: [ I ]\n法政大学小金井キャンパスで活動している音楽サークル、法政大学作曲研究会FancyRecordsです！ 音楽ジャンルにとらわれない様々な楽曲制作をしております！", "https://fancyrecords.wixsite.com/fancyrecords", "https://twitter.com/fancy_records"]}, {"names": ["神楽坂一丁目通信局"], "misc": ["Block: [ I ]\n君が創り上げる、君だけの世界。 DTM,DJ/CG,イラスト/プログラミング/Web開発を行っているメディア系総合創作サークルです。", "https://kagucho.net/", "https://mobile.twitter.com/kagucho"]}, {"names": ["デジクリサウンドチーム"], "misc": ["Block: [ I ]\n芝浦工大デジタル創作サークル「デジクリ」のDTM部門です。時代が移り変わっていく今、各々の「Nostalgia」を集めたオリジナルアルバムをお届けします。ぜひ遊びに来てください！", "https://soundcloud.com/sitdigicre", "https://twitter.com/digicre_sound"]}, {"names": ["A.I.Tech Records"], "misc": ["Block: [ J ]\n愛知工業大学DTMサークルです。今回も新譜を予定してます！", "http://aitrecords.blog.fc2.com", "https://twitter.com/Aitdtmclub"]}, {"names": ["明治大学オーディオエンジニアリングクラブ"], "misc": ["Block: [ J ]\n明治大学生田の森からやってきたオーディオサークルです。スピーカー・アンプ、DTM、イベントPAの三部門のDTM部門から、今回も個性豊かなメンバーが思い思いの曲を作ります。", "https://twitter.com/＠AUDIOTTER"]}, {"names": ["中央大学　通メ"], "misc": ["Block: [ J ]\nコンピレーションアルバムを出します", "https://twitter.com/CMS_sound_team"]}, {"names": ["山梨大学WineRed"], "misc": ["Block: [ J ]\nBPM160以上、アップテンポで勝負だ！！！", "https://yu-winered.tumblr.com/", "https://twitter.com/YU_WineRed"]}, {"names": ["情報技術クラブ"], "misc": ["Block: [ J ]\n東京理科大学葛飾キャンパス情報技術クラブのDTM部です！部員たちのオリジナル楽曲を収録したアルバムを販売しております！よろしくお願いします！", "http://tusitc.com", "https://twitter.com/tusitclub"]}, {"names": ["RICORA MUSIC TEAM"], "misc": ["Block: [ J ]\n東京理科大学DTMサークルRICORAです。よろしくお願いします！", "https://www.ed.tus.ac.jp/ricora/MusicTeam/index.html", "https://twitter.com/ricora_dtm_dj"]}, {"names": ["Tech-nation Records"], "misc": ["Block: [ J ]\n東京工業大学のDTMサークルです。新譜出します！旧譜もあります。", "https://newtechnation.tumblr.com/", "https://twitter.com/TNationRecords"]}, {"names": ["Tsukuba DTM Lab."], "misc": ["Block: [ J ]\n筑波大学作曲サークル「Tsukuba DTM Lab.」はbandcampにて一ヶ月に一度無料のEPを公開しております。m3とコミケでは有償のCDを制作し頒布しています。", "https://tsukubadtm.bandcamp.com", "http://twitter.com/tsukubadtm", "http://www.nicovideo.jp/user/48523513"]}, {"names": ["ICON音楽班"], "misc": ["Block: [ J ]\n静岡大学浜松キャンパスのICONです。アレンジやオリジナル,インスト曲の作成など幅広く活動しています。", "https://iconcreator.web.fc2.com/", "https://twitter.com/ICON_sh"]}, {"names": ["東京電機大学二部ソフトウェア研究部"], "misc": ["Block: [ J ]\n東京電機大学二部ソフトウェア研究部です！よろしくお願いします！"]}, {"names": ["法政大学宅録同好会"], "misc": ["Block: [ J ]\n毎度おなじみ法政大学市ヶ谷キャンパスのDTMサークル", "http://artist.aremond.net/hoseitakuroku/", "@hoseitakuroku"]}, {"names": ["Creative Sound lab."], "misc": ["Block: [ J ]\n我々Creative Sound Lab.は大阪工業大学に所属するDTMを行う部活動です。ジャンルにこだわりなくそれぞれが様々なジャンルの楽曲を作っています。日頃作ってきた多種多様な楽曲を頒布します。", "https://twitter.com/oitcslab"]}, {"names": ["swampland sounds"], "misc": ["Block: [ J ]\n初参加です。猫が好きです。雨の日にぴったりなインスト・エレクトロミュージックをお届けします。", "https://swamplandsounds.bandcamp.com", "https://twitter.com/hnt_lly"]}, {"names": ["CIT Softmedia DTM Team"], "misc": ["Block: [ J ]\n千葉工業大学ソフトメディア研究会DTM班です！班員のオリジナルの楽曲を収録した作品を販売します！", "http://softmedia.sakura.ne.jp/dtm/index.html", "https://twitter.com/cit_sofume", "http://www.nicovideo.jp/user/39824628"]}, {"names": ["東京大学作曲研究会GCT"], "misc": ["Block: [ J ]\n東京大学の作曲サークルです！", "https://gctutokyo.wixsite.com/home", "https://twitter.com/gct_utokyo"]}, {"names": ["吉田音楽製作所"], "misc": ["Block: [ J ]\n吉田音楽製作所は京都大学を中心として活動する総合作曲サークルです。クラブ系、ポップス、インスト系、器楽など幅広く取り揃えております。", "http://kitchon.net/", "https://twitter.com/kitchon"]}, {"names": ["TeRes DTM Project"], "misc": ["Block: [ J ]\nクラブ系のコンピレーションアルバムを販売します。", "https://twitter.com/TeresDtm"]}, {"names": ["東京電機大学ソフトウェア研究部"], "misc": ["Block: [ J ]\n班員の制作した楽曲を集めたコンピレーションアルバムを頒布します！", "http://srcsound.sakura.ne.jp/", "https://twitt