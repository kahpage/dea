aro"]}, {"names": ["Chuya Kamoi"], "misc": ["Block: [ 橙 ]\nTrackMaker/Composer/Arranger/Electronic/Noise/Ambient/DarkAmbient/Drone", "https://chuyaskyboy.wixsite.com/mysite", "https://twitter.com/ChuyaSkyBoy", "https://www.youtube.com/channel/UC-ojUMXxzewQ5kn54Y56tZA", "https://www.tunecore.co.jp/artist/chuya_kamoi#r548945"]}, {"names": ["STRLabel"], "misc": ["Block: [ 橙 ]\nアナログとデジタルを横断するモダン・クラブミュージック・レーベルです。We are a modern club music label that crosses the analog and digital divide.", "http://str3.org/", "https://twitter.com/strlabel", "https://soundcloud.com/strlabel"]}, {"names": ["Lost Garden"], "misc": ["Block: [ 橙 ]\nProgressive House、Big RoomやElectronicaなど、 幅広いジャンルのエレクトロニックダンスミュージックを色彩豊かにお届けします。", "https://lost-garden.info/", "https://twitter.com/kaguraduki", "https://www.youtube.com/user/LOSTGARDENER"]}, {"names": ["Saoriiiii"], "misc": ["Block: [ 橙 ]\n泣く子も踊りだすエレクトロ歌姫ガール", "https://www.saoriiiii.com/", "https://twitter.com/saorinkoz", "https://www.youtube.com/channel/UCj0XFEEYiX96R5QuLMI9VQQ"]}, {"names": ["Catchy Girly"], "misc": ["Block: [ 橙 ]\nラグる　めっちゃニューラグる", "https://twitter.com/Catchy_Girly", "https://soundcloud.com/gishi_rb"]}, {"names": ["Core Activity"], "misc": ["Block: [ 橙 ]\nダーク民族調ゲームBGM等なんでもありのアルバムを作ります！", "https://twitter.com/yx28dtm"]}, {"names": ["PCHW"], "misc": ["Block: [ 橙 ]\n悪そうな音楽や踊る音楽を作ったりします", "https://soundcloud.com/pchw/doping-night-xfd", "https://twitter.com/pchw"]}, {"names": ["SHIFTTUNES"], "misc": ["Block: [ 橙 ]\nSHIFT TUNESが強めの音で頑張る", "https://twitter.com/ysknrtk", "https://soundcloud.com/yoshiki-narutaki"]}, {"names": ["イキモノレコーズ"], "misc": ["Block: [ 橙 ]\nバーチャルねこの音楽を、取り扱っています。", "http://id41.fm-p.jp/482/virtualneko/", "https://twitter.com/neko_vtuber", "https://www.youtube.com/channel/UCKDHdDpoE9lurDuyAGAuNnw"]}, {"names": ["Noisejack Leonberger+Stella Cadenza"], "misc": ["Block: [ 橙 ]\nRIZARDI a.k.a. Ryusei＝一人二役。攻撃的ダンスミュージックとキテレツポップが融合する、唯一無二の迷作を。", "https://twitter.com/Ryusei_SC", "https://www.youtube.com/channel/UCrRBXVCV7ha