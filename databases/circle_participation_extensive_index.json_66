es": ["CrossRevol"], "misc": ["Block: [ K ]\n髙良かすみと槙野明、女性ツインボーカルが織り成す革命的ユニットがお送りするサークル", "https://twitter.com/CrossRevol", "https://youtube.com/channel/UCMLDIDnQBy-8J0HbbDix7SA"]}, {"names": ["#ワクラボ"], "misc": ["Block: [ K ]\n音楽家のためのオンラインサロン#ワクラボのメンバー有志16名によるコンピVol.2制作決定★", "https://kensukeinage.com/wakulabo-guide01/", "https://twitter.com/wakulaboratory?s=20&t=QxHd5zi0rZhoi-vM1e_2EQ"]}, {"names": ["appolo monomania"], "misc": ["Block: [ K ]\n心が動く音楽を。ピアノ、ストリングス、女性Vo。", "https://twitter.com/asg_am0200", "https://twitter.com/asg_am0200", "https://www.youtube.com/channel/UCnE1KdCiqg6C-McM-3sG6Ww"]}, {"names": ["Alumina"], "misc": ["Block: [ K ]\nーきっと君の恋の歌になるー 正統派ポップスを軸に活動する3人組音楽サークルです！どこか共感してしまう甘酸っぱい青春の音を紡ぎます！", "https://poporon1994.wixsite.com/website", "https://twitter.com/Alumina_yk", "https://www.youtube.com/channel/UCCEj52dpsVGtoC37Le9S0Iw"]}, {"names": ["優莉"], "misc": ["Block: [ K ]\n前向きになれる爽やかな曲をお届けします♪少女漫画「マーメイドメロディーぴちぴちピッチ」イメージソング最優秀賞なないろメモリーが入った初シングルです！ぜひお立ち寄りくださいませ★", "https://lit.link/yuritsunchaka", "https://twitter.com/yuritsunchaka", "https://www.youtube.com/channel/UCmk7xiOWr0RvnmFk3g9XB5A"]}, {"names": ["Music Pandora"], "misc": ["Block: [ K ]\n作曲家光田晋哉のサークル。歌詞を大切に曲を宛てて、少し変わったポップス曲を紡いでいます。", "http://music-pandora.com/", "https://twitter.com/musicpandora", "https://www.youtube.com/channel/UCqBSA-eetuJGzEF9CS128aQ"]}, {"names": ["踊ル音楽家"], "misc": ["Block: [ K ]\n今回は「戦隊ヒーロー」をテーマに参戦します。DTMサークル「踊ル音楽家」です。『昭和』のスーパー戦隊から『令和』のスーパー戦隊まで！楽曲をメインに、世界観を広げるボイスドラマも！ネタ8割、ガチ2割！", "https://twitter.com/odoru_music?s=21&t=XF8obIFrfQs7VNPM5ma2kQ", "https://m.youtube.com/channel/UCryZ5W-VyBYSGf1R_Ah-ehA", "https://odoru.booth.pm/"]}, {"names": ["泉の庭ちゃんぷるー"], "misc": ["Block: [ K ]\nケルト風・和風・アラビア風などの民族調の曲やダークファンタジー系シンフォニック・ロックなど、ファンタジックな世界観をお楽しみください。", "https://izuminoniwa.storeinfo.jp/", "https://twitter.com/yuuduki_mari", "https://www.youtube.com/channel/UCA5FTXNAIEwKrzka1PKzVkA", "https://twitter.com/izuniwa001"]}, {"names": ["路地裏スクランブル"], "misc": ["Block: [ K ]\n渋谷系・アキシブ系サウンドに各々が挑戦したコンピアルバムを頒布します！", "https://twitter.com/kuracchiii"]}, {"names": ["スタジオゆい"], "misc": ["Block: [ K ]\nいろんな音楽を届けるよ！", "https://twitter.com/Yui_YZK", "https://www.youtube.com/channel/UCtUWLEuu1vCxgpa4AYL8-cQ", "https://www.nicovideo.jp/user/46722342/video?ref=pc_userpage_menu"]}, {"names": ["骸骨音楽堂"], "misc": ["Block: [ K ]\nJaikki-Rocky, cosmoduorumのアルバム、その他実験音楽現代音楽などの楽曲を制作しています。", "https://smf.jaikki-rocky.com/", "https://twitter.com/smf_jaikki", "https://www.youtube.com/c/JaikkiRocky", "https://smfjapan.bandcamp.com/"]}, {"names": ["ペンギン娯楽企画"], "misc": ["Block: [ K ]\n生楽器を録ったり、オーケストラを打ちこんでみたりしています。オリジナルの歌物や音楽劇。最近はダム巡りにはまってるので、ダムソングも作ってる。", "http://penep.org/", "https://twitter.com/penep_"]}, {"names": ["放浪茶屋"], "misc": ["Block: [ L ]\n美名メロ意識しつつ、バンドでも表現出来そうな構成の歌ものを中心に製作しています。", "https://twitter.com/hourouj"]}, {"names": ["Sky Ensemble"], "misc": ["Block: [ L ]\n青空を飛び回り、駆け巡るように自由にロックサウンドをかき鳴らす！そんなモットーを胸にオリジナル曲作ってます！ゲームやアニメモチーフだったり、何気ない日常の感情がテーマな曲だったり！", "https://mobile.twitter.com/Sanae_raizin", "https://m.youtube.com/user/sanae979"]}, {"names": ["Nem0aliuS"], "misc": ["Block: [ L ]\n†混沌たる現世に舞い降りし漆黒かつ純白かつ極彩色の狂気を纏いし調べを生み堕としし孤高の未だ誰も識らない個人サークル†～ガチソプラノを添えて～", "https://twitter.com/nem0alius?t=-O2qtzJr0r5ylBvAXrgrEg&s=03"]}, {"names": ["sky color notes + SQARE Pixel"], "misc": ["Block: [ L ]\nIONによるソロ名義・sky color notesの新譜をメインに市瀬るぽとのユニット名義・SQARE PixelのCDを頒布します。", "https://inwonderlandion.wixsite.com/scns-ion-top", "https://twitter.com/w_ion_w", "https://www.youtube.com/channel/UCg6yo0Z6seOr6xA_bF2ehvg", "https://soundcloud.com/sqpx-ion"]}, {"names": ["amorphous"], "misc": ["Block: [ L ]\n「不定形少女音楽」をテーマにしたエレクトロニカやポストクラシカルなど。好きな飲み物は日本酒。", "https://amorphous.booth.pm/", "https://twitter.com/ride_san", "https://youtu.be/-PpePOPN5h8", "https://soundcloud.com/riddelap"]}, {"names": ["little figments"], "misc": ["Block: [ L ]\nちょっと懐かしいインストなど", "https://little.figments.jp/", "https://soundcloud.com/izaya-togawa"]}, {"names": ["Pleasant Sounds"], "misc": ["Block: [ L ]\n女性ボーカルのバラード曲や、Voisona(知声)の歌うUKハードコアを作っています。", "https://twitter.com/Depth_Water", "https://twitter.com/Depth_Water", "https://www.youtube.com/channel/UC1pECzOD0f4QkwvWrjhozNw"]}, {"names": ["鈴井さや"], "misc": ["Block: [ L ]\nオリジナル女性ボーカル曲を作っています。Bassが ”効いてる” ポップス、ありマス。", "https://clap-your-hands-2022.tumblr.com", "https://twitter.com/yasai7_e"]}, {"names": ["赤マフラー巻き放題"], "misc": ["Block: [ L ]\n総合制作サークル「赤マフラー巻き放題」です。Lo-fi Hiphop系の新譜とD'n'B主体の旧譜などを頒布します。", "https://muffler.red", "https://twitter.com/R_M___"]}, {"names": ["AITC"], "misc": ["Block: [ L ]\n総合制作サークル「AITC」です。ハロウィンをイメージしたコンピレーションアルバム等を頒布します。", "https://twitter.com/AInfoTechClub"]}, {"names": ["お人形になりたい。"], "misc": ["Block: [ L ]\n可愛くファンタジックでありながら、ちょっぴり毒のある世界観で活動している音楽グループです。", "http://oningyou.jp", "https://twitter.com/yuuki_noel", "https://www.youtube.com/channel/UCOAXQYqJz2FLFTQo-xdHXqA", "https://www.youtube.com/channel/UCQvciOnTY7Y3FwlWHjyBSew"]}, {"names": ["えだ豆と馬さし"], "misc": ["Block: [ L ]\n声優さんを歌い手に起用しロックからオリエンタルな曲まで幅広く制作。佐土原かおり×合渡恵子のユニットsdkの音源制作に全面協力！", "https://twitter.com/edamametobasa4", "https://twitter.com/edamametobasa4", "https://www.youtube.com/channel/UCcr-m42KWRtvc_B1H49KF6Q"]}, {"names": ["オトカプセル"], "misc": ["Block: [ L ]\n新作はポップス・ロック系のボーカル曲です。普段はインスト楽曲をメインで作っております。", "http://otocapsule.com/", "https://twitter.com/otocapsule_zan", "https://www.youtube.com/channel/UCs0g-kV1IKoikZHHFfmMeyg", "https://soundcloud.com/user-322323616"]}, {"names": ["ITC STUDIO"], "misc": ["Block: [ L ]\n「ロストアイランドコンピ」という日本のとある島をテーマにしたアルバム作品をつくりまーす。", "https://itcstudio.jimdofree.com/", "https://twitter.com/Itcha", "https://soundcloud.com/itcha"]}, {"names": ["サイアノタイプ"], "misc": ["Block: [ L ]\n存在しない青春との向き合い　救済ポップスと透明感インスト", "https://twitter.com/n_cyanotype", "https://www.youtube.com/channel/UCpci2pKgDQH6QADjaHxQl4A"]}, {"names": ["MIRINN"], "misc": ["Block: [ L ]\n六人組音楽ユニット「MIRINN」です。バンドでポップスを作っています。", "https://twitter.com/mirinn_vi", "https://www.youtube.com/channel/UCepZguEXgrygoZGDjyvd5zA"]}, {"names": ["しのりゅー"], "misc": ["Block: [ L ]\nかっこいい&かわいいチップチューンを作っています。", "https://twitter.com/sinoryu", "https://www.youtube.com/channel/UCO2PSvTMw0PD0FsoZdtdg5A", "https://soundcloud.com/sinoryu_z"]}, {"names": ["HaL_Bits"], "misc": ["Block: [ L ]\nチップチューンオリジナル曲作っております。", "https://twitter.com/Lost_Hometown", "https://www.youtube.com/channel/UCQD15nw-wXWd5dz3vGyakoA", "https://soundcloud.com/hal_bits"]}, {"names": ["七色ビタミン"], "misc": ["Block: [ L ]\n女性ボーカルのオリジナルCDを頒布しています。", "http://sp-ss.com/snowdrop/nanairo/", "https://twitter.com/tinamoroll", "https://soundcloud.com/nana-iro"]}, {"names": ["Adresse"], "misc": ["Block: [ L ]\n仲村芽衣子の個人サークルです。爽やかだったり疾走感あるキャッチーなポップスが好きです。関連サークルGift、Magi×TeN、Alstar、L-TYPEのCDも頒布します。", "http://nakamurameiko.net/", "https://twitter.com/nakamurameiko", "https://www.youtube.com/channel/UCy3xS2lWwBXXY5oScV8ElIQ"]}, {"names": ["パリ（児玉）"], "misc": ["Block: [ L ]\nパリ（児玉）のworksです。５曲ほど入ったepを出します。楽曲のみならず頒布媒体にもこだわっているので是非ブースに来て手に取ってもらえると嬉しいです。歌詞を書くのが好きです。"]}, {"names": ["Lazy*Plankton"], "misc": ["Block: [ L ]\n初参加です！アニソン・ボカロをルーツとして、それぞれの好きなように曲を作っている2人組のユニットです。", "https://twitter.com/Lazy_Plankton", "https://www.youtube.com/channel/UCJ8f3-VqC2exxj8mKLo5aHA"]}, {"names": ["Aya"], "misc": ["Block: [ L ]\n初参加です！歌もの・ポップスを作って歌っています！", "https://twitter.com/AyasanKimisan", "https://www.youtube.com/channel/UCBcQjLeUifIWzE04RYWxuIg"]}, {"names": ["ATNORNIR"], "misc": ["Block: [ L ]\n和製ファンク・R&Bを主体とした男性シンガーソングライターです！", "https://www.twitter.com/rinronta", "https://www.youtube.com/channel/UC5sFaRgdfKrE4oXcn_IPSfg", "https://www.nicovideo.jp/user/1801357"]}, {"names": ["Audrey Record"], "misc": ["Block: [ L ]\nダンス系音楽を中心としたボーカルソングやインストをリリース。あなたがもし電気グルーヴや小室哲哉クラスタなら、一度はどうぞ。", "http://www.adypro.com", "https://twitter.com/Audrey_Record", "https://www.youtube.com/channel/UC47Lz7hxsssiQdibt1lKXKQ", "http://com.nicovideo.jp/community/co1151857/"]}, {"names": ["酔鍵堂"], "misc": ["Block: [ L ]\nコシにクる音楽を貴方に(腰痛)", "http://suikendo.blog55.fc2.com/", "https://twitter.com/Suiken583", "https://soundcloud.com/suiken583"]}, {"names": ["TimeLapse"], "misc": ["Block: [ L ]\n「時間」をコンセプトにして歌モノを作りますTwitter→＠TimeLapse_tj", "https://twitter.com/timelapse_tj"]}, {"names": ["Blanc et Bleu"], "misc": ["Block: [ L ]\n歌モノ作ります。初参加です。よろしくお願いします。", "https://twitter.com/blanc_et_bleu"]}, {"names": ["Sugar Clovers"], "misc": ["Block: [ L ]\n歌物・インスト織り交ぜたオリジナルアルバムを頒布予定です！", "https://www.sugarclovers.info/", "https://twitter.com/s_c12h22o11", "https://www.youtube.com/channel/UCrBx5-lliaeiICjcezd4KwQ", "https://www.nicovideo.jp/user/54894087/mylist/67689464"]}, {"names": ["stellarism."], "misc": ["Block: [ L ]\nエモい歌ものポップスが入ったオリジナルCDを頒布予定です！！", "https://twitter.com/Number_One_P", "https://www.youtube.com/user/NumberOneP", "https://www.nicovideo.jp/user/18105146/video"]}, {"names": ["Cryingcappuccino"], "misc": ["Block: [ L ]\nあれからまた参加します。ピコピコだったりロックだったりEDMだったり色んな曲作ってるひとです。よしなに。", "https://twitter.com/Roastedwhitea", "https://m.soundcloud.com/roasted-white-tea"]}, {"names": ["夏央"], "misc": ["Block: [ L ]\n女性ボーカル・初音ミクを主とした歌モノを作っています。ジャンル不定。", "https://nao-official.storeinfo.jp/", "https://twitter.com/nao_exp", "https://www.youtube.com/channel/UCtodLk-A4Wxp8ZfN11ERZ5A", "https://www.nicovideo.jp/user/35521327"]}, {"names": ["宇月真織"], "misc": ["Block: [ L ]\n乙女ゲー・ソシャゲ等のタイアップ曲やオリジナル曲を歌唱。主に民族系+ポップスが特徴のproject lights所属歌手。", "https://twitter.com/mao_lights", "https://www.youtube.com/channel/UCHYtN5igpye-Qg4T7nkKxjA"]}, {"names": ["Tofuto Sample"], "misc": ["Block: [ L ]\nKONTAKT向けのライブラリの制作と配布を行っております。今回はオマケ音源付のフリーペーパーの配布を予定しています。", "https://mentsuyu-roll.wixsite.com/tofutosample", "@tofuto_sample"]}, {"names": ["音ゲー同好会"], "misc": ["Block: [ L ]\nHalvとMono.による音ゲー好きのためのサークルです。音ゲー大好き！！", "https://twitter.com/Monopowan", "https://twitter.com/Ha1uday0", "https://www.youtube.com/c/Halv%E3%83%8F%E3%83%AB", "https://soundcloud.com/halvsan"]}, {"names": ["Masamune"], "misc": ["Block: [ L ]\nポリシャとダフのサークル、マサムネ(ポリシャがアルバムを出すかも)", "https://soundcloud.com/masamuneofficial", "https://twitter.com/masamune_music", "https://masamunejp.bandcamp.com/"]}, {"names": ["Shinkai waveS Records"], "misc": ["Block: [ L ]\n『Shinkai waveS Records』は、クラブサウンドを主とする音楽レーベルです。", "https://www.shinkaiwaves.com/", "https://twitter.com/houjirou_chame", "https://www.youtube.com/channel/UCT_6zJF3JUwIiqy4QY7C-Vw", "https://soundcloud.com/user-796477745"]}, {"names": ["砂の城より。"], "misc": ["Block: [ L ]\n同人ハードコアとボカロックを中心としたSunajiroの個人サークルです。夏をテーマにしたアルバムを頒布予定。", "https://twitter.com/Sunajiro8", "https://www.youtube.com/channel/UCYlZBVapqYVwtnX_HoBXGnw", "https://soundcloud.com/sunajiro"]}, {"names": ["おばけの見る夢"], "misc": ["Block: [ L ]\n音ゲー楽曲を中心にボーカル活動をしている「駄々子」の個人サークルです。TAKU1175 ft.駄々子でミニアルバムを頒布予定です。", "https://twitter.com/dadacomplex", "https://youtube.com/c/dadacomplex"]}, {"names": ["ゆいネット"], "misc": ["Block: [ L ]\nuynetの個人サークルです！このPR文を書いてるのはおよそ3か月前ですが、おそらくコンピが出るはずです！過去に向かって応援してください！", "uynet.work", "https://twitter.com/uynet", "https://www.youtube.com/channel/UC0gq5YY0UQqIuOpzkhAcyUQ", "https://soundcloud.com/uynet"]}, {"names": ["凸丸荘特別出張所"], "misc": ["Block: [ L ]\n音ゲー曲に触発された音ゲーマーが音ゲーっぽい曲を作るサークルです。"]}, {"names": ["くたくた煮"], "misc": ["Block: [ L ]\n民族系×音ゲーチックなインスト曲など！", "https://twitter.com/Qutabire", "https://soundcloud.com/qutabire"]}, {"names": ["oc-tave records"], "misc": ["Block: [ L ]\n今回が初参加となります、oc-tave recordsです。ポップンミュージック、beatmania２DX、ギタドラ等ビーマニシリーズに影響を受けて曲作りを始めました。", "https://twitter.com/octave_13", "https://www.youtube.com/channel/UC9eq3RsR799p3gxZ269iRRA/featured"]}, {"names": ["コズミック★AMIDAKUZI"], "misc": ["Block: [ L ]\nオリジナルの音ゲーっぽい作品を中心に作っていきます！", "https://twitter.com/kas_0120_music", "https://www.youtube.com/channel/UCOcJXDGZ-CJ0UeME9hAP0iQ", "https://soundcloud.com/cosmic_amidakuzi"]}, {"names": ["かゆきマン劇情"], "misc": ["Block: [ L ]\n音ゲーチックでおしゃれなプログレ・フュージョン・ロックを扱います。", "https://twitter.com/kayuki_honmono", "https://m.youtube.com/channel/UCo1Kh5E664mUjncalVC0u6Q"]}, {"names": ["おとのはこにわ"], "misc": ["Block: [ L ]\nサークル代表「そよもぎ」の個人サークルです。3年ぶりに新譜が出る予定です。", "https://oto-hako.net", "https://twitter.com/soyomogi", "https://www.youtube.com/channel/UCTpiWDo1k04egoTTjg8ZqmA", "https://soundcloud.com/soyomogi"]}, {"names": ["Singerly"], "misc": ["Block: [ L ]\nサウンドデザイナーCOSIOと漫画家えらんとのサークル。今回はグルーヴとかアリスギアとか", "https://singerly.jp/", "https://twitter.com/COSIOTONE", "https://www.youtube.com/channel/UCRNf7aAe3RI-GgH0PTGJTTA"]}, {"names": ["羽毛布団"], "misc": ["Block: [ M ]\nサークル初参加から今回で丸4年、アルバムも5作目になります。初期から一貫している「メロディアスなインストゥルメンタル」を今回も届けます。", "https://solo.to/keptone", "https://twitter.com/kepton_e", "https://www.youtube.com/channel/UC9dpQ3bIc6x3rpIkTTGEHSQ", "https://www.instagram.com/keptone/"]}, {"names": ["DelightStyle"], "misc": ["Block: [ M ]\nDelightStyleとは、katsueとmisacoの2人組ユニット。ゲーム主題歌を多数担当しする他、自ら作詞作曲するなど精力的に活動中！", "https://delightstyle.jimdofree.com/", "https://twitter.com/delightstyle", "https://youtube.com/user/DSdelightstyle"]}, {"names": ["Tsurugi sound"], "misc": ["Block: [ M ]\n切なくて爽やかで激アツなゲーム音楽っぽい曲を作ってます", "https://twitter.com/kt_of_24", "https://soundcloud.com/tsurugi_kt_of_24"]}, {"names": ["カクカクシカジカ。"], "misc": ["Block: [ M ]\n星のカービィのアレンジCDを予定しています。他アレンジやオリジナルなどもあります。", "https://twitter.com/_ka_ku", "https://www.youtube.com/channel/UCpNFiPBsruM82_GDGGZjgEw", "https://soundcloud.com/ka_ku"]}, {"names": ["Hive Six Records"], "misc": ["Block: [ M ]\nアニメ・ゲームの楽曲を中心にリリースするインディーズレーベルです。 新人声優アーティストの育成も行います。", "http://records.hive-six.com/", "https://twitter.com/hivesix_records", "https://www.youtube.com/channel/UCnCMP7shI-m-Dp30GopWXMQ"]}, {"names": ["project lights"], "misc": ["Block: [ M ]\n日本・中国のアニメ・ゲーム等で音楽提供を行う音楽制作ブランドです！音楽を通じて様々な挑戦中です☆", "https://www.project-lights.jp/", "https://twitter.com/project_lights", "https://www.youtube.com/channel/UC3LTC_Yw9pyydsxNaRxan7A", "http://www.nicovideo.jp/user/14650268"]}, {"names": ["忘波亭"], "misc": ["Block: [ M ]\n少女たちの儚く切ない物語を音楽で表現します", "https://www.youtube.com/channel/UCjtWWCMW-XNKNn6ZUbNyTNA", "https://youtu.be/dKPMt3IMrCE", "https://rururusuwanami.booth.pm/items/4189802"]}, {"names": ["SouNd's Magic works"], "misc"