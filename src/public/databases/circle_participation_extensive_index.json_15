s": ["project Windy", "加藤知則"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): プロジェクトウィンディ\nProduct: 跳馬の野望"]}, {"names": ["La dolce vita", "弥都葉子"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ラドルテエヴィータ\nProduct: 小舟と一緒に"]}, {"names": ["グリーンナンバーズ", "RAFALE"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): グリーンナンバーズ\nProduct: Big99\nバス・トラックを中心とした営業車両"]}, {"names": ["八兵衛茶屋", "ぐったり八兵衛"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ハチベエチャヤ\nProduct: 超七郎旅日記\nスーパー7を中心とした車道楽な本"]}, {"names": ["じじ", "しげおさむ"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ジジ\nProduct: カプチーノのすべて"]}, {"names": ["リュア", "いないりゅあ"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): リュア\nProduct: FJ外伝"]}, {"names": ["That’s ゆーのす", "わたなべやすお"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ザッツユーノス\nProduct: Favorite"]}, {"names": ["テン使になるもん", "スージーテン"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): テンシニナルモン\nProduct: テン使になるもん！\n世界のスーパーK「スズキジムニー」の本。メカの事は、あんまりわかりませんが乗ってて楽しい感じが伝われば嬉しいです。"]}, {"names": ["デルソルネットワーク", "むーぶ"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): デルソルネットワーク\nProduct: デルソルデータブック2R"]}, {"names": ["四輪の上", "きもだこよし"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ヨリンノウエ\nProduct: m’Teppo"]}, {"names": ["情報の穴", "橋本孝"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ジョウホウノアナ\nProduct: RIZZ"]}, {"names": ["プリメーラ堂", "ブッチーイ"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): プリメーラドウ\nProduct: プリメーラXVOL12号"]}, {"names": ["RF BIRD HOUSE"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): アールエフバードハウス\nProduct: はたらいてるくるま"]}, {"names": ["Eyes of the Mind"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): アイズオブザマインド"]}, {"names": ["studio－R", "桜交機"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): スタジオアール\nProduct: ハイウェイ・プリンセス2"]}, {"names": ["Radi ＆ Kerberos", "梓幸雅"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ラディアンドケルベロス\nProduct: Radi"]}, {"names": ["赤い車の会", "ぬまにゃん"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): アカイクルマノカイ\nProduct: 赤い車の会のほん\n走り屋では決してない、エンスーを名乗るのはちょっぴり気恥ずかしい、そんな「ちょっと変わった車乗り」の集まり、『赤い車の会』。メンバーそれぞれの偏った「オレ基本」を、イラストエッセイというカタチで本にぶつけていくため、今回参戦いたしました。スペック偏重主義に飽き飽きしている方、貧乏自動車生活が好きな方、メカフェチの方(笑)、どうぞごひいきに。雰囲気のんびりを好まれる自動車愛好家の方のご来訪をお待ちしています。"]}, {"names": ["商売繁盛", "物忘多志"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ショウバイハンジョウ\nProduct: ラガー旅日記"]}, {"names": ["旅貯の会", "スーパーひたち"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): リョチョノカイ\nProduct: 旅貯の楽しみ\n旅行貯金本個人サークル。文章主体です。"]}, {"names": ["アルルプロジェクト", "槍騎兵"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): アルルプロジェクト"]}, {"names": ["茶屋町鉄道企画", "田中栄司"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): チャヤマチテツドウキカク\nProduct: SL北びわこ号撮影地ガイド"]}, {"names": ["旅のメモ帳", "J-wing"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): タビノメモチョウ\nProduct: 座席の画像集 JR東海（通勤・近郊形車両）編\nemail: j-wing@mx2.mesh.ne.jp\n鉄道車両車内写真（車内学）という分野を扱っております“旅のメモ帳”と申します。初参加となります今回は、JR東海の通勤・近郊形車両の車内と座席の写真を掲載した“座席の画像集 JR東海（通勤・近郊形車両）編”と時刻表片手に楽しめる（？）“鉄道クイズ集”をご用意する予定です。このほか、もしかすると音系もあるかもしれません。当サークルの頒布品は無料配布の予定です（委託品は除きます）。", "http://tabimemo.love.ly/"]}, {"names": ["NEエクスプレス", "protium"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): エヌイーエクスプレス\nProduct: NEエクスプレス創刊号\n鉄道旅行関係列車乗車レポート中心"]}, {"names": ["奇芸出版社", "ゆふいんの森Ⅲ世"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): キゲイシュッパンシャ\nProduct: 邪道ファン準備号"]}, {"names": ["電気通信大学鉄道研究会", "犬塚敦史"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): デンキツウシンダイガク\nProduct: しぶろく2000\n大学公認サークルです。機関誌「しぶろく」を毎年秋に発行しています。", "http://www2.to/uecrail/"]}, {"names": ["譲渡車両研究所", "j－bird"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ジョウトシャリョウケンキュ\nProduct: From Bayside To Seaside"]}, {"names": ["立命館大学鉄道研究会", "鳶川雅之"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): リツメイカンダイガクテツ\nProduct: ポイント 35号"]}, {"names": ["中央大学理工学部鉄道研究会", "スノーラビット"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): チュウオウダイガクリコウ\nProduct: Kasuga Express\n機関紙を発行中。"]}, {"names": ["ぶる～☆いんぱるす！", "光希浦遊太"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ブルーインパルス\nProduct: LSEでGO！"]}, {"names": ["KOU企画", "石川KOU"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): コウキカク\nProduct: 165系～最近の動き～"]}, {"names": ["虹森書房", "虹森沙利"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ニジモリショボウ\nProduct: 全国鉄メモスポットガイド2001"]}, {"names": ["JRAC", "ひろまこたろう"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ジェイアールエーシー\nProduct: JRAC"]}, {"names": ["MDM－project", "遠藤正浩"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): エムディーエムプロジェ\nProduct: 三鷹電車区直流急行型パーフェクトガイド"]}, {"names": ["区間準急", "薬園台しのぶ"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): クカンジュンキュウ\nProduct: 区間準急～Section Semi Express～"]}, {"names": ["EAGLE Ⅴ", "神原光理"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): イーグルファイブ\nProduct: 未定\n鉄道紀行文など"]}, {"names": ["北葉開発", "ろーれる"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ホクヨウカイハツ\nProduct: 追跡・青函連絡船2\n青函連絡船一筋", "http://ogatarina.webjump.com/"]}, {"names": ["しなやかな風Project", "新安城栄"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): シナヤカナカゼプロジェ\nProduct: Meitetsu Area Magazine"]}, {"names": ["ベルちゃんくらぶ", "戸田惣一"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ベルチャンクラブ\nProduct: 有珠山噴火函館本線迂回列車追っかけ記"]}, {"names": ["ろくろくぱーいち", "関空特快ウイング"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ロクロクパーイチ\nProduct: ろくろくぱーいち\nemail: kazamakodachi@kcc.zaq.ne.jp\n・JRの電気機関車EF66，EF81の写真の紹介及び撮影地のガイド、運用、ダイヤの案内を予定しています。", "http://web9.freecom.ne.jp/~kodachi"]}, {"names": ["廃線散歩", "おがえもん"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ハイセンサンポ\nProduct: 廃線散歩\nemail: ogaemn@ja2.so-net.ne.jp\n鉄道廃線跡探索本「廃線散歩」を発行するサークルです。即刊本Vol.1～3までと新刊Vol.4を発行予定です。 乗務人サークルが抽選漏れとなりましたので、「廃刊覚悟総合情報誌 乗務人」を委託販売いたします。乗務人ファンの方は廃線散歩サークルまでどうぞ。", "http://www02.u-page.so-net.ne.jp/ja2/ogaemn/"]}, {"names": ["放射性同位体", "あやみん"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ホウシャセイドウイタイ\nProduct: Railway Walker\n鉄道廃線跡の探訪記や、それを題材にした創作漫画中心。突発で鉄道フリートーク本も出してます。", "http://homepage1.nifty.com/aya-min/RI/"]}, {"names": ["赤い急行", "ねこのまくら"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): アカイキュウコウ\nProduct: 東武電車観察日記"]}, {"names": ["QDAT", "彩葉"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): キューディーエーティー\nProduct: 鉄っぽい本\nemail: qdat@qdat.noborito.org\n公共交通・旅行系Only自主制作誌・自主制作グッズ展示即売会「東京のりもの学会」を毎年春に東京近郊で開催。第5回・2002年会の日程・会場等の詳細は年内に発表予定。鉄道、主に私鉄に関する本を発行。今回の新刊はグループ誌「鉄っぽい本11」のほか、地方私鉄の貴重なオリジナル車両の現状を紹介し将来を予測する「私鉄遺産」2001年版、及び電気車の制御方式を楽しく詳しく解説する「制御方式入門」の大幅改訂版を予定。", "http://www.qdat.noborito.org/"]}, {"names": ["Dream☆Star", "長尾幸久"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ドリームスター\nProduct: 観察記録京成電車Vol．3～千原線編～"]}, {"names": ["辺境開発鉄道", "ちゃり"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ヘンキョウカイハツテツドウ\nProduct: 京急用語の基礎知識\nemail: henkyou@m78.com\n鉄道業界内で起こる問題や苦労話を、漫画や文章で紹介する。同時に利用客にマナーやモラルを訴える。鉄道資料の紹介。", "http://www05.u-page.so-net.ne.jp/fa2/chariots/henkyou.html"]}, {"names": ["THE！サバ！！", "ブーマー・いわお"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ザサバ\nProduct: 意地のコバルトブルー達"]}, {"names": ["アリカワールド", "有川湘一"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): アリカワールド\nProduct: delicious way2（仮）"]}, {"names": ["美女鉄", "怪瑠凛"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ビジョテツ\nProduct: With Rail"]}, {"names": ["宮代リゾートクラブ", "里尾栃"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ミヤシロリゾートクラブ\nProduct: Keikyu St^2"]}, {"names": ["One Minute Over", "TURBO"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ワンミニットオーバー\nProduct: お～ば～らん"]}, {"names": ["ぱのらますーぱー", "予備長"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): パノラマスーパー\nProduct: ぱのらますーぱー"]}, {"names": ["宝塚線 企画", "桜塚護"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): タカラヅカセンキカク\nProduct: 阪急絵日記"]}, {"names": ["West Big Temple", "長井 多可博"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ウエストビッグテンプル\nProduct: てぃ！しゃ！だぁ！\n鉄道。私鉄電車の乗務員まんが。"]}, {"names": ["西東京電鐵", "豊田電車区"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ニシトウキョウデンテツ\nProduct: 車内補充券読本\n乗車券の収集・研究を中心に活動を行うサークルです。"]}, {"names": ["都営12号線 再改称推進国民会議", "児島章朋"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): トエイジュウニゴウセンサ\nProduct: Metro Web～東京見聞録～"]}, {"names": ["鉄道資料頒布会", "NON"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): テツドウシリョウハンプカ\nProduct: 切符の収集が万病のもとだった"]}, {"names": ["地図と遊ぶ編集部", "総武"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): チズトアソブヘンシュウフ\nProduct: 地図と遊ぶ新館"]}, {"names": ["野鉄工機", "野川"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): ノテツコウキ\nProduct: 野鉄工機"]}, {"names": ["回生失効屋", "フェイマスケイ"], "misc": ["Genre: 鉄道・旅行・メカミリ\nName (kana): カイセイシッコウヤ"]}, {"names": ["六畳間企画室", "高田憲一"], "mi