太陽が嫌い", "河月玲"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): タイヨウガキライ\nProduct: 獣道"]}, {"names": ["Project想音", "富江拓世"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): プロジェクトソウオン\nProduct: PRISM FACE"]}, {"names": ["Run－feed", "HARUKA"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ランフィード\nProduct: 炎の記憶と冬の雨"]}, {"names": ["空想的考察学", "山本武"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): クウソウテキコウサツガク\nProduct: CELN"]}, {"names": ["青猫舎", "瀧澤ニャー"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): アオネコシャ\nProduct: 波涛の果て"]}, {"names": ["Fyらんなーず", "DANUP和寛"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): エフワイランナーズ\nProduct: 剣士になりたい！All In One"]}, {"names": ["M^2（えむの事情）", "峯雄二"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): エムノジジョウ\nProduct: イレギュラーズⅥ\nemail: m2@emunojijyo.ai.to\nオリジナル・ファンタジー小説メイン。小説担当→峯雄二、イラスト担当→大津正嵩最新刊「イレギュラーズ～彼方より来る者達～Ⅵ」コミケ初売！", "http://www5e.biglobe.ne.jp/~emujijyo/"]}, {"names": ["雑草屋", "一屋飯綱"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ザッソウヤ\nProduct: 夜明けの大地"]}, {"names": ["天鵞絨倶楽部", "REMIRE"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ベルベットクラブ\nProduct: 風の乙女たち、ヒトガタの見る夢は"]}, {"names": ["赤木の本屋", "赤木保"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): アカギノホンヤ\nProduct: マヤ物語"]}, {"names": ["ともっくす", "関とも雪"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): トモックス\nProduct: 糸河の風"]}, {"names": ["蓮花蕾", "冬海深月"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): レンカライ\nProduct: 白狼烈記"]}, {"names": ["DILETTANTE（文芸共同）", "草間始"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ディレッタントブンゲイ\nProduct: 自由の鳥"]}, {"names": ["有害図書愛好会", "さぼさぬけ"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ユウガイトショアイコウカイ\nProduct: 幻影魔術綺談\nemail: sibucha@he.mirai.ne.jp\n有害図書愛好会は、小早川赤彦・さぼさぬけ・御心惟の創作サークルです。現在は現代魔法ファンタジー小説「幻影魔術綺談」シリーズを中心に活動しています。夏コミ新刊は、「幻影」シリーズ最新刊「幻影魔術綺談Vol.7」と、漫画も収録されている「幻影・連載編2」を予定しています。もちろん、これまでの発行物も販売します。Vol.1～3を収録した「総集編」もありますので、どうぞよろしくおねがいします。", "http://www.mirai.ne.jp/~sibucha/"]}, {"names": ["WIND工房", "さかもと希夢"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ウインドコウボウ\nProduct: 呑気な冒険者2"]}, {"names": ["Shuna's Laboratory", "鈴音シュナ"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): シュナズラボラトリー\nProduct: Project“Witch”2nd"]}, {"names": ["暗黒神狂信者団", "魔宮命"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): アンコクシンキョウシンジャ\nProduct: ORIGINAL WIZARDRY④"]}, {"names": ["アザー･ワールド", "立川みどり"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): アザーワールド\nProduct: 「聖玉の王4内乱終結」\nオリジナル小説。ファンタジー中心。長編とか、1～2冊完結の短い話とか、多数。「ファイアーエムブレム」と「ロード・オブ・ザ・リング」もあります。", "http://www.geocities.co.jp/Bookend-Shikibu/7805/"]}, {"names": ["麗風－WOLF－", "花鳥風月"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ウルフ\nProduct: 夢幻神話"]}, {"names": ["Night Light", "神岡悠希"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ナイトライト"]}, {"names": ["蜃気楼", "文月恭"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): シンキロウ\nProduct: 嵐の刻1"]}, {"names": ["Aquatic Moon", "新城かいり"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): アクアティックムーン"]}, {"names": ["MISSION", "天野久美"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ミッション\nProduct: 風の鎮魂歌"]}, {"names": ["ST．Company", "橘悠樹"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): エスティーカンパニー\nProduct: Space Ruin Collector"]}, {"names": ["月軌堂", "幻朧麗"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ツキミチドウ\nProduct: DIANA（序）"]}, {"names": ["Blue Tooth", "由郷擽緋"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ブルートゥース\nProduct: 楽園を見つける方法\nオリジナルファンタジー小説"]}, {"names": ["FOREST BLUE", "草霞蒼"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): フォレストブルー\nProduct: 遠い旋律"]}, {"names": ["Guardian Gate", "月兎博之"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ガーディアンゲート\nProduct: 月読御遣"]}, {"names": ["鵺ケ森鳥獣戯画", "胡桃"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ヌエガモリチョウジュウキ\nProduct: 螺旋律"]}, {"names": ["ジャンク･ヤード", "早坂千尋"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ジャンクヤード\nProduct: ほしたちのこえ"]}, {"names": ["多摩ハイランダー", "中里融司"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): タマハイランダー\nProduct: 孤島の城■"]}, {"names": ["零細出版独創丸", "美沢桂介"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): レイサイシュッパンドクソ\nProduct: ニッキィ＆静シリーズ"]}, {"names": ["天野砂緒文庫", "天野砂緒"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): アマノスナオブンコ\nProduct: CHASER（とりあえず）第1巻\nemail: rxi06515@nifty.com\n☆「CHASER」 SFジュブナイル小説 ひょんなことから人狼系異星人バロンを宿してしまった三峰歩。バロンは同郷の凶悪な犯罪者ランダを追って地球に来ていたのだ。歩は協力してランダを追跡する。 現在コピー誌で2巻まで、外伝3冊発行。 ☆その他 勇者シリーズを茶うけに楽しむ「勇者のお茶会」の案内を配布しています。", "http://homepage3.nifty.com/amano_sunao/"]}, {"names": ["アルファルファ", "小出まいや"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): アルファルファ\nProduct: ウォーレン1"]}, {"names": ["YuMiTo", "古代竜"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ユミト\nProduct: ぴんくのくれよん"]}, {"names": ["MoonLight Freedom", "Over"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ムーンライトフリーダム"]}, {"names": ["ProjectT.A.C.+栗もなか", "楽光一"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): プロジェクトタックプラ\nProduct: アミューズメント・パーティ"]}, {"names": ["文書工房", "華頭王"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ブンショコウボウ\nProduct: 時空からの囁き"]}, {"names": ["ZAND企画", "暮羽仁"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ザンドキカク\nProduct: 個人小説雑誌じゃも"]}, {"names": ["脳天爆発シスターズ", "脳天爆発シスターズ姉"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ノウテンバクハツシスタース\nProduct: 超獣戦隊ファイヤーズ第52話"]}, {"names": ["Shaltics", "春日正哉"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): シャルティクス\nProduct: 素粒子戦隊ファインマン"]}, {"names": ["二瓶幻想研究所", "にへい醇一"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ニヘイゲンソウケンキュウシ\nProduct: 鉄鋼鬼神ガルフィオン"]}, {"names": ["STUDIO H．E．", "野毛山まこと"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): スタジオエイチイー\nProduct: 武龍神ヴィシュマ"]}, {"names": ["moon of wing", "羽月 陣"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ムーンオブウイング\nProduct: サイレントオブメモリー（2）\nemail: moon_of_wing@k6.dion.ne.jp\n創作物中心です。"]}, {"names": ["KEMA", "若槻柴"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ケマ"]}, {"names": ["ハナヂミール商店", "華地武"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ハナヂミールショウテン\nProduct: のんぽり進化論"]}, {"names": ["U－CON", "八木あつし"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ユーコン\nProduct: Uノベルス1号"]}, {"names": ["Dancing Bean", "桐葩冬嗣"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ダンシングビーン\nProduct: 翠玲"]}, {"names": ["つぐみ農場", "石井鶇子"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ツグミファーム\nProduct: 聖天皇帝戦記"]}, {"names": ["DA☆RK’n SIGHT", "DA☆"], "misc": ["Genre: 創作(文芸・小説)\nName (kana): ダークンサイト\nProduct: ローズフォース"