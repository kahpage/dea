c": ["Genre: 評論・情報\nName (kana): シルフエムツー\nProduct: 趣味の秋葉本"]}, {"names": ["バシでんでん組", "ムッシュカルテット"], "misc": ["Genre: 評論・情報\nName (kana): バシデンデングミ\nProduct: テムジン11大阪日本橋攻略マップ"]}, {"names": ["hirokiazuma．com", "東浩紀"], "misc": ["Genre: 評論・情報\nName (kana): ヒロキアズマドットコム\nProduct: hirokiazuma．com book"]}, {"names": ["モスコミューン出版部", "hitomisiriing"], "misc": ["Genre: 評論・情報\nName (kana): モスコミューンシュッパンフ\nProduct: Kluster"]}, {"names": ["村山通信"], "misc": ["Genre: 評論・情報\nName (kana): ムラヤマツウシン\nProduct: 村山通信"]}, {"names": ["五寸釘ファンクラブ", "高 將治"], "misc": ["Genre: 評論・情報\nName (kana): ゴスンクギファンクラブ\nProduct: ドクサイシャノコドク\nemail: koh@master.email.ne.jp\n新しい批評の可能性を追求する批評サークルです。今回は中本穂積作品の批評「中本大事典」を出す予定。ついでに樹木姫の批評（エロ）小説も出したいです（というかこちらが本命かも）。前回の『されど罪人は竜と踊る』批評小説（ドーチェッタ本）も未だ在庫は残ってます。もちろんそれらとは別の「批評論」系の本もありますのでそちらに興味がある方もどうぞ。", "http://www5d.biglobe.ne.jp/~m_akai/"]}, {"names": ["究極編集部", "持木一明"], "misc": ["Genre: 評論・情報\nName (kana): キュウキョクヘンシュウブ\nProduct: VIDEA"]}, {"names": ["ハンニバル舎", "ハンニバル北川"], "misc": ["Genre: 評論・情報\nName (kana): ハンニバルシャ\nProduct: ハンニバル舎vol．1"]}, {"names": ["暗黒通信団", "シンキロウ"], "misc": ["Genre: 評論・情報\nName (kana): アンコクツウシンダン\nProduct: 正義の理論"]}, {"names": ["imaginary press inc.", "登坂正男"], "misc": ["Genre: 評論・情報\nName (kana): イマジナリープレスインク\nProduct: 抽象企業"]}, {"names": ["IRD工房", "氷川竜介"], "misc": ["Genre: 評論・情報\nName (kana): アイアールデイーコウボウ\nProduct: ロトさんの本 vol．12"]}, {"names": ["開田無法地帯", "開田あや"], "misc": ["Genre: 評論・情報\nName (kana): カイダムホウチタイ\nProduct: ぶらりオタク旅3"]}, {"names": ["幻想創造主", "雪風嵐"], "misc": ["Genre: 評論・情報\nName (kana): ゲンソウソウゾウシュ\nProduct: 倒狂スポーツ"]}, {"names": ["こしみのの謎", "有栖川我鎖"], "misc": ["Genre: 評論・情報\nName (kana): コシミノノナゾ\nProduct: こしみのの謎Vol．Ⅲ（仮）"]}, {"names": ["サポートセンター裏路地っく", "HIDE"], "misc": ["Genre: 評論・情報\nName (kana): サポートセンターウラロジ\nProduct: 裏路地っく～2004年夏モデル～"]}, {"names": ["絶対サポセン黙示録", "FOX－兄貴"], "misc": ["Genre: 評論・情報\nName (kana): ゼッタイサポセンモクシロ\nProduct: 裏絶対サポセン黙示録"]}, {"names": ["つっこま46期縁日班宙組", "フケ顔男爵"], "misc": ["Genre: 評論・情報\nName (kana): ツッコマヨンジュウロッキエ\nProduct: ウソチクの泉ブック"]}, {"names": ["ビビンシア！寅組", "PLせつな"], "misc": ["Genre: 評論・情報\nName (kana): ビビンシアトラグミ\nProduct: 淫語のパズルえろぴったん"]}, {"names": ["あじましでお追跡委員会", "ぶつぶつ No6"], "misc": ["Genre: 評論・情報\nName (kana): アジマシデオツイセキイイ\nProduct: 吾妻ひでお著作リスト\n吾妻ひでお先生のメーリングリストのサークルです。"]}, {"names": ["あじま書店", "BASHIUT■"], "misc": ["Genre: 評論・情報\nName (kana): アジマショテン\nProduct: 吾妻ひでお同人サークル名鑑"]}, {"names": ["からまん", "唐沢なをき"], "misc": ["Genre: 評論・情報\nName (kana): カラマン\nProduct: パチモン大王1\nemail: karaman@big.or.jp\n唐沢なをきが『フィギュア王』誌にて、唐沢なとき名義で連載している『パチモン大王』をまとめた本を出します。昭和30年代～昭和40年代に発売されたパチモン駄玩具が中心の研究本です。今回出すのは第1巻で、以下続刊です。", "http://www2.big.or.jp/~karaman/pachimon/"]}, {"names": ["りんごとコーラ", "Mas・Aki"], "misc": ["Genre: 評論・情報\nName (kana): リンゴトコーラ\nProduct: コピー本の作り方\nemail: only_for_zaft@yahoo.co.jp\n日々感じることや、人生にあった出来事を描いていきます！今回はコピー本の作り方について本を出します！"]}, {"names": ["ビバ！メガネくん", "渡辺由美子"], "misc": ["Genre: 評論・情報\nName (kana): ビバメガネクン\nProduct: ビバ！メガネくん③"]}, {"names": ["大章堂"], "misc": ["Genre: 評論・情報\nName (kana): ダイショウドウ"]}, {"names": ["雑誌の住人", "MiLKMAN"], "misc": ["Genre: 評論・情報\nName (kana): ザッシノジュウニン\nProduct: エロゲ雑誌の本"]}, {"names": ["ニンジン屋", "白卯"], "misc": ["Genre: 評論・情報\nName (kana): ニンジンヤ\nProduct: プロ野球今季予想と問題点’04"]}, {"names": ["改築村上荘", "アマラン"], "misc": ["Genre: 評論・情報\nName (kana): カイチクムラカミソウ\nProduct: りぼん総目録"]}, {"names": ["鷲橋蘭", "鷲橋蘭"], "misc": ["Genre: 評論・情報\nName (kana): ワシハシラン\nProduct: LaLa総目次1976－1996"]}, {"names": ["と学会", "山本弘"], "misc": ["Genre: 評論・情報\nName (kana): トガッカイ\nProduct: と学会誌"]}, {"names": ["WARMACHINE", "眠田直"], "misc": ["Genre: 評論・情報\nName (kana): ウォーマシン\nProduct: 眠田直のこんなモノが欲しい"]}, {"names": ["こみこみっく", "K1－阿梨"], "misc": ["Genre: 評論・情報\nName (kana): コミコミック\nProduct: こみこみっく"]}, {"names": ["まんが作品データベース2004", "堀越和子"], "misc": ["Genre: 評論・情報\nName (kana): マンガサクヒンデータベ\nProduct: まんが作品データベース2004"]}, {"names": ["東文研", "唐沢俊一"], "misc": ["Genre: 評論・情報\nName (kana): トウブンケン\nProduct: トリビアの歪"]}, {"names": ["立川流本家", "立川談之助"], "misc": ["Genre: 評論・情報\nName (kana): タテカワリュウホンケ\nProduct: 本家立川流"]}, {"names": ["私立歯車高校", "石黒直樹"], "misc": ["Genre: 評論・情報\nName (kana): シリツハグルマコウコウ\nProduct: 少女小説のススメ"]}, {"names": ["歯車高校分校", "石黒直樹"], "misc": ["Genre: 評論・情報\nName (kana): ハグルマコウコウブンコウ\nProduct: 百合とオタクの日々"]}, {"names": ["淀川ランプ亭", "LOP"], "misc": ["Genre: 評論・情報\nName (kana): ヨドガワランプテイ\nProduct: サンデーの汁"]}, {"names": ["道の曲がりか堂", "工藤俊英"], "misc": ["Genre: 評論・情報\nName (kana): ミチノマガリカドウ\nProduct: ピヨピヨスポーツ"]}, {"names": ["ぴよぴよテクノロジー", "山本 将樹"], "misc": ["Genre: 評論・情報\nName (kana): ピヨピヨテクノロジー\nProduct: 高橋留美子の詳しい世界\n高橋留美子先生へのインタビュー、知人が高橋先生について語っていたり、作品を論評した本や雑誌などの、「2次文献」をデータベース化したものです。"]}, {"names": ["時計坂通信社", "七尾葉介"], "misc": ["Genre: 評論・情報\nName (kana): トケイザカツウシンシャ\nProduct: 時計坂通信\nemail: webmaster@tokeizaka.com\n高橋留美子先生の作品（うる星やつら、めぞん一刻、らんま1/2、犬夜叉など）の情報サークル", "http://www.tokeizaka.com"]}, {"names": ["互連網絡有限公司", "吉田単車"], "misc": ["Genre: 評論・情報\nName (kana): ゴレンモウラクユウゲンコ\nProduct: 樽の真相\nemail: tansya@jca.apc.org\nネットワーク版『噂の真相』を目指し、インターネットのNetnewsのカテゴリーであるfj.*やjapan.*、またかつて一世を風靡した「あやしいわーるど」・今一番ホットでナウなヤングにバカ受けの掲示板システム「2ちゃんねる」等に代表されるようなアングラUG系インターネットに題材を取って好評をいただいている『樽の真相』(略称たるしん)の新刊を発行できる予定です。 頒布予定物：◎新刊『樽の眞相』第15号 A5 300円（予価）◎既刊 『樽の眞相』第14号 A5・36P フルカラー表紙 300円 2002冬発行 『樽の眞相』第13号 A5・36P フルカラー表紙 300円 2002夏発行 『樽の眞相』第11号 A5・68P フルカラー表紙 500円 2001夏発行 『樽の眞相』第8号 A5・68P フルカラー表紙 500円 2000春発行 『樽の眞相』第5号 A5・68P オフセット 500円 1998夏発行 迷わず行けよ 行けば分かるさ ありがとぉぉぉ ＠有明 http://www.jca.apc.org/ariake/ (b^-')グッドですよ ヽ(´ー｀)人(´ー｀)ノみんな仲良く ポスト2chキッズの士農工商マガジンヽ(´ー`)ノ名誉白人 打倒！2さょんねる！！！11qa 2ぁんえるをブッ潰せ！何が2chだ糞が氏ねや 2chのここが嫌いだ！許せない！イヤだ！気色悪い！キモい！フザケんな！薄い！金返せ！ヌルい！異常だ！おかしい！イカレてる！臭い！アニヲタ眼鏡デヴ！風呂入れ！歯ァ磨け！息すんな！鼻毛切れ！使えない！ダメだ！まだらハゲ！仮性包茎！インポテンツ！士農工商！でもチョット好きハァト(´∀`) マターリ インチャーネット最前線 海老名運動公園 投稿者 カツジ さん 2001年9月25日(火) 23時52分 [P] さっき、川原でやった六尺兄貴凄かったです！ガチムチの色黒兄貴がオッス連呼で張型ケツにぶちこまれ腰振ってました。俺もくわえさせられて浣腸食らい無様に排便さらしました。バリカン出されたときは一瞬引いたけど、兄貴の「いやなら止めていいんだぜ！」の一言で覚悟決め、生まれて初めて丸刈りになりました。その後、脇・チンゲも刈られてビンビンのマラ、思いっきりしごかれ派手にガチムチ兄貴の顔に飛ばしました。スッゲー男らしく気持ちよかったです。また行くときカキコして下さい！帰ってから丸刈りの頭見て、また感じまくってます！ 生意気な＞1をシメてやるッ…！（省略されました‥全てを読むにはここを押して下さい）ここは本当に恐ろしいインターネットですね。私はインターネット歴3年のベテランですがこんなに恐ろしいインターネットは見た事がないです。ここにいる皆さんは、あまり知識がないから知らないと思いますが私はアングラーサイトというものに出入りしているのでインターネットの恐ろしさを知っているんですよ。こういうインターネットに居るとIPアドレス（メールアドレスのようなもの）がばれてしまうんですよ。皆さん、気を付けて下さい。 投稿者：DDの哲さん 投稿日：2002/01/13(日)16時49分48秒 ■ ★ 人は、認められるために生きているっちゅーても過言やないんや！認められるっちゅー事は、ほめられたり、感謝されたり、大切な責任を任されるという事を意味するんやけどな、それに見合う報酬が与えられた時、認められた事を最も具体的に感じる事が出来るんや！そう思わへんか！仕事においても、自分の努力の実が100%自分に戻って来れば、満足とや気と勇気と希望がわいて来るんや！でもな、ほとんどの組織がピラミッド型になっている今日の社会の中で、この点が大問題なんや！！しかしそんなフラストレーションを吹き飛ばしてくれる仕事があるんや！！自分の努力が、報酬という形で100%自分に戻って来る凄い仕事があるんや！！それはキミにも出来る健全で安全な仕事なんやで！！それは何かわかるか！！ それはァムゥェィや！ 1の主治医です。この度、このようなスレッドを1が立てるに至ったことは、主治医として、大変残念な事であり、また、治療の効果がまだまだ現れていないことを証明しているため、そろそろ最終的な決断を下す必要があるようです。みなさんお聞きになったことがあるかもしれませんが、必ずしも心の病は、特殊な病気ではなく、誰もがそうなる可能性があります。しかし、だからといって、これ以上、1を放置することは、例えば何の関係もない人を傷つけたり、逆に1自身の将来にとり、名から図示も良いことではありません。そこで、私は、1の両親、臨床心理士などとも相談して、1をしばらくの間、ネットの出来る環境から離して、濃密な人間関係の中で治療をすることにしました。1にとっては、納得がいかないことかもしれませんが、私も、医師免許をかけて、1を徹底して", "http://www.jca.apc.org/ariake/"]}, {"names": ["人権侵害軍", "田中"], "misc": ["Genre: 評論・情報\nName (kana): ジンケンシンガイグン\nProduct: 有名人四季報"]}, {"names": ["Rubbish’n Dust", "きば"], "misc": ["Genre: 評論・情報\nName (kana): ラヴィッシュアンドダス\nProduct: 挫折する瞬間"]}, {"names": ["ぱぱ本舗", "oguman"], "misc": ["Genre: 評論・情報\nName (kana): パパホンポ\nProduct: 全国駅弁の旅"]}, {"names": ["げんれい工房", "山桂"], "misc": ["Genre: 評論・情報\nName (kana): ゲンレイコウボウ\nProduct: 100％ふさおとめ"]}, {"names": ["第三開拓領域", "左端の天使"], "misc": ["Genre: 評論・情報\nName (kana): ダイサンカイタクリョウイキ\nProduct: keep Outers"]}, {"names": ["足高温泉ガイド", "黒井奴"], "misc": ["Genre: 評論・情報\nName (kana): アシタカオンセンガイド\nProduct: 足高温泉ガイド"]}, {"names": ["矛盾商会", "唯物教徒拝金派"], "misc": ["Genre: 評論・情報\nName (kana): ムジュンショウカイ\nProduct: シナリオとしての「対テロ戦争」"]}, {"names": ["逸拳館", "三木そよぐ"], "misc": ["Genre: 評論・情報\nName (kana): イッケンカン\nProduct: 二宮ひかる評論"]}, {"names": ["ロイたー共同", "あけのたーかい"], "misc": ["Genre: 評論・情報\nName (kana): ロイターキョウドウ\nProduct: とり扱説明書"]}, {"names": ["幽遊白書研究会"], "misc": ["Genre: 評論・情報\nName (kana): ユウユウハクショケンキュウカ\nProduct: 幽遊白書研究"]}, {"names": ["カラオケの艦隊", "本郷ゆき緒"], "misc": ["Gen