misc": ["Genre: 評論・情報\nName (kana): カイキダイヒヒョウ\nProduct: 怪奇大批評vol．1"]}, {"names": ["Multinum", "Multina"], "misc": ["Genre: 評論・情報\nName (kana): マルチニウム\nProduct: ミニミニ情報テレビガイド"]}, {"names": ["プパ観察日記", "よ～いちろ～"], "misc": ["Genre: 評論・情報\nName (kana): プパカンサツニッキ\nProduct: THE・つっこみ（CM編）"]}, {"names": ["夜通し帝国", "北狐"], "misc": ["Genre: 評論・情報\nName (kana): ヨドオシテイコク\nProduct: 夜通し帝国vol．2"]}, {"names": ["日曜研究社", "串間努"], "misc": ["Genre: 評論・情報\nName (kana): ニチヨウケンキュウシャ\nProduct: 日曜研究家"]}, {"names": ["Office YOUNG JAPAN", "血祭鉄鎚"], "misc": ["Genre: 評論・情報\nName (kana): オフィスヤングジャパン\nProduct: YOUNG JAPAN 02 MAX"]}, {"names": ["聖ヨハネ女学院サブカル研究会", "田中北京"], "misc": ["Genre: 評論・情報\nName (kana): セントヨハネジョガクイン\nProduct: サブカル評論vol．8"]}, {"names": ["神聖軍事同盟", "ジン・ジャハナム元帥"], "misc": ["Genre: 評論・情報\nName (kana): シンセイグンジドウメイ\nProduct: 征論"]}, {"names": ["げんれい工房", "山桂"], "misc": ["Genre: 評論・情報\nName (kana): ゲンレイコウボウ\nProduct: 500％ ふさまとめ半升"]}, {"names": ["第三開拓領域", "左端の天使"], "misc": ["Genre: 評論・情報\nName (kana): ダイサンカイタクリョウイキ\nProduct: Keep Outers 2005"]}, {"names": ["まんがデータベース2004", "堀越和子"], "misc": ["Genre: 評論・情報\nName (kana): マンガデータベース\nProduct: まんがデータベース2004"]}, {"names": ["改築村上荘", "アマラン"], "misc": ["Genre: 評論・情報\nName (kana): カイチクムラカミソウ\nProduct: りぼん総目録\nemail: hyb85367@biglobe.ne.jp\n・雑誌「りぼん」「クッキー」の総目録・稲作を中心とした農業関連"]}, {"names": ["4研", "三河屋"], "misc": ["Genre: 評論・情報\nName (kana): ヨンケン\nProduct: 起承転結"]}, {"names": ["阪系"], "misc": ["Genre: 評論・情報\nName (kana): ハンケイ"]}, {"names": ["TADA派", "H・アタリ"], "misc": ["Genre: 評論・情報\nName (kana): タダハ\nProduct: バトルマンガ大全\nemail: ryou_dqn@yahoo.co.jp\n漫画批評サークルです。評論とデータ研究をメインにしています。幅広く展開していきたいと思っています。とりあつかう漫画ネタは最近の漫画よりも80年代～90年代がメインとなります。「ドラゴンボール」や「グラップラー刃牙」などのバトル漫画をまとめたデータ集とレビューを予定しています"]}, {"names": ["一人遊"], "misc": ["Genre: 評論・情報\nName (kana): ヒトリアソビ\n新刊あり"]}, {"names": ["時計坂通信社", "七尾葉介"], "misc": ["Genre: 評論・情報\nName (kana): トケイザカツウシンシャ\nProduct: 時計坂通信\n私腹を肥やさない非営利団体として、権利者から黙認されることを前提に活動する非公認情報サークル"]}, {"names": ["ぴよぴよテクノロジー", "山本将樹"], "misc": ["Genre: 評論・情報\nName (kana): ピヨピヨテクノロジー\nProduct: 高橋留美子の詳しい世界\nemail: piyotech@tokeizaka.com\n高橋先生へのインタビュー、知人が高橋先生について語っている、高橋先生の作品について論評をしている本や雑誌など、高橋先生に関する「2次文献」をデータベース化したものです。", "http://rumic.dojin.com/piyotech/"]}, {"names": ["乙女の愛の夢", "bk2"], "misc": ["Genre: 評論・情報\nName (kana): オトメノアイノユメ\nProduct: ドラえもんをもう一度読み返したくなるなにか。"]}, {"names": ["海面を這う者", "イクヤフ"], "misc": ["Genre: 評論・情報\nName (kana): ミナモヲハウモノ\nProduct: 海面を這う者\nチャ-ルズ・シュルツ、P・Kディック等、漫画やSFの作家評がメインです。", "http://ww8.tiki.ne.jp/~eqyw135/"]}, {"names": ["雑誌の住人", "MiLKMAN"], "misc": ["Genre: 評論・情報\nName (kana): ザッシノジュウニン\nProduct: 美少女ゲーム雑誌リファレンスブック2004"]}, {"names": ["4 1／2SOCIETY", "瀬川操"], "misc": ["Genre: 評論・情報\nName (kana): ヨジョウハンソサエティ\nProduct: センシティブピーシィズ"]}, {"names": ["青流星", "伊吹祐"], "misc": ["Genre: 評論・情報\nName (kana): セイリュウセイ\nProduct: 歌の翼に"]}, {"names": ["1－CONFUJOKAI", "一根"], "misc": ["Genre: 評論・情報\nName (kana): イッコンフジョウカイ\nProduct: 日本人のだましかた"]}, {"names": ["WAIWAIスタジオ", "新田五郎"], "misc": ["Genre: 評論・情報\nName (kana): ワイワイスタジオ\nProduct: ぶっとびマンガ大作戦\nemail: GFH01446@nifty.ne.jp\n主に80年代以降の、一般的評価の対象外だったマンガの紹介・評論。", "http://picnic.to/~funuke/"]}, {"names": ["魁！おぼこ塾", "御童魁"], "misc": ["Genre: 評論・情報\nName (kana): サキガケオボコジュク\nProduct: Fragile非公式ガイドブック"]}, {"names": ["CONNECTION", "へび太郎"], "misc": ["Genre: 評論・情報\nName (kana): コネクション\nProduct: まんが人\nオススメのまんが、いま旬のまんがを紹介する、まんがレビュー本「まんが人」です。今までは都合上、文芸創作にいましたが、こちらがメインになってきたのでジャンル変更しました。よろしくお願いします。特集「制服の女のコ」、「モテモテ!? まんが本棚コーディネート術」など読み物いろいろ、既刊もいろいろです。新刊ももちろん、あります！"]}, {"names": ["電波管理者", "ホロケン"], "misc": ["Genre: 評論・情報\nName (kana): デンパカンリシャ\nProduct: 笑集2004～2005"]}, {"names": ["タカクラプロダック", "高倉一般"], "misc": ["Genre: 評論・情報\nName (kana): タカクラプロダック\nProduct: 変なまんが"]}, {"names": ["足高温泉ガイド", "黒井奴"], "misc": ["Genre: 評論・情報\nName (kana): アシタカオンセンガイド\nProduct: 足高温泉ガイド"]}, {"names": ["やおい書店大崎店", "橘ウナム"], "misc": ["Genre: 評論・情報\nName (kana): ヤオイショテンオオサキテン\nProduct: げんしょけん"]}, {"names": ["幽遊白書研究会"], "misc": ["Genre: 評論・情報\nName (kana): ユウユウハクショケンキュウカ\nProduct: 幽遊白書研究"]}, {"names": ["Essential Plot", "ESSEN"], "misc": ["Genre: 評論・情報\nName (kana): エッセンシャルプロット\nProduct: 美少女コミック放談"]}, {"names": ["Mechanism of Vision", "小川佳昭"], "misc": ["Genre: 評論・情報\nName (kana): メカニズムオブヴィジ\nProduct: Mechanism of Vision vol．4"]}, {"names": ["駒木研究室", "駒木ハヤト"], "misc": ["Genre: 評論・情報\nName (kana): コマギケンキュウシツ\nProduct: 「現代マンガ時評」04年度総集編"]}, {"names": ["東京大学漫画調査班TMR", "D.C."], "misc": ["Genre: 評論・情報\nName (kana): トウキョウダイガクマンカ\nProduct: TMR第37回調査報告\nemail: CBD00093@nifty.com\n三度の飯より漫画が好きな東大生達が一堂に会し独自のアプローチで漫画業界を一刀両断。日頃の研究成果の詰まった報告書を作成しています。", "http://nk.ysnet.org/tmr/index.html"]}, {"names": ["sawada special", "sawada"], "misc": ["Genre: 評論・情報\nName (kana): サワダスペシャル\nProduct: 横山三国志通信"]}, {"names": ["ジャージ革命", "三鷹"], "misc": ["Genre: 評論・情報\nName (kana): ジヤージカクメイ\nProduct: ペンマニア\nボールペンのデータ本を中心に身近なものを取り上げたコラムを中心に活動中"]}, {"names": ["村山通信"], "misc": ["Genre: 評論・情報\nName (kana): ムラヤマツウシン\nProduct: 村山通信"]}, {"names": ["同好会海", "朱夏"], "misc": ["Genre: 評論・情報\nName (kana): ドウコウカイカイ\nProduct: MAD FALCON"]}, {"names": ["河馬の好奇心", "新木達也"], "misc": ["Genre: 評論・情報\nName (kana): カバノコウキシン\nProduct: 河馬の好奇心\nemail: araq@tkk.att.ne.jp\n博物館探訪記レポート都内中心", "http://home.att.ne.jp/moon/araq"]}, {"names": ["隅田金属ぼるじひ社", "文谷数重"], "misc": ["Genre: 評論・情報\nName (kana): スミダキンゾクボルジ\nProduct: 瀛報（ようほう）"]}, {"names": ["秋風", "にょんた"], "misc": ["Genre: 評論・情報\nName (kana): アキカゼ\nProduct: クロいネコの生活\nemail: niyonta@pet.117.cx\n某宅配業界本仕事本です。暴露よりはネタ！楽しく読んで頂きたいです"]}, {"names": ["まどわく", "工藤あい"], "misc": ["Genre: 評論・情報\nName (kana): マドワク\nProduct: Folk．P－民話と確率論\nemail: kumu@hotmail.co.jp\n民話、都市伝説等、民俗学的なものを情報、用語、ゲームなどさまざまな方向からアプローチしています。"]}, {"names": ["時刻堂", "魚住まや"], "misc": ["Genre: 評論・情報\nName (kana): ジコクドウ\nProduct: 古本ぐらし\n古書と古本屋に関する実録のエッセイと評論、および情報の本です。"]}, {"names": ["なかよし同盟", "歩絵夢恋太朗"], "misc": ["Genre: 評論・情報\nName (kana): ナカヨシドウメイ\nProduct: アレな古本"]}, {"names": ["開田無法地帯", "開田あや"], "misc": ["Genre: 評論・情報\nName (kana): カイダムホウチタイ\nProduct: ぶらりオタク旅5"]}, {"names": ["IRD工房", "氷川竜介"], "misc": ["Genre: 評論・情報\nName (kana): アイアールディーコウボウ\nProduct: ロトさんの本 vol．14\n評論系サークルです"]}, {"names": ["と学会", "山本弘"], "misc": ["Genre: 評論・情報\nName (kana): トガッカイ\nProduct: と学会誌"]}, {"names": ["WAR MACHINE", "眠田直"], "misc": ["Genre: 評論・情報\nName (kana): ウォーマシン\nProduct: TOON GUIDE1"]}, {"names": ["ユニットプロセス", "あさぎりみゆき"], "misc": ["Genre: 評論・情報\nName (kana): ユニットプロセス\nProduct: 放送事故レポート"]}, {"names": ["規制絞殺同盟", "やぎひでき"], "misc": ["Genre: 評論・情報\nName (kana): キセイコウサツドウメイ\nProduct: 放送禁止用語・放送倫理規定 検定試験空想問題集"]}, {"names": ["ロケット野郎", "岡田斗司夫"], "misc": ["Genre: 評論・情報\nName (kana): ロケットヤロウ\nProduct: BSアニメ夜話裏話"]}, {"names": ["おたくをおもしろくする会", "柳瀬直裕"], "misc": ["Genre: 評論・情報\nName (kana): オタクヲオモシロクスルカイ\nProduct: ジャンクション通信"]}, {"names": ["阿素湖素子", "阿素湖素子"], "misc": ["Genre: 評論・情報\nName (kana): アソコソコ\nProduct: オンガク大好き！！"]}, {"names": ["デカダンス企画", "竹内哲史"], "misc": ["Genre: 評論・情報\nName (kana): デカダンスキカク\nProduct: 日記 2003"]}, {"names": ["立川流本家", "立川談之助"], "misc": ["Genre: 評論・情報\nName (kana): タテカワリュウホンケ\nProduct: 本家立川流"]}, {"names": ["コウザの魂", "高橋浄久"], "misc": ["Genre: 評論・情報\nName (kana): コウザノタマシイ\nProduct: コウザの魂"]}, {"names": ["互連網絡有限公司", "吉田単車"], "misc": ["Genre: 評論・情報\nName (kana): ゴレンモウラクユウゲンコ\nProduct: 樽の真相\nネットワーク版『噂の真相』を目指し、インターネットのNetnewsのカテゴリーであるfj.*やjapan.*、またかつて一世を風靡した「あやしいわーるど」・今一番ホットでナウなヤングにバカ受けの掲示板システム「2ちゃんねる」等に代表されるようなアングラUG系インターネットに題材を取って好評をいただいている『樽の真相』(略称たるしん)の新刊を発行できる予定です。 頒布予定物：◎新刊『樽の眞相』第16号 A5 300円（予価）◎既刊 『樽の眞相』第15号 A5 200円 2004冬発行『樽の眞相』第14号 A5・36P フルカラー表紙 300円 2002冬発行 『樽の眞相』第13号 A5・36P フルカラー表紙 300円 2002夏発行 『樽の眞相』第11号 A5・68P フルカラー表紙 500円 2001夏発行 『樽の眞相』第8号 A5・68P フルカラー表紙 500円 2000春発行 『樽の眞相』第5号 A5・68P オフセット 500円 1998夏発行 迷わず行けよ 行けば分かるさ ありがとぉぉぉ ＠有明 http://www.jca.apc.org/ariake/ (b^-')グッドですよ ヽ(´ー｀)人(´ー｀)ノみんな仲良く ポスト2chキッズの士農工商マガジンヽ(´ー`)ノ名誉白人 打倒！2さょんねる！！！11qa 2ぁんえるをブッ潰せ！何が2chだ糞が氏ねや 2chのここが嫌いだ！許せない！イヤだ！気色悪い！キモい！フザケんな！薄い！金返せ！ヌルい！異常だ！おかしい！イカレてる！臭い！アニヲタ眼鏡デヴ！風呂入れ！歯ァ磨け！息すんな！鼻毛切れ！使えない！ダメだ！まだらハゲ！仮性包茎！インポテンツ！士農工商！でもチョット好きハァト(´∀`) マターリ インチャーネット最前線 海老名運動公園 投稿者 カツジ さん 2001年9月25日(火) 23時52分 [P] さっき、川原でやった六尺兄貴凄かったです！ガチムチの色黒兄貴がオッス連呼で張型ケツにぶちこまれ腰振ってました。俺もくわえさせられて浣腸食らい無様に排便さらしました。バリカン出されたときは一瞬引いたけど、兄貴の「いやなら止めていいんだぜ！」の一言で覚悟決め、生まれて初めて丸刈りになりました。その後、脇・チンゲも刈られてビンビンのマラ、思いっきりしごかれ派手にガチムチ兄貴の顔に飛ばしました。スッゲー男らしく気持ちよかったです。また行くときカキコして下さい！帰ってから丸刈りの頭見て、また感じまくってます！ 生意気な＞1をシメてやるッ…！（省略されました‥全てを読むにはここを押して下さい）ここは本当に恐ろしいインターネットですね。私はインターネット歴3年のベテランですがこんなに恐ろしいインターネットは見た事がないです。ここにいる皆さんは、あまり知識がないから知らないと思いますが私はアングラーサイトというものに出入りしているのでインターネットの恐ろしさを知っているんですよ。こういうインターネットに居るとIPアドレス（メールアドレスのようなもの）がばれてしまうんですよ。皆さん、気を付けて下さい。 投稿者：DDの哲さん 投稿日：2002/01/13(日)16時49分48秒 ■ ★ 人は、認められるために生きているっちゅーても過言やないんや！認められるっちゅー事は、ほめられたり、感謝されたり、大切な責任を任されるという事を意味するんやけどな、それに見合う報酬が与えられた時、認められた事を最も具体的に感じる事が出来るんや！そう思わへんか！仕事においても、自分の努力の実が100%自分に戻って来れば、満足とやる気と勇気と希望がわいて来るんや！でもな、ほとんどの組織がピラミッド型になっている今日の社会の中で、この点が大問題なんや！！しかしそんなフラストレーションを吹き飛ばしてくれる仕事があるんや！！自分の努力が、報酬という形で100%自分に戻って来る凄い仕事があるんや！！それはキミにも出来る健全で安全な仕事なんやで！！それは何かわかるか！！ それはァムゥェィや！ 85 名前：T－TAKE(偽) 投稿日：02/11/24 21:49 ID:??? 2ちゃんねるの掲示板は2度と現れないで欲しいと思います。 実は、私が2ちゃんねるで中傷されているのを聞いてこれに恐れて友達を順次失ってしまっている状態です。今日までに10件目の友達を失っています。本当に2ちゃんねるは許せません。どんな手を使ってでも2ちゃんねるを取り壊すことと博之を抹殺してやりたいです。あいつをかばう必要はありません。暴力団にさらわれて、ぼこぼこにされて殺されて下さいです。＞1 あれほど言ったのに、まだそんなカキコするですか！もう許さんです！あんたを許すわけにはいかんです！こんなカキコでレスたくさん付くとでも思ってr", "http://www.jca.apc.org/ariake"]}, {"names": ["人権侵害軍", "田中"], "misc": ["Genre: 評論・情報\nName (kana): ジンケンシンガイグン\nProduct: 有名人四季報"]}, {"names": ["つっこま46期 縁日班 宙組", "フケ顔男爵"], "misc": ["Genre: 評論・情報\nName (kana): ツッコマヨンジュウロッキエ\nProduct: ウソチクの泉ブック 第4巻\nemail: fukegao@yahoo.co.jp\nTBSラジオ「伊集院光 深夜のバカ力」のファンブックを作っております。今回の新刊は「ウソチクの泉ブック 第4巻」「渡辺校長の平成ハレンチ学園 学習指導要領（仮）」。そして番組10周年記念本「伊集院光 深夜のバカ力 フリートーク年表」を頒布予定です。「ウソチクの泉ブック 第1-3巻」「豆知識予備校666」「あそびプレイングマニュアル」など既刊ももちろん出します。また、午前中は大手サークルに並ぶので売切れが心配と言うあなた！公式サイトで取置を受け付ける予定です。申し込んでくれた方には丈夫な紙袋プレゼント！ぜひご利用ください。", "http://pluto.pobox.ne.jp/sola/"]}, {"names": ["ビビンシア！寅組", "PLせつな"], "misc": ["Genre: 評論・情報\nName (kana): ビビンシアトラグミ\nProduct: りんごのパズル えろぴったん\n珍奇本やってます。"]}, {"names": ["私立歯車高校", "石黒直樹"], "misc": ["Genre: 評論・情報\nName (kana): シリツハグルマコウコウ\nProduct: おたく仕事ガイド"]}, {"names": ["恐るべきお兄ちゃん軍団", "本田透"], "misc": ["Genre: 評論・情報\nName (kana): オソルベキオニイチャング\nProduct: おそおに通"]}, {"names": ["波状言論", "東浩紀"], "misc": ["Genre: 評論・情報\nName (kana): ハジョウゲンロン\nProduct: 美少女ゲームの臨界点"]}, {"names": ["Parallelloop", "佐藤心"], "misc": ["Genre: 評論・情報\nName (kana): パラレルループ\nProduct: Majestic－12 vol．2"]}, {"names": ["東文研", "唐沢俊一"], "misc": ["Genre: 評論・情報\nName (kana): トウブンケン\nProduct: ゴミビア"]}, {"names": ["うわの空･藤志郎一座", "ツチダマ"], "misc": ["Genre: 評論・情報\nName (kana): ウワノソラトウシロウイチザ\nProduct: うわの空・藤志郎一座会誌"]}, {"names": ["究極編集部", "持木一明"], "misc": ["Genre: 評論・情報\nName (kana): キュウキョクヘンシュウブ\nProduct: VIDEA"]}, {"names": ["懐旧的映像資料室", "福井県人"], "misc": ["Genre: 評論・情報\nName (kana): カイキュウテキエイゾウシリ\nProduct: 文章系同人誌のための同人誌製作技術\n元々は古いアニメ等の資料本を製作するサークルですが、現在は文章系同人誌製作のノウハウ本を発行しています。"]}, {"names": ["からまん", "唐沢なをき"], "misc": ["Genre: 評論・情報\nName (kana): カラマン\nProduct: パチモン大王\n昭和30～40年代に発売されたパチもの駄玩具の研究マンガ集。『フィギュア王』誌に唐沢なとき名義で連載している『パチモン大王』に描きおろしを加えたものです。", "http://www2.big.or.jp/~karaman"]}, {"names": ["AVC", "cla"], "misc": ["Genre: 評論・情報\nName (kana): エーブイシー\nProduct: AVC"]}, {"names": ["現職地方議員裏話公開総合窓口", "massoud"], "misc": ["Genre: 評論・情報\nName (kana): ゲンショクチホウギインウ\nProduct: 爆笑！地方議員の生態\nemail: com_massoud@infoseek.to\n筆者のmassoudです。当サークルで頒布している冊子は、あまりに一般とかけ離れた地方政治の世界について、ノンフィクションに脚色を一部加えた（かもしれないし100％事実かも）内容であります。議員がどう仕事をしているか内側から明らかに。これをみて呆れた方は是非、あらゆる選挙で相応しくない面々が落選するよう投票に行きましょうー。", "http://www.geocities.jp/gcguksm/"]}, {"names": ["政界人", "水夏157"], "misc": ["Genre: 評論・情報\nName (kana): セイカイジン\nProduct: THE政界人！"]}, {"names": ["褐色館", "めぐみ帝国"], "misc": ["Genre: 評論・情報\nName (kana): カッショクカン\nProduct: 地方自治体の今 vol.1\nemail: bverg1945@nifty.com\n最近金沢地方裁判所にて判決が出た住基ネットについて取り上げます。市町村の現状や広域住民票の取得履歴等も取り上げています。", "http://homepage3.nifty.com/~kasshokukan"]}, {"names": ["新党桜華", "久村貴史"], "misc": ["Genre: 評論・情報\nName (kana): シントウオウカ\nProduct: 政教分離とは何か？"]}, {"names": ["projectTS", "TS"], "misc": ["Genre: 評論・情報\nName (kana): プロジェクトティーエス\nProduct: 政界4コマ劇場"]}, {"names": ["政鉄工房", "オーシャンクロス"], "misc": ["Genre: 評論・情報\nName (kana): セイテツコウボウ\nProduct: 日本の産業を考える\nemail: 