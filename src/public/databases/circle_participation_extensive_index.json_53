ames": ["蛍光銀河", "いわおかめめ"], "misc": ["Genre: 創作(少女)\nName (kana): ケイコウギンガ\nProduct: 恩田三姉妹"]}, {"names": ["梅アイス", "とも"], "misc": ["Genre: 創作(少女)\nName (kana): ウメアイス\nProduct: 大日本梅干教"]}, {"names": ["山桜桃分家", "桃胡"], "misc": ["Genre: 創作(少女)\nName (kana): ユスラウメブンケ\nProduct: 中華幻想\nemail: comomof@yahoo.co.jp\n歴史・伝承などを元にした中華風オリジナル。少女中心のイラストなど。", "http://www.geocities.jp/pecheouest/"]}, {"names": ["なつみつうしん", "小沢なつみ"], "misc": ["Genre: 創作(少女)\nName (kana): ナツミツウシン\nProduct: Asterisk"]}, {"names": ["古夜冬考（古夜トシタカ）", "古夜冬考"], "misc": ["Genre: 創作(少女)\nName (kana): フルヤトシタカ\nProduct: 5"]}, {"names": ["ぐんたまカンパニー", "渋蔵"], "misc": ["Genre: 創作(少女)\nName (kana): グンタマカンパニー\nProduct: けだもののように"]}, {"names": ["8・18", "宮本たか子"], "misc": ["Genre: 評論・情報\nName (kana): エイトジュウハチ\nProduct: 彼女が彼氏になった時"]}, {"names": ["よつば屋", "たかみかんな"], "misc": ["Genre: 評論・情報\nName (kana): ヨツバヤ\nProduct: だいえっとしませんか？5"]}, {"names": ["愛の歯ブラシセット", "大村砂央里"], "misc": ["Genre: 評論・情報\nName (kana): アイノハブラシセット\nProduct: OTA！（ク） 3"]}, {"names": ["フィロソフィア", "日比野たまたま"], "misc": ["Genre: 評論・情報\nName (kana): フィロソフィア\nProduct: 妻をめとらばおたく？2005\nemail: tamatama@zb3.so-net.ne.jp\n「妻をめとらばおたく？」という本を出しています。立ち読み大歓迎！来てね！", "http://www004.upp.so-net.ne.jp/tamatama/"]}, {"names": ["きつね文庫", "夕凪てら"], "misc": ["Genre: 評論・情報\nName (kana): キツネブンコ\nProduct: タンパク質はポイズン！\n夏は、お盆とピッタリ重なってしまった為、お休みしましたが、今回は頑張ります！ 西原克成博士式育児と、山西みな子先生式育児についての本です。 西原式とは、「少なくとも1歳までは、母乳かミルクのみで育て、その後2歳位まで、母乳やミルク中心で育てる。」「オシャブリは、4歳まで」「ハイハイとナメナメは充分させる」「37℃以下の飲み物は与えない、自分も飲まない」「赤ちゃん時代の寝相で、一生の健康が決まる」「赤ちゃんの手足を冷やさない」などなど…です。 そんな娘も4歳、年少クラスになりました。 身長100．6センチ、体重15．1キロです。 表紙は娘と合作コーナーも、あります。 今回は日常の事や、バレエの事など描いています。 ぜひ、遊びにいらして下さい。", "http://kitunet.chu.jp/"]}, {"names": ["WILD☆CAT", "和泉まいな"], "misc": ["Genre: 評論・情報\nName (kana): ワイルドキャット\nProduct: 絵日記"]}, {"names": ["如月堂はなてん", "You"], "misc": ["Genre: 評論・情報\nName (kana): キサラギドウハナテン\nProduct: Play a Go Go！"]}, {"names": ["内臓倶楽部", "月神Dr．"], "misc": ["Genre: 評論・情報\nName (kana): ナイゾウクラブ\nProduct: ちょっとはわかる造影剤の本"]}, {"names": ["檄団活力", "美好沖野"], "misc": ["Genre: 評論・情報\nName (kana): ゲキダンカツリョク\nProduct: オキノニッキ外伝"]}, {"names": ["火星からの通信", "神宮まさ子"], "misc": ["Genre: 評論・情報\nName (kana): カセイカラノツウシン\nProduct: 風と海と船と（シリーズ）"]}, {"names": ["JIN－力", "SYO"], "misc": ["Genre: 評論・情報\nName (kana): ジンリキ\nProduct: JIN－力 5"]}, {"names": ["福祉のお仕事", "西村元秀"], "misc": ["Genre: 評論・情報\nName (kana): フクシノオシゴト\nProduct: すちゃらか介護日記"]}, {"names": ["あいあんれっぐ", "やのじ"], "misc": ["Genre: 評論・情報\nName (kana): アイアンレッグ\nProduct: いっぽんあしの日々\nemail: yanoji@mbd.nifty.com\n義足でのリハビリや日常生活での体験記を中心に本を作って居ります。"]}, {"names": ["橘屋黒曜堂", "橘 柾樹"], "misc": ["Genre: 評論・情報\nName (kana): タチバナヤコクヨウドウ\nProduct: 一二漢方（通巻9号）\nemail: obsidian@lares.dti.ne.jp\n鍼灸師が、学び、体験し、実践した中で得た東洋医学（漢方）の知識を一般に広める目的で活動しています。"]}, {"names": ["もおやけくそ", "宗方ただし"], "misc": ["Genre: 評論・情報\nName (kana): モオヤケクソ\nProduct: 季刊日曜日"]}, {"names": ["2015年紀解読委員会", "クリスマス・ピポ"], "misc": ["Genre: 評論・情報\nName (kana): ニセンジュウゴネンキカイ\nProduct: 献血20年史"]}, {"names": ["ハードバンク", "にのまえ礼"], "misc": ["Genre: 評論・情報\nName (kana): ハードバンク\nProduct: 銀行の迷信\nコミケ唯一の？銀行業界本を発行。「銀行の迷信」シリーズ今回は、新刊「銀行の迷信3」を発行予定！"]}, {"names": ["DEEPMEN", "ぜうす"], "misc": ["Genre: 評論・情報\nName (kana): ディープメン\nProduct: 脳狂革命3\nemail: kinoc3@ybb.co.jp\nC67より長らくご愛読いただいた「脳狂革命」も、今回が最終回！郵政民営化をしようとしている小泉さんよ、農協解体が先だろ！今回も、派手に楽しく行きますよ～！", "http://homepage2.nifty.com/deepmen/"]}, {"names": ["M．P．S", "四月朔日八月朔日"], "misc": ["Genre: 評論・情報\nName (kana): エムピーエス\nProduct: 区分機まにゅある"]}, {"names": ["サークルTOPPO", "水無瀬恢"], "misc": ["Genre: 評論・情報\nName (kana): サークルトッポ\nProduct: 郵便局民営化大作戦"]}, {"names": ["政界の暗雲", "やまざきたろう"], "misc": ["Genre: 評論・情報\nName (kana): セイカイノアンウン\nProduct: 郵政民営化入門\n政治ネタ中心の時事漫画です．通常の4コマのほか，政治ネタとマンガ・アニメを組み合わせたパロディもの，解説本など幅広く描いています．パロディものの元ネタは，ふたりはプリキュア，焼きたて！ジャぱん，それいけ！アンパンマン，逆境ナイン，かっとばせ！キヨハラくん，ガンダムSEEDなど．これらを強引に政治ネタとくっつけています．解説本としては現在，郵政民営化入門などがあります．またサイトで掲載した4コマに書き下ろしを加えた総集編も刊行しています．冬コミでの新刊はガンダムSEEDの政治ネタパロディ本，それに解説本としてカシミール紛争入門を予定しています．特にカシミール本は，インスパイア（インスパイヤ？）本として，夏コミ直前に作者のWinny騒動で話題となった“あぶがにすタン”の登場人物による解説を予定．とことんハメをはずします．", "http://www.seikainoanun.com/"]}, {"names": ["現職地方議員裏話公開総合窓口", "massoud"], "misc": ["Genre: 評論・情報\nName (kana): ゲンショクチホウギインウ\nProduct: 爆笑！地方議員の生態\nemail: com_massoud@infoseek.to\n筆者のmassoudです。当サークルで頒布している冊子は、あまりに一般とかけ離れた地方政治の世界についての内容であります。議員がどう仕事をしているか内側から明らかにという観点で、国政とは異なるマスコミには載らない泥臭い内容が山盛りです。これをみて呆れた方は是非、あらゆる選挙で相応しくない面々が落選するよう投票に行きましょうー。", "http://www.geocities.jp/gcguksm/"]}, {"names": ["法研日本", "Tamaki"], "misc": ["Genre: 評論・情報\nName (kana): ホウケンニッポン\nProduct: Tokyo Copyrights"]}, {"names": ["我流のすき焼き鍋", "K・MURASAME"], "misc": ["Genre: 評論・情報\nName (kana): ガリュウノスキヤキナベ\nProduct: 盗聴法について考える\n好きなことをやる個人サークル。どこをどう間違えたか、盗聴法（通信傍受法、正式には犯罪捜査のための通信傍受に関する法律。児童ポルノ法、青少年健全育成基本法案などとも密接に関係する言論統制法です）についての評論・廃止のための主張など。総選挙で野党が勝てば、廃止の実現に繋がるはずでした。ようやく見通しが立ったかに思えました。しかし、その結果はあまりに過酷でした……………。共謀罪創設などさらなる表現・言論規制の動向も追いますが、ひとまず次回で打ち止め予定。当選した以上、必ずや集大成を発表します。また、盗聴法人物列伝も企画。他に美少女ゲーム「五月倶楽部」シリーズ、GB版Sa&#65381;Gaシリーズなど、その時々でファンとして扱って行くつもりです。", "http://pro.tok2.com/~sukiyaki/index.htm"]}, {"names": ["MFRI", "猿元"], "misc": ["Genre: 評論・情報\nName (kana): エムエフアールアイ\nProduct: 学習する人生（仮）\n謎な学問系。「萌えない法律学」とか「あやしい統計学」とか書いてます。", "http://www.puni.net/~aniki/"]}, {"names": ["due process．", "tsubasa"], "misc": ["Genre: 評論・情報\nName (kana): デュープロセス\nProduct: due process．準備号"]}, {"names": ["お楽しみ研究所", "志田朋丈"], "misc": ["Genre: 評論・情報\nName (kana): オタノシミケンキュウジョ\nProduct: ハウジング・ナウ"]}, {"names": ["らいぶら進化論", "うりりん"], "misc": ["Genre: 評論・情報\nName (kana): ライブラシンカロン\nProduct: おはなしかい繁盛記\n図書館でのお話会四コママンガがあります。"]}, {"names": ["SILVERAD", "小沢よう子"], "misc": ["Genre: 評論・情報\nName (kana): シルバラード\nProduct: 公務員進化論\n公務員の日常生活本です。"]}, {"names": ["レッツ･ロイヤルファミリー", "山野美里"], "misc": ["Genre: 評論・情報\nName (kana): レッツロイヤルファミリー\nProduct: やっぱり雅子様\n皇太子妃雅子様のファンサークルです。"]}, {"names": ["お祭り亭", "かおりちゃん"], "misc": ["Genre: 評論・情報\nName (kana): オマツリテイ\nProduct: ザツダン"]}, {"names": ["アーカム市役所職員組合", "すりーぴーきんぐ"], "misc": ["Genre: 評論・情報\nName (kana): アーカムシヤクショショクイン\nProduct: アーミティッジ・リポート"]}, {"names": ["新党桜華", "久村貴史"], "misc": ["Genre: 評論・情報\nName (kana): シントウオウカ\nProduct: 桜華の議2005"]}, {"names": ["知識雑学研究所", "石塚ひろし"], "misc": ["Genre: 評論・情報\nName (kana): チシキザツガクケンキュウ\nProduct: さらに上を目指す人の 高校卒業程度認定試験 A to Z\nemail: laboratory_itk@yahoo.co.jp\n同人誌でも唯一無二(？)の教育評論系ガイドブックのサークルです。『決してメジャーではないけれど、需要は多い進学ガイド』をコンセプトに『大学編入試験』『通信教育で教員免許』『高校卒業程度認定試験(旧：大検)』のガイドブックを刊行しています。その他評論風エッセイをイベント参加ごとに発表しています。2006年からの新プロジェクト始動に向け、ご挨拶号を刊行する予定です。", "http://laboratory-itk.hp.infoseek.co.jp/"]}, {"names": ["浜ノ湯", "湯太郎"], "misc": ["Genre: 評論・情報\nName (kana): ハマノユ\nProduct: たいへんよくできません6"]}, {"names": ["褐色館", "めぐみ帝国"], "misc": ["Genre: 評論・情報\nName (kana): カッショクカン\nProduct: 地方自治体の今 vol.2\nemail: bverg1945@nifty.com\n最近頻繁に行われている市町村合併について市町村の成立の歴史や合併の意義について検討する。", "http://homepage3.nifty.com/~kasshokukan/"]}, {"names": ["アトン", "英明"], "misc": ["Genre: 評論・情報\nName (kana): アトン\nProduct: めーど3"]}, {"names": ["Project Eye", "桜井たくや"], "misc": ["Genre: 評論・情報\nName (kana): プロジェクトアイ\nProduct: 税金とか、まねぃのほん。\nemail: comic@projecteye.info\n冬です。年末です。確定申告の準備の季節がやってきました。『同人作家の確定申告ガイド(仮)』を執筆中。詳しくは、Webサイトをご覧下さい。あと、為替系の簡単なモノも出せたら良いな…。", "http://projecteye.info/"]}, {"names": ["平和神軍観察会", "次瀬徹"], "misc": ["Genre: 評論・情報\nName (kana): ヘイワシングンカンサツカイ\nProduct: 逝き逝きて平和神軍"]}, {"names": ["XAT－STEW", "烈風羅可庵（れぷらかーん）"], "misc": ["Genre: 評論・情報\nName (kana): ザットシチュウ\nProduct: XAT・STEW NAIR"]}, {"names": ["萌学協会und東大メイド研究会", "竹林賢三"], "misc": ["Genre: 評論・情報\nName (kana): ホウガクキョウカイウントト\nProduct: 萌学協会雑誌\nemail: pmoeac@ybb.ne.jp\n当サークルは、「萌学協会」と「東京大学メイド研究会」の共同出展サークルです。今回の新刊としては「萌学協会雑誌第2巻第2号」を予定しており、夏コミで実施した「萌え」に関するアンケート結果を収録する予定です。その他の頒布物については萌学協会HP（http://www.geocities.jp/mhpcsouda/hougaku-index.htm）、ならびに東京大学メイド研究会（http://maidken.hp.infoseek.co.jp/）にて、決まり次第お知らせいたしますので、そちらをご確認いただけますよう、お願いいたします。■■萌学協会より■■ 2005年春から夏にかけて、各種経済レポートや映画、ドラマによって「萌え」の認知度が爆発的に広がりました。しかしもともと曖昧な定義しかなされていない「萌え」は、決定的な意味のインフレーションを伴って一般に普及しています。これまで「十人十萌」などと言われるように、「『萌え』は人それぞれで、定義できないもの」として、その曖昧さも仕方の無いものとして扱われてきました。しかし、その曖昧さが「萌え」に対してあらぬ誤解を生じさせるのではないか、という不安を持つ方も少なくないでしょう。「萌え」が普及し、その誤解を恐れるなら、われわれは社会一般に対して「萌え」を的確にインフォメーションする、説明責任が発生します。とはいっても「萌え」の曖昧は如何ともしがたいものです。ですから、まず「萌え」がどのように曖昧なのか、どうして曖昧なのかに焦点を当て、「萌え」の正体を探ってゆこうというのが、当会の研究姿勢です。 そのような研究のためには「萌え」が実際にどのように認識されているのか、といった情報が不可欠です。そのため当会では「萌えに関する意識調査」を前回コミックマーケットで行いました。「学漫」サークルを対象に約500枚の調査票を配布し、350枚強の有効回答を得ました。今回は、その調査結果を検討し、頒布冊子にてご報告したいと考えています。当会の研究が皆様の「萌え」認識に資するものであれば幸いに存じます。■■東京大学メイド研究会より■■昨年来、メイド喫茶を主な契機として大規模な「メイドブーム」が到来し、「メイド」という言葉と存在とが、従来に増して広く認知されるに至りました。 しかし一方で、視覚的な側面に偏重した・様々な意味でデフォルメされたイメージが浸透する反面で、そこから一歩踏み込んだメイドの特質や存在様式について、多くの場合明確なイメージは持たれていません。 また他方で、メイドのイメージは目下、それを捉える個々人の間で時に架橋しがたく分裂し、偶然的なものにすぎない要素が極大化して捉えられ、あるいは隣接し・あるいは容易に連想される「メイドでないもの」と混同され、かつてない混乱の中にあります。 東京大学メイド研究会は、このような現状に鑑み、設立以来「メイドとは何か」という問題について探求を続けています。メイドをメイドたらしめる真の要素は何なのか；メイドが成立するにはいかなる前提条件が必要なのか。そこから導かれるメイドのイメージとはどのようなものか；メイドを類似する「メイドでないもの」と分かつものは何なのか。これらの困難ながら重要な問題について、非力ながらも回答を提示し続けることが、当研究会の課題です。 コミックマーケットでは、当研究会の活動の成果を「研究報告」というかたちでお届けします。いまだ不十分な回答に留まりますが、当日会場にお越しの際には、是非ともご一読いただければ、と思います。 以上。", "http://www.geocities.jp/mhpcsouda/hougaku-index.htm"]}, {"names": ["ももぴーランド", "こうよかなた"], "misc": ["Genre: 評論・情報\nName (kana): モモピーランド\nemail: koyokanata@olive.zero.ad.jp\n二次元萌え・オタク文化に関する総合的な「萌えないコラム」を書きつづってきました。", "http://olive.zero.ad.jp/koyokanata/"]}, {"names": ["Sky Wing", "沙希"], "misc": ["Genre: 評論・情報\nName (kana): スカイウイング\nProduct: 制服大好き ウエイトレス制服 CD－ROM写真集"]}, {"names": ["葵瀬崎製作所", "まどか雅美"], "misc": ["Genre: 評論・情報\nName (kana): キセザキセイサクショ\nProduct: 学生服（プリーツスカート）の製作"]}, {"names": ["日々是縫製", "綾重和姫"], "misc": ["Genre: 評論・情報\nName (kana): ヒビコレホウセイ\nProduct: コスプレの処方箋"]}, {"names": ["炒飯天國", "Mokemoke（もけもけ）"], "misc": ["Genre: 評論・情報\nName (kana): チャーハンテンゴク\nProduct: MS少女のつくりかた。\nemail: frp@post.nifty.jp\n主に『自作コスプレ衣装の制作顛末記』『造型・衣装制作のHowto本』を発行。<br>その他2次創作/F1(Minardi F1 Team贔屓)等の同人誌も製作。<br>自家製キャストパーツ/アクセサリー等の、コスプレ向けグッズも少量頒布。<br><br>＜新刊予定＞<br>『ミナバナ(仮)』05日本GPレポート<br>『全日本歯車党・会報(仮)』車関係道楽本<br>『タイトル未定』コスプレ衣装製作記(脳噛ネウロ・ふたつのスピカ・他予定)<br><br><br>検索用(取扱作品)…ああ探偵事務所/アニメ会/交響詩篇エウレカセブン/エマ(シャーリー)/F1/OVERMANキングゲイナー/太田虎一郎/ガンダムシリーズ(MS少女)/ガンパレードマーチ/げんしけん（くじびきアンバランス）/星銃士ビスマルク/全日本妹選手権/C3 Pluriel(プルリエル)/Citro&euml;n(シトロエン)/ジョニー・ハーバート/DTエイトロン/Noir/戦闘妖精雪風(戦闘妖精少女たすけてメイヴちゃん)/成恵の世界（魔砲少女四号ちゃん）/BAROQUE/BEAT(ビート)/飛龍の拳/ファミコン(懐ゲー・ユーゲー)/Fate（Type-Moon）/ふたつのスピカ/プラネテス/HONDA(ホンダ)/マリア様がみてる/Minardi F1 Team(ミナルディ)/ラーゼフォン/WRC", "http://homepage3.nifty.com/frp/index.html"]}, {"names": ["くがやまわ～くすて～しょん", "K.Kugayama"], "misc": ["Genre: 評論・情報\nName (kana): クガヤマワークステーション\nProduct: 京都嵐山十三まいり攻略ガイド\nemail: kugayama@kiwi.ne.jp\n和服中心、主に小学校高学年女子", "http://www.kugayama-ws.net/"]}, {"names": ["みさちゅうぷろじぇくと", "みさちゅう"], "misc": ["Genre: 評論・情報\nName (kana): ミサチュウプロジェクト\nProduct: 女子校制服カタログ冬2005"]}, {"names": ["わきあいあい", "せち"], "misc": ["Genre: 評論・情報\nName (kana): ワキアイアイ\nProduct: メイド喫茶とメイド服\nemail: fantasy_hat123@yahoo.co.jp\nメイド喫茶のレポートイラストによる制服（メイド服）紹介", "http://geocities.yahoo.co.jp/gl/setisetinet"]}, {"names": ["あいまいProject", "けるる三乗"], "misc": ["Genre: 評論・情報\nName (kana): アイマイプロジェクト\nProduct: あいまいcafeのできるまで"]}, {"names": ["白砂博物館", "高木晋一郎"], "misc": ["Genre: 評論・情報\nName (kana): シロスナハクブツカン\nProduct: 手づくりめいどかふぇ体験記"]}, {"names": ["ぱるふた", "ぱるふぃ"], "misc": ["Genre: 評論・情報\nName (kana): パルフタ\nProduct: ふたばたんふぉとみっくす"]}, {"names": ["空耳アワー研究所", "研究所長"], "misc": ["Genre: 評論・情報\nName (kana): ソラミミアワーケンキュウジ\nProduct: 空耳アワー辞典\nemail: jun@mctv.ne.jp\nテレビ「タモリ倶楽部」内のコーナー「空耳アワー」のデータベース本です。", "http://soramimi.net"]}, {"names": ["TEAMCHUB", "ばいでん"], "misc": ["Genre: 評論・情報\nName (kana): チームチャブ\nProduct: BASIC\nemail: mc_baiden@hotmail.com\n映画を中心とした創作活動、批評と自主映画制作を行っています。", "http://nikoensis.hp.infoseek.co.jp/circle/"]}, {"names": ["六角橋救国戦線", "鶴間ヒョニル"], "misc": ["Genre: 評論・情報\nName (kana): ロッカクバシキュウコクセン\nProduct: グフフSGI\n社会派サブカルチャー研究集団と自称していますが、要は面白そうなモノを勝手に評論しちゃうサークルなんです。"]}, {"names": ["ヤンキー風俗研究会", "金成 由美"], "misc": ["Genre: 評論・情報\nName (kana): ヤンキーフウゾクケンキュウ\nProduct: 強面\nemail: kanariya@ares.eonet.ne.jp\nヤンキーの生態、行動、文化等の観察と研究", "http://www.eonet.ne.jp/~yanfuken"]}, {"names": ["大森屋", "大森雷子"], "misc": ["Genre: 評論・情報\nName (kana): オオモリヤ\nProduct: ネトオクのすすめ\nネットオークション体験記 傾向と対策"]}, {"names": ["ジャージ革命", "三鷹"], "misc": ["Genre: 評論・情報\nName (kana): ジャージカクメイ\nProduct: ペンマニア"]}, {"names": ["マロン男爵と小リス姫", "小リス姫"], "misc": ["Genre: 評論・情報\nName (kana): マロンダンシャクトコリスヒ\nProduct: マロン男爵と小リス姫"]}, {"names": ["西在家香織派", "中里一"], "misc": ["Genre: 評論・情報\nName (kana): ニシザイケカオリハ\nProduct: 百合の定義を論ず"]}, {"names": ["ミーハーおやぢ研究所", "さだあきら"], "misc": ["Genre: 評論・情報\nName (kana): ミーハーオヤヂケンキュウシ\nProduct: おやぢの同人誌"]}, {"names": ["エッジワース・ボックス", "黒原冬樹"], "misc": ["Genre: 評論・情報\nName (kana): エッジワースボックス\nProduct: コンテンツビジネス関連企業の経営分析"]}, {"names": ["Escape Power", "二木晶"], "misc": ["Genre: 評論・情報\nName (kana): エスケープパワー\nProduct: 忘れてしまいたい事が今の僕には多すぎる\n技術屋の日常記とか出張記です。でも技術の香りはまったくありません。", "http://www.escapepower.com"]}, {"names": ["慶應サイコロジーソサエティー", "さたらう"], "misc": ["Genre: 評論・情報\nName (kana): ケイオウサイコロジーソサエ\nProduct: Persona\nemail: fk050406@hc.cc.keio.ac.jp\n慶應義塾大学文連公認の人文社会科学系サークルです。名前は「サイコロジー」を冠しておりますが、心理学という枠にとらわれることなく、会員各々の興味関心を追求し、活発な議論を通して「共に学ぶ」ことをコンセプトに活動しています。C68にて初めてコミケットに参加し、有り難いことに持ち込んだ論考集100冊を完売させていただきました。今回の新刊も、前回好評だった「漫画の心理学」の第2弾をはじめとして、本格的な哲学論文から、最近話題のSNS（ソーシャル・ネットワーキング・サービス）についての考察まで、話題満載でお届けいたします。", "http://www.geocities.jp/kps_h17/"]}, {"names": ["富士ん口論社", "中年"], "misc": ["Genre: 評論・情報\nName (kana): フジンコウロンシャ\nProduct: 富士ん口論"]}, {"names": ["甲斐性無し", "ここあ"], "misc": ["Genre: 評論・情報\nName (kana): カイショウナシ\nProduct: 甲斐性無し機関誌"]}, {"names": ["同人誌即売会検索しすてむ", "ゆーぐりっど"], "misc": ["Genre: 評論・情報\nName (kana): ドウジンシソクバイカイ\nProduct: 同人誌即売会検索しすてむの分析本\nemail: k_inaga@msf.biglobe.ne.jp\n同人誌即売会のイベント情報を分析しています", "http://www.taiyakiyasan.org/"]}, {"names": ["世界開放環", "青葉唯石"], "misc": ["Genre: 評論・情報\nName (kana): セカイカイホウカン\nProduct: ライトノベル情報学"]}, {"names": ["白い空－Le Ciel Blanc－", "かざみあきら"], "misc": ["Genre: 評論・情報\nName (kana): シロイソラルシエルブラン\nProduct: エースコンバット5に学ぶ実践的英会話表現集 CD－ROMパイロット版"]}, {"names": ["温新報社", "neri"], "misc": ["Genre: 評論・情報\nName (kana): ヌルシンポウシャ\nProduct: ALTERNATIVE NEWS ARCHIVES 2002-2005\nemail: nurunews@hotmail.com\n個人ニュースサイト等で繰り返し取り上げられる、いわゆる「既出ネタ」等の中から使える情報を厳選し、カテゴリ別に編集。書籍化により、各情報の内容・関連性をわかりやすく伝えることを目的としています。現代日本の傍流文化（alternative culture）を読み解くテキストを目指して。", "http://nurunews.at.infoseek.co.jp"]}, {"names": ["みるく☆きゃらめる", "吉本たいまつ"], "misc": ["Genre: 評論・情報\nName (kana): ミルクキャラメル\nProduct: 灰羽連盟を見る\nemail: taimatsu@mars.dti.ne.jp\n石川ひでゆきのバカマンガと、吉本たいまつのバカ文章のコラボレーション。今回は吉本たいまつ個人プロジェクトの「灰羽連盟を見る」がメイン。あのアニメを原稿用紙350枚、120ページで詳細に解読。", "http://www.picnic.to/~taimatsu"]}, {"names": ["横浜新聞研究所", "Jimmy"], "misc": ["Genre: 評論・情報\nName (kana): ヨコハマシンブンケンキュウ\nProduct: 全国新聞事情(その7&#65381;東海編)\nemail: jimmymiya@netscape.net\n日本でほぼ唯一の新聞の流通に焦点を置いたサークルです。ローカル新聞や印刷所からの距離による全国紙の紙面が入れ替わる境界線を実地調査に基づいて調べ上げた各地の新聞のデータベース、「全国新聞事情」を出しています。現在北は北海道から西は東海まで7冊を出しており、最終的には全国カバーを目指します。", "http://yokohama.cool.ne.jp/jimmy_m/"]}, {"names": ["SOCIAL DISTORTION", "石川重徳"], "misc": ["Genre: 評論・情報\nName (kana): ソーシャルディストーション\nProduct: 水曜スペシャル川口浩探検隊シリーズ研究会誌6号"]}, {"names": ["帝国経済", "Aloin"], "misc": ["Genre: 評論・情報\nName (kana): テイコクケイザイ\nProduct: 各種チャートの読み方と分析法 2版\nemail: aloinjp@yahoo.co.jp\n金融・株関連のサークルです。", "http://www5.kcn.ne.jp/~aloin/"]}, {"names": ["1－CON FUJOKAI", "一根"], "misc": ["Genre: 評論・情報\nName (kana): イッコンフジョウカイ\nProduct: 日本人のだましかた"]}, {"names": ["なっくなっく", "九頭KUZU"], "misc": ["Genre: 評論・情報\nName (kana): ナックナック\nProduct: 危ない妄想"]}, {"names": ["真城の城", "真城悠"], "misc": ["Genre: 評論・情報\nName (kana): マシロノシロ\nProduct: 「女体変化」"]}, {"names": ["Bloody Works", "野分はるな"], "misc": ["Genre: 評論・情報\nName (kana): ブラッディワークス\nProduct: 基礎源文学"]}, {"names": ["や研。", "前川邦生"], "misc": ["Genre: 評論・情報\nName (kana): ヤケン\nProduct: おたくとセクシュアリティ\n本田透や小谷野敦について書くことになりそうです。"]}, {"names": ["虚言会社サンスクリット印刷", "大槻マコト"], "misc": ["Genre: 評論・情報\nName (kana): キョゲンガイシャサンスク\nProduct: This is KAIENTAI－DOJIN"]}, {"names": ["egg－heads", "山手秋葉"], "misc": ["Genre: 評論・情報\nName (kana): エッグヘッズ\nProduct: with．I CG集"]}, {"names": ["東京大学漫画調査班TMR", "D.C."], "misc": ["Genre: 評論・情報\nName (kana): トウキョウダイガクマンカ\nProduct: TMR調査報告\nemail: CBD00093@nifty.com\nあるテーマに沿った漫画作品のレビュー、特集、座談会や長期休みに行われるブックオフツアーの成果などを東京大学の漫画好き達が会誌にまとめて年5回発行しています。", "http://nk.ysnet.org/tmr/index.html"]}, {"names": ["労農ソビエト解放区", "川本師照"], "misc": ["Genre: 評論・情報\nName (kana): ロウノウソビエトカイホウク\nProduct: 朝鮮人民軍協奏団音楽舞踊総合公演"]}, {"names": ["魁！おぼこ塾", "御童魁"], "misc": ["Genre: 評論・情報\nName (kana): サキガケオボコジュク\nProduct: 電彼男"]}, {"names": ["しぇからしか！！", "かわうそ"], "misc": ["Genre: 評論・情報\nName (kana): シェカラシカ\nProduct: 上京物語"]}, {"names": ["ひなげし", "たぬき"], "misc": ["Genre: 評論・情報\nName (kana): ヒナゲシ\nProduct: ひなげし"]}, {"names": ["GAK理学部線香花火研究会", "中谷有吾"], "misc": ["Genre: 評論・情報\nName (kana): ガクシュウインダイガク\nProduct: せんけんいほう"]}, {"names": ["MLながら", "東浜 舞"], "misc": ["Genre: 評論・情報\nName (kana): ムーンライトナガラ\nProduct: 格安旅行評論\nemail: my@nagara.ne.jp\n格安旅行の評論誌"]}, {"names": ["サポートセンター裏路地っく", "HIDE"], "misc": ["Genre: 評論・情報\nName (kana): サポートセンターウラロジ\nProduct: 裏路地っく ～2005年冬モデル～\nemail: hide@internet.ne.jp\nパソコンサポート業界の裏話や、同人活動用自宅サーバ構築方法の紹介など", "http://hide.internet.ne.jp/"]}, {"names": ["隅田金属ぼるじひ社", "文谷数重"], "misc": ["Genre: 評論・情報\nName (kana): スミダキンゾクボルジ\nProduct: 瀛報（ようほう）"]}, {"names": ["OB会", "SAC"], "misc": ["Genre: 評論・情報\nName (kana): オービーカイ\nProduct: コミケットの歩き方"]}, {"names": ["White Knights"], "misc": ["Genre: 評論・情報\nName (kana): ホワイトナイツ\n初参加です。スタッフの目から見た「コミケの歩き方」を紹介。"]}, {"names": ["初心者の皮", "ニンジャ"], "misc": ["Genre: 評論・情報\nName (kana): ショシンシャノカワ\nProduct: コミケット一般参加の歩き方"]}, {"names": ["外禁っぽい", "烏城西"], "misc": ["Genre: 評論・情報\nName (kana): ガイキンッポイ\nProduct: 外禁っぽい"]}, {"names": ["救護室", "石上佳孝"], "misc": ["Genre: 評論・情報\nName (kana): キュウゴシツ\nProduct: 救護室第14号"]}, {"names": ["絶対サポセン黙示録", "FOX－兄貴"], "misc": ["Genre: 評論・情報\nName (kana): ゼッタイサポセンモクシロ\nProduct: 裏絶対サポセン黙示録"]}, {"names": ["秋葉に住む"], "misc": ["Genre: 評論・情報\nName (kana): アキバニスム\nProduct: 秋葉に住む\n「住む」という観点から見た秋葉原電気街（主に千代田区外神田1,3,4丁目）についての本を発行しています。今回発行の「秋葉に住む VOL.03」では秋葉原で暮らすのに必須の生活関連店舗を紹介します。超高層マンションTOKYO TIMES TOWER関連情報、秋葉原再開発の動向、電気街及びその周辺での分譲・仲介・賃貸物件の紹介、等々を予定。毎号ご好評を頂いている？「終電路線図」もアップデート版を掲載のほか、今回は2005年以降に完成の新築賃貸物件特集を掲載します。あなたも秋葉原に住んでみませんか？", "http://sotokanda.org/"]}, {"names": ["暗黒通信団", "シンキロウ"], "misc": ["Genre: 評論・情報\nName (kana): アンコクツウシンダン\nProduct: 精神力学序説"]}, {"names": ["貝のカラ", "しぇる"], "misc": ["Genre: 評論・情報\nName (kana): カイノカラ\nProduct: 石のウラのはなし\n今回は石（主に墓石関係）についての本を作る予定です。また、同時に道のDVDも出す予定となっています。"]}, {"names": ["神聖軍事同盟", "ジン・ジャハナム元帥"], "misc": ["Genre: 評論・情報\nName (kana): シンセイグンジドウメイ\nProduct: 征論"]}, {"names": ["大章堂"], "misc": ["Genre: 評論・情報\nName (kana): ダイショウドウ"]}, {"names": ["おやじタバコの会", "U－N子"], "misc": ["Genre: 評論・情報\nName (kana): オヤジタバコノカイ\nProduct: コミケで10倍笑う方法"]}, {"names": ["こみこみっく", "K1－阿梨"], "misc": ["Genre: 評論・情報\nName (kana): コミコミック\nProduct: こみこみっく"]}, {"names": ["日替わりA定食", "月影暗輝"], "misc": ["Genre: 評論・情報\nName (kana): ヒガワリエーテイショク\nProduct: 剣術流派別辞典 た行"]}, {"names": ["MISSION", "みずき・けい"], "misc": ["Genre: 評論・情報\nName (kana): ミッション\nProduct: いろものジュエリーdigression水晶＆カルセドニー"]}, {"names": ["いただきます", "ふぃぎゅあふぉーむ"], "misc": ["Genre: 評論・情報\nName (kana): イタダキマス\nProduct: うまいもの"]}, {"names": ["すふざん", "SUFUZAN"], "misc": ["Genre: 評論・情報\nName (kana): スフザン\nProduct: よくわからないADSL"]}, {"names": ["革萌同現地闘争本部", "八木あつし"], "misc": ["Genre: 評論・情報\nName (kana): カクモエドウゲンチトウソ\nProduct: 革萌同通信\nemail: yagiatusi@kakumoedou.org\n萌えと共産趣味が融合した擬似的新左翼党派風サークルです。", "http://www.kakumoedou.org/"]}, {"names": ["駒木研究室", "駒木ハヤト"], "misc": ["Genre: 評論・情報\nName (kana): コマギケンキュウシツ\nProduct: 「現代マンガ時評」05年度上半期総集編"]}, {"names": ["そしおかおす編集委員会", "ヨネモン"], "misc": ["Genre: 評論・情報\nName (kana): ソシオカオスヘンシュウイイン\nProduct: そしおかおす"]}, {"names": ["Hellcast秋葉支店", "LIP"], "misc": ["Genre: 評論・情報\nName (kana): ヘルキャストアキバシテン\nProduct: 実緑メイド店"]}, {"names": ["E－CLUB", "えいど"], "misc": ["Genre: 評論・情報\nName (kana): イークラブ\nProduct: J．LEAGUE AHOUDS"]}, {"names": ["クラスメイ党本部", "奥玉まりえる"], "misc": ["Genre: 評論・情報\nName (kana): クラスメイトウホンブ\nProduct: 『諸君、我々はクラスメイトが好きだ』"]}, {"names": ["sawada special", "ぱろひろし"], "misc": ["Genre: 評論・情報\nName (kana): サワダスペシャル\nProduct: 沈黙の新刊"]}, {"names": ["あにだん", "バロン金山"], "misc": ["Genre: 評論・情報\nName (kana): アニダン\nProduct: おたく業界うんちく日記2\nおたく業界の裏話を中心に活動しています。あずまんが関係も扱っています。", "http://www.h4.dion.ne.jp/~baron/"]}, {"names": ["IWTC", "サトウタカマサ"], "misc": ["Genre: 評論・情報\nName (kana): アイダブリュティーシー\nProduct: インタビュー・ウィズ・ザ・クリエイターズ"]}, {"names": ["蜂列車を待ちながら", "てんちょ"], "misc": ["Genre: 評論・情報\nName (kana): ハチレッシャヲマチナガラ\nProduct: MY MADLAX\nemail: muka334@yahoo.co.jp\nアニメ演出家・真下耕一のファンサイト「蜂列車を待ちながら」による真下耕一研究本。評論を中心に展開。", "http://www.geocities.jp/mashimotop/index.htm"]}, {"names": ["思想悩楼", "山本 晋"], "misc": ["Genre: 評論・情報\nName (kana): シソウノウロウ\nProduct: マンガージュマン\nemail: sy1942@yahoo.co.jp\nアニメ・マンガ、及びその周辺状況に対する研究。押井守中心。押井総論他、最後のサークル参加！", "http://shisou.xtr.jp/"]}, {"names": ["imaginary press inc.", "登坂正男"], "misc": ["Genre: 評論・情報\nName (kana): イマジナリープレスインク\nProduct: 抽象企業"]}, {"names": ["野良犬の塒", "都々目さとし"], "misc": ["Genre: 評論・情報\nName (kana): ノライヌノネグラ\nProduct: 犬からの手紙\nemail: webmaster@kyo-kan.net\n押井守とProduction I.Gの情報を扱う。今回は、延び延びになっていた『攻殻機動隊 STAND ALONE COMPLEX』特集。この作品の脚本に参加した、佐藤大氏へのインタヴューを掲載。神山健治監督へのインタヴューも予定しているが、スケジュールの都合により微妙な状態（何とか収録したいが……）。あと、愛知万博 愛・地球博 めざめの方舟のアンケートなどを掲載予定。今回の本が、最後の『犬からの手紙』になるかもしれないので、何とかいい物を作りたい所なんですが。", "http://www.kyo-kan.net/"]}, {"names": ["ま～坊のまったりたいむ", "ま～坊"], "misc": ["Genre: 評論・情報\nName (kana): マーボウノマッタリタイム\nProduct: 声優になってやる！\nemail: kainmaster@hotmail.com\n普段は、駆け出し声優として、日々活動しています！めざせ！一人前の声優!!(サークルとしては初参加です。どうぞ、よろしくお願いします♪)", "http://park16.wakwak.com/~kainmaster/index.html"]}, {"names": ["MNK・WORKS", "草の精霊"], "misc": ["Genre: 評論・情報\nName (kana): エムエヌケーワークス\nProduct: ○学院演劇俳優科のひみつ"]}, {"names": ["幻視球", "bono"], "misc": ["Genre: 評論・情報\nName (kana): ゲンシキュウ\nProduct: ORBIT\nemail: bono@plum.plala.or.jp\nアニメ評論。", "http://bono.chips.jp/"]}, {"names": ["Logical Product", "カバナス星人"], "misc": ["Genre: 評論・情報\nName (kana): ロジカルプロダクト\nProduct: LogicalProduct\nemail: logical-product@snzui.com\nオタク系何でも来いな評論サークル。新刊は今更ながら十年を経たEVAをメインに取り扱います。また、コスプレ系飲食店56店舗を紹介したガイドブック「メイド喫茶ミシュラン第二版」もあります。", "http://www.senzui.com/logical-product"]}, {"names": ["ぴよぴよテクノロジー", "江戸 都"], "misc": ["Genre: 評論・情報\nName (kana): ピヨピヨテクノロジー\nProduct: 高橋留美子の詳しい世界\n高橋先生へのインタビュー、知人が高橋先生について語っている、高橋先生の作品について論評をしている本や雑誌など、高橋先生に関する「二次文献」をデータベース化したものです。", "http://rumic.dojin.com/piyotech/"]}, {"names": ["時計坂通信社", "七尾葉介"], "misc": ["Genre: 評論・情報\nName (kana): トケイザカツウシンシャ\nProduct: 時計坂通信社"]}, {"names": ["王国パワーEX", "ヒト秋"], "misc": ["Genre: 評論・情報\nName (kana): オウコクパワーイーエックス\nProduct: これだ！！！\n料理漫画「ミスター味っ子」に登場する料理の試食レポート本。レシピ付き。"]}, {"names": ["ロイたー共同", "あけのたーかい"], "misc": ["Genre: 評論・情報\nName (kana): ロイターキョウドウ\nProduct: とり扱説明書"]}, {"names": ["ときめきくらぶ"], "misc": ["Genre: 評論・情報\nName (kana): トキメキクラブ"]}, {"names": ["阪系"], "misc": ["Genre: 評論・情報\nName (kana): ハンケイ"]}, {"names": ["Essential Plot", "ESSEN"], "misc": ["Genre: 評論・情報\nName (kana): エッセンシャルプロット\nProduct: 美少女コミック放談"]}, {"names": ["ひやあせSHOP", "エリーズ☆田村"], "misc": ["Genre: 評論・情報\nName (kana): ヒヤアセショップ\nProduct: おたくなカントリー"]}, {"names": ["ロボズキッチン", "岸本炎馬"], "misc": ["Genre: 評論・情報\nName (kana): ロボズキッチン\nProduct: 奥さまランチな日々\nemail: robos_kitchen@yahoo.co.jp\n日常エッセイマンガ。オタク夫婦の日常をかいています。", "http://www5b.biglobe.ne.jp/~emma/"]}, {"names": ["カラオケの艦隊", "本郷ゆき緒"], "misc": ["Genre: 評論・情報\nName (kana): カラオケノカンタイ\nProduct: オタクの遺言状～いつかかならず～"]}, {"names": ["村山通信"], "misc": ["Genre: 評論・情報\nName (kana): ムラヤマツウシン\nProduct: 村山通信"]}, {"names": ["阿素湖素子", "阿素湖素子"], "misc": ["Genre: 評論・情報\nName (kana): アソコソコ\nProduct: インドネシア世界遺産の旅"]}, {"names": ["お天気お姉さん", "青空 まひる"], "misc": ["Genre: 評論・情報\nName (kana): オテンキオネエサン\nProduct: 変質者研究\n働く性風俗女性の体験談本を作っています。", "http://aozoramahiru.hp.infoseek.co.jp/"]}, {"names": ["club SS", "トリノ鳥子"], "misc": ["Genre: 評論・情報\nName (kana): クラブスターシャトル\nProduct: 飲み屋のお作法\nナイトワークの体験談（おもにキャバ・クラブ等飲み屋のこと）"]}, {"names": ["トリッキーにさりげなく", "あさぎこ。"], "misc": ["Genre: 評論・情報\nName (kana): トリッキーニサリゲナク\nProduct: BUNNY BOOK"]}, {"names": ["世間様って何？", "ちさと"], "misc": ["Genre: 評論・情報\nName (kana): セケンサマッテナニ\nProduct: 世間様って何？"]}, {"names": ["minion", "真田博子"], "misc": ["Genre: 評論・情報\nName (kana): ミニオン\nProduct: 癒しの旅 台湾"]}, {"names": ["江戸屋", "江戸美憂"], "misc": ["Genre: 評論・情報\nName (kana): エドヤ\nProduct: フレンド5"]}, {"names": ["安楽病棟", "えせナース"], "misc": ["Genre: 評論・情報\nName (kana): アンラクビョウトウ\nProduct: 安楽病棟⑩"]}, {"names": ["ゲゲボツアー友の会",