names": ["THUNDER SPIRITS", "伊藤しんめい"], "misc": ["Genre: FC(青年)\nName (kana): サンダースピリッツ\nProduct: お茶とビールと北海道"]}, {"names": ["LET’s STAMPEDE", "みなづきまなみ"], "misc": ["Genre: FC(青年)\nName (kana): レッツスタンピード\nProduct: smokin' in the boys room\nemail: lspd@zm.oops.jp\nTRIGUN・ウルフウッド×ミリィ・ウルフウッド×メリル・ウルフウッド×女のコ", "http://lspd.oops.jp"]}, {"names": ["Wheel of Fortune", "山中茉莉花"], "misc": ["Genre: FC(青年)\nName (kana): ウィールオブフォーチューン\nProduct: 夢の轍VIT～旅路～"]}, {"names": ["ゾック神社", "れらしう"], "misc": ["Genre: FC(青年)\nName (kana): ゾックジンジャ\nProduct: 朝霧の巫女事典\nemail: rerasiu@lions.vip.co.jp\n朝霧の巫女に登場する事物を紹介する「朝霧の巫女事典」に加え、エヴァンゲリオンのアスカシンジもの、いわゆるLASを取り扱っています。", "http://webmania.jp/~rerasiu/"]}, {"names": ["八洲コンツェルン", "児玉太郎"], "misc": ["Genre: FC(青年)\nName (kana): ヤシマコンツェルン\nProduct: ちなもにね。"]}, {"names": ["G･U･N･S", "HAL"], "misc": ["Genre: FC(青年)\nName (kana): ガンズ\nProduct: パワー オブ ラブ"]}, {"names": ["四流無法者"], "misc": ["Genre: FC(青年)\nName (kana): ヨンリュウムホウモノ"]}, {"names": ["綾金市消防局", "安東敏也"], "misc": ["Genre: FC(青年)\nName (kana): アヤガネシショウボウキョ\nProduct: とりあえず・・・ぢおぶりのほん"]}, {"names": ["WED", "高山真由美"], "misc": ["Genre: FC(青年)\nName (kana): ウエンズデイ\nProduct: LINK LINK LINK"]}, {"names": ["ペテン師パウロ", "お人好しペテロ"], "misc": ["Genre: FC(青年)\nName (kana): ペテンシパウロ"]}, {"names": ["H2プロジェクト", "鏡原ひろき"], "misc": ["Genre: FC(青年)\nName (kana): エイチツープロジェクト\nProduct: ΛEB ～レヴ～"]}, {"names": ["超人生活", "ほえば蘭"], "misc": ["Genre: FC(青年)\nName (kana): チョウジンセイカツ\nProduct: 超人生活"]}, {"names": ["HEAVY WATER", "綾小路明日菜"], "misc": ["Genre: FC(青年)\nName (kana): ヘヴィウォーター\nProduct: FEANNA’S REPLAYING LIFE"]}, {"names": ["サバれもん味", "芥せい"], "misc": ["Genre: FC(青年)\nName (kana): サバレモンアジ\nProduct: 人類最速伝説"]}, {"names": ["キロポスト", "キロポス子"], "misc": ["Genre: FC(青年)\nName (kana): キロポスト\nProduct: バービヨトレトレバービヨ\n「キリン」（少年画報社）パロディギャグ"]}, {"names": ["日常茶飯事", "cage"], "misc": ["Genre: FC(青年)\nName (kana): ニチジョウサハンジ"]}, {"names": ["Super Nova", "icyjoker"], "misc": ["Genre: FC(青年)\nName (kana): スーパーノヴァ\nProduct: Out of sight\nかしまし"]}, {"names": ["モノクロラ