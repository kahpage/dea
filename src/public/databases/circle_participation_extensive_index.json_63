70"]}, {"names": ["Halozy"], "misc": ["Block: [ A ]\n東方電波ソングアレンジ「物凄いシリーズ」といえばココ！新作出します！！！", "http://halozy.com/", "https://twitter.com/Halozy_official"]}, {"names": ["彩音 〜xi-on〜"], "misc": ["Block: [ A ]\n東方アレンジ楽曲ＣＤ　インスト系　アレンジジャンル多数", "http://xion-music.com/", "https://twitter.com/xion_p"]}, {"names": ["Amateras Records"], "misc": ["Block: [ A ]\n同人音楽サークル Amateras Records", "http://amateras-records.com", "https://twitter.com/amaterasrec"]}, {"names": ["Alstroemeria Records"], "misc": ["Block: [ A ]\nお久しぶりの参加です。冬コミ新作を始め、オリジナルの新作ミニアルバムを頒布いたします。", "http://alst.net", "https://twitter.com/M_Minoshima"]}, {"names": ["幽閉サテライト&幽閉カタルシス"], "misc": ["Block: [ A ]\n東方と艦これなどのボーカルアレンジやっています！", "http://www.yuuhei-satellite.jp/", "https://twitter.com/yuuka_st", "http://www.nicovideo.jp/user/25436798"]}, {"names": ["少女フラクタル"], "misc": ["Block: [ A ]\n東方などのボーカルアレンジを行っています！", "http://shoujo-fractal.jp/", "https://twitter.com/shoujo_fractal", "http://www.nicovideo.jp/user/45163419"]}, {"names": ["IOSYS"], "misc": ["Block: [ A ]\n北海道から来ましたIOSYSです。音ゲー楽曲・オリジナル電波ソング・東方アレンジ・艦これアレンジなどを制作しています。", "http://www.iosysos.com/", "https://twitter.com/IOSYS_OS", "http://www.nicovideo.jp/user/19490382"]}, {"names": ["TatshMusicCircle"], "misc": ["Block: [ A ]\n音楽ゲーム等に楽曲を提供しているTatshの音楽サークルです", "http://yaplog.jp/tatsh_blog/", "https://twitter.com/Tatsh_Shimizu"]}, {"names": ["かめるかめりあ"], "misc": ["Block: [ A ]\n「かめりあ」個人サークルのかめるかめりあです。オリジナル同人CDなどを頒布します。", "http://cametek.jp/", "https://twitter.com/cametek", "http://www.nicovideo.jp/user/425677"]}, {"names": ["djgenki.net"], "misc": ["Block: [ B ]\nDJ Genkiが頑張っているサークルです。やばい新譜出します", "http://djgenki.net", "https://twitter.com/genkianamei"]}, {"names": ["HARDCORE TANO*C"], "misc": ["Block: [ B ]\nハードコアは楽しい", "http://www.tano-c.net/", "https://twitter.com/redalice"]}, {"names": ["オルタナフェイス"], "misc": ["Block: [ B ]\nボーカロイド作品を頒布します。結月ゆかり作品が中心となります。", "http://nejishiki.com", "https://twitter.com/nejishiki0221", "http://www.nicovideo.jp/user/35275687"]}, {"names": ["Mad Pierrot"], "misc": ["Block: [ B ]\n美少女ゲーム・アニメの音楽レーベル「Mad Pierrot」です！今回は青葉りんごさん／橘まおさんのこれでもかーな豪華新譜をお届け！最新情報は公式HP、ツイッターをチェック！", "http://www.madpierrot-label.com/", "https://twitter.com/madpierrotlabel"]}, {"names": ["project lights"], "misc": ["Block: [ B ]\nTVアニメやギャルゲ、乙女ゲー等、日本・中国で音楽提供を行う音楽クリエイター集団。", "http://www.project-lights.jp/", "https://twitter.com/project_lights", "http://www.nicovideo.jp/user/14650268"]}, {"names": ["ささらすぴん"], "misc": ["Block: [ B ]\nボカロ小学生歌愛ユキちゃんは今日もかわいい。VOCALOID「歌愛ユキ」「結月ゆかり」のアンビエント・エレクトロニカ曲を中心としたアルバムCDを頒布します。歌愛ユキコンピ「ユキちゃんの授業参観」もあります。", "https://kgneissr.booth.pm/", "https://twitter.com/kgneissr", "http://www.nicovideo.jp/user/4427080"]}, {"names": ["GYARISUTA!"], "misc": ["Block: [ B ]\nボカロを使用したJAZZっぽい音楽CDなどを頒布します。最近の代表作→ボーカロイドたちが◯◯するだけシリーズ", "http://www.gyari.com/", "https://twitter.com/GYARI_", "http://www.nicovideo.jp/user/1653063"]}, {"names": ["猫大樹"], "misc": ["Block: [ B ]\n男女ハイトーンボイスユニット「猫大樹」！音楽ゲーム「jubeat」シリーズ「REFLEC BEAT」シリーズ「SOUND VOLTEX」に楽曲提供しています！猫体質と新井大樹が送るデジタルサウンド！", "http://www.nekohiroki.com/", "https://twitter.com/p_nekohiroki"]}, {"names": ["Astral Sky vs. 非可逆リズム"], "misc": ["Block: [ B ]\numa vs. モリモリあつしのスプリットアルバムを頒布する予定です。あの曲のロングやあの曲のリミックスを収録した最高の一枚にしたい…と思い悩んでしまった結果夜しか寝れません。よろしくお願いします。", "http://sound.jp/nrr/", "https://twitter.com/ats024", "http://www.nicovideo.jp/user/2505530"]}, {"names": ["NIZI-RINGO"], "misc": ["Block: [ B ]\nginkihaが主宰するサークル「NIZI-RINGO」です．CD出します．よろしくお願いします．", "http://nzrg.jp/", "https://twitter.com/ginkiha"]}, {"names": ["ESTiメイト"], "misc": ["Block: [ B ]\nESTiと友達が日本に来ます。", "http://www.estimate.co.kr", "https://twitter.com/esti_jp"]}, {"names": ["Team Grimoire"], "misc": ["Block: [ B ]\n音ゲーっぽい曲作ります", "https://soundcloud.com/team-grimoire", "https://twitter.com/teamgrimoire", "http://www.nicovideo.jp/user/16602567"]}, {"names": ["山崎組"], "misc": ["Block: [ B ]\n山崎もえ個人サークル。商業発表曲が入った新譜があるよ！", "https://mmtb0524.tumblr.com/", "https://twitter.com/1027_kyn", "http://www.toranoana.jp/mailorder/article/