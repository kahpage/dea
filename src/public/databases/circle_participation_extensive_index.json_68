": ["iro〆mono project"], "misc": ["個人VTuber「警戒ブロオドキャストCHERRY」のサークルです。", "https://irotomonoproject.wixsite.com/website"]}, {"names": ["そるきゃっと"], "misc": ["作曲する猫「ディンガー」と砂糖よりも甘い「無糖しお」とのマリアージュ。筆が早いのに付け込んで納期ギリギリコンビ。", "https://x.com/mutou_shio?s=21&t=VuqGntEO4LfridYAiT0N5g"]}, {"names": ["ècru"], "misc": ["シマナガエナとHmt2によるユニット「ècru」のサークルです。", "https://twitter.com/HAMA_topground"]}, {"names": ["せなのまど"], "misc": ["ボカロP・作曲家「瀬名航（せなわたる）」のサークルです！1996年4月17日生まれ。東京都在住。エレクトロニカ・ポップス・チップチューンの要素を持つ可愛らしく優しいサウンドが持ち味。", "https://www.senawataru.com/"]}, {"names": ["七篠さよ"], "misc": ["七夕の夜、みんなの願いから生まれたVsinger七篠さよ。「明日元気になれ」をテーマに軽快なロックサウンドからポップスまで幅広いジャンルで音楽活動を行っているVtuber。", "https://www.nanashinosayo-website.com/"]}, {"names": ["おじゃこ研究所"], "misc": ["VtuberなのにVtuberっぽくない事をやってるサークルです。", "https://ojaken.com/"]}, {"names": ["Blatantly Emotional Records"], "misc": ["激しいギターや透き通ったボーカルなどを主としたRock支部とシンセサイザーで奏でられる多様な音で心動かすEDM支部が一貫して「エモい」音楽を目指しているサークルです。", "https://www.youtube.com/c/BlatantlyEmotionalRecords"]}, {"names": ["MDK"], "misc": ["ボカロP・シンガーソングライターとして活動中。M3ではオリジナル曲を制作し自ら歌った新譜アルバムを頒布。", "https://twitter.com/kurosawamadoka"]}, {"names": ["Rhythm-Garden Project"], "misc": ["「心に響け」\n 心を揺さぶるエモーショナルな音楽作りを目指す、バーチャルシンガープロジェクトです。\n 様々なテーマ、様々なジャンルの楽曲が集まる、音楽の庭へようこそ。", "https://rhythm-garden.com/"]}, {"names": ["苺咲べりぃ"], "misc": ["いちごの国からやってきた歌うことが大好きなアイドルVtuber苺咲べりぃです！", "https://www.maisakiberry.com/"]}, {"names": ["山田家"], "misc": ["はじめましてっ❣\n たまぷろじぇくと所属、最強最カワVtuberの山田テュテュルだよっ♡\n M3-2025春では初のミニアルバムを発売するよっ❣\n その他グッズ等もあるので遊びに来てねっ♡", "https://lit.link/YamadaTutur"]}, {"names": ["りりあむ屋"], "misc": ["クリエイターVtuber lily-an / りりあむ 初参加します！", "https://x.com/liztora"]}, {"names": ["アラズヨ"], "misc": ["クリエイターグループ「アラズヨ」です。同グループのアーティストである音楽ユニット「NoWorld」のVtuber・NoiRが手掛ける独自の世界観を追求した楽曲をお届けします。", "https://t.co/CDjItPnwRF"]}, {"names": ["海月シェル"], "misc": ["水族館生まれ水族館育ち人魚の女の子「海月シェル」です！\n 作詞・作曲・歌って踊れる音楽系Vtuber/Vsingerです♪癒されて元気になれる歌や音楽をお届けしています！", "https://shell.localinfo.jp/"]}, {"names": ["YUC'e（ゆーしえ）"], "misc": ["シンガーソングライターでありトラックメーカーのYUC'eのサークルです。", "https://x.com/yuce_e"]}, {"names": ["Assertive Records"], "misc": ["AssertiveはサークルとしてM3に初参加！クラシックなUKハードコアアンセムとフレッシュなJ-Coreサウンドの両方からインスピレーションを受ける！", "https://soundcloud.com/assertivef"]}, {"names": ["FLOATING SYNC"], "misc": ["オリジナルCD-R(テクノ、エレクトロ、インダストリアル、インテリジェント…)\n ディレイと歪みを多用した4つ打ちじゃない系テクノ、新作「INSIDE」他、旧作・特価品など販売します！", "https://floatingsync.jpn.org/archives/1681"]}, {"names": ["ADV Records"], "misc": ["美少女ゲームくんたちが音楽を作ります5", "https://twitter.com/RecordsAdv"]}, {"names": ["グレヱト重工＆G.G.P"], "misc": ["ハードコアやテクノを中心としたダンスミュージックを制作しているサークルです。", "https://x.com/GAR3RGEC8N"]}, {"names": ["ALTURA"], "misc": ["「ALTURA」はスペイン産ダンスミュージック\"MAKINA\"のイベント。2012年から国内MAKINAシーンを牽引しており、今回スペインと日本を繋ぐ一歩となるEPのリリースを予定。", "https://www.instagram.com/alturajpn/"]}, {"names": ["hors-d'œuvre"], "misc": ["りんごネギと超蟹化現象のコンビです。初コンピアルバムを出します。", "https://x.com/horsoeuvre?s=21&t=LArb3bc1et0sveUAscY6KA"]}, {"names": ["I'm Here"], "misc": ["EP出すよ", "https://x.com/ykng_music"]}, {"names": ["TERRAFORM MUSIC"], "misc": ["長年ハードコア音楽を作っております。", "https://x.com/mproject"]}, {"names": ["中島アンテナ"], "misc": ["綺麗で聴きやすい Progressive House / Trance / Techno /\n Drum’n’bass などを作ってます。", "https://nakashima-antenna.tumblr.com/"]}, {"names": ["工藤ゼミ"], "misc": ["コンピCD、Vol.15を含めた過去作など。", "https://kudo-seminar.jimdofree.com/"]}, {"names": ["本気でやらないDTM部"], "misc": ["部活の掟：(1)曲を最後まで完成させようとしない。(2)いい曲を作ろうとしない。(3)決して時流に乗らない。(4)間違えてもいい。(5)でもありったけの思いは込めて！！\n レコメンドは熱く。", "https://x.com/honkideyaranai"]}, {"names": ["NQQ records"], "misc": ["NQQ records 1st album Release!! 『blueprints』 第二展示場 1F\n スペース：あ-06b Composer：\n あやとり/ohigeCat/KyoChang/yabashimong Artwork： 紫山四子 先生", "https://linktr.ee/yabashimong"]}, {"names": ["miso-nicomi records"], "misc": ["ピカチュウの黒い部分", "https://www.m3net.jp/attendance/misorec.tumblr.com/about"]}, {"names": ["Glasses Lovers"], "misc": ["オタククラブミュージック", "https://x.com/glovers5635"]}, {"names": ["水煮亜細亜"], "misc": ["レコーディングエンジニア・コレナガタクロウの「水煮井戸」とドラマー諸石和馬の「MASTERJIA」が合体した「水煮亜細亜」！異形エレクトロサウンドにご期待あれ！", "https://open.spotify.com/intl-ja/artist/61OOUXU69duY2mP3IbB3h0?si=-ysODlAxTr6jdCSackWA0g"]}, {"names": ["Asthenosphere Records"], "misc": ["国内外レーベル等からTrance楽曲を発表しているアーティスト、Central\n Divideが主宰を務めるサークルです。主宰による個人制作楽曲等を頒布します。", "https://x.com/wfCD_"]}, {"names": ["熾天録音"], "misc": ["士祐天───。\n 枯淡なる旋律と呻くような独特の歌詞、古から響くかの如し強烈なサウンドで目眩く幻惑の世界を展開し、新しい日本の音楽を追求する令和の鬼才。\n 当アーティストの所属する熾天録音がM3に出展いたします。\n 深遠なる士祐天の世界へ、どうぞお越し下さい。", "https://www.shiyuten.com/"]}, {"names": ["Tsukuba DTM Lab."], "misc": ["今年10周年を迎えた筑波大学の公認DTMサークルです。今イベントでは10周年記念アルバムと、トランスのアルバムを頒布する予定です。公式bandcampで毎月会員による曲をEP形式でリリースしています。", "https://x.com/tsukubadtm?s=21"]}, {"names": ["Oin RECords"], "misc": ["Oin RECordsです。ゆるゆる音楽を作ります！", "https://oin-records.com/"]}, {"names": ["STICKLOVERZ"], "misc": ["YABASUGI CREATOR GROUPです。えへへ", "https://stickloverrecords.bandcamp.com/"]}, {"names": ["sculptured"], "misc": ["\"sculptured\"は、「既存の概念にとらわれない表現」を再解釈/追求/提案する日本発のアーティスト・コレクティブです。", "https://sculptured.bandcamp.com/"]}, {"names": ["そる日和"], "misc": ["EZ2ACの非公式攻略本とかオリジナル楽曲とか", "https://x.com/SOLB_EDVARD"]}, {"names": ["Unitone"], "misc": ["自分たちの好きな音楽を作っています。", "https://unitone.fm/"]}, {"names": ["aranmusic"], "misc": ["aranによる個人音楽サークル。", "http://aranmusic.net/"]}, {"names": ["C-GOD"], "misc": ["音ゲーのカッコよさにファンタジー系の圧倒的世界観を混ぜ込んだ曲を専門に制作している軍団です。", "https://c-godofficialsite-proto.studio.site/"]}, {"names": ["おいでませ、マンダーランド"], "misc": ["貴様らを　マンダーランドに　連れてくぞ　拒否権ないぞ　ドナドナするぞ", "https://x.com/haya_mandara"]}, {"names": ["jeNoth-Tyle"], "misc": ["jeNoth運勢の個人レーベル、HARDCORE\n TECHNO/Trance/EDM/J-Core/音ゲーっぽいの/etc....", "https://lit.link/jenoth"]}, {"names": ["Demolition Freaks"], "misc": ["NibbleParticle運営の同人音楽レーベルです。HARDCORE\n TECHNO/Trance/EDM/J-CORE/etc…", "https://x.com/Demo_Freaks"]}, {"names": ["Crystal Form"], "misc": ["Marsとkari*nのデジタルサウンドユニット。様々な女性ボーカルソングをお届けします！今回もCyber\n Illusionと合同です！！", "https://crystalform.net/"]}, {"names": ["Cyber Illusion"], "misc": ["メロディアスなダンストラックを制作している、トランス好きP'ceによるサークルです。ヴォーカル作品やコアなダンストラックにも乞うご期待。", "https://cyber-illusion.tumblr.com/"]}, {"names": ["酔鍵堂"], "misc": ["海の底より愛をこめて：第２弾", "http://suikendo.blog55.fc2.com/"]}, {"names": ["Audrey Record"], "misc": ["ダンス系音楽を中心としたボーカルソングやインストをリリース。　女性ボーカル、男性ボーカル、Vocaloid楽曲を取り揃えております。", "http://www.adypro.com/"]}, {"names": ["電力発電所"], "misc": ["トラックメイカー、Xibaの作品を取り揃えています。この名義を使用しての楽曲投稿から10年が経ちました。それにふさわしいメモリアルな譜を作ろうと考えています。", "https://xiba200.wixsite.com/xepp"]}, {"names": ["月面終末観測所"], "misc": ["FullMoonによる創作物を扱っています。サークル「月面終末観測所」は2025年の春で5周年！5年分の軌跡を振り返るメモリアル作品を頒布予定です。\n ＊ 【新譜紹介】 ①5周年コンピ『Multiverse Observer』\n 月面終末観測所の設立5周年を記念したコンピレーションアルバム。\n 過去に開催した「フリー音源縛りコンピ」「錯音ジバ・シノコンピ」「英単語コンピ」の3つが混ざり合い、今、鮮やかに甦る！\n ＊ ②怪文書コンピ『ULTIMATE CHAOS BOX』\n 混沌、無秩序、特級呪物──。\n 音楽と音楽以外全部。媒体を問わず集められた「混沌」が1冊の本として爆誕！\n きっと宇宙に1つしかない、前衛的コンピレーション＆アンソロジー。", "https://sites.google.com/view/fullmoon-ruro"]}, {"names": ["K.S.T.Music"], "misc": ["Trance、Hard\n Danceを中心とした楽曲を制作しており、アプリゲーム『原神』のクラブミュージックアレンジのCDを頒布予定です。", "https://www.youtube.com/@Ks-traXKSTMusic/featured"]}, {"names": ["TO-MAX"], "misc": ["滋賀県長浜市で行政書士の傍ら、90’s\n Techno・Rave・Trance・Breakbeatsなどのクラブミュージックをルーツに活動しております。今回は新作を2枚出します！", "https://sound.to-max-gyosho.com/"]}, {"names": ["N3XT Future Records"], "misc": ["未来な音楽サークル　音ゲーチックなダンスミュージックを取り扱っています", "https://n3xt-future-records.github.io/"]}, {"names": ["Restrike"], "misc": ["同人音楽生まれ同人音楽育ち、インターネットの作曲家”KUROI”が主宰する音楽サークル｢Restrike｣。Vtuberやシンガーさんのプロデュース、”最強”のコンピレーションアルバムの制作などを行っています。", "https://kuroisan.booth.pm/"]}, {"names": ["ふわふわレコーズ"], "misc": ["ふわふわなファンコットを頒布しますね。", "https://x.com/FUWARECO"]}, {"names": ["AniManyaoJapan"], "misc": ["アジアダンスミュージックの制作をしています。（インドネシア、中国、ベトナム、フィリピン、マレーシア）", "https://twitter.com/W000_BIRDPLACE"]}, {"names": ["Unison Code"], "misc": ["神奈川工科大学　作曲研究部です", "https://soundcloud.com/unisoncode"]}, {"names": ["東京工芸大学サウンド研究会"], "misc": ["東京工芸大学サウンド研究会です。クラブミュージックや電子音楽を中心に日々DJ、DTMの活動をしています。", "https://twitter.com/kg_DTM?s=20&t=2TtrlDWAFdtLrBD-d1xOVQ"]}, {"names": ["Hello1103"], "misc": ["昨年リリースしたアルバム『Billion\n Balances』とその関連作品を中心に頒布します。", "https://hello1103.com/"]}, {"names": ["tnym_lab"], "misc": ["Tonoyamaが電子音楽をベースにいろいろ作るサークルです。", "https://linktr.ee/tonoyama"]}, {"names": ["MAZ"], "misc": ["サブカル音楽好きが集まってワイワイ音楽活動するサークル", "https://x.com/musik_action_z"]}, {"names": ["Login Records"], "misc": ["ハードコア・ハードスタイルを中心にコンピレーションを制作しているpocotanの個人サークルです。不可逆ハードコアReturnsも扱っております。", "http://pocotan.moe/"]}, {"names": ["Project Azure"], "misc": ["純国産クラブミュージック、国内のアーティストとコラボレーションしたボーカルクラブミュージックを制作しています。今作はLU-I氏とコラボしたボーカルトランス、旧譜のトランス・ハードコア作品もお取り扱いがあります。\n 弊サークルの音楽は、多摩川の水でマスターチェックを行いました。", "http://azupro.info/"]}, {"names": ["Diamond Lead"], "misc": ["ハードコアをメインで制作しております。今回は特別企画としてコンセプトアルバムをリリース予定！", "http://diamondlead.web.fc2.com/"]}, {"names": ["MNKsound"], "misc": ["ハードコアテクノを中心に、オリジナルのクラブサウンドを制作してます。", "http://kalanchoe-design.com/mnksound/"]}, {"names": ["音圧第一"], "misc": ["音圧第一", "https://x.com/Chinatsu_YASAI"]}, {"names": ["しばくでクルー"], "misc": ["毎日仲良く楽しく仕事を頑張りますよろしくお願いいたします", "https://soundcloud.com/shibakude"]}, {"names": ["法政大学宅録同好会"], "misc": ["2016年4月3日より発足。主な活動はPCを用いた作曲(DTM)及びその発信。今回も部員によるコンピレーションアルバムが出ます。", "https://x.com/hoseitakuroku"]}, {"names": ["BE THE FOOL"], "misc": ["クラブミュージック知らない人でもバカになって踊れる、そんな音楽を目指していきます。"]}, {"names": ["SD-Distortion"], "misc": ["クラブで踊れるチップチューン等、ダンスな音楽を中心に制作しているsdhizumiの個人サークルです。", "https://sdhizumi.com/"]}, {"names": ["CDM RECORDS"], "misc": ["korg\n gadgetでchiptune風なスピードコアやハードテクノを作曲し活動しています", "https://kizan518.hatenablog.jp/"]}, {"names": ["Smoothin' Studio"], "misc": ["このサークルは、自由気ままな音屋と絵描きの一次創作メディアミックスサークルです。", "https://smoothinstudio.wixsite.com/home"]}, {"names": ["GraphicEdition"], "misc": ["我々は808を用いた表現を探求します。", "https://x.com/GraphicEdition"]}, {"names": ["元気もりもりティーンズ"], "misc": ["ハンバーガーショップと、クレープ屋さんと、音楽が好きなナウいティーンズが集まってコンピレーションアルバムを制作します。", "https://twitter.com/dj__arashi"]}, {"names": ["東京都市大学　デジタルコンテンツ研究会"], "misc": ["新作CDを頒布します。", "https://tcu-dc.net/"]}, {"names": ["とろんとろんちーず"], "misc": ["Electro / EDM / ColorBass / Drum'n Bass /\n クラブミュージックで色々遊んでます。", "http