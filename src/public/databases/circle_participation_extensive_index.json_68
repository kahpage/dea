ttps://x.com/magialchemy"]}, {"names": ["SC14"], "misc": ["CHIPTUNEオリジナル楽曲アルバムや、ゲームアレンジアルバムを頒布しています♪", "http://sc14.blog.fc2.com/"]}, {"names": ["PROJECT MAGIC CANVAS! × 市ノ宮電音工房"], "misc": ["チップチューン系ピコピコチーム『PROJECT MAGIC\n CANVAS!』(通称:マジキャン)とNintendo 3DS [KORG\n DSN-12]でピコピコ音楽を作る『市ノ宮電音工房\n -A.I.E.S.S.-』の合同出展です！", "https://project-magican.bandcamp.com/"]}, {"names": ["POPiN RECORDS"], "misc": ["chipでpopなmusic。GB/FC/FM音源を中心としたオリジナルのチップチューンを制作しているscytheの個人レーベルです。", "https://scythe-chiptune.com/"]}, {"names": ["七狼組"], "misc": ["一匹狼 新人VTuber 七狼さくや、人生2回目の「M3」参戦です。\n デビュー直後の秋に続き、今回の春も新曲二曲で参加！「Blue\n Position」に続き、同じタッグでデジタルJ-Popの新曲もあります🐺💙", "https://twitter.com/70398_"]}, {"names": ["オトナリダンギ"], "misc": ["YouTubeチャンネル「オトナリダンギ」の月岡彦穂と長利和季がM3に初参加！今日のために作った特別な音源をぜひ聴いてみてください！", "https://www.youtube.com/@otonaridangi"]}, {"names": ["Vtuberオリジナル曲ドラフト会議実行委員会"], "misc": ["Vtuberとコンポーザーを繋ぐオリジナル曲制作企画「Vtuberオリジナル曲ドラフト会議」にて生まれた楽曲がコンピレーションCD化！\n ＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝＝\n イヌガミユキ&タウによる新ユニット『Signallite』\n 記念すべき1st Single - Memorizeを頒布。", "https://www.youtube.com/watch?v=zW4-lkokfwk"]}, {"names": ["Aokiro!"], "misc": ["自身歌唱のフルアルバムを頒布します。渾身のインターネット・ミュージックを聴け！", "https://x.com/haishinblue"]}, {"names": ["名古屋なも"], "misc": ["★M3初参加★個人勢VTuber名古屋なもです！オリジナルソングCDとASMRのシチュエーションCDを頒布予定です♡", "https://www.youtube.com/channel/UCMqNG8e8ptfN6Aky1EgqlCw"]}, {"names": ["HotSandCartel"], "misc": ["我らHotSandCartelと申す者。皆に管弦と影作をやるために日夜働けり。よくば見に来たまへ。待ちたてまつれり。", "https://www.youtube.com/@HSC-Hey"]}, {"names": ["るかるーせんせーしょん"], "misc": ["シャーベットボイスを持つ声優【るかるー】による新譜「ブルーレモネード」コンセプトの女性ボーカル音楽CDを頒布。", "https://soundcloud.com/rukaruu/m3-2025-30bep?si=91bd86e3d8d4486bb9e67fa547e79596&utm_source=clipboard&utm_medium=text&utm_campaign=social_sharing"]}, {"names": ["USAGI Production"], "misc": ["VTuberオリジナル楽曲・映像制作、イベント企画、コンサルティング業務を主に請け負っている事務所です。", "https://virtuareal.net/"]}, {"names": ["サクラリウム"], "misc": ["バーチャルアイドル夕凪みちるです。「あなたに届けるために」音楽活動をしています。新譜コンセプトEP、旧譜EP他頒布予定。", "https://www.youtube.com/@yunagi_michiru"]}, {"names": ["mokz"], "misc": ["VSinger「mokz」のオリジナル楽曲", "https://mokzcat.com/"]}, {"names": ["古川ノブ"], "misc": ["トランス・ハウス等の楽曲、Vtuber古川ノブのグッズ頒布", "https://x.com/furukawa_nob"]}, {"names": ["nitewalk prod."], "misc": ["Soundtracks for the unseen, the unreal, and the\n unforgettable—you. ｜\n \"無い\"世界を構築するインターネット・コレクティブです。", "https://x.com/nitewalkprod"]}, {"names": ["Vtuber事務所3'dPLAYce"], "misc": ["新興Vtuber事務所3’dPLAYceです！　ゆよゆっぺさんを始め有名クリエイターの方々とオリジナル楽曲を制作しております。　是非ご覧ください！", "https://3dplayce.com/"]}, {"names": ["きるぷろ"], "misc": ["今年の歌与はすごいぞ！ゲストもいっぱい参加するCD制作中！", "https://lit.link/utayopome"]}, {"names": ["U・SA・GEAR"], "misc": ["演奏を楽しむ人に向けたスマホアプリを作成しています", "https://u-sa-gear.blogspot.com/"]}, {"names": ["佐々木宏人"], "misc": ["原点に戻ってシンセのインストアルバムを作ってみました。", "https://x.com/hiroto_sasaki"]}, {"names": ["中目黒二丁目病院"], "misc": ["レトロゲーム各種、アイドルマスター(シンデレラガールズ,ミリオンライブ！)などの楽曲アレンジ中心です。テクノ・シンセウェイヴ・Lo-Fi・8bitからメタルまで。WEBサイトよりご試聴いただけます。", "http://www.chu2byo.net/"]}, {"names": ["BPM:Maximum Creations"], "misc": ["765プロから初星学園までのアイドルマスターのアレンジCDを取り揃えております。", "https://bpmmax.com/"]}, {"names": ["Future Link Sound"], "misc": ["UNDERTALE、DELTARUNE、FGO、艦これ\n 等のゲームアレンジCDの他、ボカロアルバムやファンタジーやガンアクションをイメージしたオリジナルアルバムなどを頒布予定です。", "http://flsound.jp/"]}, {"names": ["Circle S&G"], "misc": ["ハードウェアMIDI音源やFM音源によるゲーム（STGとかアクションとか）風インスト楽曲を作ってます！", "https://blog.goo.ne.jp/sandgms"]}, {"names": ["Daisy / Straight"], "misc": ["ジャンルはフロートサイバーデジロック。現実と幻想の境界をSynthesizer\n Vの歌声に乗せてお届けします。今回はオリジナル楽曲ではなくCSゲーム（ポケットモンスター）のボーカルアレンジで参加を予定しております。", "https://x.com/daisy_straight"]}, {"names": ["Nekonesta"], "misc": ["Nekonestaは、リコーダーや小編成室内楽をもとに、心安らぐ音楽をお届けします。情景や物語、心情といったものをテーマに制作しています。なお、今回はアレンジでの出展の予定です！", "https://www.youtube.com/@Nekone_Siesta"]}, {"names": ["ESPITZ MUSIC"], "misc": ["韓国代表同人レーベル・音盤プロバイダーの一つ「ESPITZ\n MUSIC」オリジナル・ブルーアーカイブアレンジ新譜発売予定！", "https://x.com/espitzofficial"]}, {"names": ["ちんもち"], "misc": ["BMSで主に活動しているチームです、各メンバーのCDを頒布予定"]}, {"names": ["technoplanet"], "misc": ["遥か彼方からやってきたエレクトロニックモンスターユニット。作編曲家ハセガワシュンのアルターエゴ。メジャーシーンにはない。でもコアでマニアックでもない。そんな音楽をお届けしたいと思っております。", "http://technopla.net/"]}, {"names": ["ux design"], "misc": ["２回目の参加です！シンセのイカつい音を作ってきました！", "https://x.com/ux_mis"]}, {"names": ["demaescape"], "misc": ["活動20年記念で制作した映像作品まとめ解説冊子を作ります", "https://demaescape.tumblr.com/contact"]}, {"names": ["EigHt"], "misc": ["ゴシックや綺麗な曲が好きで作っています。", "https://twitter.com/EigHtNovel"]}, {"names": ["Phantom Notes"], "misc": ["Phantovel（ファントベル）の個人サークルです。普段はハードコアテクノ系の音ゲー風な曲や、イラストの制作をしています。今回も新譜頒布します！", "https://twitter.com/phantovel2011"]}, {"names": ["Hakoniwa with Atelier"], "misc": ["主宰のあんくらげです！今回は新しい試みとして「はちどり」さんをお迎えすることになりました！「はちどりです！あんくらげさんのお誘いでm3初参戦です！！」", "https://x.com/ankurage"]}, {"names": ["鍵盤をシバいた猫"], "misc": ["かわいいインスト曲を出します、Kawaii Future Bassメインです。", "https://x.com/dj_kiko28"]}, {"names": ["7bridges"], "misc": ["7maiです！　可愛い音ゲーっぽい楽曲中心の新譜を販売する予定です！", "https://soundcloud.com/7mai"]}, {"names": ["天束"], "misc": ["ピアノを中心とした音楽、情景を作るのが得意としています。", "https://x.com/papion_0652551"]}, {"names": ["4O5人 - しおこじん"], "misc": ["IDMやアンビエント等の電子音楽アーティスト。変拍子やポリリズム、メトリックモジュレーションを応用した曲も多い。\n 2022年には365日連続でオリジナル曲を投稿し続け、全曲サブスクで配信リリースするなど多作である。\n M3では、CDに収録できるギリギリまで4O5人の電子音楽を詰め込んだアルバムを会場限定価格で頒布します。", "https://youtube.com/@shiokoshow24"]}, {"names": ["ハイファイ：ローファイ"], "misc": ["音ゲーコアやゲーム音楽を中心に、オリジナル曲・アレンジを制作している個人サークルです。\n イラストの制作も行っています。CDのジャケットに使用しているイラスト(作者明記がないもの)は自作です。", "https://www.core-apple.com/"]}, {"names": ["Die Ellipse"], "misc": ["変拍子ロックを主体としたドラマチックな楽曲を提供します。 SOUND\n VOLTEX 「最果ての勇者にラブソングを」\n 太鼓の達人「キャラメル・ジャンキヰ」など制作。", "https://www.dieellipse.com/"]}, {"names": ["HARCA project"], "misc": ["コンポーザー、譜面制作者、プレイヤーのためのPC向けリズムゲームプラットフォーム『HARCA』の開発projectです。ゲームの試遊の他、収録楽曲のコンピレーションアルバム、その他グッズの頒布を予定しております。", "https://harca.jp/"]}, {"names": ["小夜嵐山"], "misc": ["奥行きのあるコンピレーションを制作しています。", "https://sayoarashiyama.tumblr.com/"]}, {"names": ["Round Table Music Team"], "misc": ["Round Table.....", "https://x.com/t_round_table"]}, {"names": ["Hylen Lab"], "misc": ["Bass Music ComposerのHylenが率いる新サークル\"Hylen Lab”", "https://hylenlab.info/"]}, {"names": ["LuzeriA"], "misc": ["縦連打は人生。テクノミュージックを中心に幅広く取り扱っております。", "https://www.luzeria.net/"]}, {"names": ["蛾喰い"], "misc": ["2000年代初頭のドラマチック、ゴシック、トランス等のジャンルから影響を受けて作られた音楽です。聞き手を地獄に突き落としてしまうような混沌さを纏っています。もし悪魔に蝕まれたいのならぜひぜひ来てください。", "https://twitter.com/mushibamu"]}, {"names": ["HONEYCOME HOUSE"], "misc": ["初参加です。「Hypertrance」というジャンルに特化したコンピを出します！\n あとサークル名間違えて申し込みました！\n HONEYCOMBHOUSEです！本当にすみません！\n 新譜はめちゃくちゃかっこいい曲多いので要チェックでお願いします！！", "https://hncm0001-manifoldluminous.netlify.app/"]}, {"names": ["steμ"], "misc": ["初参加です。ボーカルsiroaをフィーチャーした楽曲中心に、音楽ゲーム楽曲のロングバージョンも収録予定です。ＣＤ限定楽曲としてセルフボーカル曲もあります。", "https://x.com/steMusiCreate"]}, {"names": ["夢想茶館"], "misc": ["Risen(りせん)による個人サークルです。綺麗系・爽やか系UK\n Hardcoreを中心に透明感のある四つ打ちミュージックを作ります。", "https://musousakan.wixsite.com/risen-music"]}, {"names": ["CHUBAY's CHAMBER"], "misc": ["CHUBAYの個人サークルです。3rdアルバムとか出します。", "https://twitter.com/chubay_phys"]}, {"names": ["すぱのばふぇす実行委員会"], "misc": ["新設！！！！！", "https://x.com/SPNVFest2024?t=1fSTRjhOPl38Cr-mCBiqug&s=09"]}, {"names": ["takio's music"], "misc": ["━━━(ﾟ∀ﾟ)━( ﾟ∀)━( 　ﾟ)━(　　)━(ﾟ 　)━(∀ﾟ )━(ﾟ∀ﾟ)━━━", "https://twitter.com/takio872"]}, {"names": ["大前司"], "misc": ["大前司の2枚目のアルバムなどを出します。私はあなたを愛しています。", "https://tsukasa-ohmae.com/"]}, {"names": ["Technological audio Works."], "misc": ["Feel the TECHNO Music.\n テクノとかエレクトロを普段は作っていますが今回はちょっと趣向を変えます。", "https://tawminus50.wixsite.com/cite"]}, {"names": ["KYZ_HOUSING"], "misc": ["House系楽曲を集めたコンピレーション", "https://potofu.me/k4y5kyzhousing"]}, {"names": ["Starry Canyon"], "misc": ["今回は新譜として東方紅魔郷のアレンジコンピレーションアルバムを出す予定です！", "https://x.com/setcanon"]}, {"names": ["AxiaBridge"], "misc": ["当サークル作品（ゲーム・ノベルなど）のコンピレーションアルバムを制作してます！　デジタルJ-POP成分強めです！\n ※M3-2025春特別企画：\n 現在「ヒイロノメザメ」発売記念Xプレゼントキャンペーン開催中です。詳しくは公式サイトか公式Xアカウントをご参照ください。", "https://www.axiabridge.com/"]}, {"names": ["不気味社"], "misc": ["男声合唱によるあらゆる楽曲（特撮曲・アニソン・歌謡曲含）のカバー。全てを男の口から出た音のみで表現。", "http://www.bukimi.com/maal/"]}, {"names": ["ENA studio"], "misc": ["VRChat中心に活動しているピアノ×ボーカルのアニソンデュオ「Enamel」による、アニソン風の楽曲を頒布します！", "https://x.com/muse_energy"]}, {"names": ["Isiulian"], "misc": ["日本人作詞家と中国人作曲家（中国在住）の国境を越えた遠距離二人組ユニットです。\n 神話・童話・宇宙・自然・科学などをモチーフにした独創的で唯一無二の世界観を表現しています。", "https://isiulian.wixsite.com/isiulian"]}, {"names": ["冨塚ドリームランド"], "misc": ["アイカツが好きすぎてアイカツはじめました。カヴァーとオリジナルです。女児活動。", "https://twitter.com/hitsuji_tmtk"]}, {"names": ["Popp!n Blue"], "misc": ["新設！Pop!n Blue！ はじめまして！ニロと申します！\n 合計7曲のオリジナル女性ボーカル曲に加えリミックスもあるジャンルもりもりアルバムです！是非来てねーーーーー！", "https://lit.link/nilo026"]}, {"names": ["美曲倶楽部"], "misc": ["愛する「美味しんぼ」のBGMを自分で演奏できることに気づいてしまった集団。アニメ「美味しんぼ」サントラのカバーCD、同人エッセイを頒布します。", "https://x.com/bikyoku_club"]}, {"names": ["ceylon MUSIC cafe"], "misc": ["今回は特別編！コスプレイヤーが歌う、超！アニソン風オリジナル曲を是非お楽しみください！！", "https://twitter.com/ceylon_music"]}, {"names": ["かなでももこだよ！"], "misc": ["革命機ヴァルヴレイヴED主題歌でお馴染み、かなでももこです！　オリジナル曲、東方ボーカルアレンジなど取り揃えてお待ちしております！", "https://lit.link/kanademomoko"]}, {"names": ["アニジャズラボ"], "misc": ["アニソンやゲームミュージックをハッピーにカバーするジャズサークルです。", "http://anijazz.com/"]}, {"names": ["Triad Fusion"], "misc": ["幅広いジャンルで色々なテーマを決めてオリジナル曲を作曲しているサークルです。今回は作曲家の田淵智也さん、田中秀和さんが作曲・編曲された曲を参考にオリ曲を作成する予定です。", "https://x.com/Triad_Fusion"]}, {"names": ["ニチアサコンピ製作委員会"], "misc": ["「魔法少女や特撮が好きなクリエイターたちによる架空のニチアサ楽曲コンピ」を企画しているサークルです！", "https://x.com/sound_odn"]}, {"names": ["RE:無題02"], "misc": ["MUSIC: Loud&Heavy for you and me", "https://mrmusic10.bandcamp.com/album/bling-128"]}, {"names": ["優莉"], "misc": ["色鮮やかな歌、楽曲が特徴的。今回は青春系バンドをテーマにした楽曲を書き下ろしました。", "http://youtube.com/@yuritsunchaka"]}, {"names": ["MistoriA"], "misc": ["ゴシック&ダークな世界観とテクニカルな8弦ギターを駆使した女性Vo.シネマティックジェントメタルユニット。", "https://mistoriaofficial.wixsite.com/mystoria"]}, {"names": ["Seraph"], "misc": ["貴方の日常をほんの少し彩るダークエッセンスはいかがですか？", "https://www.seraph.jp.net/"]}, {"names": ["霜月便り"], "misc": ["同人音楽のプログレッシヴロック作品紹介・ディスクガイド発行およびCD等委託頒布。他、東方系・MLP・ウマ娘系同人誌頒布。", "https://novemberletter1120.wixsite.com/mysite"]}, {"names": ["アムリタス"], "misc": ["メランコリックな夏をテーマにした歌詞と追憶感あふれるポップなメロディ、\n エレクトリックなロックサウンドとウクレレの融合というアプローチで\n 独自のスタイルを追求する。", "https://amritas.jp/"]}, {"names": ["FREE AS BIRDS"], "misc": ["ロック・メタルバンドです。\n キャッチーでテクニカルでドラマチックな音楽を目指しています。よろしくお願いします。", "https://www.freeasbirds.biz/"]}, {"names": ["RoseraieInterdit"], "misc": ["女性ヴォーカルによる、ゴシックオリジナル楽曲を制作しています。皆様の心に薔薇の棘が絡みますように。", "https://x.com/R_Interdit?t=gpe8vBi8-Kr4WG9BuqWfhQ&s=09"]}, {"names": ["エミルの愛した月夜に第III幻想曲を"], "misc": ["女性Vo、アニソン系メロディ＆重厚バンドサウンド。TVアニメや、音楽ゲームにも提供しています！", "http://www.emiru3.com/"]}, {"names": ["unreal image & 箱々症候軍"], "misc": ["「unreal image」→男性Vo.のパワーメタル。\n 「箱々症候軍」→女性Vo.ゴシックメタル。【Vo:KOKOMI(MISLIAR /\n ex.Asriel)・満希 (Isiulian)・海紅(Seraph)・aym・羽鳥玲、他】\n 【新譜】La Raisond'etre　（10曲）\n 『呪われし少女と悪魔の-真実の愛-を求める物語』女性Vo・ゴシックメタルコンセプトアルバム\n 【準新譜】Tear in Dystopia（B5フルカラー16P） ・イラスト集\n 描きおろし＆これまでリリースした楽曲のキービジュアルより抜粋して収録\n ・物語 コンセプトアルバムの主軸となる物語「狂愛ルクセリア」収録\n ・楽曲 物語の序章「Tear in Dystopia」収録。（DLC）\n 新譜セット（上記2点+ポストカード　全14曲） 「La\n Raisond'etre　MV」「シークレット楽曲」DLコード付", "https://x.com/H_B_ShowKohGun"]}, {"names": ["WILD COLOR RECORDS"], "misc": ["合成音声のメタル系アルバムを取り揃えております！今回サークル10周年のベストアルバムもリリース！女性ヴォーカルを起用したメロディアスで力強いクリーンボイスのデスメタルとデスコアのアルバムもございます！", "https://twitter.com/sukenoji1"]}, {"names": ["SYNC.ART'S"], "misc": ["女性ボーカルメインのオリジナルや東方アレンジ", "https://syncarts.jp/"]}, {"names": ["Phizatto"], "misc": ["自虐的でダーティなミクスチャーロック。オリジナル曲を自分で作って自分で歌う。その男の名はPhizatto(ふぃざっと)。哀と孤立がお友達。", "https://phipunkz.wixsite.com/phizatto"]}, {"names": ["VRAIN"], "misc": ["\"Neo Dramatic Cyber\n Hard\"なるそのサウンドは「サイバーパンク」「スペースシンフォニー」がキーワードとなるドラマチックなハードロックである。伝説の楽曲「銀翼」をついにリリース！", "https://vrain.jp/"]}, {"names": ["schilf."], "misc": ["初めまして、ryo-shunと申します。\n 主にロック、オルタナ、エモ、スクリーモ等を基調とした音楽を作って自分で歌ったり、歌ってもらったりしています。\n 春M3は初参加、よろしくお願いします！", "https://x.com/ryoshun_negi"]}, {"names": ["nannou"], "misc": ["カテゴライズされない独自の世界観を創造し、聴く者を夢と現実の狭間へと誘う。美しく魔術的な旋律を奏でるギターに、時に内省的、時に激情を顕にした透き通った穢れない歌声がのる。", "https://www.instagram.com/nannou_official/"]}, {"names": ["SOUTH OF HEAVEN"], "misc": ["主にラウドロック、メタルのオリジナル楽曲を中心に活動してます。東方project等のアレンジ楽曲も作っております。", "https://s-o-h.booth.pm/"]}, {"names": ["project MIK's Tea"], "misc": ["2023年に始動したクリエイター集団による新プロジェクト！\n 第3弾の今回は純ロックをテーマにしたミニアルバムにゲストを迎えて制作。過去作品を合わせてぜひ手に取っていただけたらと思います。", "https://ichidaiasterisk.wixsite.com/timelapsemiks1st"]}, {"names": ["Acute Strings"], "misc": ["ポストロック、インストロックを主体に活動するAdanのソロバンド", "https://acutestrings.net/"]}, {"names": ["狂奏楽団"], "misc": ["オリジナル、女性ツインヴォーカル、プログレ・ゴシックメタル系バンド音楽。ギターベースドラム生音録音", "https://kyousou-gakudan.com/"]}, {"names": ["Ghost Cries"], "misc": ["女性ボーカルのシンフォニック・デスメタルバンドです。", "https://ghostcriesmail.wixsite.com/ghostcries"]}, {"names": ["asnomi studio"], "misc": ["約2年分の楽曲をまとめた軽快な歌モノギターロックアルバムを頒布します。シンセサイザーV小春六花と夏色花梨も使ってます。", "https://asnomi.com/"]}, {"names": ["the Grail of Sics"], "misc": ["GOTHIC/Symphonicメタルコアバンド the Grail of Sics\n 重々しいメタルコアサウンドと、壮厳なオーケストレーションの楽曲に\n 叙情的な歌が重なり、単なるゴシックの世界には収まらない独自の陰鬱世界へ導いてゆく。", "https://gof6.aremond.net/"]}, {"names": ["ヌンチャクゴリラ"], "misc": ["こじらせ系ギターロックインスト", "https://nungor.bandcamp.com/"]}, {"names": ["Lekphjunokia"], "misc": ["トランスシンセ、四つ打ち、男女ボーカル入りメロディックデスメタル。中の人はDisarmonia\n Mundi, Blood Stain Child, Edge of Sanityなどが好き。", "https://x.com/lekphjunokia?mx=2"]}, {"names": ["distortion clear"], "misc": ["ラウド&ポップなギターサウンドがウリです！", "https://twitter.com/to_dorigt"]}, {"names": ["Pendulum Pandemonium"], "misc": ["4名のコンポーザーによるメタルサークル。メロデスをベースにプログレ、メタルコア、ブラックと多彩なジャンルを取り込んだエクストリームメタルを発信。", "https://ppmetal.tumblr.com/"]}, {"names": ["Trouveres"], "misc": ["剣と魔法と勇者のメロディ。男女ツインVoによる熱く麗しい戦いを貴方に。V系メタルプロジェクトzellosの委託もあります", "https://trtrouveres.wixsite.com/trouveres"]}, {"names": ["SoundstorM"], "misc": ["「重く・激しく・美しく」をコンセプトに歌モノ・インストを問わず楽曲制作しています。音声合成ソフト「SynthesizerV」を用いたシンフォニックメタル、DnB、デジロックを頒布予定です(ポップな作品もございます！)", "https://note.com/stormkamui"]}, {"names": ["INVASION OF SOLITUDE RECORDS"], "misc": ["孤高のヘヴィ・メタル・ウォーリアー\"ロード・メタル\"による独りメタル・プロジェクトのCD販売！メロディック・デス・メタル、デス・メタル、ブラック・メタル系統強めです！", "https://x.com/LORDFUCKINMETAL"]}, {"names": ["-LostFairy-"], "misc": ["異世界「エル・ナ・ディア 」での幻想を「物語」と「楽曲」で表現。\n ゴシック・シンフォニック・ダークメルヘンを主軸とした、バンドサウンドながらも幅広い作風が特徴。Vtuber「フラン・エクレール」もここ。", "https://twitter.com/Noel_lostfairy"]}, {"names": ["楓楽舎"], "misc": ["‪仙台を拠点に活動している音楽サークル「楓楽舎」です！Rock、Pops、アキシブ、デンパ、メタル、造語コーラス等、さまざまなジャンルの曲を作っています。", "http://fugakusha.net/"]}, {"names": ["Poly★Planet"], "misc": ["バンドサウンドの切ない系のロックな楽曲を作っています。", "https://x.com/polyprop16g"]}, {"names": ["R'sFactory"], "misc": ["VOCALOIDやSynthVを用いてメタル・ラウド系の音楽を作ってます。\n 今回のM3では過去作全て持ち込みます\n 新規頒布ははじめましての方も、いつも買ってくださってる方も両方楽しめるように、過去曲のRemix数曲を収録したサンプルCDを無償頒布予定(諸々間に合えばEPくらい出すかも…？🤔)\n 持ってないCDあったら買ってくれると嬉しいです！", "https://www.youtube.com/RsFactory01"]}, {"names": ["Tokyo.MeltiMelt"], "misc": ["Japanese GoSick Visual Metal", "https://meltimelt.tokyo/"]}, {"names": ["int. 音と君と。"], "misc": ["それでも僕は、ロキノンロックが好きなんです。", "https://twitter.com/makorin_bear"]}, {"names": ["Elymusia"], "misc": ["物語音楽やゴシックロックなど"]}, {"names": ["foreteller"], "misc": ["ロックを軸に様々な音楽を融合させた、静と動のあるコンセプト作品を制作しています。", "https://x.com/foretellermusic"]}, {"names": ["mu-ma."], "misc": ["飯能のことを紹介できます。", "https://www.mu-ma.net/"]}, {"names": ["ALICETOPIA"], "misc": ["ダークファンタジーをコンセプトとする注目の若手メロディック・メタルバンド！メロディアスかつキャッチーな楽曲にVo.Minami\n Mariaの唯一無二の歌声をのせたサウンドは聴く者を魅了する！", "https://alicetopia.net/"]}, {"names": ["葉月ゆら"], "misc": ["ゴシック・ダークメルヘン・民族風楽曲を好んで制作しております(´▽｀*)　宜しくお願いします。", "http://hatukiyura.sakura.ne.jp/"]}, {"names": ["TEMPLIME"], "misc": ["おしゃかわポップの音楽ユニットTEMPLIMEです！２年ぶりにM３に出ます！", "https://templi.me/"]}, {"names": ["ナカムラ書房×華力発電所"], "misc": ["テクノ&テクノ&ロック&テクノポップ　本屋と発電所が前代未聞の業務提携、開陳！", "https://nkmrmuku.amebaownd.com/"]}, {"names": ["Suicidal Ideation"], "misc": ["DSBM(デプレッシブブラックメタル)やってます。新規プロジェクトデモを配布します。", "https://suicidalideation.bandcamp.com/album/songs-after-dissipation"]}, {"names": ["もちもちうさぎパレード"], "misc": ["合成音声とうるさいギター。ロックです　たぶん。", "https://x.com/toro4nba"]}, {"names": ["ヨルガタアキラ"], "misc": ["初参加の正統派邦ロッククリエイター、ヨルガタアキラの朝は遅い─────。\n 初参加で彼は何もわかっていない─────。", "https://x.com/long_long_rice?s=21"]}, {"names": ["主謀者翔馬"], "misc": ["演説+音楽を融合させた作品を制作し、頒布します。", "https://x.com/shubousha_shoma"]}, {"names": ["phrilli"], "misc": ["”\n あの頃の感情に帰るような自由な音楽”をコンセプトに、ロック・アニソン・ポップス・パンク・メタルなどのジャンルを取り入れた楽曲を制作しています。", "https://phrilli.com/"]}, {"names": ["貝と蜃気楼"], "misc": ["バーチャルとリアルを接続する、轟音系オルタナティブ・ヘヴィ・ロックバンド。", "https://x.com/clam_and_mirage"]}, {"names": ["梨炭酸（pear soda）"], "misc": ["梨炭酸（pear\n soda）は東京都で結成されたインディーポップバンド。男女ツインボーカルで、ノスタルジーやエモーションを掻き立てるメロディ、情緒的な歌詞、ジャンルに捉われない多彩なアレンジが特長。", "https://x.com/pear_so_da"]}, {"names": ["Lyrical:code"], "misc": ["叙情的音楽プロジェクト。激しく、美しく、切なく、琴線に触れる音楽を。素敵な実力派ヴォーカル達。", "https://www.youtube.com/@code_lyrical"]}, {"names": ["Type-Y.O"], "misc": ["Type-Y.Oのギター弾きDTMerのYOYOです。\n 自作小説をコンセプトにしたフルアルバム「Pygmalion」（SynthesizerV：Maiがメイン）を販売します。\n プログレやメタル、オルタナやポストロックが好きな方は是非手に取ってください。\n ジャケットのイラストは小説のキャラデザも担当しているDakenさんです。\n CD購入特典は小説発表のイラストを使用したポストカードです！\n 旧譜「迷宮季譚」（VOCALOID：GUMI）もよろしく！", "https://www.youtube.com/user/YOYO91q"]}, {"names": ["きらとら家"], "misc": ["重音テトxハードロックなど激しい音楽を作ってます！", "http://twitter.com/@KIRATORA_7035"]}, {"names": ["Sound I’z"], "misc": ["サークル活動10周年！初のフルアルバムをリリース予定でしたが延期し、アルバムに向けた新作EPをリリース！\n また、今回は例大祭in静岡でリリースしたメタル色強めの東方アレンジ新作も持っていきます！\n オリジナルの新作EP、東方アレンジ新作、ぜひ両方とも聴いてもらいたいです。\n そして10周年記念ベスト盤2種もよろしくお願いします！ ◆Sound\n I'zとは ロック系シンガーソングライターai-zの個人サークル。\n サポートを迎えて、打ち込みメインから、生音ギター・ベースの重めなバンドサウンドになりました。", "https://www.sound-aiz.com/"]}, {"names": ["Sea Chicken"], "misc": ["「心の葛藤」と「無意識への気づき」をテーマにしたオルタナティブロック(歌声はきりたん&めろう)です！よろしくお願いします！", "https://twitter.com/SeaChicken26"]}, {"names": ["東京都立大学　TMU作曲サークル"], "misc": ["東京都立大学　TMU作曲サークルです！今年初参加です！メンバーの力作を収録しているアルバムを是非！", "https://x.com/TMU_compose"]}, {"names": ["ごみ箱のひとつまえ"], "misc": ["こんにちはりけいです。\n 性懲りもなくVJ素材を現地で頒布していきます。よろしくね", "https://twitter.com/Re_Re_kei"]}, {"names": ["Artistic Creation"], "misc": ["2回目の参加です。Clear Sea\n 個人による電子音楽レーベルです。クラブミュージック・アルバム第二弾の頒布を予定しております。", "https://artisticcreation.jp/"]}, {"names": ["Sound Create"], "misc": ["公立はこだて未来大学DTMサークルのSound\n Createは音ゲー曲やクラブミュージックを主軸とした作曲活動を行っています。", "https://x.com/soundcreatefun"]}, {"names": ["Neotope"], "misc": ["Dubstepを中心に多様な生態系のベースミュージックを作ります。", "https://www.m3net.jp/attendance/%3C%3E"]}, {"names": ["KASOKUKI:Collective"], "misc": ["M3初登場＆新譜「KIMAGURE POTENTIAL」発売！", "https://koukondaikon.xyz/"]}, {"names": ["mon"], "misc": ["孤独DTM vs リアイベ", "https://tyaxonomy.net/"]}, {"names": ["アトリエ猫柳"], "misc": ["DTMer/愛機：KORG Gadget 3\n synthesizerを用いてinstrumentalを製作しています。", "https://note.com/ne_ko_yanagi/n/nff574e1c51ae?magazine_key=mb69c44268089"]}, {"names": ["JANGA Records"], "misc": ["のんびりナードコア作っています。", "https://x.com/mea598?t=uExhNaoD6E4nNrWUuajvJw&s=09"]}, {"names": ["えびす食堂"], "misc": ["大阪万博2025", "http://www2s.biglobe.ne.jp/~TK-2/main.htm"]}, {"names": ["ピコピコ安全県"], "misc": ["メロディアスなシンセインストテクノポップを作るピコピコ安全県のサークル。ライブ、作詞、作曲、イラストなど幅広く活動中！", "https://pikoan.amebaownd.com/"]}, {"names": ["Cyberspace"], "misc": ["数年前からイベントの存在は認知していましたが、今回がサークル・一般参加を問わずM3初参戦となります。メロディアスさとアグレッシブネスを兼ね備えたHardstyleを発信しています！是非遊びに来てください！", "https://gohardforv.jp/"]}, {"names": ["osetino records"], "misc": ["様々なジャンルの音楽をお届け予定の新興レーベル", "https://x.com/treasurepplanet"]}, {"names": ["chronoize"], "misc": ["Ino(chronoize)による個人サークル", "https://x.com/chronoize"]}, {"names": ["高天原応用通信研究所"], "misc": ["マシンライブやDJ向けのエフェクターモジュールをKORG\n NTS-1用に実装。ハードウェア主体で制作の楽曲とともにお待ちしてます。", "https://twin.tail.net/"]}, {"names": ["Mt.Lagoon"], "misc": ["レトロゲームの曲を中心にアレンジしています。よろしければお立ち寄りください。", "https://twitter.com/MtLagoon"]}, {"names": ["地下室のおもちゃ箱"], "misc": ["CAVE　STGのHR/HMアレンジ／ナナシス　WN4アレンジ／ケツイアレンジです"]}, {"names": ["Y3LLoW H34RT"], "misc": ["バーチャル東京でラップ音楽を作っています。マッチョではなくナードな感じです。ご縁があれば手に取ってみてください。", "https://x.com/v_ttikdm"]}, {"names": ["EGOEND"], "misc": ["今日も正義執行", "https://x.com/4444_Exxxx"]}, {"names": ["seeyou DAYOKA"], "misc": ["見たな？", "https://x.com/seeyou_DAYOKA"]}, {"names": ["ミカビット"], "misc": ["今回は声優の星川愛さん・我修院達也さん(ハウルの動く城/カルシファー役など)歌唱の新曲「燃えるアウラで逢いましょう！」をCD初販売！「舞台」がテーマのごちゃごちゃソング、めちゃんこレアかも…!?", "https://www.youtube.com/@mika_bit1469"]}, {"names": ["BLUE FORCE"], "misc": ["「シン・シンフォニックメタル」を提供するバンドとし、全ての音楽ファン皆さまにアニメ、ゲーム、V系、メタル、J-POP\n etc..を独自で解釈し全メンバーが一丸となって挑戦し続けております。", "https://x.com/BlueForce666"]}, {"names": ["グラスホッパー"], "misc": ["“デジタル時代の手作り感”、素朴な外装と確かな作り込みで勝負する個人サークル。得意分野は主に80年代サウンド。", "http://greengrasshopper.seesaa.net/"]}, {"names": ["FANTASY EYE"], "misc": ["ロックだったりEDMだったりボカロだったり", "https://www.youtube.com/channel/UCYGm35jXZfwlllMTv9bJMHg"]}, {"names": ["にょろにょろ軒"], "misc": ["スリーピースバンドで小春六花(SynthesizerV ) ×\n ロック・J-POPのオリジナルを制作しています。全13曲のアルバム頒布します。", "https://youtu.be/zkFzaVwnOXY?si=TxzFbbnbXYpYSp-o"]}, {"names": ["雨季呂"], "misc": ["浮遊感ロック", "https://x.com/ukiro_sound?s=21"]}, {"names": ["AdanAll"], "misc": ["様々な音楽ジャンルをブレンドした彼らの音楽は、予測不能かつアバンギャルドでPOPなケミストリーを皆さまにお届けするべく、2024年9月都内某所にて新装開店！お客様のご来店を心よりお待ちしております。", "https://x.com/AdanAll_O"]}, {"names": ["Lunatic Assassin"], "misc": ["今年、23周年目になるデジタル(midi)メタルバンドです。オーケストラものも書きます。", "https://sound.jp/lunaticassasin/"]}, {"names": ["アボミネーションインピュリティ"], "misc": ["京都発、ブルータルデスメタルバンド", "https://abominationimpurity666.bandcamp.com/"]}, {"names": ["Tioko"], "misc": ["ティオコ -\n オーストラリア出身、日本在住のソロ・エレクトロニック・アーティスト。作詞・作曲・録音・ミックスまで全てを自身で手がける、独創的なサウンドをお届けします。", "https://linktr.ee/tioko12"]}, {"names": ["Saya"], "misc": ["関東で活動しているギタリストのSayaです。普段は30弦メタルバンドのPARAMENAでギターを弾いています。今回は自身がリリースしたいしソロアルバムを2枚持っていく予定です。", "https://lit.link/saya0808"]}, {"names": ["HRK studio"], "misc": ["プログレとかクラシックのアレンジとか", "http://hrk-studio.site/"]}, {"names": ["Voyage Music"], "misc": ["新譜は、現在開発中のゲーム『イヴと秘密の友達（イヴとイマジナリーフレンド）のオリジナルサウンドトラックを頒布予定です。ゲームサントラですが、音楽作品としてもお楽しみいただけるように制作しています。", "https://www.voyage-music.online/"]}, {"names": ["tamayura"], "misc": ["アンビエント系な楽曲を作っています。", "https://x.com/nx0vp?s=21&t=g0VdmVpRdwkEAHpCu8TMig"]}, {"names": ["星のさとのユスラウメ"], "misc": ["ふわふわなひとときをお届けします。", "https://wakaba-shirasu.info/Hoshinosato_no_yusuraume.html"]}, {"names": ["Hawk Circle"], "misc": ["さわゆき個人サークル、2年半ぶりに参加。今回は少しファンタジー寄りのオリジナル・インスト新作あり！インスト作品やVocaloid作品など旧作あります。気軽にお立ち寄りください。", "http://hawkcircle.blog.fc2.com/"]}, {"names": ["とおでん"], "misc": ["インスト曲、女性Vo.曲など。", "https://x.com/to_den"]}, {"names": ["Sorpico"], "misc": ["ファンタジーで壮大なオーケストラサウンドを追求しています！", "https://x.com/yamachisorpico"]}, {"names": ["Codaly音楽教室"], "misc": ["ソプラノ歌唱による、ドイツ歌曲、日本歌曲、童謡、宗教曲。アカペラ(多重録音)、和楽器アレンジなど。", "https://x.com/codaly3?s=21&t=Q2CESlbhRUVtZQbk3dNSRw"]}, {"names": ["pemusica"], "misc": ["初参加。劇伴好きのオタクです。地方のテレビ番組やCM、映像作品等の劇伴をやらせていただいてます。\n サントラ風ミニアルバム 「桜色、セピア」CD 1枚 300円（予定）", "https://youtu.be/unPdTGiLfuY?si=y0KF1ZQ2BZUAMJ0B"]}, {"names": ["白葉水族館"], "misc": ["BGMメインで活動している個人サークルです！ピアノBGMが好きな方ぜひお立ち寄りください！", "https://x.com/shiroquji"]}, {"names": ["Simple Gift's Music"], "misc": ["祈りをテーマにしたサントラを生み出す、吹奏楽出身の音楽サークルです。新譜はジャズもどきです！", "https://scrapbox.io/simplegifts-music"]}, {"names": ["Ethereal Epic Rage for Arts"], "misc": ["実験的なフィルレコ・ノイズ・テクノ作品を作っています。", "https://www.facebook.com/EtherealEpicRageforArts"]}, {"names": ["あいふぇり保管庫"], "misc": ["ゲームで使う予定のオーケストラ楽曲を頒布しようと思っています。歌モノとかその他は入るか未定です。", "https://x.com/Iferi0103"]}, {"names": ["YNETワイエヌエンタテインメンツ"], "misc": ["東方ProjectのBGMアレンジを収録したアルバムを制作中です。「癒し系サウンド」をテーマにインスト曲などを作ってます！", "https://ynet-news.amebaownd.com/"]}, {"names": ["ばーちゃる墓地"], "misc": ["初参戦です　救済をテーマにしたかわいい曲をお墓からお届けします", "https://x.com/nyaqj"]}, {"names": ["MONOCHROME CANVAS"], "misc": ["シンガーソングライター「宮本彩陽(みやもといろは)」が作詞作曲ボーカルを務めるサークル。シティポップ・R&Bを中心に女性ボーカルのポップミュージック。新譜はアニメ調の仕上がりのアップテンポソング「サーチライト」、ループで癖になるR&B「タイムリープ・ガール」、2024年12月開催の大阪音けっと新譜「Life\n Goes on」の3曲入りシングルです。", "https://irohamiyamoto.booth.pm/"]}, {"names": ["日芸商業音楽研究会"], "misc": ["日本大学藝術学部音楽学科の学生を中心として結成された音楽制作集団です。", "https://x.com/nua_shoon?s=21"]}, {"names": ["Salt Like City"], "misc": ["影響を受けて憧れている好きな音楽を、好きな街の風景みたいに作りました。初出展ですがこれから精力的に活動しようと思っているのでよろしくお願いします！！！"]}, {"names": ["たこわさ茶漬けの音楽酒場"], "misc": ["たこわさ茶漬け、念願の1号店をM3に初出店します！　是非来てください！", "https://x.com/wasatya_n?t=JDNwJnZBTMr1q1jzf_hVoQ&s=09"]}, {"names": ["pirikaWOOLA"], "misc": ["peЯoco.\n による音楽プロジェクト、pirikaWOOLA(ピリカウーラ)です。オリジナルボーカル楽曲CDを頒布いたします。ポップスを基調に多様なジャンルでお届けします。", "https://peroco.wixsite.com/pirika-woola/address"]}, {"names": ["もえぎのしおり"], "misc": ["女性ボーカル、ちゃもの個人サークルです。オリジナルCD頒布をさせていただきます。好きなものを形に自由きままに活動しています。", "https://twitter.com/chamo_gg"]}, {"names": ["LD50"], "misc": ["初参加の個人サークルです。きれいなポップスアルバム！", "https://x.com/LD5049"]}, {"names": ["8時間睡眠"], "misc": ["オリジナル曲を作っています。よろしくお願いします。"]}, {"names": ["TRIFLATS"], "misc": ["心に残るBGMをお届けします。", "https://www.youtube.com/@Nofu"]}, {"names": ["バンド組もうぜ！"], "misc": ["バンドメンバーを募集するために参加させていただきました！もしCD聴いて良いやんってなった人は気軽に連絡してください！！！！", "https://x.com/y_waaaaa?s=21"]}, {"names": ["THE CAMELLS"], "misc": ["都内を中心に活動中のロックバンドです。X(旧Twitter)@THECAMELLS", "https://x.com/THECAMELLS"]}, {"names": ["GlariZ"], "misc": ["アニソン等をドゥームメタル・ドローンメタルアレンジした作品の音源を頒布しているサークルです。", "https://x.com/GlariZ1"]}, {"names": ["IGM 生楽器ゲーム音楽"], "misc": ["個人でゲームの戦闘時に流れているようなロックテイストのBGMを中心に制作しています！\n ギター、ベース、ドラム、ストリングスは生楽器を使用しています。\n 今回初参加ですが是非お立ち寄りください！！！", "https://x.com/IGM_man"]}, {"names": ["享楽屋"], "misc": ["自主音楽レーベル「享楽屋」。　眼鏡仕掛けの四重奏「Cartilage」や、すこやかパンクバンド「しにぞこナイツ」などのCDをリリース。サブスク配信・イベント運営なども行っております。", "https://www.kyorakuya.shop/"]}, {"names": ["スペースNINJA"], "misc": ["厳しい戦いの末、地獄の軍団の魔の手からサイバーシティを救ったスペースNINJA達。しかし安心も束の間、地獄の軍団は遂に全宇宙への侵略を開始した！彼奴等の野望を阻止するため、戦え！スペースNINJA！", "https://spaceninja.bandcamp.com/"]}, {"names": ["PHANTOM"], "misc": ["VRロックバンド「PHANTOM」です！", "https://phantom-web.jp/"]}, {"names": ["StrollZ"], "misc": ["VRChatで活動しているサックスプレイヤーざっくとピアニストしあのによるインストユニットStrollZです", "http://strollz.booth.pm%20https//linkcloud.mu/4207cae0"]}, {"names": ["METALITY UNITED"], "misc": ["メタバース生まれのメタルバンドです！シンフォニックメロディックパワーメタル！！！", "https://metality.band/"]}, {"names": ["503 bad gateway"], "misc": ["熱く燃え滾るグラムメタル/メロディックハードをメインに、みなさまの活動のモチベーションをブチ上げる楽曲をお届けしています！", "https://x.com/503_bad"]}, {"names": ["猫のちゃび"], "misc": ["すみだはなが描く「猫のちゃび」に、田村一哉の音楽を乗せて「ミニアルバム」をお届け", "https://x.com/sumida0hana"]}, {"names": ["CATCH ME YESTERDAY"], "misc": ["制作・録音・編集・映像なんでもDIYロックバンド。SNSフォロワー累計1.7万。2024年アブダビアニメフェス、2023年フィリピンフェス、2022年サウジアラビアフェスに3回出演。2025も海外ツアー予定。", "https://www.facebook.com/catchmeyesterday/"]}, {"names": ["atsusix project"], "misc": ["ギタリスト&コンポーザーatsusix(アツシックス)によるソロプロジェクト。悲哀に満ちたオルタナティブヘビーロック。", "https://www.tunecore.co.jp/artists?id=327232"]}, {"names": ["EVILLEN"], "misc": ["外国人ヴォーカリストを起用したフルアルバムにて活動開始。エピック・モダン\n ヘヴィーロックやシンフォニックメタル、エレクトロなこだわりの\n EVILLEN サウンドを展開。", "https://twitter.com/EvillenOfficial"]}, {"names": ["452番街"], "misc": ["ベースサイボーグMYKという名前で動画活動していた人が歌モノの作品を作ります", "https://x.com/myksunn"]}, {"names": ["チョモランマ学園生徒会"], "misc": ["＜優れた筋肉は世界を統べる――＞筋肉擬人化×美少女をテーマにした架空アニメ「ますらぶっ！」の楽曲CDを頒布いたします。聴けばムキムキ間違いなし！！ぜひお越しください！", "https://muslove-anime.studio.site/"]}, {"names": ["青木工務店"], "misc": ["青木\"syun\"俊明が、色々なアーティストとコラボしていくシリーズ。今回は、一体誰とコラボするのかな", "https://lit.link/TA0321"]}, {"names": ["PINPURI.COM"], "misc": ["渋谷発の音楽レーベル「ピンプリ」は、プリクラをテーマにしたアートワークを特徴とし、新世代のギャルミュージックを創作しています。所属：まーちりん（MAAACHIRIN）、ちいざろっく！", "http://pinpuri.com/"]}, {"names": ["第4代プランクトン"], "misc": ["ぜんぜんわからない　俺たちは雰囲気でDTMをやっている", "https://x.com/daiyondaiplank"]}, {"names": ["御園まひな & Project Rio Salado"], "misc": ["ニコニコ、YouTubeで歌ったり、作曲している御園まひなと、YouTubeにオリジナル曲をアップしているProject\n Rio\n Saladoの合同出展です。ポップで少しダークな世界観のオリジナル曲を作っています。", "https://x.com/PjtRioSalado"]}, {"names": ["にこごり"], "misc": ["多ジャンルのコンピレーションアルバムを頒布予定です。全作品に重たい感情が乗っている予定です。"]}, {"names": ["Pollaid"], "misc": ["女性ボーカルのアニソンは音域高くて歌うの大変じゃないですか？ちょうどいい曲があります。", "https://polopolopollaid.wixsite.com/website"]}, {"names": ["Studio Shoebill"], "misc": ["M3出展2回目です、今回はSynthsizer\n VのPOPYちゃんと一緒にいろんな方や音楽に出会えることを楽しみにしてます！", "https://x.com/3TA_modoki"]}, {"names": ["buchi"], "misc": ["石川県金沢市でシティポップ系のボカロ曲作ってま〜す", "https://x.com/dmagmizo"]}, {"names": ["Kei Morimoto"], "misc": ["Future Bassやエレクトロポップ系の楽曲をメインに発表しています！", "https://youtube.com/@keimorimoto_music"]}, {"names": ["広瀬プロモーション"], "misc": ["初参加！大正ロマンな執事喫茶のボイスドラマを頒布します！"]}, {"names": ["追求型モノ語リ劇場【Lyco】"], "misc": ["現役シナリオライター2名による、本格派ボイスドラマ制作サークルです。記念すべき1st作品では、あなたを和風ポストアポカリプス世界へと誘います――。", "https://x.com/LycoStory24"]}, {"names": ["まるみふぁくとりぃ"], "misc": ["『働く青年』を建前におじさんだらけのボイスドラマ作ってます。基本コメディ。ブロマンスにうぶ毛が生えた程度のBLも有ります。", "https://marumifactory.com/"]}, {"names": ["soba"], "misc": ["64パッドで遊べる、新しいシンセ体験。\n ちょっと変わった演奏スタイルを体感してください!", "https://x.com/orivertaisho"]}, {"names": ["作田恒星"], "misc": ["UTAUなどの広義ボカロでポップスを作ってます．発表済み曲を収録したアルバムを頒布します．", "https://x.com/sakuta_kousei"]}, {"names": ["せきうさてしぐさ"], "misc": ["音楽的同位体『星界』ちゃんのラップです。韻がタイトです。", "https://x.com/SekiwanRabbit"]}, {"names": ["SENONLTS"], "misc": ["ボカロCDを数種類用意しています。（ミク・ラピス・IA）"]}, {"names": ["おけら"], "misc": ["最近5年間の活動の集大成となるアルバムを販売します！\n 珠玉の歌モノ10曲とインスト2曲を収録！ ジャンル・・・Irish,\n rock'n'roll, AOR, mazurka, calypso, Eurobeat, hillbilly,\n 00sJpop, pianorock 【おけらプロフィール】\n 東京都在住の作曲家、作詞家、編曲家、歌手、詩人、ギタリスト、ベーシスト、キーボーディスト、パーカッショニスト、ウクレレ奏者、篠笛奏者、ミックスエンジニア、マスタリングエンジニア、YouTuber、ツイキャスLiver、音楽ジャーナリスト、アニメ評論家、環境保護活動家。\n 様々な音楽ジャンルを研究しつつ、ネット上に自作曲を発表している。", "https://www.m3net.jp/attendance/%3C%3E"]}, {"names": ["ばにらくらぶ"], "misc": ["アイスはバニラが最強にして至高", "https://x.com/koara_DTM"]}, {"names": ["スノードーム"], "misc": ["夏っぽい歌！", "https://ci-en.dlsite.com/creator/4205"]}, {"names": ["sawend"], "misc": ["今年はGUMI（Synthesizer\n V）で覚醒をテーマにしたミニアルバムを頒布します。", "https://www.asahi-net.or.jp/~ep7s-tnk/"]}, {"names": ["FREES"], "misc": ["静岡県浜松市を拠点に活動している創作活動サークルです。前回に引き続き、Synthesizer\n Vによるロック・ミュージックをお届けします。", "https://frees.jp/freesrecords/"]}, {"names": ["FREE AS A CAT"], "misc": ["シンセ多め系ポップ作ってます！", "https://x.com/L_uke_Janus"]}, {"names": ["StarlessTrilogy"], "misc": ["初参加。synthesizer\n vでロックを中心とした楽曲を頒布予定です。普段は東方アレンジでHRをやってます。", "https://www.starlesstrilogy.com/"]}, {"names": ["あしたがんばる"], "misc": ["きっとがんばる", "https://x.com/ashita_music"]}, {"names": ["アンサツモモンガ"], "misc": ["シューゲイザー×マスロック×プラスαなギターロックをつくっています。", "https://answertothemomonga.tumblr.com/"]}, {"names": ["ARK Sound Lab"], "misc": ["勝利の女神NIKKEのアレンジサークルです！\n 第1弾コンピレーション「Rebuild Ark Vol.1」リリース！", "https://soundcloud.com/ark-sound-lab"]}, {"names": ["Hive Six Records"], "misc": ["声優事務所ハイブシックスの音楽レーベル、「Hive Six\n Records」です！新人声優がPCゲームのタイアップの歌唱を担当し、今回は新譜のアルバムを出す予定をしております！", "https://records.hive-six.com/"]}, {"names": ["趣味工房にんじんわいん"], "misc": ["版権フリーのゲーム製作用音楽を制作しています。主にオーケストラ系です。", "https://hacarrotwine.wixsite.com/carrotwine"]}, {"names": ["きなくるみ"], "misc": ["サウンドクリエータ籾山紗希がで手掛けたPCゲーム内のサウンドトラック\n 販売します♪", "https://kinakurumi.catfood.jp/"]}, {"names": ["SCATTY TONE"], "misc": ["ゲーム戦闘曲風のメタル・ロックインストをメインにやってます！", "https://scattytone01.stars.ne.jp/"]}, {"names": ["46-POP"], "misc": ["美少女ゲームをテーマにした1st mini AlbumをRelease！\n 90年代から2000年代を彷彿とさせる至極の楽曲\n ボイスドラマと連動しているので合わせてお楽しみください🌟\n 旧譜も少部数もっていきます。 ・『SAUNAround。』2nd\n Single＠まるっとサウナをテーマにしたCD ・『Identity』1st\n Single＠マグロが好き過ぎて作った曲といい感じの2曲が入ったCD", "https://lit.link/Cilopop"]}, {"names": ["Yellow Squadron"], "misc": ["艦これBGMをエレキギター主体のインストアレンジ。ヘヴィメタルを中心にサーフ、カントリーなども", "https://www.yellow-sq.com/"]}, {"names": ["Melody spinners"], "misc": ["9TailしっぽとKEIメインで毎回ゲストを呼んでコンピアルバムを作っています！今回もM3にて先行発売します！春はEPIC系秋はデジタル系をリリースします！", "https://9tailscience.booth.pm/"]}, {"names": ["kanmi"], "misc": ["バリエーション豊かなアレンジ、楽器演奏でお届けするブルーアーカイブジャズアレンジアルバム第3弾！", "https://www.youtube.com/channel/UC7kNq_ibdCiVAfQZyLqatVw"]}, {"names": ["My Better Works"], "misc": ["Acoustic,Electro,and Scapes", "https://x.com/eri_mbw"]}, {"names": ["toyKasket"], "misc": ["ロック、クラブ系、民族系...何でもアリのごちゃ混ぜサークル「toyKasket」です。今回は、MMO-RPG風のコンピアルバムで参加予定です。\n 久しぶりの方も、初めましての方も是非お越しください。", "https://toykasket.net/"]}, {"names": ["KaguraLea"], "misc": ["ブルーアーカイブのマルチジャンルアレンジCDとオリジナルアルバムCDを頒布します。", "https://x.com/KAGURA_LEA"]}, {"names": ["蝶々結び"], "misc": ["男女デュオ、女性ボーカル、架空言語＆造語多重コーラスなど。民族調・ファンタジー・物語楽曲を主に制作しています。新譜は宝石や鉱物をモチーフにした幻想・造語コーラス楽曲集です！", "https://nanami615.wixsite.com/nanamip"]}, {"names": ["u..."], "misc": ["新譜あります。現在制作中のノベルゲーム「九尾は誰に恋をする」のサウンドトラックと、コンセプトを決めずに作った楽曲の詰め合わせを頒布してます。", "https://utakatadou.blogspot.com/"]}, {"names": ["のねさうんど"], "misc": ["\"星音せのん\"の音楽活動個人サークルです。オーケストラ系のBGMやSynthesizerVを使ったボーカル曲を書いてます。", "https://nn-sound.com/"]}, {"names": ["Pitohui Records"], "misc": ["毒可愛いトイトロニカを作ってます。", "http://pitohuirecords.com/"]}, {"names": ["Aquamaria"], "misc": ["ファンタジー・民族調の要素と、生楽器系サウンドを取り入れたポップスを制作しています。世界観を感じられる、アコースティックで透明感ある楽曲を目指しています。歌曲・インスト曲を収録した新譜ミニアルバムを頒布します！", "https://aquamaria.info/"]}, {"names": ["歌う窓辺"], "misc": ["りくりが歌っています。", "https://melltiki.wixsite.com/utaumadobe"]}, {"names": ["Lunaphia"], "misc": ["M3初参加&初オリジナル曲リリース！\n 同人声優・ボーカルの瀬戸ユトギによる個人サークルです。\n 1stEP「祈り、かつての光芒」\n 銀の光が照らす道の先へ。この歌と共に。 ꧁—————————————꧂\n 静寂と寂寥に身を委ねる今。 甘い幸福な夢に溺れた過去。\n 悲しみ先にある夜明けへ進む未来。\n 時間を辿り紡ぐ、悲しくもあたたかな音楽をあなたへ。\n ꧁—————————————꧂", "https://x.com/Yutogi_kataru"]}, {"names": ["Yasu"], "misc": ["クラシックギター1本で奏でるブラジル音楽ベースのオリジナルインスト曲です。", "http://yasunarinishio.net/biography/"]}, {"names": ["単簧堂"], "misc": ["M-3初参加になります。ファンタジー小説風歌もの楽曲です。各曲で繋がる一つの物語をお楽しみください。", "https://x.com/natsu640577102"]}, {"names": ["Flowlight Music"], "misc": ["架空ファンタジーRPGサントラついに完結！Flowlight作編曲のオーケストラ、民族音楽曲を中心に、さまざまなアレンジの楽曲を収録予定！", "https://flowlight-music.com/"]}, {"names": ["MASAToooN!"], "misc": ["8弦ギター１本で『音の魔法の旅』を奏でるモダンソロギタリストMASAToooN!が3rd\n EPをM3会場限定で先行販売します。ぜひブースにお立ち寄りください。", "https://www.masatooon.com/"]}, {"names": ["純米大吟醸"], "misc": ["お酒好きが音楽作ってます。インストメインでジャズ・フュージョン・トランス・ハウス多め。", "http://blog.livedoor.jp/sio2to-daiginjou/"]}, {"names": ["GrivR."], "misc": ["GrivR.(ぐらいばー)と申します。 よろしくお願いします。", "https://x.com/grivrrrr"]}, {"names": ["幻想の欠片"], "misc": ["ファンタジーな作品を出します。", "https://x.com/MESA_RAZORBACK"]}, {"names": ["el ma Riu"], "misc": ["一人で創作ファンタジー音楽物語を制作♪\n 民族調・幻想音楽・架空言語・多重コーラス・ゲームサウンド系です。\n 物語や世界観を大切にしています。企画の主催なども。", "https://el-ma-riu.com/"]}, {"names": ["Imaginary Perception"], "misc": ["ピアノ・インスト・プロジェクトです。\n メロディと音色の美しさや、変拍子によるプログレッシヴな緊張感のあるリズムの楽曲がメインです。\n 透明感のある音が好きな方は是非聴いてみてください。", "https://note.com/i_perception/m/mf280a7758ace"]}, {"names": ["DIMEND"], "misc": ["哀愁漂うオリジナル曲をクラシックギター1本で奏でます！", "https://x.com/DimendMetal"]}, {"names": ["あるみかんのうえにあるみかん。"], "misc": ["オレンジ色のサークルスペースで、オレンジ色でハイテンションなひらのみふみがやっている個人サークルです。作品は超ローテンションです。", "http://hirano323.sakura.ne.jp/"]}, {"names": ["Radacina"], "misc": ["BGM素材集を作成・配布のほか、オペラ作品をモチーフにした魔女×学園×ファンタジー音楽物語などを企画しています。", "https://watofujisaki.wixsite.com/watosmusic"]}, {"names": ["Lazward"], "misc": ["民族調・ファンタジー物語音楽アルバムメインのサークルです。気になる１枚があれば是非！", "https://lazward.mints.ne.jp/"]}, {"names": ["Leviathan"], "misc": ["VRChatでソロギターを弾いています！海が好きです！", "https://lit.link/Revias"]}, {"names": ["づ"], "misc": ["ピアノを中心とした、物語性があるようなないような切なくて優しい音楽を作っています。\n ■新譜「星々の冒険譚」 特別な魔法使いは、ありふれた凡人に。\n 魔法に満ちていた世界は、科学で説明できる世界に。\n 変わりゆく「冒険の旅」を描く、づの8thCD。\n 【ボーカル3曲＋インスト2曲】 1.指先の一番星（Vocal：あひる）\n 2.いつか、魔法使いは（Instrumental） 3.霞む星影（Vocal：ケィニ）\n 4.忘れ去られた魔法（Instrumental）\n 5.いつもの星空（Vocal：花摘藍）", "https://www.du-music.work/"]}, {"names": ["STUDIO AGASHA"], "misc": ["“何処かにありそうな「架空ゲーム・アニメ」サントラ集”ピアノから民族楽器までバラエティー豊富な楽器を使用し多彩な世界観を表現するサウンド制作スタジオです。", "https://studio-agasha.com/"]}, {"names": ["Abandoned Antique Moon Faktoria"], "misc": ["いつも通りいろいろな音楽やります。", "https://twitter.com/yagokoro_8556"]}, {"names": ["Tynwald music"], "misc": ["アコースティック楽器を用いた楽曲を得意としていて、ポップスの中に民族音楽やオーケストラを取り入れた音楽を制作しています。", "https://tynwald.jp/"]}, {"names": ["LOLISTYLE GABBERS"], "misc": ["次元跳躍型高速爆音ユニットLOLISTYLE GABBERSです。", "https://www.m3net.jp/attendance/loligabba.com"]}, {"names": ["LYRICFLASK"], "misc": ["シンガー・棗いつきの個人サークルです。オリジナル小説をベースにしたアルバムを制作しています。", "https://itsukinatsume.com/"]}, {"names": ["非可逆リズム"], "misc": ["モリモリあつしが主宰する同人音楽サークルです。主にオリジナル楽曲や東方アレンジのCD制作・楽曲配信を行っています。HNが生ごみすぎてサークル名が全然浸透しないのが悩みです。", "https://ats024.com/"]}, {"names": ["AXTORM"], "misc": ["重なる、奏でる、混ざり合う ーー。MASH VP!\n Re:VISIONオリジナルサウンドトラック第二弾頒布予定！", "https://www.axtormjapan.com/"]}, {"names": ["Next Reflection"], "misc": ["nora2rの個人サークルです。ソロアルバムやグッズを頒布予定です。", "http://nextreflection.net/"]}, {"names": ["Tanchiky.com"], "misc": ["Tanchikyの個人サークルでーす！！！オリジナル音楽出しまーす！！", "https://tanchiky.com/"]}, {"names": ["ただただだいず"], "misc": ["だだだいずががんばって音ゲー曲を作るサークルです", "https://x.com/DICE__game"]}, {"names": ["アルマが遺した金枝篇"], "misc": ["【文庫本を読み解くような世界観】\n violinからdrumまで生音を中心として、ゴシック、民謡、讃美歌、オーケストラなど広く奏でます。\n l l l 【落涙】-それでも綴る、生きる事の美しさ-\n 📔1st-letter-[blue tiara]feat.nayuta📖\n ━緻密な光彩画、文学的な詩、祈りのような朗読━\n これらが煌めく旋律で表現された、【美麗世界】\n 金の箔押しが彩る、豪華デジトレイ仕様。\n シンフォニカルなリリックを紡ぐ。", "https://www.melonbooks.co.jp/detail/detail.php?product_id=2895361"]}, {"names": ["Ariabl'eyeS"], "misc": ["［耽美幻想シンフォニア］をコンセプトに、様々な「蒼」の世界を切ない物語とメロディアスな楽曲で表現しています。", "http://ariableyes.com/"]}, {"names": ["Symholic with こまつりな"], "misc": ["シンフォニック系物語音楽サークル『Symholic』となごみ系ボーカリスト『こまつりな』の合同スペースです。新譜リリース予定です。", "https://www.xorsizer.com/"]}, {"names": ["FATE GEAR"], "misc": ["女性クリーン＆女性デスVo.ゴシック、シンフォニックメタル。今年で10周年！\n FATE GEAR M3春2025 新譜「Lady Devil」\n 過去にTVアニメに提供した曲のセルフカバー作品！ 1.煉獄のグロリア\n feat.KOKOMI(ex. Asriel, MISLIAR) 2.MEGABULLETS (Japanese ver.)\n feat.橋村姫 3.煉獄のグロリア Symphonic ver.\n ジャケットイラスト：リブユウキ(ICDD)", "https://fategear.jp/?p=4139"]}, {"names": ["John Harmony's Garden"], "misc": ["作曲家・和田貴史のソロプロジェクトJohn Harmony's\n Garden。歌ものポップスとしての和田貴史を是非聴いてください。", "https://www.tunecore.co.jp/artists/John-Harmony's-Garden"]}, {"names": ["Beagle Kick"], "misc": ["プロによる生演奏でフュージョンなどを制作。音質にとことんこだわるハイレゾ音楽制作ユニット！M3ではCD版を先行頒布。", "https://beaglekick.com/"]}, {"names": ["Hagali"], "misc": ["情景の見える音楽を。HagaliはRaiによる作曲活動名義です。民族音楽やクラシックなどのテイストを取り入れた、サウンドトラック風楽曲を多く作ります。Hagallから改名しました。", "https://hagall.info/"]}, {"names": ["あちらのおきゃくさま"], "misc": ["漫画家やた郎による民族ダークファンタジー『砂塵の詩』を表した漫画つきアートブックと、連動した音楽集。", "https://x.com/ytaoh"]}, {"names": ["Pastel Tone Music"], "misc": ["ボーカル＆作編曲などで活動中の、ruha個人サークル｡\n 民族調・多重コーラス・架空言語を用いた、ファンタジー系世界観の作品をメインに制作しております。新譜として、活動10周年記念ベストアルバムを頒布予定。", "https://pasteltone-music.booth.pm/"]}, {"names": ["語部＆Lily"], "misc": ["絵本の世界を歌で紡ぐ【語部】とあなたの世界を彩る歌を届ける【Lily】2人のピアノ弾き語りｼﾝｶﾞｰｿﾝｸﾞﾗｲﾀｰが出店!この世界観を感じて欲しい。ご来店お待ちしております!", "https://www.tee-up.jp/lily"]}, {"names": ["メガミノウタゲ"], "misc": ["higma、Nor、Hylen、打打だいず、picco、ァネイロ、shikisai等、人気アーティストが多数楽曲に参加するコラボソングプロジェクトです", "https://megamirec.com/"]}, {"names": ["Room97"], "misc": ["インターネット音楽室907号", "https://lit.link/room97"]}, {"names": ["Feel My Hearts"], "misc": ["アップテンポなpopsからシリアスなバラードまでバラエティー豊かな楽曲を、爽やかなボーカルと熱いギターで送ります。", "https://x.com/kamuiandzoukun"]}, {"names": ["カツミヨウ"], "misc": ["作編曲家、ギタリストカツミ\n ヨウのロックでブルージー、そしてメロディアスな世界をお届けします。", "https://x.com/katsumi_0912"]}, {"names": ["Limica"], "misc": ["Limicaはワシが育てた", "https://www.m3net.jp/attendance/Limited_cast"]}, {"names": ["Tears Fall Spills"], "misc": ["メタルコア、エモ、スクリーモのジャンルをメインに4人のコンポーザーによるコンピレーションアルバムを作成しています。", "https://ameblo.jp/tearsfallspills/"]}, {"names": ["中村さんそ"], "misc": ["可愛くてpopな音楽を作ってます。", "https://twitter.com/sanso_o3"]}, {"names": ["Generation Z"], "misc": ["Z世代のアーティスト。主にgaburyu、nyankobrq & yaca\n などのメンツのサークルです。", "https://twitter.com/GeneZ_sedai"]}, {"names": ["Rigel Theatre"], "misc": ["天使, 妖精, 星をテーマにした民族音楽系の同人音楽座です。Nordic\n Folk, Celtic, Pagan Folkを作ります。", "https://rigeltheatre.com/"]}, {"names": ["冬月みぃな"], "misc": ["『開運！なんでも鑑定団』エンディングテーマ歌唱、USEN全国包装などで活躍中。今回、ケルト民族調の２曲の新曲を発表します。", "https://m3iina.info/"]}, {"names": ["金管処 さーし！"], "misc": ["金管楽器のもろもろを広めるために馳せ参じました。金管楽器の形や音色などのバリエーションの広さや面白さを伝えられたらなあと思います。", "https://x.com/Koh_compose"]}, {"names": ["outré"], "misc": ["outréは、自由で創造的な創作と表現のためのリゾーム的組織です。〔この集団は混沌に見出す秩序にして沈黙に響く叫びです。輪郭は静かに交わり、解け、また新たな｜形／《造形思考》／で融け合います。〕", "https://note.com/shiro_white1111/n/n50261100318d"]}, {"names": ["stilka"], "misc": ["オーケストラ・ロックを軸としたクラシカルクロスオーヴァーによるオリジナルの物語音楽を制作しています。", "https://twitter.com/stil_ka"]}, {"names": ["houyhnhnm."], "misc": ["ファンタジー風インスト音楽。旅するような曲が多いです。", "https://x.com/aim_hynm"]}, {"names": ["涓滴會"], "misc": ["本格的な物語音楽を主戦場とするサークルです、興味のある方は是非遊びに来てくださいね", "https://x.com/kentekikai?t=HpjUwNV6np5jo8VxIgMI7w&s=09"]}, {"names": ["Lilyane"], "misc": ["＊春新譜あり　瑞々しい果実の想いは、甘い春を彩って。＊　民族音楽×Lilyane。\n ファンタジー×メルヘン、女性ボーカルデュエットを添えて。", "https://www.youtube.com/@lilyane-music"]}, {"names": ["帝国音楽堂＆日本共産堂"], "misc": ["軍歌・革命歌・鉄道音楽アレンジCDを頒布します。新譜あります！", "https://x.com/imperial_music_"]}, {"names": ["小笠原幸子"], "misc": ["ジャズピアニスト,作曲家＜Jazz Pianist,Composer,jazz\n live,recording,host＞東京在住\n 2021年〜筑西JAZZ講師&定期240名規模コンサート,TVCM曲", "https://fugelmusik.main.jp/"]}, {"names": ["いたずら書きのメロディ"], "misc": ["フルート×ピアノのポップインストユニットです。オリジナル曲のミニアルバムを頒布します！", "https://www.youtube.com/@itazuragakino"]}, {"names": ["ゆなづきゆかり"], "misc": ["ゆなさんとくにいさんがドラクエみたいな雰囲気の曲を歌ったりするなにかを出そうと思ってるんですよ！ルイーダの酒場でたまにかかったりする感じの曲ってことでねえ。\n スライム型コースターと、コースターに貼り付けて遊べるシールがついてますよ。\n 名札ケースに入れて頒布ですよ。首から下げるとかわいいですよ。\n 今回はオレンジですよー。\n 試聴は前回の2曲目（街イメージ）と1曲目（カジノイメージ）の1番のところですよー。", "https://tokkuri.syrena.net/luida2/"]}, {"names": ["Elixir Nocturne"], "misc": ["メルヘンゴシック・ラテンジャズを主軸に世界観の観える音楽を制作しております。\n 今回は民族調×エレクトロニカによる幻想電子音楽の予定です。", "https://malva.work/"]}, {"names": ["OriverMusic"], "misc": ["ケルトの笛(ティンホイッスル、アイリッシュフルート)や生録のオーケストラを中心とする曲を作っています。東方アレンジも。今回新譜がなければ腹をきります", "https://www.orivermusic.com/"]}, {"names": ["Lunatic Venus"], "misc": ["幻想的な音響作品を制作してきたLunatic\n Venus。今回は10周年の記念に多くのキャストとボーカルを迎え、ゴシックな世界観のコンセプトアルバムを制作しました。", "https://lunaticvenus.wixsite.com/lunaticvenus"]}, {"names": ["Riot Blue Records"], "misc": ["バーチャルワールドと現実世界を行き来するアーティストレーベル『Riot\n Blue Records』から、Violinist Vtuber『舞弦ウラ』が初の単独参戦！", "https://x.com/RiotBlue1001"]}, {"names": ["あたし"], "misc": ["今回も頑張ります！", "https://x.com/atashi_vocal?s=21&t=EeGrtzqizr93UcA1gIHKuw"]}, {"names": ["かざ団地"], "misc": ["kazaはM3初参加。初めてのCDをみんなにお届け。あったかいのに優しくてちょっと寂しい気持ち。つかれちゃったら一緒に田舎に行こう", "https://x.com/kaza_3n"]}, {"names": ["AYUMI ONE. STRIKERS"], "misc": ["AYUMI ONE. STRIKERSです", "https://ayumione.co.jp/"]}, {"names": ["memex"], "misc": ["【新譜フルアルバム頒布予定】 『未来を実装するバンド』\n 2019年1月1日活動開始。\n インターネット上でユーザーがリアルタイムに交流するVR空間「メタバース」で行うライブ「バーチャルライブ」を中心に、次世代の音楽活動を自ら切り拓くバンド。\n ボーカルを担当するアラン、作曲と技術開発を担当するぴぼの2人組。\n 自作システムを用いたVR空間での全世界同時ライブ「#解釈不一致」がTwitterトレンド入りするなど、次世代の音楽活動を自ら切り拓いている。\n 邦オルタナティブロックとインターネット音楽シーンに影響された楽曲とアランの歌唱力は高く評価されており、CHUNITHM、SOUND\n VOLTEX、pop’n music、Muse\n Dashを始めとした数々の音楽ゲームに楽曲提供を行っている。", "https://www.youtube.com/c/memex_am"]}, {"names": ["ロータスルートオーケストラ"], "misc": ["悠花ユカ（ボーカル・作編曲・デザイン・イラスト）が仄暗いファンタジーとレトロな雰囲気中心の楽曲作品を制作しています。\n 新譜はラフスケッチ集『Lotusketch』\n ファンタジー系ボーカル曲2曲と、即興ピアノインスト1曲の3曲入りです！", "https://lro-info.jimdofree.com/"]}, {"names": ["流浪の民"], "misc": ["幻想民族音楽作ってます。まれによく迷走いたします。ストーリーあるファンタジー（拡大解釈）アルバムが中心です！　最近はマダミス、TRPG用の音楽も。", "https://rulotami.weblike.jp/"]}, {"names": ["u-full"], "misc": ["世界の様々な民族、伝統音楽より影響を受け、旅をする音楽をコンセプトに音で地図を描く。Acco&Vo.寺田侑加と、Gt.フナハシダイチによるユニット。歌ものからインストゥルメンタルまで幅広く展開する。", "https://www.u-full.com/"]}, {"names": ["LILT RECORDS"], "misc": ["齋藤博人とNima.のオリジナル音楽CD。ジャンルは本当に色々。", "https://lilt.net/"]}, {"names": ["Unknown - Dimension"], "misc": ["ピアノや弦を主体をしたヒーリング音楽をメインに、民族音楽やオーケストラなどインスト音楽を制作しています。", "https://unknown-dimension.com/"]}, {"names": ["(実在しない)切り抜きチャンネル"], "misc": ["「(実在しない)切り抜きチャンネル」では、VTuberの切り抜き動画を投稿しています。\n 今回は渋谷・ユーロスペースにて初号上映を迎えた「映画館のために作られた切り抜き動画＝劇場用アニメーション映画」を完全収録した『20分でわかるエマ・リーランド』のBlu-ray＋BOOKを即売会初頒布いたします。\n 音楽を担当した清水嶺さんのサークルではオリジナル・サウンドトラックを初頒布。当サークル初の合同出展です。", "https://www.youtube.com/@kirinukifilm"]}, {"names": ["nil-Glass"], "misc": ["女性ボーカル、ギター、ベース、バイオリンの生演奏有りで幅広い曲想の曲を作るサークルです。今回はnil-Glass作品の他、架空ゲームのサントラのコラボ新譜を頒布予定です！", "https://sounds-cocktail.com/nil-Glass"]}, {"names": ["eLEMental CODE"], "misc": ["民族調幻想ポップスを制作しているパフォーマンスユニット、エレメンタルコードです。今回は準新譜『NENIA』の他、架空ゲームのサントラのコラボ新譜を頒布予定です！", "https://acelementalcode.wixsite.com/elementalcode-nenia"]}, {"names": ["六畳間のオーケストラ"], "misc": ["こやみのソロサークルです。新譜が出る予定です。旧譜のオーケストラコンピとソロアルバムも用意しています。", "https://koyami.netlify.app/"]}, {"names": ["Yurureal Lab"], "misc": ["U-Ruri主催によるYurureal\n Lab、コンピレーションアルバム第一弾は、ピアノをメインに使用した楽曲を集めたアルバムを出します！", "https://x.com/YururealLab"]}, {"names": ["B.rose&crown"], "misc": ["オリジナル物語をイメージした、幻想的な楽曲を多重コーラスで制作しております。民族調だったり、クラシカル、ゴシック調など様々な楽曲を、ゲストの歌い手様をお招きして制作しているサークルです。", "https://rujoutan.wixsite.com/the-artist-jp"]}, {"names": ["お月さま交響曲"], "misc": ["多重コーラスを用いた物語音楽やミュージカル、音ゲー楽曲などを制作するサークルです。新作ある予定です。", "http://moon-symphony.site/"]}, {"names": ["Chip crane"], "misc": ["ゆるい電子音楽とアンビエントを作っています。", "https://x.com/Chipcrane_info"]}, {"names": ["奇廻花"], "misc": ["熱帯植物×心象風景をテーマとしたプログレッシブ・テクノ&アンビエント。湿度高め／オリエンタル／SF／ややダークな作風です。新譜（予定）＋既譜も少々持ち込みます。お気軽にどうぞ。", "https://x.com/KIK_KAI_KAA"]}, {"names": ["Minimal Sky"], "misc": ["物語音楽サークル Minimal Skyです。", "https://minimalsky.net/"]}, {"names": ["dsgarage Records"], "misc": ["アンビエント＆シネマティックサウンドをベースに、ポストロックの要素も交えて頒布します！", "https://x.com/dsgaragerecords?s=21&t=j9cn65oFJKQFKM_rCoRycw"]}, {"names": ["Sound Sketches"], "misc": ["フィンガースタイル・ソロギターによる生演奏のインスト楽曲、ボーカル楽曲制作にも取り組む個人サークル。独自の変則チューニングを用いたギター演奏、シンプルでいて豊かな叙情性をもつ音楽性を目指しています。", "http://ryo-works.info/"]}, {"names": ["in the blue"], "misc": ["民族音楽・エレクトロニカ・イージーリスニング系女性ボーカル＆インスト曲を制作。山本由貴子（やまもまや）個人サークル。", "http://www.tiara.cc/~blueblue/"]}, {"names": ["Ishras Poem"], "misc": ["風のクロノアコンピを頒布予定！Funky Furry\n Trackmaker「REONOAH」の個人サークルです。", "https://x.com/stereonoah"]}, {"names": ["Yutopia Qremia"], "misc": ["変拍子のテクニック解説書あります！", "https://x.com/OrangeTheKeyqa"]}, {"names": ["Symphonic Garden"], "misc": ["民族調のファンタジー音楽を制作しています", "https://x.com/Sound_Aquarium"]}, {"names": ["GOLDFISH"], "misc": ["千夜の果ては愛か、絶望か…。ジャズ調の楽曲と語り聞かせる歌声、弦管打すべて生演奏で描くアラビアンナイト。", "https://goldfishes.wixsite.com/goldfish"]}, {"names": ["Eurobeat Union"], "misc": ["音楽制作チーム \"Eurobeat Union\"\n のCEOでございます！ユーロビートの制作・追求につきましては完全にお任せ下さい。徹底的に仕上げた宇宙最強クオリティの楽曲をお届けいたします！！！", "https://eurobeatunion.com/"]}, {"names": ["染色硝子ノ欠片"], "misc": ["東方VocalアレンジCDや映像作品を頒布予定です♪", "https://twitter.com/sgnk_official"]}, {"names": ["Comfique Harmony"], "misc": ["M3初参加です！東方のジャズピアノアレンジのCDを頒布します。", "https://twitter.com/Indigo0262"]}, {"names": ["かみやゆりみっくす"], "misc": ["ユーロビートを作って歌う練馬系ユーロ女子です！！", "https://kamiyayurimix.booth.pm/"]}, {"names": ["Re:Volte & Sorrel Records"], "misc": ["音楽＆音声サークルRe:Voteと、歌と語りと物語のsaoriの作品があります★\n DLsite等で50000↑DL「東方入眠抄」他、EDMまたは癒やしの東方ボーカルアレンジ、癒し音声、オリジナル作品あります。", "http://re-volte.net/"]}, {"names": ["K2E Cradle"], "misc": ["東方Projectを原曲としたEUROBEATアレンジ「TOHO EURO\n TRIGGER」を制作しています！", "https://www.k2e-cradle.com/"]}, {"names": ["Four Corners"], "misc": ["世界中のアルバムを販売します！いろんなジャンルのアレンジとオリジナルがあります！", "https://twitter.com/4CornersDoujin"]}, {"names": ["Endless Sound Records"], "misc": ["東方同人音楽サークル", "https://www.m3net.jp/attendance/endless-sound.top"]}, {"names": ["ACCORD ON CODES"], "misc": ["東方projectゲーム/CD楽曲をジャズアレンジ、バンド演奏した音源を頒布します。スタジオRec盤、ライブ盤あります。", "https://accord-on-codes.com/"]}, {"names": ["Dドライブ"], "misc": ["DJイベント連動型、東方クラブアレンジサークル！", "https://gennsougakusai.wixsite.com/mysite"]}, {"names": ["桜雪みゅーじっく"], "misc": ["オンラインゲームにて出会った二人による活動サークルです！東方関係の作品を制作しております。お時間のある方や作品に興味のある方は是非足を運んでみてください！", "https://x.com/YOU_3400"]}, {"names": ["Syo- Time Music"], "misc": ["東方ピアノ・ユーロビートアレンジやヒーリングピアノミュージックなどのオリジナル作品を制作しています！", "https://syo-time-music.com/"]}, {"names": ["TTL SOUND"], "misc": ["ユーロビートを制作してます。新作含むたくさんのユーロビートを用意してお待ちしてます", "http://ttlsound.wixsite.com/ttlsound"]}, {"names": ["Studio Amazing"], "misc": ["東方のユーロビートアレンジ、本物ユーロビートを収録するCDを頒布致します", "https://twitter.com/StudioAmazing01"]}, {"names": ["SuganoMusic"], "misc": ["本家イタリア産ユーロビートを目指して日々ユーロビートを作り続けています！", "https://suganomusic.com/"]}, {"names": ["石川プロ"], "misc": ["自主制作アニメを作るサークルです。アニメの作り方を詳しく紹介したメイキング本と、アニメ本編を収録したＤＶＤを頒布します。", "https://home1.tigers-net.com/sammena/"]}, {"names": ["GGT CREATE"], "misc": ["映像素材・VJ素材を制作しています。VJ\n LOOP、配信用背景、ゲーム用素材等を主に扱っています。", "https://ggtsukahara.tumblr.com/"]}, {"names": ["Silverize. + 満月紅茶店"], "misc": ["Silverize.代表しるばです。今回はちょっと特別なコンセプトで送りいたします、声優さんと一緒ってことは…！？\n /\n 満月紅茶店のよもぎかすみです！ASMRやお歌メイン♪今回はオリジナル楽曲のミニアルバム制作中…！", "https://x.com/st_silver"]}, {"names": ["garnet"], "misc": ["宝石をタイトルにした曲を作っています。", "https://x.com/narry_y"]}, {"names": ["Aspire"], "misc": ["オリジナル曲を発表するサークルです。\n M3-2025春の新譜はSynthsizerV宮舞モカのカバーアルバム「ボ・カ・ア・ス３」と年始に先行配信した「イツワリノセカイ」と「灰の雪」になります。\n どちらもHi-Res SONOCA仕様です。\n 旧譜も含め全曲視聴できますので、是非スペースまでお越しください！", "https://lit.link/aaaspire"]}, {"names": ["iaitokyo"], "misc": ["浮遊感ある歌声と独創性のある音楽＋世界観のあるイラスト。ロボットの被り物をした女の子「ロボット頭」が生きるパラドックスのセカイを舞台にした音楽CD付き絵本作品を頒布します", "https://www.iaitokyo.com/"]}, {"names": ["PlatScale"], "misc": ["今回は「ポストアポカリプス」をテーマに、様々なジャンルの曲をそろえたCDを用意しました。", "https://x.com/PlatScale4024"]}, {"names": ["バケモノ"], "misc": ["君が死なない為の歌", "https://youtube.com/@bakemono_001?si=o_7dy8JSqkFY6qB0"]}, {"names": ["Kobutyaduke Studio"], "misc": ["「Kobutyaduke Studio」主宰のおーえんです！\n 個人サークルとして初参加となる今回は、和楽器の響きとダンスミュージックを組み合わせたオリジナル楽曲を収録した新作アルバムを頒布します！", "https://x.com/owen_613"]}, {"names": ["Springald"], "misc": ["昼休みにiPhoneのGarageBandで作った曲の発表。偶にカバー。", "http://naidaumi0529sakunoyoru.web.fc2.com/"]}, {"names": ["HONE88"], "misc": ["「限りなく遠くまで届くように…」", "https://x.com/HONE88152875"]}, {"names": ["海の闇に白を灯す"], "misc": ["エモさ全開のメロディーメーカーakatsukikyoが贈る「アニソン系せつなポップロック」歌い手×作曲×小説プロジェクト！", "https://akatsukikyo.com/"]}, {"names": ["yoakenote."], "misc": ["シカ君とヤギちゃんと狼君を愛でる会", "https://ionlithos.amebaownd.com/"]}, {"names": ["from.kasuka"], "misc": ["青春系Pops制作するのが目標だけど青春系Popsとは何かというのはよく分かってないat.kasuka個人サークル", "https://twitter.com/at_kasuka"]}, {"names": ["S×URGE"], "misc": ["新コンピレーションアルバム発表！", "https://x.com/DtmUrge"]}, {"names": ["優しさの配列"], "misc": ["点字図書の普及活動を通じて、この世の全ての人に想いと心を込めた作品を手に取って頂いた方に感謝の気持ちを込めてお届けいたします", "https://kaikoutosaikai.tumblr.com/"]}, {"names": ["VTuberみてるよみてる"], "misc": ["雑談、企画、ときどき作曲のVTuberみてるよみてるです。\n ここ1年で出してきたオリジナル曲を1枚のアルバムにしました。", "https://x.com/3teru43teru"]}, {"names": ["Chilla Record"], "misc": ["優しく儚いシンプルな音楽を創ってます！チンチラ飼いなのでチンチラ好きさんも是非お越しください！", "https://x.com/qlobeni"]}, {"names": ["Amelia"], "misc": ["苦しくて、息もできない。 ― Ameliaが送る9作目の新譜を頒布します", "https://sakura-yuno.amebaownd.com/"]}, {"names": ["SOUNDFROG"], "misc": ["オトヲカエル", "https://soundfrog.base.shop/"]}, {"names": ["ヨキヤ・グリーン"], "misc": ["オリジナルの歌モノ曲を頒布予定です。Synthesizer V\n 重音テトを使用した曲等を頒布します。", "https://x.com/tanfary"]}, {"names": ["創作堂さくら紅葉"], "misc": ["音楽サークル創作堂さくら紅葉です!クオリティー重視で不完全燃焼にならないように作品を作っています。HPには作品紹介以外にもフリーで使えるBGM等がありますので、お時間ある時に見て頂けたら嬉しいです!", "https://yukizakura.net/"]}, {"names": ["三原色"], "misc": ["今までは大学のサークルでの参加でしたが、今回は一人での参加を試みてみました。音楽を愛してやまない人間の創るRemix曲をぜひ聴いてください。", "https://x.com/jank3698"]}, {"names": ["ぴんくるぽっぷ！"], "misc": ["作詞作曲系イラストレーターが贈る、ピンクでポップなテーマパーク♡電波系/アイドル系/オーケストラ系などかわいくてアップテンポなボーカル曲をリリースしています♪", "https://twitter.com/hiyokomiya_0307"]}, {"names": ["東北大学DTM同好会"], "misc": ["東北大学のDTMサークルです。今年もとあるテーマを掲げ、それに沿った各々の個性全開のコンピレーションアルバムを新譜として頒布します。それぞれの世界観をお楽しみください！", "https://tudtmworkshop.wixsite.com/home"]}, {"names": ["Nevyluluのミライ"], "misc": ["可愛いからカッコいいまでたくさんの音楽をギュッと詰め込んだポップなアルバムを出しております。是非お気軽にお立ち寄りください。", "https://lit.link/nevylulululu"]}, {"names": ["薄明生徒会"], "misc": ["生徒から寄せられる様々な問題を解決する組織、生徒会。\n 現在の構成は「生徒会長 月乃」「副会長 つぐ」「書記 るる」の3名。\n 今日も学園の平和のため、私たちは歌います！", "https://x.com/Hakumei_SC"]}, {"names": ["Stray Morpho"], "misc": ["Wasabeepの個人サークルです。旧譜の1st\n EPに加えて新作も頒布予定です。", "https://wasabeep.amebaownd.com/"]}, {"names": ["長尾ちえみ"], "misc": ["Eurobeat Union、Spacelectro、Harozy等、\n 東方アレンジCDにてゲストボーカルをしている長尾ちえみの個人サークル。オリジナル楽曲のCDを頒布しています。", "https://www.youtube.com/watch?v=OYOmxLaT6Z4"]}, {"names": ["温泉芸術フライングリャマ"], "misc": ["カセットでボカロ！カセットテープ頒布します！ジャンル:インディーポップ、ローファイ", "https://x.com/mypanty_is_good/"]}, {"names": ["Hisoyaka from TYC"], "misc": ["日頃気をつけた方が良い事を中心に歌い上げるポップス", "https://x.com/hisovibes"]}, {"names": ["Sprite Recordings/ENDLESS SUMMER Studio"], "misc": ["cittan*主宰、近未来SF x\n 美少女ノベルゲーム「パーガトリー・ブルー」を制作しているENDLESS\n SUMMER Studioと音楽サークルSprite Recordingsです!", "https://purgatory-blue.tokyo/"]}, {"names": ["DigicreSoundTeam"], "misc": ["芝浦工業大学公認サークル「デジクリ」DTM部門からの参加です。今年も様々なジャンルからの出展です。よろしくお願いします！！", "https://digicre.net/"]}, {"names": ["Beqqor's Soundonuts"], "misc": ["Beqqorによる個人サークル、名付けて「Beqqor's\n Soundonuts」です。2024年秋に頒布した「夕景」の完全版EPを販売予定！よろしくお願いします！", "https://twitter.com/mrcl_drm0224"]}, {"names": ["coalessense"], "misc": ["「coalessense」（コアレセンス）は、ボカロP×歌い手がタッグを組んで最高の一曲を創り上げるコンピレーションアルバムです。", "https://sites.google.com/view/coalessense"]}, {"names": ["絵に描いた城"], "misc": ["レマノルドによるオリジナル音楽を頒布します。 KalmeRi ／\n 結月ゆかり ／ インストBGM素材", "https://enikaitashiro.com/"]}, {"names": ["西川口虫"], "misc": ["西川口の非公認キャラクター「西川口虫」!おしゃれなポップスやエモい曲あるよ！", "https://www.youtube.com/watch?v=qsJNqIUKYqo"]}, {"names": ["スタジオへむり（新井健史）"], "misc": ["作曲家、新井健史が代表を務めるサークルです。大ヒット曲「レッツゴーまめチャン！」の続編「カワイイむぎチャン！」リリース予定です！", "https://studiohemuri.com/"]}, {"names": ["StellaPhizz"], "misc": ["キーボーディストの宇都圭輝、DJ／作曲家の早川博隆、ボーカルのHanonからなる、シンセ・サウンドが特徴的な3人組ユニット。", "https://x.com/StellaPhizz"]}, {"names": ["雪乃制作班"], "misc": ["できたらいいな　新譜", "https://yukikurage.net/"]}, {"names": ["トキトウメイ×青猫と月夜の晩に"], "misc": ["【トキトウメイ】\n ボカロPと歌い手の二刀流「トキトウメイ。」2回目の参戦。\n 【青猫と月夜の晩に】\n 楽曲制作からイラスト、動画まで手がける総合クリエイター集団。愛されたいがための音楽を。", "https://lit.link/aonecoto"]}, {"names": ["いーあんゆいまーる"], "misc": ["音楽学校で知り合った仲間達と作ったアイドル同人サークル。元気いっぱいな王道アイドルグループとして", "https://www.m3net.jp/attendance/@ianyuimaru"]}, {"names": ["senpaiこみゅ"], "misc": ["女性アーティスト\"kohai\"がお天気ポップをお届けします！懐かしいのに新しい、グッとくるミュージック。", "https://twitter.com/karenamachan"]}, {"names": ["蓮音まゆ"], "misc": ["生命と自然。 共存と精神世界。 倍音の歌声と\n 動物や生き物たちの鳴き声と四大元素のハーモニー　この世界に耳を傾けて\n 聴いてみてください。　蓮音まゆ　森は生きている", "http://hasunemayu.jimdo.com/"]}, {"names": ["どぶだばだ"], "misc": ["Youtubeやニコニコ動画で活動している溝野あわのサークルです。ダークでホラーなストーリーものの音楽が多いですが時には感情に寄り添った音楽も作ります。", "https://dobunoawa.com/"]}, {"names": ["ADelY's"], "misc": ["ボーカルの子月千夜と楽曲制作のBUTOの二人組の音楽サークルです。可愛い系のキャッチーな女性ボーカルのポップスを作っています。", "https://x.com/buto_i"]}, {"names": ["Tapapixel"], "misc": ["M3初挑戦！高校生クリエイターが贈る、ピコピコ電子音と\"かわいい\"全開のKawaii\n Future Bassミニアルバムをお届けします！", "https://x.com/tapanohito"]}, {"names": ["Synthetic Station"], "misc": ["デジタルJ-POPのオリジナル曲をメインとする、作曲家イチカベサケンのサークルです。普通のJ-POPもやります。過去作ではAIシンガーをフィーチャーしたデジタルJ-POP作品を出していました。", "https://syn-station.net/?utm_source=m3"]}, {"names": ["Salad Bowl"], "misc": ["色々やってます"]}, {"names": ["えびたろうさーくる"], "misc": ["えびたろうのサークルです。", "https://ebitaroebitaroll.wixsite.com/ebitaro"]}, {"names": ["Harvest"], "misc": ["オリジナルCD頒布予定です！近況はツイッター＠HarvestNssuyにて！", "https://soundcloud.com/harvest-nssuy"]}, {"names": ["ミーウェルの幻想物語音楽"], "misc": ["物語音楽を作曲し、オペラとポップスの声を融合させて歌う女性打ち込みシンガー【ミーウェル】のＣＤやグッズ販売など。", "https://miwele.com/discography/"]}, {"names": ["T.O.E."], "misc": ["岡孝明（Takaaki Oka）の自作曲の楽譜とCDを頒布しております。", "https://www.m3net.jp/attendance/@to_pianocompose"]}, {"names": ["明治大学総合コンテンツ制作サークル"], "misc": ["総合コンテンツ制作サークルは明治大学中野キャンパスを拠点として活動しています。音楽班、ゲーム班、映像班、イラスト班の4つの班に分かれて活動しており、様々なデジタルコンテンツを創作しています。", "https://sokon.jp/"]}, {"names": ["Pulse Plum"], "misc": ["作曲担当YMPが様々な方と音楽を作ります。エレクトロ、ファンタジー、民族調など", "https://pagumin5531.wixsite.com/pulse-plum"]}, {"names": ["クロノメルフェ"], "misc": ["童話を題材としたゴシックダークファンタジー。2人の女性ボーカルと様々なジャンルの楽曲が織りなすハーモニーで貴方を、本当は怖い童話の世界へ案内します…。", "http://chronomerfe.chu.jp/"]}, {"names": ["まじろぐみ"], "misc": ["アニソン風ロック、ポップス等、女性ボーカル曲のCDを頒布します（ボーカル：真白\n 彩）", "http://www.ayacho.com/"]}, {"names": ["タバサリサ"], "misc": ["ハイブリットなEUROBEATサウンドをお届け", "https://thavasarisa.bitfan.id/"]}, {"names": ["Sheary Nut's Record feat.ニートヤン"], "misc": ["ニートヤンと共同出展。声優からラッパーまで様々なアーティストとコラボした音源を頒布", "http://www.shearty.com/"]}, {"names": ["まおにょろ"], "misc": ["作る曲がことごとくゲーム音楽っぽくなるロリィタギタリスト。春は歌モノです。", "https://maonyoro.com/"]}, {"names": ["羽っ鳥もさく共和国／羽鳥風画"], "misc": ["作曲家　羽鳥風画の個人サークルです。オリジナルを中心に音楽制作をしています。", "https://x.com/fugahatori"]}, {"names": ["のらぐろ"], "misc": ["雑食系PoPs。4オクターブを駆使して歌います", "https://x.com/nora_guro1192"]}, {"names": ["Human Night Safari"], "misc": ["夜をテーマにした音楽を作っています。"]}, {"names": ["ヘアーサロンイナビカリ💈"], "misc": ["爽快なポップロック。女性ボーカル", "https://hikarirobo.wixsite.com/website"]}, {"names": ["『ようなぴ・ガトチワ・イロハマイのお店』"], "misc": ["エレクトロポップとアコースティックのソロアーティスト『ようなぴ』/弱者に寄り添った音楽を作っている犬『ガトリングチワワ』/エレポップSSW&トラックメイカー『イロハマイ』の合同サークルです！", "https://x.com/i_ro_ha_mai"]}, {"names": ["四谷プロ"], "misc": ["可愛い曲を書いてます！", "https://www.twitter.com/kino_gassa"]}, {"names": ["いとう屋さん"], "misc": ["歌って踊る人型遊園地「アミューズLaLa♪ハッピーランド」こと、いとうあいかのお店", "https://www.tunecore.co.jp/artists/AIKA-ITO?lang=ja"]}, {"names": ["終末パン"], "misc": ["よろしくお願いします"]}, {"names": ["Λibes record"], "misc": ["バイブスアゲます。"]}, {"names": ["damabgm records"], "misc": ["竜騎士ちゃんシリーズの新譜が出てます！！", "https://x.com/damahysk"]}, {"names": ["うわのそらぼ"], "misc": ["「うわのそら」になってしまう瞬間を切り取った音楽をあなたへ。はじめまして、音楽研究チーム【うわのそらぼ】です。\n M3初出店、女性ボーカルの音楽グループです。", "https://www.m3net.jp/attendance/%3C%3E"]}, {"names": ["モノハス"], "misc": ["僕たちはずっとJPOPが大好きですが、最近の曲は感情の起伏が極端な時に聞きたくなるものが少し多いようにも感じていました。何とも言えない気分の時にも寄り添ってくれる曲を作ってきたのでぜひ聴いてください！", "https://x.com/monohasu"]}, {"names": ["埼玉県"], "misc": ["Itsuki Miyamura、埼玉県在住。", "https://lit.link/imiyamura"]}, {"names": ["Sound Rave"], "misc": ["様々な音楽を取り込んだ“Hybrid\n Pop”というジャンルでボーカル楽曲の制作をしています！", "https://soundrave.org/"]}, {"names": ["emem。です。"], "misc": ["音楽が好きなので、1人で歌ったり曲を作ったりしています。", "https://lit.link/emem1124"]}, {"names": ["野井勇飛"], "misc": ["都内で宅録を中心に活動するシンガーソングライター。2024年までに4枚のフルアルバムを発表。\n 楽曲のテーマは「都市生活者の孤独」もしくは「人間讃歌」。", "https://www.tunecore.co.jp/artists/noiyuhi?lang=ja"]}, {"names": ["飛遥"], "misc": ["シンガーソングライター、トラックメイカー。自由自在なピアノと青く透き通った歌声を乗せた魔法のような音楽。その研ぎ澄まされた感性で遊び心溢れる仕掛けを楽曲に吹き込んでいく。", "https://x.com/hiyoukotake"]}, {"names": ["ナナシのゴシック!"], "misc": ["初出展。物語音楽シリーズCD第1弾『Score of Clap』を頒布予定。\n ゴシック風で幻想的な楽曲や、シンフォニックメタルを収録。", "https://score-of-clap.netlify.app/"]}, {"names": ["Alchemy+"], "misc": ["バンドサウンドを基盤としたPopsを奏でるAlchemy+です♪", "http://twitter.com/@Alchemy_mazzy"]}, {"names": ["ひろいもの"], "misc": ["新志零樹 ×りみす主宰の気ままな音楽サークル。 New\n Album『パズルピース』頒布予定", "https://hiroimono.re-miss.com/"]}, {"names": ["NOKO音楽クラブ"], "misc": ["大学の軽音部のメンバーで組んだ音楽制作グループです！", "https://x.com/keta_komori"]}, {"names": ["Six-BEARs Records"], "misc": ["― 個人の音楽を表現する ―　Six-BEARs\n Recordsは2024年に発足したインターネット同人音楽レーベルです。　''ジャンルにとらわれず、やりたい音楽を表現する''　をコンセプトに様々な楽曲を展開します。", "https://hmusic2024.wixsite.com/six-bears-records"]}, {"names": ["Guava Co."], "misc": ["ジャズ、ロック、エレクトロニカなんでもあり歌物中心に作ってます！変拍子多め。studio-kurage、foolenさんの群青箱庭もここ。", "https://guava-co.info/"]}, {"names": ["みさんちゃ"], "misc": ["多彩が楽曲を作るメンバーがそれぞれのアルバムを頒布します！そして色々なボカロPの方をお呼びしたコンピアルバムもありますのでぜひともお立ち寄りください！", "https://twitter.com/eat_me_u"]}, {"names": ["MarrynaMusic."], "misc": ["川上まりえとチューリップが好きすぎるPが創り上げる新しい世界に癖になるメロディー。今回は3rdアルバムを新刊として頒布させて頂きます！青春、初恋、夢など、初々しい感じの曲を集めました。", "https://r.goope.jp/marienone/"]}, {"names": ["Isle ＆ Notes"], "misc": ["物語音楽新作アルバム、全ボーカル8曲です！旧譜も若干数持ち込みます！", "https://x.com/IsleandNotes"]}, {"names": ["Leaforest Records"], "misc": ["M3初参加になります！ピアノサウンドが好きなhonana/kenkenpah/si-soundsの3名が、様々な“花”をテーマに制作したオリジナル楽曲を1枚にまとめたCDを頒布します。参加メンバーの旧譜も少し持っていく予定です。", "https://leaforest-records-1st.tumblr.com/"]}, {"names": ["ハイテク宅録おじさんを目指す集い"], "misc": ["SDGsだの、メタバースだの、NFTだの、世界にはナウでヤングな横文字が飛びかってますね。当サークルは、おじさんにはWikiっても理解し難いアレを学びつつ、活かすでもなく音楽制作を楽しんでおります。", "https://riversiderecords2009.wixsite.com/riversiderecords/hightech"]}, {"names": ["四季折々"], "misc": ["新進気鋭のアーティスト瑞希と令和の歌姫JK星森ステラの最強最高のグルーヴ！のはず。", "https://www.m3net.jp/attendance/mizuki_project"]}, {"names": ["freedimension"], "misc": ["オタク文化とアウトサイダーの視点をラップと音で表現する自由次元", "https://freedimension.amebaownd.com/"]}, {"names": ["家出作曲部"], "misc": ["\"無い\"音楽を作っています。今回は春をイメージした楽曲を収録しています。"]}, {"names": ["ふーせんたぬきプロジェクト"], "misc": ["ソングライター、やまみのりの個人サークルです。ちょっと古めのJPOP風の歌ものを作っています。", "https://yamaminori.jpn.org/"]}, {"names": ["Pumpkingdom"], "misc": ["“女性ボーカル×キャッチーなメロディ”をコンセプトに\n オリジナル楽曲の制作、即売会（M3・コミックマーケット）における\n 作品の頒布をしているサークルです。", "https://pumpkingdom.info/"]}, {"names": ["KimiEdge Records"], "misc": ["シンガー・キクチミユキが織りなす、どろっどろのR&Bをお届けします。\n 新譜『Rage』3曲EP R&B女性ボーカル", "https://kimiedge-records.booth.pm/"]}, {"names": ["DTMステーションCreative"], "misc": ["DTMステーションが運営するレーベルです。今回はネット番組DTMステーションPlus!内のコーナー「田村響華と今日からDTM♪」で制作してきた楽曲のリリースします", "https://www.dtmstation.com/"]}, {"names": ["A.I.Tech Records"], "misc": ["愛知工業大学のDTMサークルのA.I.Tech\n Recordsです。今回は新譜を1枚出す予定です。", "https://x.com/aitdtmclub"]}, {"names": ["UNIT16+"], "misc": ["ゲストボーカルにLil\n Hyvääさん(Tr1)、yunosameさん(Tr2)を迎えたエレクトロポップのEPを作りました。\n 優しさや懐かしさを感じる心地よい作品に仕上がっています。\n CD実物もアイテムとして気に入っていただけるよう、3面アートワークの見開き紙ジャケットにもこだわりました。\n 是非現地で手にとって見てみてください！\n 第二展示場コ-03bにてお待ちしています！", "https://potofu.me/unit16"]}, {"names": ["はゆまーけっと！"], "misc": ["「はゆまーけっと！」の勿忘うたです！今作は「アイドルの恋愛」をテーマに制作しています！春にお会いしましょう◎", "https://x.com/waurena_x"]}, {"names": ["To-pia"], "misc": ["歌で綴る短編集", "https://x.com/Topiasann"]}, {"names": ["みゃねっと"], "misc": ["ファミコン音源他のチップチューンのCDを頒布予定です。", "https://m.cyanet.jp/"]}, {"names": ["WIZARD ODYSSEY"], "misc": ["コンポーザー矢野トモのダークファンタジープロジェクト ”WIZARD\n ODYSSEY”による叙情的かつドラマティックな世界観をお届けします。", "https://yanotomo.wixsite.com/yanotomo"]}, {"names": ["ポジティヴレコーズ"], "misc": ["オルタナティブJ-POPを標榜するSSW・Theムッシュビ♂トのサークルです。くそやばい音楽を発信します。", "https://x.com/monsiurbeat_2"]}, {"names": ["*baletta"], "misc": ["新譜は初の和風ファンタジー。*balettaはボーカル如月梢、高橋そら(sola)と作曲suimによる、少女×セカイをテーマにした物語音楽制作ユニットです。", "http://balettasong.com/"]}, {"names": ["こすげといづみ"], "misc": ["シンガーソングライターこすげといづみです。歌ったり、即興劇をしています。少し懐かしい、歌謡曲な、大正浪漫な曲もご用意しています。イラストのグッズも頒布しています。", "https://www.youtube.com/watch?v=AcnOQILiz8s&list=PLtAJrMlnX7oYOFZQFZHFXMdfIB7NnXJRY"]}, {"names": ["るりる電波部"], "misc": ["電波ソング、電子音楽、女性ボーカルの楽曲を制作しています", "https://profcard.info/u/tpunpkuyiQa6O4CiFXG1cRkXuq52"]}, {"names": ["みるきゅーる"], "misc": ["かわいいを極める3人組2.5次元アイドルグループです！", "https://x.com/milcure_OA"]}, {"names": ["stretta di mano"], "misc": ["月子が主催・運営するサークルです♪\n 　長らく延期していた新譜を今度こそ頒布！！！", "https://twitter.com/tsukiko_sdm"]}, {"names": ["アタリメ"], "misc": ["渋谷系ポップユニットのアタリメです。渋谷系テイストな楽曲を中心に、AOR、ギターポップ、シティ・ポップス、バラードなど幅広いポップソング制作しております。\n 今回はM3-2024秋の新譜『raspberry syrup』を中心に頒布します。\n アタリメの活動の集大成とも言える全曲リード曲のアルバムとなっております！\n 太鼓の達人楽曲募集2023に採用いただいた「ロケットモード」も収録されておりますのでぜひ！", "https://a-tari-me.booth.pm/"]}, {"names": ["OURPARTZ"], "misc": ["ぼくたちは「OURPARTZ（オーパーツ）」として活動する音楽ユニットです。\n 多才なShiO（シオ）と物語を紡ぐTOOV（トーヴ）が、自由な発想で音楽とビジュアルを創り出します！", "https://lit.link/ourpartz"]}, {"names": ["yoki"], "misc": ["作詞・作曲・編曲・歌唱・gtなど広く手掛けるシンガーソングライターyokiです。\n あどけなさと儚さがあるyokiの声と、EDMとJ POP\n ロックを兼ね備えたオリジナリティある楽曲を制作します。", "https://lit.link/wokasi4"]}, {"names": ["locate"], "misc": ["なつかしくて あたらしい\n 色とりどりのオリジナルサウンドとコットンボイスをお届けします", "https://fukutsuki.wixsite.com/locate"]}, {"names": ["蓮華宝°C"], "misc": ["初の大型女性ボーカルコンピCD企画＆頒布を行います。豪華ゲストボーカルの皆様をお迎えした渾身の楽曲群をどうぞご堪能下さいませ。", "https://twitter.com/elena_hasumi"]}, {"names": ["柴犬観測センター"], "misc": ["歌声合成ソフトウェアSynthesizer V\n の夏色花梨やMaiが歌うの曲を頒布します！！　ロックやポップスなどのバンドサウンドが中心です", "https://x.com/shobobobon"]}, {"names": ["えにしむすび"], "misc": ["セルフプロデュースソロアイドルによるサークルです。エモーショナルで儚げな私を表現したCDを頒布いたします！作詞にも挑戦するので是非お手に取ってくだされば嬉しいです。", "https://twitter.com/x/migrate?tok=7b2265223a222f656e697368696179616d65222c2274223a313733353936313935347d9e22b9ca256ff95cb8f0d9e941dd3f55"]}, {"names": ["Degistalgia"], "misc": ["TOCORO十, 赤蕾ライラ, 夜世生 宵, ちょぴん, 菜月なこ,\n BJ.chika　★デジタルでノスタルジックな音楽レーベル。今回はボーカルアルバム『旅ゆく貴方に残すもの』を頒布予定", "https://twitter.com/chi08ka"]}, {"names": ["OrbitArk"], "misc": ["宇宙からきました。よろしくお願いします", "https://orbitark.com/"]}, {"names": ["食べるプラネタリウム"], "misc": ["エレクトロ出身ジャズ卒のノンジャンルDTMユニット", "https://x.com/edi_planetarium?t=MjpBy5KaEQ50YetyLsfkXA&s=09"]}, {"names": ["USAGIMICK"], "misc": ["和風エレクトロポップのUSAGIMICKだぴょん", "https://x.com/usagimick"]}, {"names": ["つきみぐー、[Project:OVER]"], "misc": ["歌い手・Vsinger・ボカロPとして活動するつきみぐー、およびその個人企画Project:OVERのサークルです。", "https://tsukimizzz.com/"]}, {"names": ["_blank"], "misc": ["ゴシック・テクノ・アコースティックなど多様なサウンドを旅するオリジナルヴォーカルユニット", "https://blank-blank.net/"]}, {"names": ["七色ビタミン"], "misc": ["女性ボーカルのオリジナルCDを頒布しています。", "https://twitter.com/tinamoroll"]}, {"names": ["Leyline"], "misc": ["音楽制作集団です。様々なアーティストのCDを頒布予定。", "https://x.com/leylinemusicinc"]}, {"names": ["N.B.W"], "misc": ["初音ミク、夢眠ネム、花隈千冬歌唱のシンセポップやってます！新譜は花隈千冬歌唱です！", "https://linktr.ee/N.B.W"]}, {"names": ["PORT 14"], "misc": ["歌もの。Ambient × 80s × POP × 432Hz", "https://www.youtube.com/watch?v=hW5jzg8jQjc"]}, {"names": ["月燈舎"], "misc": ["塩屋リコ、よしさこほの、PolyphonicBranch、てりぬるによる幻想創作空間。空想科学や宇宙、天文、鉱石などをテーマに、\n オリジナル楽曲の制作を中心に活動中。", "http://gettohsha.com/"]}, {"names": ["木下珠子 / Tamako Kinoshita"], "misc": ["Arcaea《Last | Moment,Eternity》SDVX《Don't you dare play\n GOD》などを歌唱した木下珠子制作のアルバムやグッズを頒布します。", "https://tamachan-music.amebaownd.com/"]}, {"names": ["emotionarhythm"], "misc": ["植物イメージアンソロジー「Blooming\n ELEMENT's」2作目（完成版）を頒布予定！", "http://emotionarhythm.sakura.ne.jp/"]}, {"names": ["KANZME RECORDZ"], "misc": ["「みんなで音楽をやってみよう！」の掛け声の下、プロもアマも一緒になって、多様なジャンルの曲を仕上げました。シェフたち渾身の「音の缶詰」、是非ご賞味あれ。", "https://x.com/KanzmeRecordz"]}, {"names": ["Unlimited Color"], "misc": ["富山良いとこ！一度はおいで！！", "https://www.youtube.com/@unlimitedcolor7540"]}, {"names": ["RM3"], "misc": ["電子楽器メーカーローランド株式会社の部活動です。今回が2回目の参加！ご好評いただきました前回に引き続き、今回もインスタントラーメンを作る「３分」縛りのオリジナルコンピレーションCDです♪", "https://x.com/3_Jigen_daisuke"]}, {"names": ["BeζUMa The さうんど"], "misc": ["3分未満のショートミュージック集(初音ミク・可不)を配布します(ﾟ∀ﾟ)！", "https://x.com/kumakaritu"]}, {"names": ["五阿弥ルナ"], "misc": ["アーティスト・劇伴シンガー。映画「ラストマイル」、ドラマ「最愛」、「NieR:Automata\n 少女ヨルハ」等で歌が話題に。坂本龍一氏に「独特の周波数を持つ声と才能」と称された。幻想性×スリリングなPOPSでソロ曲も。", "http://lunagoami.com/"]}, {"names": ["LIZE"], "misc": ["エンタテインメント制作会社のLIZE inc.\n 　コンセプチャルなコンピCDを販売。レトロでオルタナティブな世界観を是非！", "https://www.hyoe.org/taiyou-ga-kureru"]}, {"names": ["MSGEX"], "misc": ["ポップ・ロック・メタル同人音楽サークル「MSGEX」です！活動11年目は新たなメンバーを多数迎えてサークルコンセプトに原点回帰！デジタルJ-POP、デジロック、メロスピ等の新曲を収録した16th\n Albumを頒布予定です！", "https://msgex.jp/"]}, {"names": ["パンケーキキャッツ"], "misc": ["Singer\n 咲良ゆの×Sennzai、月乃×Eye、拠鳥きまゆ×魔ノ姫こあく、まるもこ×大瀬良あい、yuru×双葉ななた、あーち×ひらななか\n 「逢いに行こう！まだ見ぬハーモニーを奏でに。」\n 全曲デュエット！新たな魅力とわがままが詰まったフルアルバム、遂に完成！\n これまでのパンケーキキャッツ作品を彩ったシンガーである、あーち・咲良ゆの・月乃・まるもこ・yuru・拠鳥きまゆの6名が、それぞれデュエットしたいシンガーをマッチング！\n 本作のためにマッチした6組のオリジナルコンビの魅力を最大限に生かした、バラエティ豊かな楽曲を収録。\n パンケーキキャッツならではの生演奏サウンドは、更に理想を追求。\n お馴染みの椎名なお・huton[Gt.]、いはけん・ナツメ\n ユウキ・まひお[Ba.]、ジャンク[Dr.]に加え、新たにHONNWAKA88[Gt.&Ba.]、Akki[Pf.]が参加。", "https://www.youtube.com/watch?v=cgAylXphnls"]}, {"names": ["FIRST AVENUE STUDIO 戸塚"], "misc": ["横浜市戸塚の古い音楽スタジオ＆小さなライブハウスの出店です。地域の音楽家たちの作品を持っていく予定です。ノンジャンル。ライブの出演者も募集しています。", "https://firstavenue-st.com/"]}, {"names": ["ゲキヤバゲキカワギャング"], "misc": ["ゲキヤバで、ゲキカワな、クラブミュージック、ベースミュージックを行っています。", "https://twitter.com/r1cefarm"]}, {"names": ["mixi2・DTMerズ"], "misc": ["できたてホヤホヤSNS｢mixi2｣、サービス開始直後にコンピ結成！！", "https://mixi.social/communities/d9184ca2-c6cc-4378-baf9-c615dde11212/events/e37758d6-d237-41de-9938-e184feb75a1c?r=8hcjhgprvch3"]}, {"names": ["Aerial Notes"], "misc": ["VTuber × Composer の音楽ユニットです。\n アニソンをルーツに様々な要素を取り入れた楽曲と、可愛さと透明感のある歌声で独特な世界観をお届けします。", "https://x.com/Aerial_Notes"]}, {"names": ["Petite Chanela"], "misc": ["『小さな猫と天使の物語』\n 初参加！水色大好き、猫天使ユニットの『Petite Chanela /\n ぷてぃ・しゃねら』です！童話をモチーフに1st\n ミニアルバムを制作しました！セラフィーとむむ猫による新人歌い手ユニットです！", "https://x.com/petitechanela?s=21&t=hiBPYtOiXI598qZcyWVaNQ"]}, {"names": ["牛満刻"], "misc": ["お久しぶりです"]}, {"names": ["τlﾚ"], "misc": ["ひねくれたポップス作ります", "https://x.com/ontltl"]}, {"names": ["泉の庭ちゃんぷるー"], "misc": ["民族調・和風・EDM・シンフォニックロック等ジャンルは様々なファンタジックな音楽を作っています。", "https://izuminoniwa.storeinfo.jp/"]}, {"names": ["踊ル音楽家"], "misc": ["”春らしくない”という理由で今年お箱入りになっていたゆめみ☆デスゲーム、ついに登場！", "https://odoru.booth.pm/"]}, {"names": ["wagataki"], "misc": ["ピアノ系のインストを中心に制作しています！", "https://x.com/wagataki_v"]}, {"names": ["水魚みぃむ"], "misc": ["水音の世界からやってきた歌姫研修生vtuber。オリジナル曲や歌ってみた動画を発表してます。フランスで開催されたイベントに参加したり、NHK-FMさんの番組「ぶいあーる！」で紹介されたり日々頑張ってます！", "https://twitter.com/miomiim316"]}, {"names": ["ろいた"], "misc": ["\"異なる惑星で生まれた2人の少女が惑星に迫る危機に立ち向かう\"\n 架空のアニメ「双星の約束」をテーマにしたアニソンポップスを扱っております。\n ゲストボーカルを迎えたEP(全8曲)を頒布予定です。", "https://loitad61.wixsite.com/sousei"]}, {"names": ["| MO2RE 〉"], "misc": ["音と音、人と人、様々な「もつれ」を探索する音楽プロジェクト。\n アレンジャー soniol とベーシスト anmangichi を中心に展開。", "https://www.youtube.com/watch?v=AOCn91b2TzA"]}, {"names": ["ラフニ"], "misc": ["”浸れるひとときを 求めるひとたちへ”\n 特定のコンセプトを基に複数のクリエイターが1つの作品を作り上げます", "https://x.com/LaughNeed2024"]}, {"names": ["louviq:"], "misc": ["シングルコイルのギターと繊細かつ迫力のあるボーカルが織り成す「エモーショナルなバンドサウンド」が特徴の2人組ユニットです。", "https://lit.link/shikakuisquare"]}, {"names": ["夢乃ゆき"], "misc": ["女性ボーカル、オリジナル楽曲を頒布しています！", "https://www.yumenoyuki.com/"]}, {"names": ["FROZEN QUALIA"], "misc": ["コンポーザーkazukiとボーカルyukiによる音楽プロジェクトです。", "https://frozenqualia.tumblr.com/"]}, {"names": ["ゆめやさん"], "misc": ["シンガートラックメイカーかききまなみのプロジェクトです。ノスタルジックホラーでダークのなかに懐かしさを込めた歌詞と幼なげな歌声の楽曲です。", "https://nekowarashi.jimdofree.com/"]}, {"names": ["るなほしショップ"], "misc": ["声優・歌手・登山家\n るなっち☆ほしのCD屋さん。チップチューンや電波ソング多めです。", "https://www.m3net.jp/attendance/runaporitan"]}, {"names": ["アートモバイル"], "misc": ["自称音楽家です。宅録系シンガーソングライター、時々ボカロ。", "https://artmobile.jp/"]}, {"names": ["OVERTASK"], "misc": ["架空劇判ユニット、OVERTASKが手掛けるチップチューン！", "https://x.com/Overtasked"]}, {"names": ["A little bit"], "misc": ["女性ボーカル・後藤ハルキがオシャレでジャジーなオリジナルＣＤを制作しているサークル。新作あります！", "http://alittlebit.jeez.jp/"]}, {"names": ["幼蚕文庫とBigbird"], "misc": ["浮森かや子とオッカです。届くようで届かないようなどこか懐かしく、様々な曲を作っています。", "https://yosanbunko.mimoza.jp/"]}, {"names": ["cyan slime"], "misc": ["名古屋発2人組クリエイティブユニット「cyan slime」\n Vtuberをボーカルに取り入れたオルタナティブ・ポップス楽曲をリリース", "https://cyan-slime.studio.site/"]}, {"names": ["futuristic sounds"], "misc": ["名古屋から世界へ届けたい音楽がある。", "https://x.com/futuristic_msc"]}, {"names": ["きゅいきゅいすたー"], "misc": ["ツインボーカルユニットのきゅいきゅいすたーです！ユニットとしての2枚目のアルバムを出します！まよりの2枚目のソロアルバムもリリース予定です！可愛いミュージックを皆さんにお届けします♪", "https://kyuikyui.tumblr.com/"]}, {"names": ["サクラのいろは"], "misc": ["～春夏秋冬の和風楽曲をお届けします～", "https://x.com/yamato_rrr"]}, {"names": ["RICORA MUSIC TEAM"], "misc": ["東京理科大学DTMサークルRICORAです。よろしくお願いします！", "https://music.tus-ricora.com/"]}, {"names": ["東京理科大学情報技術クラブITC"], "misc": ["現役理系大学生が作った楽曲CDを頒布します！テーマは\"Innocence\"。純真、潔白、無邪気、天真爛漫…などなど、何を表現するのかは部員たち次第！", "https://tusitclub.net/"]}, {"names": ["Stellar Trills"], "misc": ["アニソンゲーソンを魂に刻んだバンドマン3人によるサークルです！\n アルバム毎にテーマを決めて、多様な音楽を展開していきます♪", "https://x.com/stellar_trills"]}, {"names": ["みけねこれこーど☆"], "misc": ["かわいいエナジー系電波ソング出ます！！", "https://mikerec.wixsite.com/mikerec"]}, {"names": ["地獄のべくちゃん"], "misc": ["超弩級サブカルシンガー「べくちゃん」と、超敏腕プロデューサー「地獄イヌ」による新進気鋭の音楽サークル\n ！！独特の世界観あふれる楽曲に、あなたもきっとアッと驚く為五郎！！", "https://x.com/vec_jigoku"]}, {"names": ["Fence Break Heaters"], "misc": ["ギターボーカル・ベース・ドラムと異なるバックグラウンドを持つ三人が三者三様のポップな楽曲を誠意作成しています。", "https://lit.link/fencebreakheaters"]}, {"names": ["Airycraft◇"], "misc": ["道南から、優しい音の物語をお届け", "https://ima-immersive.netlify.app/"]}, {"names": ["ペラペラポミッタ"], "misc": ["また変な曲を作りたいと思います。よろしくお願いします。", "https://peraperapomitta.com/"]}, {"names": ["有坂愛海"], "misc": ["ロリータシンガーソングライター有坂愛海です！新譜予定！", "https://arisakaemi.com/"]}, {"names": ["175 LABO"], "misc": ["豊島区千川に新規オープンしたレコーディングスタジオ「175LABO」の音楽サークルです。代表でありベーシストである稲子渾身のアルバム、ぜひお聞きください！", "http://175labo.com/"]}, {"names": ["Sati"], "misc": ["ゆったりpopsだったりややhiphopだったり、1Vo1MCのバンド", "https://sati.official.ec/"]}, {"names": ["endroll fanclub"], "misc": ["lo-fiっぽいhiphopっぽ感じのゆったりめな音楽を可不ちゃんに歌ってもらってます", "https://twitter.com/yismsand27"]}, {"names": ["日本ポップ屋協同組合"], "misc": ["良質なポップスの作り手（ポップ屋）たちを熱烈支援！その才能、無駄にはしないぜ。", "https://www.popkyo.jp/"]}, {"names": ["２次元レストラン"], "misc": ["虹咲まる&そーずがお届けする《料理のように多種多様な音楽》をお届けするごった煮系音楽ユニット", "https://x.com/2d_restaurant?s=21&t=DgvIscIMH0xycZEcj36iyQ"]}, {"names": ["箱庭Ｓ"], "misc": ["ショタ・少年を主人公にしたオリジナル音響ドラマ製作サークルです。笑って泣けるお話を作っています！", "http://hakoniwas.web.fc2.com/"]}, {"names": ["Keito Kikuchi"], "misc": ["かわいいBGMを作っています！", "https://lit.link/sugerk"]}, {"names": ["RBC"], "misc": ["創設昭和63年。全年齢向けの胡散臭い創作音響劇（オリジナルドラマCD）と使い勝手の悪い効果音を作っております。", "https://rbcnet.jp/"]}, {"names": ["EPIC VOICE"], "misc": ["第一弾の音声作品の声優は松本梨香様！第二弾の声優は新田恵海様！誰もが一度は聞いたことのあるような、耳馴染みのある声優様を起用し、脚本やイラストにも力を入れた独創性のある音声作品を発表していきます。", "https://x.com/EPIC_VOICE_info"]}, {"names": ["StudioT916"], "misc": ["他にはない「音声作品」を創造しています。", "https://studiot916.wixsite.com/studiot916"]}, {"names": ["Sound劇団AltRia"], "misc": ["素敵な声の声優さんの演技をお届けする音声劇のサークルです\n 友情、師弟、主従…女の子同士の関係性を描いた物語を取り扱っております", "https://kakuyomu.jp/works/16818093094423883382/episodes/16818093094423920863"]}, {"names": ["翠櫻院"], "misc": ["オリジナルボイスドラマサークル翠櫻院です。魔法少女ちぇりぼむシリーズを中心にロマンティックラブコメディメインな作品を気ままに作ってます", "https://twitter.com/suiohin"]}, {"names": ["怪奇大成"], "misc": ["実話怪談（本当にあった不思議な話や怖い心霊体験）を語ったCDを頒布。猫怪談、犬怪談、水場怪談、ASMR囁き声、本に関する不思議な怪談など、様々なテーマのCDを揃えています。", "https://twitter.com/shima0115"]}, {"names": ["ドロップシアター"], "misc": ["マイペースにボイスドラマ作品を作成しています！"]}, {"names": ["みつぼし亭"], "misc": ["BL一次創作「I’m Home.」のドラマCDを頒布します。「I'm\n Home.」は6人の男性たちが暮らすシェアハウスを舞台にしたBL創作。彼らの日常の一コマを切り取った作品になっています。", "https://lit.link/mitsuboshi"]}, {"names": ["F.T.W."], "misc": ["百合ボイスドラマ『死埋葬』他。新作頒布予定。", "http://blog.livedoor.jp/ftw999/"]}, {"names": ["イロガミのブーケ"], "misc": ["日常の中の非日常の中の日常を描いたボイスドラマを作っています。届いたあなたへ、感謝(ブーケ)を。", "https://www.youtube.com/channel/UCfa7ufJCzp5biw7FWiIVJ-A"]}, {"names": ["とろとろポトフでメガネが曇る"], "misc": ["リアル会場初出展の「とろポト」です！　オリジナルボイスドラマを制作しています！　聞いてくださる方の心を揺さぶる作品を目指しています。", "https://ptf1257trpt.nobody.jp/"]}, {"names": ["ムラサキノオト"], "misc": ["昔ながらのラジオドラマ的なオーディオドラマを制作しているサークルです。", "https://ameblo.jp/purplesounds/"]}, {"names": ["星屑アイス"], "misc": ["あなたに寄り添うボイスドラマを頒布しています！今回のテーマは「メイドさん」です！", "https://hoshikuzuice.amebaownd.com/"]}, {"names": ["quo's / storybeat"], "misc": ["「音楽」と「ボイスドラマ\n 」を融合させた新感覚の音楽『ストーリービート』の作品を頒布します。", "https://quosstorybeat.com/"]}, {"names": ["ワタツエニシ"], "misc": ["ドラマCDを販売します。ワタツエニシです。古語で海の縁という意味です。サークル初参加ですがよろしくお願いします！", "http://twitter.com/@Watatsue24"]}, {"names": ["Piece of Lapis"], "misc": ["癒やしメインのASMR作品を頒布予定です。"]}, {"names": ["我竜庵"], "misc": ["演劇×音楽、映像、あらゆる選択肢で物語を伝えるクリエイター我竜麻里子による音楽の庵。", "https://x.com/mariko_garyou"]}, {"names": ["創作project黒蝶の戯れ"], "misc": ["記念すべき10回目の連続参加になります！！主催ソロシチュボを記念に頒布します！！", "https://black0630.booth.pm/"]}, {"names": ["碧空プラネタリウム"], "misc": ["少年少女が不思議な出来事を通して成長していく、どこか懐かしい創作音声劇を制作しています", "http://hekiku.net/"]}, {"names": ["Spiral Spirit"], "misc": ["少年と少し不思議な物語を制作、頒布しております。新作「ブラッシュローズの咲く夜に」と演劇ユニットロキジョーンズのフライヤーを頒布予定です。8年ぶりの参加です、宜しくお願いいたします。", "https://spiralspirit.net/"]}, {"names": ["Capsule Instruments"], "misc": ["DTMerの電子楽器 \"CapsuleChord\"\n を展示します。「ギターやピアノは挫折したけど、気軽にアイデアを広げられる方法が欲しい！」という方にピッタリの楽器です。ごく少数ですが旧譜の販売も行う予定です。", "https://capsulechord.wararyo.com/"]}, {"names": ["Solitary Ensemble"], "misc": ["ギター1本だけあれば気軽に始められるのに奥が深い、ソロギタースタイルのインスト曲やアレンジ曲の譜面を出しています。", "https://twitter.com/sumisologuitar"]}, {"names": ["左をサークル"], "misc": ["左を@hidari_woによる音楽創作同人サークルです。\n オリジナル曲8曲入りCD(DLリンク付き)を頒布します。", "https://twitter.com/hdrw_msc"]}, {"names": ["花と論理"], "misc": ["15年以上にわたり同人音楽を聴き続けた「聴き専」による、同人音楽テキスト本(作品の感想・エッセイ・ガイド本など)を頒布します。", "http://onimo2.blog40.fc2.com/"]}, {"names": ["オタクとメタルと私"], "misc": ["メタル系及びその周辺ジャンルの同人音楽CDのレビューを中心とした同人誌「DOUJIN\n METAL」を発行しています。", "https://www.tumblr.com/doujinmetal"]}, {"names": ["Melodious Nekochan"], "misc": ["代表&作曲の相生あおはです\n オーケストラ&ピアノ成分たっぷりの曲を可不が歌います！", "https://semicolon0103.com/"]}, {"names": ["senaleon's shop"], "misc": ["今回も個性的なメンツを揃えてきました！ビリビリしてください！", "https://x.com/3329h0rned0w1"]}, {"names": ["Orca Step Records"], "misc": ["リズム系のバラエティ豊かなボカロサウンドを主にお届けします\n 初のフルアルバム【Born for This Purpose】を頒布予定！\n 全18曲の個性溢れる楽曲をお聴きください", "https://www.m3net.jp/attendance/%3C%3E"]}, {"names": ["ミズノトアミ"], "misc": ["ボーカロイド＋女性Vo男性Voロックシューゲ……ごった煮です。", "https://mi